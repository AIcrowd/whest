,"1402":4,"1403":4,"1404":4,"1405":4,"1406":4,"1407":4,"1408":4,"1409":4,"1410":4,"1411":4,"1412":4,"1413":4,"1414":4,"1415":4,"1416":4,"1417":4,"1418":4,"1419":4,"1420":4,"1421":4,"1422":4,"1423":4,"1424":4,"1425":4,"1426":4,"1427":4,"1428":4,"1429":4,"1430":4,"1431":4,"1432":4,"1433":4,"1434":4,"1435":4,"1436":4,"1437":4,"1438":4,"1439":4,"1440":4,"1441":4,"1442":4,"1443":4,"1444":4,"1445":4,"1446":4,"1447":4,"1448":4,"1449":4,"1450":4,"1451":4,"1452":4,"1453":4,"1454":4,"1455":4,"1456":4,"1457":4,"1458":4,"1459":4,"1460":4,"1461":4,"1462":4,"1463":4,"1464":4,"1465":4,"1466":4,"1467":4,"1468":4,"1469":4,"1470":4,"1471":4,"1472":4,"1473":4,"1474":4,"1475":3,"1476":3,"1477":3}}},"docs":{"docs":{"1":{"id":"/docs/changelog","page_id":"/docs/changelog","type":"page","content":"Changelog","breadcrumbs":["Documentation"],"tags":[],"url":"/docs/changelog"},"2":{"id":"/docs/changelog-0","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#unreleased","content":"Unreleased"},"3":{"id":"/docs/changelog-1","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#added","content":"Added"},"4":{"id":"/docs/changelog-2","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#changed","content":"Changed"},"5":{"id":"/docs/changelog-3","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#removed","content":"Removed"},"6":{"id":"/docs/changelog-4","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#fixed","content":"Fixed"},"7":{"id":"/docs/changelog-5","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#added-1","content":"Added"},"8":{"id":"/docs/changelog-6","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#020-2026-04-03","content":"0.2.0 (2026-04-03)"},"9":{"id":"/docs/changelog-7","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#new-features","content":"New features"},"10":{"id":"/docs/changelog-8","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#breaking-changes","content":"Breaking changes"},"11":{"id":"/docs/changelog-9","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#bug-fixes","content":"Bug fixes"},"12":{"id":"/docs/changelog-10","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#documentation","content":"Documentation"},"13":{"id":"/docs/changelog-11","page_id":"/docs/changelog","type":"heading","tags":[],"url":"/docs/changelog#010-2026-04-01","content":"0.1.0 (2026-04-01)"},"14":{"id":"/docs/changelog-12","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**Wall-clock time limits.** `BudgetContext` now accepts `wall_time_limit_s` to\nset a wall-clock deadline. When exceeded, `TimeExhaustedError` is raised at the\nnext operation boundary with diagnostic info (operation name, elapsed time, limit).\nThe deadline is checked both before and after each numpy call (cooperative\nenforcement). The entry banner shows the time limit when set."},"15":{"id":"/docs/changelog-13","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**Per-operation duration tracking.** Every operation now records its wall-clock\nduration in `OpRecord.duration`. The budget summary (both plain-text and Rich)\nshows wall time, tracked/untracked breakdown, and per-operation timing. Use\n`budget.summary()` or `we.budget_summary()` to see the timing data."},"16":{"id":"/docs/changelog-14","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**`TimeExhaustedError`** added to both the core library and the client package."},"17":{"id":"/docs/changelog-15","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**Einsum path caching.** Contraction paths are now cached in a module-level\nLRU cache (default 4096 entries). Repeated `we.einsum()` calls with the same\nsubscripts, shapes, optimizer, and symmetry structure reuse the cached path\ninstead of recomputing it. New public API: `we.clear_einsum_cache()`,\n`we.einsum_cache_info()`, and `we.configure(einsum_path_cache_size=N)`."},"18":{"id":"/docs/changelog-16","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**Multi-version NumPy support.** whest now supports NumPy 2.0, 2.1, and 2.2\n(`>=2.0.0,<2.3.0`). Default install resolves to NumPy 2.2. Functions not available\nin older NumPy versions raise `UnsupportedFunctionError` with an actionable message\nat call time (not import time)."},"19":{"id":"/docs/changelog-17","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**`matvec` and `vecmat`** — new FLOP-counted wrappers for NumPy 2.2's matrix-vector\nand vector-matrix product ufuncs. Cost = `output_size * contracted_axis` (weight 1.0)."},"20":{"id":"/docs/changelog-18","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**`UnsupportedFunctionError`** — new exception for calling functions that require a\nnewer NumPy version than what's installed."},"21":{"id":"/docs/changelog-19","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added","content":"**CI NumPy version matrix** — tests now run against NumPy 2.0, 2.1, and 2.2."},"22":{"id":"/docs/changelog-20","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#changed","content":"**Renamed package from `mechestim` to `whest`** to reflect the new challenge\nname \"ARC Whitebox Estimation Challenge\". The import convention changes from\n`import mechestim as me` to `import whest as we`."},"23":{"id":"/docs/changelog-21","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#changed","content":"**Symmetric BLAS classification restored.** Pairwise contractions with\nsymmetric inputs now correctly report `SYMM`, `SYMV`, or `SYDT` BLAS\ntypes instead of the generic `GEMM`, `GEMV`, `DOT`. This was disabled\nduring the subgraph-symmetry refactor because per-input symmetry wasn't\nbeing looked up; now each step's inputs are queried via\n`symmetry_oracle.sym(ssa_to_subset[ssa_id])` before calling `can_blas`."},"24":{"id":"/docs/changelog-22","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#changed","content":"**Symmetry detection rewritten** — the induced-symmetry mechanism is replaced\nby a subset-keyed subgraph symmetry oracle (`SubgraphSymmetryOracle`). The\noracle analyses the bipartite structure of the einsum expression, evaluates\nsymmetry lazily per operand subset, and caches results. This correctly handles\nintermediates (not just the top-level contraction) and eliminates over-eager\nper-step propagation."},"25":{"id":"/docs/changelog-23","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#changed","content":"**Every optimizer is symmetry-aware** — the `symmetry_oracle` kwarg is plumbed\nthrough `_PATH_OPTIONS` so that optimal, branch-\\*, greedy, random-greedy, and\ndynamic-programming algorithms all receive symmetry information and use the\nexact `unique/dense` ratio for scoring. DP uses a subset-keyed ratio cache\n(`get_ratio(s, legs)`) co-located with the existing `bitmap_to_subset` closure\ninside `DynamicProgramming.__call__`, amortizing the int↔str label translation\nacross all `_dp_compare_*` helper calls for a given subset. Previously only\ngreedy received symmetry info in some code paths."},"26":{"id":"/docs/changelog-24","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#changed","content":"**Silent fallback deleted** — the previous code silently fell back to dense\ncosts when detection produced no result. The oracle now enforces that symmetry\ninformation is consumed. Enforcement is verified by\n`tests/test_no_silent_symmetry_drop.py`."},"27":{"id":"/docs/changelog-25","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#removed","content":"`symmetric_flop_count`'s `input_symmetries` parameter (high-level API)"},"28":{"id":"/docs/changelog-26","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#removed","content":"`propagate_symmetry` and related helpers"},"29":{"id":"/docs/changelog-27","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#removed","content":"`_detect_induced_output_symmetry` and related helpers"},"30":{"id":"/docs/changelog-28","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#removed","content":"`induced_output_symmetry` kwarg on `contract_path`"},"31":{"id":"/docs/changelog-29","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#fixed","content":"**`bitmap_to_subset` in DP now correctly handles operand renumbering.**\nPreviously, when `_dp_parse_out_single_term_ops` removed or renumbered\noperands before the DP loop (e.g., on `einsum('i,ab,cd->abcd', v, X, X)`\nwhere `v` has a unique index that reduces to a scalar), the\nbitmap-to-subset mapping would point at the wrong original operand\npositions, causing the oracle to return symmetry for an unrelated\nintermediate. This bug was latent under the conservative 2× heuristic\nand only surfaces with exact ratio scoring."},"32":{"id":"/docs/changelog-30","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#fixed","content":"**Heterogeneous block dimensions in `unique_elements`** — the stars-and-bars\nblock-cardinality calculation assumed all axes within a block had the same\ndimension. For rectangular block-symmetric tensors (e.g.\n`einsum('ab,cd->abcd', X, X)` with `X` of shape `(3, 4)`), it computed\n`n**s = 3**2 = 9` instead of the correct product `3*4 = 12`, silently\nunderestimating the unique-element count by up to \\~8× on rank-3 cases.\n`block_card` is now computed as `prod(size_dict[c] for c in blocks[0])`,\nwhich reduces to the old formula for per-index groups and gives the\ncorrect product for block groups with differing axis sizes."},"33":{"id":"/docs/changelog-31","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added-1","content":"**Enriched `PathInfo` display** — `we.einsum_path().format_table(verbose=False)`\n(called by `__str__`) now shows an `Optimizer:` header line resolving\n`optimize='auto'`/`'auto-hq'` to the inner choice that actually ran\n(e.g. `optimal`, `dynamic_programming`, `random_greedy_128`), a\n`contract` column giving the path-supplied contraction tuple, and a\n`unique/dense` column showing the bare element counts that the\nsymmetry savings derive from. Call `format_table(verbose=True)` for an\nindented detail row per step showing the merged operand subset, the\nintermediate's output shape, and the running cumulative cost — the\nmost useful view when debugging why a particular step's savings are\nwhat they are."},"34":{"id":"/docs/changelog-32","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#added-1","content":"**New `PathInfo.optimizer_used: str`** field and new `StepInfo` fields\n`path_indices: tuple[int, ...]` and `merged_subset: frozenset[int] | None`.\nThe `merged_subset` field is the exact key\n`SubgraphSymmetryOracle.sym(...)` uses for its lookups, making the\nsymmetry column directly attributable to the oracle's view of each\nintermediate."},"35":{"id":"/docs/changelog-33","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#020-2026-04-03","content":"Second release with unified einsum cost model, NumPy compatibility testing, and expanded operation coverage."},"36":{"id":"/docs/changelog-34","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**Unified einsum cost model** — all einsum-like operations (einsum, dot, matmul, tensordot) now share a single cost model based on opt\\_einsum's contraction path optimizer"},"37":{"id":"/docs/changelog-35","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**Symmetry-aware path finding** — the opt\\_einsum path optimizer now factors symmetry savings into contraction ordering decisions, producing different (cheaper) paths for symmetric inputs"},"38":{"id":"/docs/changelog-36","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**NumPy compatibility test harness** — run NumPy's own test suite against whest via monkeypatching; 7,300+ tests passing across 7 NumPy test modules"},"39":{"id":"/docs/changelog-37","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**Polynomial operations** — `polyval`, `polyfit`, `polymul`, `polydiv`, `polyadd`, `polysub`, `poly`, `roots`, `polyder`, `polyint` with analytical FLOP costs"},"40":{"id":"/docs/changelog-38","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**Window functions** — `bartlett`, `hamming`, `hanning`, `blackman`, `kaiser` with per-function cost formulas"},"41":{"id":"/docs/changelog-39","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**FFT module** — `fft`, `ifft`, `rfft`, `irfft`, `fft2`, `ifft2`, `fftn`, `ifftn`, `rfftn`, `irfftn` and free helpers (`fftfreq`, `rfftfreq`, `fftshift`, `ifftshift`)"},"42":{"id":"/docs/changelog-40","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**Client-server architecture** — `whest-client` and `whest-server` packages for sandboxed competition evaluation over ZMQ"},"43":{"id":"/docs/changelog-41","page_id":"/docs/changelog","tags":[],"type":"text","url":"/docs/changelog#new-features","content":"**Global default budget** — a 1e15 FLOP budget auto-activates on first use, so explicit `BudgetContext` is no longer required for quick scripts"},"44":{"id":"/docs/changelog-42","page_id":"/docs/changelog