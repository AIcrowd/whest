rom-numpy-33","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"`SymmetricTensor` available"},"766":{"id":"/docs/guides/migrate-from-numpy-34","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"Wrap with `we.as_symmetric()` for cost savings"},"767":{"id":"/docs/guides/migrate-from-numpy-35","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"All NumPy ops available"},"768":{"id":"/docs/guides/migrate-from-numpy-36","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"Most available, 32 blacklisted"},"769":{"id":"/docs/guides/migrate-from-numpy-37","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"I/O and config ops raise `AttributeError`"},"770":{"id":"/docs/guides/migrate-from-numpy-38","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"No cost tracking"},"771":{"id":"/docs/guides/migrate-from-numpy-39","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"Automatic FLOP counting"},"772":{"id":"/docs/guides/migrate-from-numpy-40","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#what-changes","content":"Every counted op deducts from budget"},"773":{"id":"/docs/guides/migrate-from-numpy-41","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#common-pitfalls","content":"**Symptom:** `AttributeError` when calling an I/O or config function (e.g., `we.save`, `we.seterr`)"},"774":{"id":"/docs/guides/migrate-from-numpy-42","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#common-pitfalls","content":"**Fix:** 32 operations are blacklisted because they are I/O, configuration, or datetime functions with no FLOP cost. See Operation Categories for the full list. Use `numpy` directly for these."},"775":{"id":"/docs/guides/migrate-from-numpy-43","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#common-pitfalls","content":"**Symptom:** Using `np.linalg.svd` instead of `we.linalg.svd`"},"776":{"id":"/docs/guides/migrate-from-numpy-44","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#common-pitfalls","content":"**Fix:** If you import NumPy alongside whest, make sure to use `we.` for operations you want counted. Operations called through `np.` bypass FLOP counting entirely."},"777":{"id":"/docs/guides/migrate-from-numpy-45","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#related-pages","content":"Operation Categories — what's supported and what isn't"},"778":{"id":"/docs/guides/migrate-from-numpy-46","page_id":"/docs/guides/migrate-from-numpy","tags":[],"type":"text","url":"/docs/guides/migrate-from-numpy#related-pages","content":"API Reference — full list of all operations"},"779":{"id":"/docs/guides/symmetry","page_id":"/docs/guides/symmetry","type":"page","content":"Symmetry Savings","breadcrumbs":["Documentation","Guides"],"tags":[],"url":"/docs/guides/symmetry"},"780":{"id":"/docs/guides/symmetry-0","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#why-symmetry-matters","content":"Why symmetry matters"},"781":{"id":"/docs/guides/symmetry-1","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#quick-start","content":"Quick start"},"782":{"id":"/docs/guides/symmetry-2","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#how-to-declare-symmetry","content":"How to declare symmetry"},"783":{"id":"/docs/guides/symmetry-3","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#full-symmetric-shorthand-with-symmetric_axes","content":"Full symmetric shorthand with `symmetric_axes`"},"784":{"id":"/docs/guides/symmetry-4","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#multiple-independent-full-symmetric-groups","content":"Multiple independent full symmetric groups"},"785":{"id":"/docs/guides/symmetry-5","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#explicit-full-symmetric-groups-with-permutationgroupsymmetric","content":"Explicit full symmetric groups with `PermutationGroup.symmetric`"},"786":{"id":"/docs/guides/symmetry-6","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#cyclic-symmetry-with-permutationgroupcyclic","content":"Cyclic symmetry with `PermutationGroup.cyclic`"},"787":{"id":"/docs/guides/symmetry-7","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#dihedral-symmetry-with-permutationgroupdihedral","content":"Dihedral symmetry with `PermutationGroup.dihedral`"},"788":{"id":"/docs/guides/symmetry-8","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#arbitrary-subgroups-from-custom-generators","content":"Arbitrary subgroups from custom generators"},"789":{"id":"/docs/guides/symmetry-9","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#multiple-explicit-groups-on-one-tensor","content":"Multiple explicit groups on one tensor"},"790":{"id":"/docs/guides/symmetry-10","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"Generating example data with the Reynolds operator"},"791":{"id":"/docs/guides/symmetry-11","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"Symmetry propagation at a glance"},"792":{"id":"/docs/guides/symmetry-12","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#slicing-rules","content":"Slicing rules"},"793":{"id":"/docs/guides/symmetry-13","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#reduction-rules","content":"Reduction rules"},"794":{"id":"/docs/guides/symmetry-14","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#binary-pointwise-ops-and-broadcasting","content":"Binary pointwise ops and broadcasting"},"795":{"id":"/docs/guides/symmetry-15","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#warnings-conservative-behavior-and-re-tagging","content":"Warnings, conservative behavior, and re-tagging"},"796":{"id":"/docs/guides/symmetry-16","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#under-the-hood","content":"Under the hood"},"797":{"id":"/docs/guides/symmetry-17","page_id":"/docs/guides/symmetry","type":"heading","tags":[],"url":"/docs/guides/symmetry#going-deeper","content":"Going deeper"},"798":{"id":"/docs/guides/symmetry-18","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry","content":"*Reduce FLOP costs when your tensors have symmetry.*"},"799":{"id":"/docs/guides/symmetry-19","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry","content":"**You will learn:**"},"800":{"id":"/docs/guides/symmetry-20","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry","content":"How to declare full and non-full tensor symmetries with `we.as_symmetric()`"},"801":{"id":"/docs/guides/symmetry-21","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry","content":"How to generate example tensors for arbitrary permutation groups"},"802":{"id":"/docs/guides/symmetry-22","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry","content":"When to use `we.random.symmetric()` (sample + project) versus `we.symmetrize()`\n(project existing data)"},"803":{"id":"/docs/guides/symmetry-23","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry","content":"How slicing, reductions, and binary pointwise ops preserve, weaken, or drop symmetry metadata"},"804":{"id":"/docs/guides/symmetry-24","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry","content":"When to re-tag results with `we.as_symmetric()` after conservative propagation"},"805":{"id":"/docs/guides/symmetry-25","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"Many tensors contain repeated structure. A symmetric matrix has only\n`n * (n + 1) / 2` unique elements instead of `n^2`, and higher-order tensors\nwith permutation symmetry can shrink the effective element count even more.\nWhen whest knows a tensor's symmetry, it charges FLOPs based on unique elements\ninstead of dense ones."},"806":{"id":"/docs/guides/symmetry-26","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"Operation"},"807":{"id":"/docs/guides/symmetry-27","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"Dense cost"},"808":{"id":"/docs/guides/symmetry-28","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"Symmetry-aware cost"},"809":{"id":"/docs/guides/symmetry-29","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"Why it drops"},"810":{"id":"/docs/guides/symmetry-30","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`we.exp(s2_matrix)`"},"811":{"id":"/docs/guides/symmetry-31","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`n^2`"},"812":{"id":"/docs/guides/symmetry-32","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`n * (n + 1) / 2`"},"813":{"id":"/docs/guides/symmetry-33","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"only unique matrix entries matter"},"814":{"id":"/docs/guides/symmetry-34","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`we.einsum('ki,kj->ij', x, x, symmetric_axes=[(0, 1)])`"},"815":{"id":"/docs/guides/symmetry-35","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`m * n^2`"},"816":{"id":"/docs/guides/symmetry-36","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`m * n * (n + 1) / 2`"},"817":{"id":"/docs/guides/symmetry-37","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"the repeated `x` operand lets whest detect symmetric output and reduce the cost"},"818":{"id":"/docs/guides/symmetry-38","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`we.einsum('i,j,k->ijk', v, v, v)`"},"819":{"id":"/docs/guides/symmetry-39","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"`n^3`"},"820":{"id":"/docs/guides/symmetry-40","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"symmetry-reduced"},"821":{"id":"/docs/guides/symmetry-41","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"repeated operands induce output symmetry"},"822":{"id":"/docs/guides/symmetry-42","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#why-symmetry-matters","content":"By contrast, `symmetric_axes` on an `einsum` output tags the result for downstream\noperations; it does not reduce that `einsum`'s own cost by itself."},"823":{"id":"/docs/guides/symmetry-43","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#quick-start","content":"`we.as_symmetric()` validates the data first. After that, whest propagates\nsymmetry metadata algebraically through many operations. Unary pointwise ops preserve symmetry-aware costs and keep the same symmetric axes. For non-full groups such as `C_k` or `D_k`, the current implementation widens the metadata to full symmetry on those axes. Slicing, reductions, and binary pointwise ops can weaken it or remove it entirely."},"824":{"id":"/docs/guides/symmetry-44","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#full-symmetric-shorthand-with-symmetric_axes","content":"Use `symmetric_axes` when the tensor is invariant under every permutation of a\nset of axes."},"825":{"id":"/docs/guides/symmetry-45","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#full-symmetric-shorthand-with-symmetric_axes","content":"This is the most common declaration: full `S_2` symmetry on matrix axes\n`(0, 1)`."},"826":{"id":"/docs/guides/symmetry-46","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#multiple-independent-full-symmetric-groups","content":"This declares one full symmetric group on axes `(0, 1)` and another on\n`(2, 3)`."},"827":{"id":"/docs/guides/symmetry-47","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#explicit-full-symmetric-groups-with-permutationgroupsymmetric","content":"This is equivalent in meaning to `symmetric_axes=(0, 1, 2)`, but explicit\ngroups are useful once you want to inspect or combine them directly."},"828":{"id":"/docs/guides/symmetry-48","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#cyclic-symmetry-with-permutationgroupcyclic","content":"`C_3` means rotations are allowed, but reflections are not. This is weaker\nthan `S_3`, so it usually gives fewer savings."},"829":{"id":"/docs/guides/symmetry-49","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#dihedral-symmetry-with-permutationgroupdihedral","content":"`D_4` includes both rotations and reflections of a four-position structure."},"830":{"id":"/docs/guides/symmetry-50","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#arbitrary-subgroups-from-custom-generators","content":"Use this form when the built-in constructors do not describe your symmetry."},"831":{"id":"/docs/guides/symmetry-51","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#multiple-explicit-groups-on-one-tensor","content":"This is the explicit-group equivalent of `symmetric_axes=[(0, 1), (2, 3)]`."},"832":{"id":"/docs/guides/symmetry-52","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"When you want example tensors for arbitrary groups, prefer `we.random.symmetric`.\nIt is a handy helper that samples from a distribution and applies the Reynolds\noperator.\nUse `we.symmetrize` when you already have concrete data to symmetrize, and\n`we.as_symmetric` when you already have concrete data to validate and tag."},"833":{"id":"/docs/guides/symmetry-53","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"`R_G(T) = (1 / |G|) * sum_{g in G} g · T`"},"834":{"id":"/docs/guides/symmetry-54","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"This helper is ideal for docs, tests, and experiments:"},"835":{"id":"/docs/guides/symmetry-55","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"it works for `S_k`, `C_k`, `D_k`, and custom generator sets"},"836":{"id":"/docs/guides/symmetry-56","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"prefer `we.random.symmetric()` for synthetic data generation"},"837":{"id":"/docs/guides/symmetry-57","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"`we.random.symmetric` internally samples data and calls `we.symmetrize` so the\nprojection and validation behavior is identical."},"838":{"id":"/docs/guides/symmetry-58","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"approximate costs (meaningful estimate):"},"839":{"id":"/docs/guides/symmetry-59","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"`we.random.symmetric`: `C_dist(n) + |G| * n + n` + validation"},"840":{"id":"/docs/guides/symmetry-60","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"`we.symmetrize`: `|G| * n + n` + validation\\\nwith `n` total elements and `|G|` group order."},"841":{"id":"/docs/guides/symmetry-61","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"in exact arithmetic it projects onto the invariant subspace, and in practice\n`we.as_symmetric()` validates the result with its usual validation tolerances"},"842":{"id":"/docs/guides/symmetry-62","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"it keeps examples consistent across symmetry classes"},"843":{"id":"/docs/guides/symmetry-63","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#generating-example-data-with-the-reynolds-operator","content":"The propagation examples below assume `import whest as we`; generated tensors\nabove use `we.random.symmetric(...)` and the explicit transform helper is\n`we.symmetrize(...)`."},"844":{"id":"/docs/guides/symmetry-64","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"Symmetry propagation is conservative. Whest keeps symmetry metadata only when\nthe operation's structure guarantees that the output still respects the\nsurviving group."},"845":{"id":"/docs/guides/symmetry-65","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"Operation"},"846":{"id":"/docs/guides/symmetry-66","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"Result type"},"847":{"id":"/docs/guides/symmetry-67","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"Rule"},"848":{"id":"/docs/guides/symmetry-68","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`we.exp(s3_tensor)`"},"849":{"id":"/docs/guides/symmetry-69","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`SymmetricTensor`"},"850":{"id":"/docs/guides/symmetry-70","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"unary pointwise ops preserve symmetric axes; non-full groups are currently widened to full symmetry on those axes"},"851":{"id":"/docs/guides/symmetry-71","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`we.add(s3_tensor, c3_tensor)`"},"852":{"id":"/docs/guides/symmetry-72","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`SymmetricTensor` or `ndarray`"},"853":{"id":"/docs/guides/symmetry-73","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"binary pointwise ops keep the intersection of both operands' groups"},"854":{"id":"/docs/guides/symmetry-74","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`s2_matrix * 3`"},"855":{"id":"/docs/guides/symmetry-75","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`SymmetricTensor`"},"856":{"id":"/docs/guides/symmetry-76","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"scalar binary ops preserve the tensor's groups"},"857":{"id":"/docs/guides/symmetry-77","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`s2_matrix[0]`"},"858":{"id":"/docs/guides/symmetry-78","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`ndarray`"},"859":{"id":"/docs/guides/symmetry-79","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"integer indexing removes one axis; no nontrivial group survives"},"860":{"id":"/docs/guides/symmetry-80","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`s2_matrix[:3, :3]`"},"861":{"id":"/docs/guides/symmetry-81","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`SymmetricTensor`"},"862":{"id":"/docs/guides/symmetry-82","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"equal-size slices can preserve symmetry"},"863":{"id":"/docs/guides/symmetry-83","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`s2_matrix[:3, :2]`"},"864":{"id":"/docs/guides/symmetry-84","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`ndarray`"},"865":{"id":"/docs/guides/symmetry-85","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"unequal-size slices break symmetry between those axes"},"866":{"id":"/docs/guides/symmetry-86","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`s2_matrix[we.array([0, 1])]`"},"867":{"id":"/docs/guides/symmetry-87","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`ndarray`"},"868":{"id":"/docs/guides/symmetry-88","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"advanced indexing drops symmetry conservatively"},"869":{"id":"/docs/guides/symmetry-89","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`we.sum(s3_tensor, axis=0)`"},"870":{"id":"/docs/guides/symmetry-90","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`SymmetricTensor`"},"871":{"id":"/docs/guides/symmetry-91","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"reductions keep the surviving setwise stabilizer subgroup"},"872":{"id":"/docs/guides/symmetry-92","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`we.sum(d4_tensor, axis=(1, 3))`"},"873":{"id":"/docs/guides/symmetry-93","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`SymmetricTensor`"},"874":{"id":"/docs/guides/symmetry-94","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"reductions can keep a proper subgroup like `C_2`"},"875":{"id":"/docs/guides/symmetry-95","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`s2_matrix @ s2_matrix`"},"876":{"id":"/docs/guides/symmetry-96","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`ndarray`"},"877":{"id":"/docs/guides/symmetry-97","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"matrix products are not assumed symmetric in general"},"878":{"id":"/docs/guides/symmetry-98","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#symmetry-propagation-at-a-glance","content":"`we.exp(c3_tensor)` still gets symmetry-aware cost savings, but the result is currently tagged as full symmetry on `(0, 1, 2)` rather than preserving the original `C_3` subgroup exactly."},"879":{"id":"/docs/guides/symmetry-99","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"Slicing uses the **pointwise stabilizer** of the removed axes. Informally:\nevery removed axis must stay fixed under any surviving group element."},"880":{"id":"/docs/guides/symmetry-100","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"What happens here:"},"881":{"id":"/docs/guides/symmetry-101","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"`same_size_slice` stays symmetric because both surviving axes still have the\nsame size"},"882":{"id":"/docs/guides/symmetry-102","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"`different_size_slice` loses symmetry because the two axes no longer match"},"883":{"id":"/docs/guides/symmetry-103","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"`expanded_s2_matrix` keeps the same `S_2` action, but the axes are renumbered\nfrom `(0, 1)` to `(1, 2)`"},"884":{"id":"/docs/guides/symmetry-104","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"`advanced_index_slice` returns a plain `ndarray`; whest does not attempt to\npropagate symmetry through array/list indexing"},"885":{"id":"/docs/guides/symmetry-105","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"`Ellipsis` behaves like NumPy's normal expansion rules. It can change which\naxes remain, but it does not change the propagation rule itself."},"886":{"id":"/docs/guides/symmetry-106","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"The difference between full and non-full groups matters immediately:"},"887":{"id":"/docs/guides/symmetry-107","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"`s3_slice` keeps an `S_2` subgroup on the surviving axes"},"888":{"id":"/docs/guides/symmetry-108","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#slicing-rules","content":"`c3_slice` loses all nontrivial symmetry, because `C_3` has no non-identity\nelement that fixes one point"},"889":{"id":"/docs/guides/symmetry-109","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#reduction-rules","content":"Reductions use the **setwise stabilizer** of the reduced axes. Informally:\nreduced axes are allowed to permute among themselves, because summation treats\nall positions along the reduced set equivalently."},"890":{"id":"/docs/guides/symmetry-110","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#reduction-rules","content":"What happens here:"},"891":{"id":"/docs/guides/symmetry-111","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#reduction-rules","content":"`s3_reduced` keeps an `S_2` subgroup on the remaining axes"},"892":{"id":"/docs/guides/symmetry-112","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#reduction-rules","content":"`c3_reduced` loses all nontrivial symmetry"},"893":{"id":"/docs/guides/symmetry-113","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#reduction-rules","content":"`c4_reduced` keeps a `C_2` subgroup"},"894":{"id":"/docs/guides/symmetry-114","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#reduction-rules","content":"`c4_keepdims` keeps the same surviving subgroup, but the output axes stay in\ntheir original tensor positions because `keepdims=True`"},"895":{"id":"/docs/guides/symmetry-115","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#reduction-rules","content":"Reducing an axis that is not in a symmetry group leaves that group alone, apart\nfrom any axis renumbering caused by the removed dimension."},"896":{"id":"/docs/guides/symmetry-116","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#binary-pointwise-ops-and-broadcasting","content":"Binary pointwise ops keep only the symmetry present in **both** operands. For\ngeneral groups, that means element-set intersection on matching output axes,\nnot just matching tuples of axis numbers."},"897":{"id":"/docs/guides/symmetry-117","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#binary-pointwise-ops-and-broadcasting","content":"`intersection_tensor` keeps `C_3`, because `C_3` is the common subgroup of\n`S_3` and `C_3`."},"898":{"id":"/docs/guides/symmetry-118","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#binary-pointwise-ops-and-broadcasting","content":"Multiple groups are handled independently:"},"899":{"id":"/docs/guides/symmetry-119","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#binary-pointwise-ops-and-broadcasting","content":"`shared_group_tensor` keeps symmetry on `(0, 1)` and loses the independent\ngroup on `(2, 3)`."},"900":{"id":"/docs/guides/symmetry-120","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#binary-pointwise-ops-and-broadcasting","content":"Broadcasting matters too:"},"901":{"id":"/docs/guides/symmetry-121","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#binary-pointwise-ops-and-broadcasting","content":"Before group intersection, any axis stretched from size `1` to a larger output\nsize is removed from the candidate group. That is why broadcasted singleton\naxes do not automatically stay symmetric after a binary op."},"902":{"id":"/docs/guides/symmetry-122","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#warnings-conservative-behavior-and-re-tagging","content":"Whest propagates symmetry metadata conservatively. When the operation does not\nguarantee that the declared symmetry survives, the result falls back to a plain\n`ndarray`."},"903":{"id":"/docs/guides/symmetry-123","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#warnings-conservative-behavior-and-re-tagging","content":"`row_slice` is a plain `ndarray`, not a `SymmetricTensor`. That is expected."},"904":{"id":"/docs/guides/symmetry-124","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#warnings-conservative-behavior-and-re-tagging","content":"`SymmetryLossWarning` tells you that metadata was dropped or weakened during an\noperation. If you know more about the result than the conservative propagation\nrule does, you can re-tag it with `we.as_symmetric()`."},"905":{"id":"/docs/guides/symmetry-125","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#warnings-conservative-behavior-and-re-tagging","content":"One important caveat: the current implementation does **not** report every\npossible partial weakening via `SymmetryLossWarning`. Treat the warning system\nas helpful guidance, not as a complete audit of every same-axis subgroup\nchange."},"906":{"id":"/docs/guides/symmetry-126","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"The propagation rules are easier to predict if you keep three ideas in mind:"},"907":{"id":"/docs/guides/symmetry-127","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"**Unary pointwise ops** currently rebuild results from `symmetric_axes`, so\nthey preserve the same symmetric axes but not exact subgroup identity for\n`C_k`, `D_k`, or custom groups"},"908":{"id":"/docs/guides/symmetry-128","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"**Slicing** uses the pointwise stabilizer of the removed axes"},"909":{"id":"/docs/guides/symmetry-129","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"**Reductions** use the setwise stabilizer of the reduced axes"},"910":{"id":"/docs/guides/symmetry-130","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"**Binary pointwise ops** use intersection of both operands' groups after\nbroadcast alignment"},"911":{"id":"/docs/guides/symmetry-131","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"After computing the surviving subgroup, whest restricts it to the axes still\npresent in the output and remaps those axes to the output tensor's numbering."},"912":{"id":"/docs/guides/symmetry-132","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"That is why:"},"913":{"id":"/docs/guides/symmetry-133","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"slicing one axis of `S_3` leaves `S_2`"},"914":{"id":"/docs/guides/symmetry-134","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"slicing one axis of `C_3` leaves nothing nontrivial"},"915":{"id":"/docs/guides/symmetry-135","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#under-the-hood","content":"reducing `{1, 3}` of `C_4` can still leave `C_2`"},"916":{"id":"/docs/guides/symmetry-136","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#going-deeper","content":"Einsum Patterns — how declared and induced symmetry interact with `we.einsum`"},"917":{"id":"/docs/guides/symmetry-137","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#going-deeper","content":"Symmetry Detection Deep Dive — the full detection algorithm for `einsum`"},"918":{"id":"/docs/guides/symmetry-138","page_id":"/docs/guides/symmetry","tags":[],"type":"text","url":"/docs/guides/symmetry#going-deeper","content":"Symmetry Explorer — experiment with symmetry interactively"},"919":{"id":"/docs/infrastructure/client-server","page_id":"/docs/infrastructure/client-server","type":"page","content":"Client-Server Model","breadcrumbs":["Documentation","Infrastructure"],"tags":[],"url":"/docs/infrastructure/client-server"},"920":{"id":"/docs/infrastructure/client-server-0","page_id":"/docs/infrastructure/client-server","type":"heading","tags":[],"url":"/docs/infrastructure/client-server#why-client-server","content":"Why client-server?"},"921":{"id":"/docs/infrastructure/client-server-1","page_id":"/docs/infrastructure/client-server","type":"heading","tags":[],"url":"/docs/infrastructure/client-server#how-it-works","content":"How it works"},"922":{"id":"/docs/infrastructure/client-server-2","page_id":"/docs/infrastructure/client-server","type":"heading","tags":[],"url":"/docs/infrastructure/client-server#communication-protocol","content":"Communication protocol"},"923":{"id":"/docs/infrastructure/client-server-3","page_id":"/docs/infrastructure/client-server","type":"heading","tags":[],"url":"/docs/infrastructure/client-server#api-compatibility","content":"API compatibility"},"924":{"id":"/docs/infrastructure/client-server-4","page_id":"/docs/infrastructure/client-server","type":"heading","tags":[],"url":"/docs/infrastructure/client-server#when-to-use-which","content":"When to use which"},"925":{"id":"/docs/infrastructure/client-server-5","page_id":"/docs/infrastructure/client-server","type":"heading","tags":[],"url":"/docs/infrastructure/client-server#three-packages-in-this-repo","content":"Three packages in this repo"},"926":{"id":"/docs/infrastructure/client-server-6","page_id":"/docs/infrastructure/client-server","type":"heading","tags":[],"url":"/docs/infrastructure/client-server#related-pages","content":"Related pages"},"927":{"id":"/docs/infrastructure/client-server-7","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server","content":"This page covers the client-server architecture used for **competition evaluation**, where participant code runs in an isolated container. For how whest wraps NumPy internally, see How whest Works."},"928":{"id":"/docs/infrastructure/client-server-8","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server","content":"*Use this page to understand how whest's client-server architecture works and why it exists.*"},"929":{"id":"/docs/infrastructure/client-server-9","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server","content":"**You will learn:**"},"930":{"id":"/docs/infrastructure/client-server-10","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server","content":"Why whest uses a client-server model for competition evaluation"},"931":{"id":"/docs/infrastructure/client-server-11","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server","content":"How arrays, operations, and budgets flow between client and server"},"932":{"id":"/docs/infrastructure/client-server-12","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server","content":"How to choose between the local library and client-server packages"},"933":{"id":"/docs/infrastructure/client-server-13","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#why-client-server","content":"In competition evaluation, participant code runs in an **isolated container** that cannot import NumPy directly. This prevents participants from bypassing FLOP counting by calling NumPy functions outside whest."},"934":{"id":"/docs/infrastructure/client-server-14","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#why-client-server","content":"The client-server model enforces this isolation:"},"935":{"id":"/docs/infrastructure/client-server-15","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#how-it-works","content":"**Server** runs the real whest library backed by NumPy. It stores all arrays, enforces budgets, and counts FLOPs."},"936":{"id":"/docs/infrastructure/client-server-16","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#how-it-works","content":"**Client** is a drop-in replacement (`import whest as we`) that proxies every operation to the server over ZMQ (msgpack-encoded messages)."},"937":{"id":"/docs/infrastructure/client-server-17","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#how-it-works","content":"**Arrays stay on the server.** The client holds lightweight `RemoteArray` handles that reference server-side data. When you call `we.einsum(...)`, the client sends the operation and handle IDs to the server, which executes it and returns a new handle."},"938":{"id":"/docs/infrastructure/client-server-18","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#how-it-works","content":"**Budget enforcement happens server-side.** The client cannot manipulate FLOP counts."},"939":{"id":"/docs/infrastructure/client-server-19","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#communication-protocol","content":"**Transport:** ZMQ (REQ/REP pattern)"},"940":{"id":"/docs/infrastructure/client-server-20","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#communication-protocol","content":"**Serialization:** msgpack with binary-safe array payloads"},"941":{"id":"/docs/infrastructure/client-server-21","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#communication-protocol","content":"**Default endpoint:** `ipc:///tmp/whest.sock` (configurable via `WHEST_SERVER_URL`)"},"942":{"id":"/docs/infrastructure/client-server-22","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#communication-protocol","content":"**Timeout:** 30 seconds per request"},"943":{"id":"/docs/infrastructure/client-server-23","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#api-compatibility","content":"Code written for the local library works unchanged with the client:"},"944":{"id":"/docs/infrastructure/client-server-24","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#when-to-use-which","content":"Use case"},"945":{"id":"/docs/infrastructure/client-server-25","page_id":"/docs/infrastructure/client-server","tags":[],"type":"text","url":"/docs/infrastructure/client-server#when-to-use-which","content":"Package"},"946":{"id":"/docs/infrastructure/client-server-26","page