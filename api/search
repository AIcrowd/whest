`"},"285":{"id":"/docs/development/contributing-43","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated slim API operation index consumed by `/docs/api`"},"286":{"id":"/docs/development/contributing-44","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/public/api-data/ops/*.json`"},"287":{"id":"/docs/development/contributing-45","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated per-operation detail payloads for standalone op pages"},"288":{"id":"/docs/development/contributing-46","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/.generated/op-doc-imports.ts`"},"289":{"id":"/docs/development/contributing-47","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated static import map used by `/docs/api/ops/<slug>/`"},"290":{"id":"/docs/development/contributing-48","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`scripts/generate_api_docs.py`"},"291":{"id":"/docs/development/contributing-49","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Regenerates the API index, per-op payloads, and import map"},"292":{"id":"/docs/development/contributing-50","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`docker/`"},"293":{"id":"/docs/development/contributing-51","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Local client-server and hardened evaluation images"},"294":{"id":"/docs/development/contributing-52","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#initial-setup","content":"For normal work on the core package, docs, and root test suite:"},"295":{"id":"/docs/development/contributing-53","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#initial-setup","content":"`make install` runs `uv sync --all-extras` and configures the local git hooks."},"296":{"id":"/docs/development/contributing-54","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#which-environment-to-use","content":"The root environment covers the core package, linting, docs, and the main test\nsuite. The client and server each also have their own `pyproject.toml`."},"297":{"id":"/docs/development/contributing-55","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#which-environment-to-use","content":"One important caveat: `whest-server` depends on the local `whest`\npackage, which is not resolved from a package index in a fresh source checkout.\nFor server development, run commands from the repository root with\n`PYTHONPATH=src:whest-server/src` instead of relying on `cd whest-server\n&& uv run ...`."},"298":{"id":"/docs/development/contributing-56","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#core-library","content":"If you prefer direct `uv` commands:"},"299":{"id":"/docs/development/contributing-57","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#core-library","content":"When running the local docs site and you want whest error messages to link to\nyour local copy instead of the hosted site, set:"},"300":{"id":"/docs/development/contributing-58","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#core-library","content":"If `WHEST_DOCS_ROOT` is unset, whest falls back to the hosted docs at\n`https://aicrowd.github.io/whest/docs`."},"301":{"id":"/docs/development/contributing-59","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#client-package","content":"The client package is independently installable, so its test suite can run via\nits own project file:"},"302":{"id":"/docs/development/contributing-60","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#client-package","content":"Client integration and adversarial tests start a real server subprocess using\nthe repository root `.venv/bin/python`, so run `make install` first."},"303":{"id":"/docs/development/contributing-61","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#server-package","content":"Run server tests from the repository root so the local core package is on\n`PYTHONPATH`:"},"304":{"id":"/docs/development/contributing-62","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#server-package","content":"To launch the server manually from a source checkout:"},"305":{"id":"/docs/development/contributing-63","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-client-and-server-together-without-docker","content":"From a source checkout, use repo-root commands so both packages resolve\ncorrectly:"},"306":{"id":"/docs/development/contributing-64","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-client-and-server-together-without-docker","content":"See Running with Docker if you want the same split\nusing containers."},"307":{"id":"/docs/development/contributing-65","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#generated-documentation","content":"Do not hand-edit `website/public/ops.json`,\n`website/public/api-data/ops/*.json`, or `website/.generated/op-doc-imports.ts`.\nThe interactive API reference and standalone op pages consume those generated\nartifacts directly."},"308":{"id":"/docs/development/contributing-66","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#generated-documentation","content":"Instead, update `scripts/generate_api_docs.py`, the relevant source docstrings,\nor the operation registry, then regenerate and verify:"},"309":{"id":"/docs/development/contributing-67","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#numpy-compatibility-testing","content":"whest's goal is to be a drop-in replacement for NumPy: `import whest as np` should work for all supported functions. To verify this, we run NumPy's own test suite against whest."},"310":{"id":"/docs/development/contributing-68","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#how-it-works","content":"A pytest conftest at `tests/numpy_compat/conftest.py` monkeypatches numpy functions with their whest equivalents at session start. When we point pytest at NumPy's installed test files using `--pyargs`, every test that calls `np.sum(...)`, `np.mean(...)`, etc. actually calls whest's version."},"311":{"id":"/docs/development/contributing-69","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#avoiding-infinite-recursion","content":"whest functions internally call numpy (e.g., `we.dot` calls `_np.dot`). Since `_np` IS the numpy module, patching `numpy.dot = we.dot` would cause infinite recursion: `we.dot` → `_np.dot` → `numpy.dot` → `we.dot` → ..."},"312":{"id":"/docs/development/contributing-70","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#avoiding-infinite-recursion","content":"We solve this by **freezing numpy before patching**: the conftest creates a snapshot of the numpy module (and its submodules like `numpy.linalg`, `numpy.fft`), then rebinds every whest module's `_np` reference to the frozen copy. Now whest's internal calls go to the original numpy functions, while the test suite sees whest's versions."},"313":{"id":"/docs/development/contributing-71","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Of whest's 508 registered functions, most non-ufunc functions are patched onto numpy during testing. The only categories skipped:"},"314":{"id":"/docs/development/contributing-72","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Category"},"315":{"id":"/docs/development/contributing-73","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Count"},"316":{"id":"/docs/development/contributing-74","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Why skipped"},"317":{"id":"/docs/development/contributing-75","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Ufuncs"},"318":{"id":"/docs/development/contributing-76","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"101"},"319":{"id":"/docs/development/contributing-77","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"whest functions are plain callables, not ufuncs -- they lack `.reduce`, `.accumulate`, `.outer`, `.nargs`. Tests check these attributes at collection time."},"320":{"id":"/docs/development/contributing-78","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Blacklisted"},"321":{"id":"/docs/development/contributing-79","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"32"},"322":{"id":"/docs/development/contributing-80","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Intentionally unsupported"},"323":{"id":"/docs/development/contributing-81","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"`linalg.outer`"},"324":{"id":"/docs/development/contributing-82","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"1"},"325":{"id":"/docs/development/contributing-83","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"`we.linalg.outer` delegates to `np.outer` (not `np.linalg.outer`), which has different validation behavior"},"326":{"id":"/docs/development/contributing-84","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Everything else -- free ops, counted custom ops (dot, einsum, etc.), submodule functions (linalg, fft), reductions, and special functions -- is patched."},"327":{"id":"/docs/development/contributing-85","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"We run 7 NumPy test modules covering core math, ufuncs, numerics, linear algebra, FFT, polynomials, and random:"},"328":{"id":"/docs/development/contributing-86","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Suite"},"329":{"id":"/docs/development/contributing-87","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Module"},"330":{"id":"/docs/development/contributing-88","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Passed"},"331":{"id":"/docs/development/contributing-89","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"xfailed"},"332":{"id":"/docs/development/contributing-90","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Core math"},"333":{"id":"/docs/development/contributing-91","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"`numpy._core.tests.test_umath`"},"334":{"id":"/docs/development/contributing-92","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"4,668"},"335":{"id":"/docs/development/contributing-93","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"13"},"336":{"id":"/docs/development/contributing-94","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Ufunc infrastructure"},"337":{"id":"/docs/development/contributing-95","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"`numpy._core.tests.test_ufunc`"},"338":{"id":"/docs/development/contributing-96","page_id":"/docs/develop