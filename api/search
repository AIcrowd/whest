nt/contributing-117","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"0"},"360":{"id":"/docs/development/contributing-118","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"**Total**"},"361":{"id":"/docs/development/contributing-119","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"**7,363**"},"362":{"id":"/docs/development/contributing-120","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"**331**"},"363":{"id":"/docs/development/contributing-121","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"All failures are tracked as xfails in `tests/numpy_compat/xfails.py`."},"364":{"id":"/docs/development/contributing-122","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-the-tests","content":"Tests use `pytest-xdist` for parallel execution across all CPU cores."},"365":{"id":"/docs/development/contributing-123","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-the-tests","content":"The numpy\\_compat tests are excluded from the default `pytest` run (via `pyproject.toml` `addopts`) to prevent the monkeypatch from contaminating the main test suite. They run as a separate step in CI."},"366":{"id":"/docs/development/contributing-124","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Tests that fail due to known, accepted differences are tracked in `tests/numpy_compat/xfails.py`. Each entry maps a test pattern to a categorized reason:"},"367":{"id":"/docs/development/contributing-125","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Category"},"368":{"id":"/docs/development/contributing-126","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Meaning"},"369":{"id":"/docs/development/contributing-127","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Examples"},"370":{"id":"/docs/development/contributing-128","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`NOT_IMPLEMENTED`"},"371":{"id":"/docs/development/contributing-129","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Function exists but lacks a kwarg or edge case"},"372":{"id":"/docs/development/contributing-130","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Missing `out=`, `where=`, `subok=` kwargs"},"373":{"id":"/docs/development/contributing-131","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`UNSUPPORTED_DTYPE`"},"374":{"id":"/docs/development/contributing-132","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"whest doesn't support this dtype"},"375":{"id":"/docs/development/contributing-133","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"timedelta, object arrays"},"376":{"id":"/docs/development/contributing-134","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`UFUNC_INTERNALS`"},"377":{"id":"/docs/development/contributing-135","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Test relies on ufunc protocol"},"378":{"id":"/docs/development/contributing-136","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`.reduce`, `__array_ufunc__`"},"379":{"id":"/docs/development/contributing-137","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`BUDGET_SIDE_EFFECT`"},"380":{"id":"/docs/development/contributing-138","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Test assumes no global state changes"},"381":{"id":"/docs/development/contributing-139","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Budget deduction during assertions"},"382":{"id":"/docs/development/contributing-140","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`NUMPY_INTERNAL`"},"383":{"id":"/docs/development/contributing-141","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Test uses numpy internals"},"384":{"id":"/docs/development/contributing-142","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`_umath_tests`, internal type tables"},"385":{"id":"/docs/development/contributing-143","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"The linalg suite has the most xfails (255) because whest's linalg wrappers don't support stacked/batched arrays, 0-size arrays, or some advanced kwargs that numpy's linalg tests exercise extensively."},"386":{"id":"/docs/development/contributing-144","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"Run a suite: `uv run pytest tests/numpy_compat/ --pyargs <module> -n auto --tb=line`"},"387":{"id":"/docs/development/contributing-145","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"Categorize each failure"},"388":{"id":"/docs/development/contributing-146","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"If it's a bug we should fix, create an issue"},"389":{"id":"/docs/development/contributing-147","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"If it's an accepted divergence, add it to `xfails.py`"},"390":{"id":"/docs/development/contributing-148","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"We considered alternatives:"},"391":{"id":"/docs/development/contributing-149","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"**Array subclass with `__array_ufunc__`**: Would intercept ufunc calls, but whest arrays are plain `numpy.ndarray` by design -- no custom tensor class."},"392":{"id":"/docs/development/contributing-150","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"**Running tests with `import whest as np`**: NumPy's test files import from `numpy._core`, `numpy.testing`, etc. -- can't redirect all internal imports."},"393":{"id":"/docs/development/contributing-151","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"**Monkeypatching with frozen numpy**: Simple, works with NumPy's existing test infrastructure, tests exactly what users experience (same function signatures), and the frozen-numpy trick prevents infinite recursion."},"394":{"id":"/docs/development/contributing-152","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#related-pages","content":"Running with Docker — containerized client-server setup"},"395":{"id":"/docs/development/contributing-153","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#related-pages","content":"Client-Server Model — architecture overview"},"396":{"id":"/docs/getting-started/competition","page_id":"/docs/getting-started/competition","type":"page","content":"Competition Guide","breadcrumbs":["Documentation","Getting Started"],"tags":[],"url":"/docs/getting-started/competition"},"397":{"id":"/docs/getting-started/competition-0","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#setting-a-flop-budget","content":"Setting a FLOP budget"},"398":{"id":"/docs/getting-started/competition-1","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#decorator-form","content":"Decorator form"},"399":{"id":"/docs/getting-started/competition-2","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#wall-time-limits","content":"Wall-time limits"},"400":{"id":"/docs/getting-started/competition-3","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Reading the budget summary"},"401":{"id":"/docs/getting-started/competition-4","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#quick-tips-for-competition","content":"Quick tips for competition"},"402":{"id":"/docs/getting-started/competition-5","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#when-things-go-wrong","content":"When things go wrong"},"403":{"id":"/docs/getting-started/competition-6","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"*Everything you need to compete within a FLOP budget.*"},"404":{"id":"/docs/getting-started/competition-7","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"**You will learn:**"},"405":{"id":"/docs/getting-started/competition-8","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How to set budget limits with `BudgetContext`"},"406":{"id":"/docs/getting-started/competition-9","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How to use the `@we.budget` decorator form"},"407":{"id":"/docs/getting-started/competition-10","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How wall-time limits work via `wall_time_limit_s`"},"408":{"id":"/docs/getting-started/competition-11","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How to read budget summaries"},"409":{"id":"/docs/getting-started/competition-12","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"Common competition pitfalls and tips"},"410":{"id":"/docs/getting-started/competition-13","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#setting-a-flop-budget","content":"Every competition submission runs inside a FLOP budget. Use `BudgetContext` to declare how many FLOPs your code is allowed to spend:"},"411":{"id":"/docs/getting-started/competition-14","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#setting-a-flop-budget","content":"If your code exceeds the budget, whest raises `BudgetExhaustedError` *before* the offending operation executes. The error message includes the cost of the failed operation and the remaining budget."},"412":{"id":"/docs/getting-started/competition-15","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#setting-a-flop-budget","content":"The `namespace` parameter sets the root namespace prefix for that budget context. Nested `we.namespace(...)` scopes extend it with dotted segments, but they do not create child budgets or split the FLOP limit into separate pools."},"413":{"id":"/docs/getting-started/competition-16","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#decorator-form","content":"For cleaner code, use `@we.budget` to attach a budget directly to a function:"},"414":{"id":"/docs/getting-started/competition-17","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#decorator-form","content":"Each call to the decorated function runs inside the same `BudgetContext`; the namespace is only the root prefix used for attribution, not a separate budget pool. Repeated calls reuse that context and keep accumulating on the same budget and operation log."},"415":{"id":"/docs/getting-started/competition-18","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"In addition to FLOP budgets, competitions may enforce a wall-clock time limit via `wall_time_limit_s`. This prevents solutions from stalling on operations that are analytically cheap but slow in practice:"},"416":{"id":"/docs/getting-started/competition-19","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"If the wall-clock time is exceeded, whest raises `TimeExhaustedError`. The timer starts when the context is entered and is checked after each counted operation."},"417":{"id":"/docs/getting-started/competition-20","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"What `wall_time_limit_s` does and does not do:"},"418":{"id":"/docs/getting-started/competition-21","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It is a `BudgetContext` setting, so you configure it in the same place you set `flop_budget`."},"419":{"id":"/docs/getting-started/competition-22","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It measures total wall-clock time for the active context, not FLOPs."},"420":{"id":"/docs/getting-started/competition-23","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It is checked cooperatively before and after counted NumPy calls, so overshoot is bounded by the duration of one NumPy call."},"421":{"id":"/docs/getting-started/competition-24","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It is a clean diagnostic limit inside whest. Hard process/container kills still belong to the outer execution environment."},"422":{"id":"/docs/getting-started/competition-25","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Call `budget.summary()` when you want the current context's summary, or `we.budget_summary()` for the accumulated session/global view. Both stay flat by default; use `by_namespace=True` only when you want a namespace breakdown:"},"423":{"id":"/docs/getting-started/competition-26","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Use these forms for different questions:"},"424":{"id":"/docs/getting-started/competition-27","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"`budget.summary()` answers \"what did this one explicit context spend?\""},"425":{"id":"/docs/getting-started/competition-28","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"`we.budget_summary()` answers \"what has this process/session spent overall?\""},"426":{"id":"/docs/getting-started/competition-29","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"`budget.summary_dict(...)` and `we.budget_summary_dict(...)` return the same information as structured data instead of formatted text."},"427":{"id":"/docs/getting-started/competition-30","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"The block below shows `print(budget.summary(by_namespace=True))` for the `solver` context:"},"428":{"id":"/docs/getting-started/competition-31","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Key things to look for:"},"429":{"id":"/docs/getting-started/competition-32","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**Budget / Used / Remaining:** the top rows show the explicit competition budget, current spend, and remaining headroom"},"430":{"id":"/docs/getting-started/competition-33","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**By namespace:** `solver` is the root prefix, and nested scopes show up as dotted paths like `solver.precompute`. Use `budget.summary(by_namespace=True)` for the current context or `we.budget_summary(by_namespace=True)` for the accumulated session/global view"},"431":{"id":"/docs/getting-started/competition-34","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**By operation:** this toy pass is dominated by the single `einsum`; `exp` and `sum` are tiny by comparison"},"432":{"id":"/docs/getting-started/competition-35","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**Wall / tracked / untracked time:** wall time is total elapsed time for the context, tracked time is time spent inside counted NumPy calls, and untracked time is everything else in the context (`wall_time - tracked_time`)"},"433":{"id":"/docs/getting-started/competition-36","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**Flat default:** the default summary stays flat unless you opt into `by_namespace=True`"},"434":{"id":"/docs/getting-started/competition-37","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"For programmatic access, use `we.budget_summary_dict()`:"},"435":{"id":"/docs/getting-started/competition-38","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Check costs before committing budget.** Use cost query functions to estimate before executing:"},"436":{"id":"/docs/getting-started/competition-39","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Use namespaces for phases.** Split your solution into named phases (e.g., `\"init\"`, `\"solve\"`, `\"refine\"`) so the budget summary shows exactly where FLOPs are spent."},"437":{"id":"/docs/getting-started/competition-40","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Exploit symmetry for savings.** If your tensors are symmetric, wrapping them with `we.as_symmetric()` can halve pointwise costs and significantly reduce einsum costs. See Symmetry Savings for details."},"438":{"id":"/docs/getting-started/competition-41","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Prefer cheaper operations.** A matrix-vector product via `we.einsum('ij,j->i', A, x)` costs `m*n` FLOPs, while a full matrix-matrix multiply costs `m*n*k`. Avoid computing more than you need."},"439":{"id":"/docs/getting-started/competition-42","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Watch out for hidden costs.** Operations like `we.array()` and `we.concatenate()` are *not* free -- they charge `numel(output)` FLOPs, and `we.where()` charges `numel(condition)`. Check the cost of any operation you are unsure about."},"440":{"id":"/docs/getting-started/competition-43","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#when-things-go-wrong","content":"If you hit `BudgetExhaustedError`, see Budget Planning & Debugging for a systematic approach to diagnosing overruns and reducing costs."},"441":{"id":"/docs/getting-started/installation","page_id":"/docs/getting-started/installation","type":"page","content":"Installation","breadcrumbs":["Documentation","Getting Started"],"tags":[],"url":"/docs/getting-started/installation"},"442":{"id":"/docs/getting-started/installation-0","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#install-as-a-dependency","content":"Install as a dependency"},"443":{"id":"/docs/getting-started/installation-1","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#install-for-development","content":"Install for development"},"444":{"id":"/docs/getting-started/installation-2","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#verify-installation","content":"Verify installation"},"445":{"id":"/docs/getting-started/installation-3","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#what-youll-see","content":"What you'll see"},"446":{"id":"/docs/getting-started/installation-4","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#common-pitfalls","content":"Common pitfalls"},"447":{"id":"/docs/getting-start