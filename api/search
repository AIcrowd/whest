ng","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Client proxy used in sandboxed participant environments"},"295":{"id":"/docs/development/contributing-32","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`flopscope-server/src/flopscope_server/`"},"296":{"id":"/docs/development/contributing-33","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"ZMQ server that executes the real library"},"297":{"id":"/docs/development/contributing-34","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`tests/`"},"298":{"id":"/docs/development/contributing-35","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Core library test suite"},"299":{"id":"/docs/development/contributing-36","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`flopscope-client/tests/`"},"300":{"id":"/docs/development/contributing-37","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Client unit, integration, and adversarial tests"},"301":{"id":"/docs/development/contributing-38","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`flopscope-server/tests/`"},"302":{"id":"/docs/development/contributing-39","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Server unit tests"},"303":{"id":"/docs/development/contributing-40","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/content/docs/`"},"304":{"id":"/docs/development/contributing-41","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Docs source for the published site"},"305":{"id":"/docs/development/contributing-42","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/public/ops.json`"},"306":{"id":"/docs/development/contributing-43","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated slim API operation index consumed by `/docs/api`"},"307":{"id":"/docs/development/contributing-44","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/public/api-data/ops/*.json`"},"308":{"id":"/docs/development/contributing-45","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated per-operation detail payloads for canonical operation pages"},"309":{"id":"/docs/development/contributing-46","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/.generated/public-api-routes.json`"},"310":{"id":"/docs/development/contributing-47","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated canonical route manifest for `/docs/api/...` pages"},"311":{"id":"/docs/development/contributing-48","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/.generated/op-doc-imports.ts`"},"312":{"id":"/docs/development/contributing-49","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated static import map for operation docs"},"313":{"id":"/docs/development/contributing-50","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/.generated/symbol-doc-imports.ts`"},"314":{"id":"/docs/development/contributing-51","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated static import map for public helper and object docs"},"315":{"id":"/docs/development/contributing-52","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`website/.generated/public-api-symbols.json`"},"316":{"id":"/docs/development/contributing-53","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Generated manifest of non-registry public API pages"},"317":{"id":"/docs/development/contributing-54","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`scripts/generate_api_docs.py`"},"318":{"id":"/docs/development/contributing-55","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Regenerates API route manifests, per-operation payloads, and public symbol docs"},"319":{"id":"/docs/development/contributing-56","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`docker/`"},"320":{"id":"/docs/development/contributing-57","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Local client-server and hardened evaluation images"},"321":{"id":"/docs/development/contributing-58","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#initial-setup","content":"For normal work on the core package, docs, and root test suite:"},"322":{"id":"/docs/development/contributing-59","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#initial-setup","content":"`make install` runs `uv sync --all-extras` and configures the local git hooks."},"323":{"id":"/docs/development/contributing-60","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#which-environment-to-use","content":"The root environment covers the core package, linting, docs, and the main test\nsuite. The client and server each also have their own `pyproject.toml`."},"324":{"id":"/docs/development/contributing-61","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#which-environment-to-use","content":"One important caveat: `flopscope-server` depends on the local `flopscope`\npackage, which is not resolved from a package index in a fresh source checkout.\nFor server development, run commands from the repository root with\n`PYTHONPATH=src:flopscope-server/src` instead of relying on `cd flopscope-server\n&& uv run ...`."},"325":{"id":"/docs/development/contributing-62","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#core-library","content":"If you prefer direct `uv` commands:"},"326":{"id":"/docs/development/contributing-63","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#core-library","content":"When running the local docs site and you want flopscope error messages to link to\nyour local copy instead of the hosted site, set:"},"327":{"id":"/docs/development/contributing-64","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#core-library","content":"If `FLOPSCOPE_DOCS_ROOT` is unset, flopscope falls back to the hosted docs at\n`https://aicrowd.github.io/flopscope/docs`."},"328":{"id":"/docs/development/contributing-65","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#client-package","content":"The client package is independently installable, so its test suite can run via\nits own project file:"},"329":{"id":"/docs/development/contributing-66","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#client-package","content":"Client integration and adversarial tests start a real server subprocess using\nthe repository root `.venv/bin/python`, so run `make install` first."},"330":{"id":"/docs/development/contributing-67","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#server-package","content":"Run server tests from the repository root so the local core package is on\n`PYTHONPATH`:"},"331":{"id":"/docs/development/contributing-68","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#server-package","content":"To launch the server manually from a source checkout:"},"332":{"id":"/docs/development/contributing-69","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-client-and-server-together-without-docker","content":"From a source checkout, use repo-root commands so both packages resolve\ncorrectly:"},"333":{"id":"/docs/development/contributing-70","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-client-and-server-together-without-docker","content":"See Running with Docker if you want the same split\nusing containers."},"334":{"id":"/docs/development/contributing-71","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#generated-documentation","content":"Do not hand-edit `website/public/ops.json`,\n`website/public/api-data/ops/*.json`, `website/.generated/public-api-routes.json`,\n`website/.generated/op-doc-imports.ts`, `website/.generated/symbol-doc-imports.ts`,\nor `website/.generated/public-api-symbols.json`. The interactive API reference,\ncanonical API pages, and legacy redirect routes consume those generated\nartifacts directly."},"335":{"id":"/docs/development/contributing-72","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#generated-documentation","content":"Instead, update `scripts/generate_api_docs.py`, the relevant source docstrings,\nor the operation registry, then regenerate and verify:"},"336":{"id":"/docs/development/contributing-73","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#numpy-compatibility-testing","content":"flopscope's goal is NumPy API compatibility on the counted surface: `import flopscope.numpy as np` should work for supported functions. To verify this, we run NumPy's own test suite against flopscope."},"337":{"id":"/docs/development/contributing-74","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#how-it-works","content":"A pytest conftest at `tests/numpy_compat/conftest.py` monkeypatches numpy functions with their flopscope equivalents at session start. When we point pytest at NumPy's installed test files using `--pyargs`, every test that calls `np.sum(...)`, `np.mean(...)`, etc. actually calls flopscope's version."},"338":{"id":"/docs/development/contributing-75","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#avoiding-infinite-recursion","content":"flopscope functions internally call numpy (for example, `fnp.dot` eventually delegates to `_np.dot` inside the implementation modules). Since `_np` is the numpy module, patching `numpy.dot = fnp.dot` without isolating those backend references would cause infinite recursion: `fnp.dot` → `_np.dot` → `numpy.dot` → `fnp.dot` → ..."},"339":{"id":"/docs/development/contributing-76","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#avoiding-infinite-recursion","content":"We solve this by **freezing numpy before patching**: the conftest creates a snapshot of the numpy module (and its submodules like `numpy.linalg`, `numpy.fft`), then rebinds every flopscope module's `_np` reference to the frozen copy. Now flopscope's internal calls go to the original numpy functions, while the test suite sees flopscope's versions."},"340":{"id":"/docs/development/contributing-77","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Of flopscope's 508 registered functions, most non-ufunc functions are patched onto numpy during testing. The only categories skipped:"},"341":{"id":"/docs/development/contributing-78","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Category"},"342":{"id":"/docs/development/contributing-79","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Count"},"343":{"id":"/docs/development/contributing-80","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Why skipped"},"344":{"id":"/docs/development/contributing-81","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Ufuncs"},"345":{"id":"/docs/development/contributing-82","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"101"},"346":{"id":"/docs/development/contributing-83","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"flopscope functions are plain callables, not ufuncs -- they lack `.reduce`, `.accumulate`, `.outer`, `.nargs`. Tests check these attributes at collection time."},"347":{"id":"/docs/development/contributing-84","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Blacklisted"},"348":{"id":"/docs/development/contributing-85","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"32"},"349":{"id":"/docs/development/contributing-86","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Intentionally unsupported"},"350":{"id":"/docs/development/contributing-87","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"`linalg.outer`"},"351":{"id":"/docs/development/contributing-88","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"1"},"352":{"id":"/docs/development/contributing-89","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"`fnp.linalg.outer` delegates to `np.outer` (not `np.linalg.outer`), which has different validation behavior"},"353":{"id":"/docs/development/contributing-90","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#what-gets-patched","content":"Everything else -- free ops, counted custom ops (dot, einsum, etc.), submodule functions (linalg, fft), reductions, and special functions -- is patched."},"354":{"id":"/docs/development/contributing-91","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"We run 7 NumPy test modules covering core math, ufuncs, numerics, linear algebra, FFT, polynomials, and random:"},"355":{"id":"/docs/development/contributing-92","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Suite"},"356":{"id":"/docs/development/contributing-93","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Module"},"357":{"id":"/docs/development/contributing-94","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Passed"},"358":{"id":"/docs/development/contributing-95","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"xfailed"},"359":{"id":"/docs/development/contributing-96","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Core math"},"360":{"id":"/docs/development/contributing-97","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"`numpy._core.tests.test_umath`"},"361":{"id":"/docs/development/contributing-98","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"4,668"},"362":{"id":"/docs/development/contributing-99","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"13"},"363":{"id":"/docs/development/contributing-100","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"Ufunc infrast