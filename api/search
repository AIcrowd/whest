/contributing-148","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`_umath_tests`, internal type tables"},"412":{"id":"/docs/development/contributing-149","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"The linalg suite has the most xfails (255) because flopscope's linalg wrappers don't support stacked/batched arrays, 0-size arrays, or some advanced kwargs that numpy's linalg tests exercise extensively."},"413":{"id":"/docs/development/contributing-150","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"Run a suite: `uv run pytest tests/numpy_compat/ --pyargs <module> -n auto --tb=line`"},"414":{"id":"/docs/development/contributing-151","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"Categorize each failure"},"415":{"id":"/docs/development/contributing-152","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"If it's a bug we should fix, create an issue"},"416":{"id":"/docs/development/contributing-153","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#triaging-new-failures","content":"If it's an accepted divergence, add it to `xfails.py`"},"417":{"id":"/docs/development/contributing-154","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"We considered alternatives:"},"418":{"id":"/docs/development/contributing-155","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"**Array subclass with `__array_ufunc__`**: Would intercept ufunc calls, but flopscope arrays are plain `numpy.ndarray` by design -- no custom tensor class."},"419":{"id":"/docs/development/contributing-156","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"**Running tests with `import flopscope as np`**: NumPy's test files import from `numpy._core`, `numpy.testing`, etc. -- can't redirect all internal imports."},"420":{"id":"/docs/development/contributing-157","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#why-monkeypatching-not-subclassing","content":"**Monkeypatching with frozen numpy**: Simple, works with NumPy's existing test infrastructure, tests exactly what users experience (same function signatures), and the frozen-numpy trick prevents infinite recursion."},"421":{"id":"/docs/development/contributing-158","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#related-pages","content":"Running with Docker — containerized client-server setup"},"422":{"id":"/docs/development/contributing-159","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#related-pages","content":"Client-Server Model — architecture overview"},"423":{"id":"/docs/getting-started/competition","page_id":"/docs/getting-started/competition","type":"page","content":"Competition Guide","breadcrumbs":["Documentation","Getting Started"],"tags":[],"url":"/docs/getting-started/competition"},"424":{"id":"/docs/getting-started/competition-0","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#setting-a-flop-budget","content":"Setting a FLOP budget"},"425":{"id":"/docs/getting-started/competition-1","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#decorator-form","content":"Decorator form"},"426":{"id":"/docs/getting-started/competition-2","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#wall-time-limits","content":"Wall-time limits"},"427":{"id":"/docs/getting-started/competition-3","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Reading the budget summary"},"428":{"id":"/docs/getting-started/competition-4","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#quick-tips-for-competition","content":"Quick tips for competition"},"429":{"id":"/docs/getting-started/competition-5","page_id":"/docs/getting-started/competition","type":"heading","tags":[],"url":"/docs/getting-started/competition#when-things-go-wrong","content":"When things go wrong"},"430":{"id":"/docs/getting-started/competition-6","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"*Everything you need to compete within a FLOP budget.*"},"431":{"id":"/docs/getting-started/competition-7","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"**You will learn:**"},"432":{"id":"/docs/getting-started/competition-8","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How to set budget limits with `BudgetContext`"},"433":{"id":"/docs/getting-started/competition-9","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How to use the `@flops.budget` decorator form"},"434":{"id":"/docs/getting-started/competition-10","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How wall-time limits work via `wall_time_limit_s`"},"435":{"id":"/docs/getting-started/competition-11","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"How to read budget summaries"},"436":{"id":"/docs/getting-started/competition-12","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition","content":"Common competition pitfalls and tips"},"437":{"id":"/docs/getting-started/competition-13","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#setting-a-flop-budget","content":"Every competition submission runs inside a FLOP budget. Use `BudgetContext` to declare how many FLOPs your code is allowed to spend:"},"438":{"id":"/docs/getting-started/competition-14","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#setting-a-flop-budget","content":"If your code exceeds the budget, Flopscope raises `BudgetExhaustedError` *before* the offending operation executes. The error message includes the cost of the failed operation and the remaining budget."},"439":{"id":"/docs/getting-started/competition-15","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#setting-a-flop-budget","content":"The `namespace` parameter sets the root namespace prefix for that budget context. Nested `fnp.namespace(...)` scopes extend it with dotted segments, but they do not create child budgets or split the FLOP limit into separate pools."},"440":{"id":"/docs/getting-started/competition-16","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#decorator-form","content":"For cleaner code, use `@flops.budget` to attach a budget directly to a function:"},"441":{"id":"/docs/getting-started/competition-17","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#decorator-form","content":"Each call to the decorated function runs inside the same `BudgetContext`; the namespace is only the root prefix used for attribution, not a separate budget pool. Repeated calls reuse that context and keep accumulating on the same budget and operation log."},"442":{"id":"/docs/getting-started/competition-18","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"In addition to FLOP budgets, competitions may enforce a wall-clock time limit via `wall_time_limit_s`. This prevents solutions from stalling on operations that are analytically cheap but slow in practice:"},"443":{"id":"/docs/getting-started/competition-19","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"If the wall-clock time is exceeded, Flopscope raises `TimeExhaustedError`. The timer starts when the context is entered and is checked after each counted operation."},"444":{"id":"/docs/getting-started/competition-20","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"What `wall_time_limit_s` does and does not do:"},"445":{"id":"/docs/getting-started/competition-21","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It is a `BudgetContext` setting, so you configure it in the same place you set `flop_budget`."},"446":{"id":"/docs/getting-started/competition-22","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It measures total wall-clock time for the active context, not FLOPs."},"447":{"id":"/docs/getting-started/competition-23","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It is checked cooperatively before and after counted NumPy calls, so overshoot is bounded by the duration of one NumPy call."},"448":{"id":"/docs/getting-started/competition-24","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#wall-time-limits","content":"It is a clean diagnostic limit inside flopscope. Hard process/container kills still belong to the outer execution environment."},"449":{"id":"/docs/getting-started/competition-25","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Call `budget.summary()` when you want the current context's summary, or `flops.budget_summary()` for the accumulated session/global view. Both stay flat by default; use `by_namespace=True` only when you want a namespace breakdown:"},"450":{"id":"/docs/getting-started/competition-26","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Use these forms for different questions:"},"451":{"id":"/docs/getting-started/competition-27","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"`budget.summary()` answers \"what did this one explicit context spend?\""},"452":{"id":"/docs/getting-started/competition-28","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"`flops.budget_summary()` answers \"what has this process/session spent overall?\""},"453":{"id":"/docs/getting-started/competition-29","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"`budget.summary_dict(...)` and `flops.budget_summary_dict(...)` return the same information as structured data instead of formatted text."},"454":{"id":"/docs/getting-started/competition-30","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"The block below shows `print(budget.summary(by_namespace=True))` for the `solver` context:"},"455":{"id":"/docs/getting-started/competition-31","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"Key things to look for:"},"456":{"id":"/docs/getting-started/competition-32","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**Budget / Used / Remaining:** the top rows show the explicit competition budget, current spend, and remaining headroom"},"457":{"id":"/docs/getting-started/competition-33","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**By namespace:** `solver` is the root prefix, and nested scopes show up as dotted paths like `solver.precompute`. Use `budget.summary(by_namespace=True)` for the current context or `flops.budget_summary(by_namespace=True)` for the accumulated session/global view"},"458":{"id":"/docs/getting-started/competition-34","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**By operation:** this toy pass is dominated by the single `einsum`; `exp` and `sum` are tiny by comparison"},"459":{"id":"/docs/getting-started/competition-35","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**Wall / backend / flopscope overhead / residual time:** wall time is total elapsed time for the context. Flopscope backend time is spent inside the underlying NumPy / BLAS / LAPACK calls being counted. Flopscope overhead is spent in flopscope's own dispatch code (wrapper preambles, FLOP cost computation, view-casts, post-call wrapping, `maybe_check_nan_inf` when opted in). Residual wall time is the measured remainder outside backend calls and flopscope overhead (user Python between ops, sleeps, GC pauses). The decomposition is exact: `wall_time_s = flopscope_backend_time_s + flopscope_overhead_time_s + residual_wall_time_s`"},"460":{"id":"/docs/getting-started/competition-36","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"**Flat default:** the default summary stays flat unless you opt into `by_namespace=True`"},"461":{"id":"/docs/getting-started/competition-37","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#reading-the-budget-summary","content":"For programmatic access, use `flops.budget_summary_dict()`:"},"462":{"id":"/docs/getting-started/competition-38","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Check costs before committing budget.** Use cost query functions to estimate before executing:"},"463":{"id":"/docs/getting-started/competition-39","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Use namespaces for phases.** Split your solution into named phases (e.g., `\"init\"`, `\"solve\"`, `\"refine\"`) so the budget summary shows exactly where FLOPs are spent."},"464":{"id":"/docs/getting-started/competition-40","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Exploit symmetry for savings.** If your tensors are symmetric, wrapping them with `flops.as_symmetric()` can halve pointwise costs and significantly reduce einsum costs. See Symmetry Savings for details."},"465":{"id":"/docs/getting-started/competition-41","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Prefer cheaper operations.** A matrix-vector product via `fnp.einsum('ij,j->i', A, x)` costs `m*n` FLOPs, while a full matrix-matrix multiply costs `m*n*k`. Avoid computing more than you need."},"466":{"id":"/docs/getting-started/competition-42","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#quick-tips-for-competition","content":"**Watch out for hidden costs.** Operations like `fnp.array()` and `fnp.concatenate()` are *not* free -- they charge `numel(output)` FLOPs, and `fnp.where()` charges `numel(condition)`. Check the cost of any operation you are unsure about."},"467":{"id":"/docs/getting-started/competition-43","page_id":"/docs/getting-started/competition","tags":[],"type":"text","url":"/docs/getting-started/competition#when-things-go-wrong","content":"If you hit `BudgetExhaustedError`, see Budget Planning & Debugging for a systematic approach to diagnosing overruns and reducing costs."},"468":{"id":"/docs/getting-started/installation","page_id":"/docs/getting-started/installation","type":"page","content":"Installation","breadcrumbs":["Documentation","Getting Started"],"tags":[],"url":"/docs/getting-started/installation"},"469":{"id":"/docs/getting-started/installation-0","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getting-started/installation#install-as-a-dependency","content":"Install as a dependency"},"470":{"id":"/docs/getting-started/installation-1","page_id":"/docs/getting-started/installation","type":"heading","tags":[],"url":"/docs/getti