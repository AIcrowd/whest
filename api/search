/development/contributing#test-suites","content":"`numpy.random.tests.test_random`"},"385":{"id":"/docs/development/contributing-122","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"142"},"386":{"id":"/docs/development/contributing-123","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"0"},"387":{"id":"/docs/development/contributing-124","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"**Total**"},"388":{"id":"/docs/development/contributing-125","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"**7,363**"},"389":{"id":"/docs/development/contributing-126","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"**331**"},"390":{"id":"/docs/development/contributing-127","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#test-suites","content":"All failures are tracked as xfails in `tests/numpy_compat/xfails.py`."},"391":{"id":"/docs/development/contributing-128","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-the-tests","content":"Tests use `pytest-xdist` for parallel execution across all CPU cores."},"392":{"id":"/docs/development/contributing-129","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#running-the-tests","content":"The numpy\\_compat tests are excluded from the default `pytest` run (via `pyproject.toml` `addopts`) to prevent the monkeypatch from contaminating the main test suite. They run as a separate step in CI."},"393":{"id":"/docs/development/contributing-130","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Tests that fail due to known, accepted differences are tracked in `tests/numpy_compat/xfails.py`. Each entry maps a test pattern to a categorized reason:"},"394":{"id":"/docs/development/contributing-131","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Category"},"395":{"id":"/docs/development/contributing-132","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Meaning"},"396":{"id":"/docs/development/contributing-133","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Examples"},"397":{"id":"/docs/development/contributing-134","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`NOT_IMPLEMENTED`"},"398":{"id":"/docs/development/contributing-135","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Function exists but lacks a kwarg or edge case"},"399":{"id":"/docs/development/contributing-136","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"Missing `out=`, `where=`, `subok=` kwargs"},"400":{"id":"/docs/development/contributing-137","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"`UNSUPPORTED_DTYPE`"},"401":{"id":"/docs/development/contributing-138","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#known-divergences-xfails","content":"flopscope doesn't support this dtype"},"402"