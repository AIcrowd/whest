":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing","content":"How auto-generated documentation is maintained"},"267":{"id":"/docs/development/contributing-25","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"This repository contains three Python packages plus docs and Docker assets:"},"268":{"id":"/docs/development/contributing-26","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Path"},"269":{"id":"/docs/development/contributing-27","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Purpose"},"270":{"id":"/docs/development/contributing-28","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`src/whest/`"},"271":{"id":"/docs/development/contributing-29","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Core library backed by NumPy"},"272":{"id":"/docs/development/contributing-30","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`whest-client/src/whest/`"},"273":{"id":"/docs/development/contributing-31","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"Client proxy used in sandboxed participant environments"},"274":{"id":"/docs/development/contributing-32","page_id":"/docs/development/contributing","tags":[],"type":"text","url":"/docs/development/contributing#repository-layout","content":"`whest-server/src/whest_server/`"},"275":{"id":"/docs/development/contributing-33","page_id":"/docs/development/contributing","tags":[],"type":"text","