    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Test whether any array element along a given axis evaluates to True."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns single boolean if "
              },
              {
                "kind": "code",
                "text": "axis"
              },
              {
                "kind": "text",
                "text": " is "
              },
              {
                "kind": "code",
                "text": "None"
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array or object that can be converted to an array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array or object that can be converted to an array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which a logical OR reduction is performed.\nThe default ("
                      },
                      {
                        "kind": "code",
                        "text": "axis=None"
                      },
                      {
                        "kind": "text",
                        "text": ") is to perform a logical OR over all\nthe dimensions of the input array. "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " may be negative, in\nwhich case it counts from the last to the first axis. If this\nis a tuple of ints, a reduction is performed on multiple\naxes, instead of a single axis or all the axes as before."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "None or int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which a logical OR reduction is performed.\nThe default ("
                  },
                  {
                    "kind": "code",
                    "text": "axis=None"
                  },
                  {
                    "kind": "text",
                    "text": ") is to perform a logical OR over all\nthe dimensions of the input array. "
                  },
                  {
                    "kind": "code",
                    "text": "axis"
                  },
                  {
                    "kind": "text",
                    "text": " may be negative, in\nwhich case it counts from the last to the first axis. If this\nis a tuple of ints, a reduction is performed on multiple\naxes, instead of a single axis or all the axes as before."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Alternate output array in which to place the result.  It must have\nthe same shape as the expected output and its type is preserved\n(e.g., if it is of type float, then it will remain so, returning\n1.0 for True and 0.0 for False, regardless of the type of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ").\nSee "
                      },
                      {
                        "display_text": "ufuncs-output-type",
                        "explicit_title": false,
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.ufuncs-output-type.html",
