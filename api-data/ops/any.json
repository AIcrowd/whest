      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Not a Number (NaN), positive infinity and negative infinity evaluate\nto "
              },
              {
                "kind": "code",
                "text": "True"
              },
              {
                "kind": "text",
                "text": " because these are not equal to zero."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [],
            "directive": "versionchanged",
            "options": [],
            "raw_source": ".. versionchanged:: 2.0\n   Before NumPy 2.0, ``any`` did not return booleans for object dtype\n   input arrays.\n   This behavior is still available via ``we.logical_or.reduce``.",
            "supported": true,
