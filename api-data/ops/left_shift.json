            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.binary_repr(5)"
              },
              {
                "kind": "output",
                "text": "'101'"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.left_shift(5, 2)"
              },
              {
                "kind": "output",
                "text": "20"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.binary_repr(20)"
              },
              {
                "kind": "output",
                "text": "'10100'"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
