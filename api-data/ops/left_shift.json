              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(a, type(a)) # Unexpected result due to upcasting"
              },
              {
                "kind": "output",
                "text": "510 <class 'we.int64'>"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.left_shift(we.uint8(255), we.uint8(1))"
