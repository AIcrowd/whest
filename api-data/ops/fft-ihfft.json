                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Length of the inverse FFT, the number of points along\ntransformation axis in the input to use.  If "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " is smaller than\nthe length of the input, the input is cropped.  If it is larger,\nthe input is padded with zeros. If "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " is not given, the length of\nthe input along the axis specified by "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " is used."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Length of the inverse FFT, the number of points along\ntransformation axis in the input to use.  If "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " is smaller than\nthe length of the input, the input is cropped.  If it is larger,\nthe input is padded with zeros. If "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " is not given, the length of\nthe input along the axis specified by "
