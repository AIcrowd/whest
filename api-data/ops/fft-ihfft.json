            "inline": [
              {
                "kind": "text",
                "text": "Compute the inverse FFT of a signal that has Hermitian symmetry."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
