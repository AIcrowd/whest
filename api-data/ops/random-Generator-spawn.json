      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Starting from a seeded default generator:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# High quality entropy created with: f\"0x{secrets.randbits(128):x}\""
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "entropy = 0x3034c61a9ae04ff8cb62ab8ec2c4b501"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng(entropy)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Create two new generators for example for parallel execution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "child_rng1, child_rng2 = rng.spawn(2)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Drawn numbers from each are independent but derived from the initial\nseeding entropy:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.uniform(), child_rng1.uniform(), child_rng2.uniform()"
              },
              {
                "kind": "output",
                "text": "(0.19029263503854454, 0.9475673279178444, 0.4702687338396767)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "It is safe to spawn additional children from the original "
              },
              {
                "kind": "code",
                "text": "rng"
              },
              {
                "kind": "text",
                "text": " or\nthe children:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "more_child_rngs = rng.spawn(20)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "nested_spawn = child_rng1.spawn(20)"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
