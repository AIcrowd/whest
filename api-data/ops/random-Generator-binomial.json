  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from a binomial distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from a binomial distribution with specified\nparameters, n trials and p probability of success where\nn an integer >= 0 and p is in the interval [0,1]. (n may be\ninput as a float, but it is truncated to an integer in use)"
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Parameter of the distribution, >= 0. Floats are also accepted,\nbut they will be truncated to integers."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or array_like of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Parameter of the distribution, >= 0. Floats are also accepted,\nbut they will be truncated to integers."
                  }
                ],
                "name": "n",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Parameter of the distribution, >= 0 and <=1."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Parameter of the distribution, >= 0 and <=1."
                  }
                ],
                "name": "p",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "p"
                      },
                      {
                        "kind": "text",
                        "text": " are both scalars.\nOtherwise, "
                      },
                      {
                        "kind": "code",
                        "text": "flops.broadcast(n, p).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  If size is "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " (default),\na single value is returned if "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "p"
                  },
                  {
                    "kind": "text",
                    "text": " are both scalars.\nOtherwise, "
                  },
                  {
                    "kind": "code",
                    "text": "flops.broadcast(n, p).size"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn."
                  }
                ],
                "name": "size",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
