                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Drawn samples from the parameterized binomial distribution, where\neach sample is equal to the number of successes over the n trials."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Drawn samples from the parameterized binomial distribution, where\neach sample is equal to the number of successes over the n trials."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
