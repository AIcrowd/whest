{
  "detail_href": "/docs/api/ops/linalg-slogdet/",
  "detail_json_href": "/api-data/ops/linalg-slogdet.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the sign and (natural) logarithm of the determinant of an array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "If an array has a very small or very large determinant, then a call to\n"
              },
              {
                "kind": "code",
                "text": "det"
              },
              {
                "kind": "text",
                "text": " may overflow or underflow. This routine is more robust against such\nissues, because it computes the logarithm of the determinant rather than\nthe determinant itself."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array, has to be a square 2-D array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(..., M, M) array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array, has to be a square 2-D array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [],
                "data_type": "A namedtuple with the following attributes:",
                "inline": [],
                "name": "",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A number representing the sign of the determinant. For a real matrix,\nthis is 1, 0, or -1. For a complex matrix, this is a complex number\nwith absolute value 1 (i.e., it is on the unit circle), or else 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(...) array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A number representing the sign of the determinant. For a real matrix,\nthis is 1, 0, or -1. For a complex matrix, this is a complex number\nwith absolute value 1 (i.e., it is on the unit circle), or else 0."
                  }
                ],
                "name": "sign",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The natural log of the absolute value of the determinant."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(...) array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The natural log of the absolute value of the determinant."
                  }
                ],
                "name": "logabsdet",
                "type": "field_list"
              },
              {
                "body_blocks": [],
                "data_type": "If the determinant is zero, then `sign` will be 0 and `logabsdet`",
                "inline": [],
                "name": "",
                "type": "field_list"
              },
              {
                "body_blocks": [],
                "data_type": "will be -inf. In all cases, the determinant is equal to",
                "inline": [],
                "name": "",
                "type": "field_list"
              },
              {
                "body_blocks": [],
                "data_type": "``sign * we.exp(logabsdet)``.",
                "inline": [],
                "name": "",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "",
                "description_inline": [],
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.det.html",
                "href": "",
                "label": "det",
                "original_target": "det",
                "role": "",
                "target": "det",
                "unresolved": false
              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Broadcasting rules apply, see the "
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.linalg.html",
                "href": "",
                "kind": "link",
                "target": "linalg",
                "text": "we.linalg"
              },
              {
                "kind": "text",
                "text": " documentation for\ndetails."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The determinant is computed via LU factorization using the LAPACK\nroutine "
              },
              {
                "kind": "code",
                "text": "z/dgetrf"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The determinant of a 2-D array "
              },
              {
                "kind": "code",
                "text": "[[a, b], [c, d]]"
              },
              {
                "kind": "text",
                "text": " is "
              },
              {
                "kind": "code",
                "text": "ad - bc"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[1, 2], [3, 4]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "(sign, logabsdet) = we.linalg.slogdet(a)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "(sign, logabsdet)"
              },
              {
                "kind": "output",
                "text": "(-1, 0.69314718055994529) # may vary"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "sign * we.exp(logabsdet)"
              },
              {
                "kind": "output",
                "text": "-2.0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Computing log-determinants for a stack of matrices:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([ [[1, 2], [3, 4]], [[1, 2], [2, 1]], [[1, 3], [3, 1]] ])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a.shape"
              },
              {
                "kind": "output",
                "text": "(3, 2, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "sign, logabsdet = we.linalg.slogdet(a)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "(sign, logabsdet)"
              },
              {
                "kind": "output",
                "text": "(array([-1., -1., -1.]), array([ 0.69314718,  1.09861229,  2.07944154]))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "sign * we.exp(logabsdet)"
              },
              {
                "kind": "output",
                "text": "array([-2., -3., -8.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "This routine succeeds where ordinary "
              },
              {
                "kind": "code",
                "text": "det"
              },
              {
                "kind": "text",
                "text": " does not:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.linalg.det(we.eye(500) * 0.1)"
              },
              {
                "kind": "output",
                "text": "0.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.linalg.slogdet(we.eye(500) * 0.1)"
              },
              {
                "kind": "output",
                "text": "(1, -1151.2925464970228)"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
