            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If an ndarray, a random sample is generated from its elements.\nIf an int, the random sample is generated as if it were "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.arange(a).html",
                        "href": "",
                        "kind": "link",
                        "target": "arange(a)",
                        "text": "we.arange(a)"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "1-D array-like or int",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If an ndarray, a random sample is generated from its elements.\nIf an int, the random sample is generated as if it were "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.arange(a).html",
                    "href": "",
                    "kind": "link",
                    "target": "arange(a)",
                    "text": "we.arange(a)"
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                  }
                ],
                "name": "size",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Whether the sample is with or without replacement. Default is True,\nmeaning that a value of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " can be selected multiple times."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "boolean, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Whether the sample is with or without replacement. Default is True,\nmeaning that a value of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " can be selected multiple times."
                  }
                ],
                "name": "replace",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The probabilities associated with each entry in a.\nIf not given, the sample assumes a uniform distribution over all\nentries in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "1-D array-like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The probabilities associated with each entry in a.\nIf not given, the sample assumes a uniform distribution over all\nentries in "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "p",
                "type": "field_list"
              }
            ],
