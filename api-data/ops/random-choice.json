        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Setting user-specified probabilities through "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " uses a more general but less\nefficient sampler than the default. The general sampler produces a different sample\nthan the optimized sampler even if each element of "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " is 1 / len(a)."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Sampling random rows from a 2-D array is not possible with this function,\nbut is possible with "
              },
              {
                "kind": "code",
                "text": "Generator.choice"
              },
              {
                "kind": "text",
                "text": " through its "
              },
              {
                "kind": "code",
                "text": "axis"
              },
              {
                "kind": "text",
                "text": " keyword."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a uniform random sample from we.arange(5) of size 3:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.random.choice(5, 3)"
              },
              {
                "kind": "output",
                "text": "array([0, 3, 4]) # random"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "#This is equivalent to we.random.randint(0,5,3)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a non-uniform random sample from we.arange(5) of size 3:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.random.choice(5, 3, p=[0.1, 0, 0.3, 0.6, 0])"
              },
              {
                "kind": "output",
                "text": "array([3, 3, 0]) # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a uniform random sample from we.arange(5) of size 3 without\nreplacement:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.random.choice(5, 3, replace=False)"
              },
              {
                "kind": "output",
                "text": "array([3,1,0]) # random"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "#This is equivalent to we.random.permutation(we.arange(5))[:3]"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a non-uniform random sample from we.arange(5) of size\n3 without replacement:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.random.choice(5, 3, replace=False, p=[0.1, 0, 0.3, 0.6, 0])"
              },
              {
                "kind": "output",
                "text": "array([2, 3, 0]) # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Any of the above can be repeated with an arbitrary array-like\ninstead of just integers. For instance:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "aa_milne_arr = ['pooh', 'rabbit', 'piglet', 'Christopher']"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.random.choice(aa_milne_arr, 5, p=[0.5, 0.1, 0.1, 0.3])"
              },
              {
                "kind": "output",
                "text": "array(['pooh', 'pooh', 'pooh', 'Christopher', 'piglet'], # random"
              },
              {
                "kind": "output",
                "text": "      dtype='<U11')"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
