        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This is similar to choose or select, except that functions are\nevaluated on elements of "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " that satisfy the corresponding condition from\n"
              },
              {
                "kind": "code",
                "text": "condlist"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The result is:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "      |--\n      |funclist[0](x[condlist[0]])\nout = |funclist[1](x[condlist[1]])\n      |...\n      |funclist[n2](x[condlist[n2]])\n      |--",
            "type": "literal_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Define the signum function, which is -1 for "
              },
              {
                "kind": "code",
                "text": "x < 0"
              },
              {
                "kind": "text",
                "text": " and +1 for "
              },
              {
                "kind": "code",
                "text": "x >= 0"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.linspace(-2.5, 2.5, 6)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.piecewise(x, [x < 0, x >= 0], [-1, 1])"
              },
              {
                "kind": "output",
                "text": "array([-1., -1., -1.,  1.,  1.,  1.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Define the absolute value, which is "
              },
              {
                "kind": "code",
                "text": "-x"
              },
              {
                "kind": "text",
                "text": " for "
              },
              {
                "kind": "code",
                "text": "x <0"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " for\n"
              },
              {
                "kind": "code",
                "text": "x >= 0"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.piecewise(x, [x < 0, x >= 0], [lambda x: -x, lambda x: x])"
              },
              {
                "kind": "output",
                "text": "array([2.5,  1.5,  0.5,  0.5,  1.5,  2.5])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Apply the same function to a scalar value."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = -2"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.piecewise(y, [y < 0, y >= 0], [lambda x: -x, lambda x: x])"
              },
              {
                "kind": "output",
                "text": "array(2)"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
