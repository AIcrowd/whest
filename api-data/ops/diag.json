                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.arange(9).reshape((3,3))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2],"
              },
              {
                "kind": "output",
                "text": "       [3, 4, 5],"
              },
              {
                "kind": "output",
                "text": "       [6, 7, 8]])"
              }
