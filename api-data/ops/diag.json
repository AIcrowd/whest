              {
                "kind": "output",
                "text": "array([0, 4, 8])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diag(x, k=1)"
              },
              {
                "kind": "output",
                "text": "array([1, 5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diag(x, k=-1)"
              },
              {
                "kind": "output",
                "text": "array([3, 7])"
              }
            ],
