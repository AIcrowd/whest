      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.intersect1d([1, 3, 4, 3], [3, 1, 2, 1])"
              },
              {
                "kind": "output",
                "text": "array([1, 3])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "To intersect more than two arrays, use functools.reduce:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from functools import reduce"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "reduce(we.intersect1d, ([1, 3, 4, 3], [3, 1, 2, 1], [6, 3, 4, 2]))"
              },
              {
                "kind": "output",
                "text": "array([3])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "To return the indices of the values common to the input arrays\nalong with the intersected values:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([1, 1, 2, 3, 4])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = we.array([2, 1, 4, 6])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "xy, x_ind, y_ind = we.intersect1d(x, y, return_indices=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x_ind, y_ind"
              },
              {
                "kind": "output",
                "text": "(array([0, 2, 4]), array([1, 0, 2]))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "xy, x[x_ind], y[y_ind]"
              },
              {
                "kind": "output",
                "text": "(array([1, 2, 4]), array([1, 2, 4]), array([1, 2, 4]))"
              }
            ],
            "type": "doctest_block"
          }
        ],
