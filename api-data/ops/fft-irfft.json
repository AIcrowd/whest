                        "kind": "text",
                        "text": " where "
                      },
                      {
                        "kind": "code",
                        "text": "m"
                      },
                      {
                        "kind": "text",
                        "text": " is the length of the input along the axis\nspecified by "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
