    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the one-dimensional discrete Fourier Transform for real input."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function computes the one-dimensional "
              },
              {
                "kind": "emphasis",
                "text": "n"
              },
              {
                "kind": "text",
                "text": "-point discrete Fourier\nTransform (DFT) of a real-valued array by means of an efficient algorithm\ncalled the Fast Fourier Transform (FFT)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
