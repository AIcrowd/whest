  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the eigenvalues of a complex Hermitian or real symmetric matrix."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Main difference from eigh: the eigenvectors are not computed."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A complex- or real-valued matrix whose eigenvalues are to be\ncomputed."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(..., M, M) array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A complex- or real-valued matrix whose eigenvalues are to be\ncomputed."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Specifies whether the calculation is done with the lower triangular\npart of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " ('L', default) or the upper triangular part ('U').\nIrrespective of this value only the real parts of the diagonal will\nbe considered in the computation to preserve the notion of a Hermitian\nmatrix. It therefore follows that the imaginary part of the diagonal\nwill always be treated as zero."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'L', 'U'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Specifies whether the calculation is done with the lower triangular\npart of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " ('L', default) or the upper triangular part ('U').\nIrrespective of this value only the real parts of the diagonal will\nbe considered in the computation to preserve the notion of a Hermitian\nmatrix. It therefore follows that the imaginary part of the diagonal\nwill always be treated as zero."
                  }
                ],
                "name": "UPLO",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The eigenvalues in ascending order, each repeated according to\nits multiplicity."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(..., M,) ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The eigenvalues in ascending order, each repeated according to\nits multiplicity."
                  }
                ],
                "name": "w",
                "type": "field_list"
              }
            ],
            "title": "Returns",
