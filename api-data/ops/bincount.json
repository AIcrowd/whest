  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Count number of occurrences of each value in array of non-negative ints."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The number of bins (of size 1) is one larger than the largest value in\n"
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": ". If "
              },
              {
                "kind": "code",
                "text": "minlength"
              },
              {
                "kind": "text",
                "text": " is specified, there will be at least this number\nof bins in the output array (though it will be longer if necessary,\ndepending on the contents of "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": ").\nEach bin gives the number of occurrences of its index value in "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": ".\nIf "
              },
              {
                "kind": "code",
                "text": "weights"
              },
              {
                "kind": "text",
                "text": " is specified the input array is weighted by it, i.e. if a\nvalue "
              },
              {
                "kind": "code",
                "text": "n"
              },
              {
                "kind": "text",
                "text": " is found at position "
              },
              {
                "kind": "code",
                "text": "i"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "out[n] += weight[i]"
              },
              {
                "kind": "text",
                "text": " instead\nof "
              },
              {
                "kind": "code",
                "text": "out[n] += 1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
