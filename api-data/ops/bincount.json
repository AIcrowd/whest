      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bincount(we.arange(5))"
              },
              {
                "kind": "output",
                "text": "array([1, 1, 1, 1, 1])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bincount(we.array([0, 1, 1, 3, 2, 1, 7]))"
              },
              {
                "kind": "output",
                "text": "array([1, 3, 1, 1, 0, 0, 0, 1])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([0, 1, 1, 3, 2, 1, 7, 23])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bincount(x).size == we.amax(x)+1"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The input array needs to be of integer dtype, otherwise a\nTypeError is raised:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bincount(we.arange(5, dtype=float))"
              },
              {
                "kind": "output",
                "text": "Traceback (most recent call last):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": ""
              },
              {
                "kind": "output",
                "text": "TypeError: Cannot cast array data from dtype('float64') to dtype('int64')"
              },
              {
                "kind": "output",
                "text": "according to the rule 'safe'"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "A possible use of "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/bincount",
                "kind": "link",
                "target": "bincount",
                "text": "bincount"
              },
              {
                "kind": "text",
                "text": " is to perform sums over\nvariable-size chunks of an array, using the "
              },
              {
                "kind": "code",
                "text": "weights"
              },
              {
                "kind": "text",
                "text": " keyword."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "w = we.array([0.3, 0.5, 0.2, 0.7, 1., -0.6]) # weights"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([0, 1, 1, 2, 2, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bincount(x,  weights=w)"
              },
              {
                "kind": "output",
                "text": "array([ 0.3,  0.7,  1.1])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
