          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density function for the Wald distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "P(x;mean,scale) = \\sqrt{\\frac{scale}{2\\pi x^3}}e^ \\frac{-scale(x-mean)^2}{2\\cdotp mean^2x}"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "As noted above the inverse Gaussian distribution first arise\nfrom attempts to model Brownian motion. It is also a\ncompetitor to the Weibull for use in reliability modeling and\nmodeling stock returns and interest rate processes."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nBrighton Webs Ltd., Wald Distribution,\nhttps://web.archive.org/web/20090423014010/http://www.brighton-webs.co.uk:80/distributions/wald.asp",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nChhikara, Raj S., and Folks, J. Leroy, \"The Inverse Gaussian\nDistribution: Theory : Methodology, and Applications\", CRC Press,\n1988.",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "3\n\nWikipedia, \"Inverse Gaussian distribution\"\nhttps://en.wikipedia.org/wiki/Inverse_Gaussian_distribution",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw values from the distribution and plot the histogram:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "h = plt.hist(rng.wald(3, 2, 100000), bins=200, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
