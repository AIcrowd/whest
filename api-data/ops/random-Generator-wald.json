                      {
                        "kind": "text",
                        "text": "Drawn samples from the parameterized Wald distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Drawn samples from the parameterized Wald distribution."
                  }
                ],
