  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Set the internal state of the generator from a tuple."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "For use if one has reason to manually (re-)set the internal state of\nthe bit generator used by the RandomState instance. By default,\nRandomState uses the \"Mersenne Twister\""
              },
              {
                "kind": "text",
                "text": "[1]_"
              },
              {
                "kind": "text",
                "text": " pseudo-random number\ngenerating algorithm."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The "
                      },
                      {
                        "kind": "code",
                        "text": "state"
                      },
                      {
                        "kind": "text",
                        "text": " tuple has the following items:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "the string 'MT19937', specifying the Mersenne Twister algorithm."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "a 1-D array of 624 unsigned integers "
                              },
                              {
                                "kind": "code",
                                "text": "keys"
                              },
                              {
                                "kind": "text",
                                "text": "."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "an integer "
                              },
                              {
                                "kind": "code",
                                "text": "pos"
                              },
                              {
                                "kind": "text",
                                "text": "."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "an integer "
                              },
                              {
                                "kind": "code",
                                "text": "has_gauss"
                              },
                              {
                                "kind": "text",
                                "text": "."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "a float "
                              },
                              {
                                "kind": "code",
                                "text": "cached_gaussian"
                              },
                              {
                                "kind": "text",
                                "text": "."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": true,
                    "type": "list"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If state is a dictionary, it is directly set using the BitGenerators\n"
                      },
                      {
                        "kind": "code",
                        "text": "state"
                      },
                      {
                        "kind": "text",
                        "text": " property."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{tuple(str, ndarray of 624 uints, int, int, float), dict}",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The "
                  },
                  {
                    "kind": "code",
                    "text": "state"
                  },
                  {
                    "kind": "text",
                    "text": " tuple has the following items:"
                  }
                ],
                "name": "state",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Returns 'None' on success."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "None",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Returns 'None' on success."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
