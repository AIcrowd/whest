        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Setting user-specified probabilities through "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " uses a more general but less\nefficient sampler than the default. The general sampler produces a different sample\nthan the optimized sampler even if each element of "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " is 1 / len(a)."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " must sum to 1 when cast to "
              },
              {
                "kind": "code",
                "text": "float64"
              },
              {
                "kind": "text",
                "text": ". To ensure this, you may wish\nto normalize using "
              },
              {
                "kind": "code",
                "text": "p = p / flops.sum(p, dtype=float)"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When passing "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " as an integer type and "
              },
              {
                "external_url": "",
                "href": "/docs/api/numpy/size/",
                "kind": "link",
                "target": "size",
                "text": "size"
              },
              {
                "kind": "text",
                "text": " is not specified, the return\ntype is a native Python "
              },
              {
                "kind": "code",
                "text": "int"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a uniform random sample from flops.arange(5) of size 3:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.choice(5, 3)"
              },
              {
                "kind": "output",
                "text": "array([0, 3, 4]) # random"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "#This is equivalent to rng.integers(0,5,3)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a non-uniform random sample from flops.arange(5) of size 3:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.choice(5, 3, p=[0.1, 0, 0.3, 0.6, 0])"
              },
              {
                "kind": "output",
                "text": "array([3, 3, 0]) # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a uniform random sample from flops.arange(5) of size 3 without\nreplacement:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.choice(5, 3, replace=False)"
              },
              {
                "kind": "output",
                "text": "array([3,1,0]) # random"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "#This is equivalent to rng.permutation(flops.arange(5))[:3]"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a uniform random sample from a 2-D array along the first\naxis (the default), without replacement:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.choice([[0, 1, 2], [3, 4, 5], [6, 7, 8]], 2, replace=False)"
              },
              {
                "kind": "output",
                "text": "array([[3, 4, 5], # random"
              },
              {
                "kind": "output",
                "text": "       [0, 1, 2]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a non-uniform random sample from flops.arange(5) of size\n3 without replacement:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.choice(5, 3, replace=False, p=[0.1, 0, 0.3, 0.6, 0])"
              },
              {
                "kind": "output",
                "text": "array([2, 3, 0]) # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Any of the above can be repeated with an arbitrary array-like\ninstead of just integers. For instance:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "aa_milne_arr = ['pooh', 'rabbit', 'piglet', 'Christopher']"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.choice(aa_milne_arr, 5, p=[0.5, 0.1, 0.1, 0.3])"
              },
              {
                "kind": "output",
                "text": "array(['pooh', 'pooh', 'pooh', 'Christopher', 'piglet'], # random"
              },
              {
                "kind": "output",
                "text": "      dtype='<U11')"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
