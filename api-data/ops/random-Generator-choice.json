  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generates a random sample from a given array"
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If an ndarray, a random sample is generated from its elements.\nIf an int, the random sample is generated from flops.arange(a)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{array_like, int}",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If an ndarray, a random sample is generated from its elements.\nIf an int, the random sample is generated from flops.arange(a)."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn from the 1-d "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ". If "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " has more\nthan one dimension, the "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/numpy/size/",
                        "kind": "link",
                        "target": "size",
                        "text": "size"
                      },
                      {
                        "kind": "text",
                        "text": " shape will be inserted into the\n"
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " dimension, so the output "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/numpy/ndim/",
                        "kind": "link",
                        "target": "ndim",
                        "text": "ndim"
                      },
                      {
                        "kind": "text",
                        "text": " will be "
                      },
                      {
                        "kind": "code",
                        "text": "a.ndim - 1 +\nlen(size)"
                      },
                      {
                        "kind": "text",
                        "text": ". Default is None, in which case a single value is\nreturned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{int, tuple[int]}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
