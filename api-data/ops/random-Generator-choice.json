                    "target": "ndim",
                    "text": "ndim"
                  },
                  {
                    "kind": "text",
                    "text": " will be "
                  },
                  {
                    "kind": "code",
                    "text": "a.ndim - 1 +\nlen(size)"
                  },
                  {
                    "kind": "text",
                    "text": ". Default is None, in which case a single value is\nreturned."
                  }
                ],
                "name": "size",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Whether the sample is with or without replacement. Default is True,\nmeaning that a value of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " can be selected multiple times."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Whether the sample is with or without replacement. Default is True,\nmeaning that a value of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " can be selected multiple times."
                  }
                ],
                "name": "replace",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The probabilities associated with each entry in a.\nIf not given, the sample assumes a uniform distribution over all\nentries in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "1-D array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The probabilities associated with each entry in a.\nIf not given, the sample assumes a uniform distribution over all\nentries in "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "p",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The axis along which the selection is performed. The default, 0,\nselects by row."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The axis along which the selection is performed. The default, 0,\nselects by row."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Whether the sample is shuffled when sampling without replacement.\nDefault is True, False provides a speedup."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Whether the sample is shuffled when sampling without replacement.\nDefault is True, False provides a speedup."
                  }
                ],
                "name": "shuffle",
