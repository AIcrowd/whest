            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isinf(we.inf)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isinf(we.nan)"
              },
              {
                "kind": "output",
                "text": "False"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isinf(-we.inf)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isinf([we.inf, -we.inf, 1.0, we.nan])"
              },
              {
                "kind": "output",
                "text": "array([ True,  True, False, False])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([-we.inf, 0., we.inf])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = we.array([2, 2, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isinf(x, y)"
              },
              {
                "kind": "output",
                "text": "array([1, 0, 1])"
