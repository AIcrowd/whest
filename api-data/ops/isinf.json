                "kind": "text",
                "text": "Test element-wise for positive or negative infinity."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns a boolean array of the same shape as "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": ", True where "
              },
              {
                "kind": "code",
                "text": "x ==\n+/-inf"
              },
              {
                "kind": "text",
                "text": ", otherwise False."
              }
            ],
            "type": "paragraph"
          }
        ],
