  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Randomly permute "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " along axis "
              },
              {
                "kind": "code",
                "text": "axis"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Unlike "
              },
              {
                "kind": "code",
                "text": "shuffle"
              },
              {
                "kind": "text",
                "text": ", each slice along the given axis is shuffled\nindependently of the others."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array to be shuffled."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, at least one-dimensional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array to be shuffled."
                  }
                ],
                "name": "x",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Slices of "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " in this axis are shuffled. Each slice\nis shuffled independently of the others.  If "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " is\nNone, the flattened array is shuffled."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Slices of "
                  },
                  {
                    "kind": "code",
                    "text": "x"
                  },
                  {
                    "kind": "text",
                    "text": " in this axis are shuffled. Each slice\nis shuffled independently of the others.  If "
                  },
                  {
                    "kind": "code",
                    "text": "axis"
                  },
                  {
                    "kind": "text",
                    "text": " is\nNone, the flattened array is shuffled."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If given, this is the destination of the shuffled array.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " is None, a shuffled copy of the array is returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If given, this is the destination of the shuffled array.\nIf "
                  },
                  {
                    "kind": "code",
                    "text": "out"
                  },
                  {
                    "kind": "text",
                    "text": " is None, a shuffled copy of the array is returned."
