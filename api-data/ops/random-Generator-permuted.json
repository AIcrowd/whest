        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "An important distinction between methods "
              },
              {
                "kind": "code",
                "text": "shuffle"
              },
              {
                "kind": "text",
                "text": "  and "
              },
              {
                "kind": "code",
                "text": "permuted"
              },
              {
                "kind": "text",
                "text": " is\nhow they both treat the "
              },
              {
                "kind": "code",
                "text": "axis"
              },
              {
                "kind": "text",
                "text": " parameter which can be found at\n"
              },
              {
                "display_text": "generator-handling-axis-parameter",
                "explicit_title": false,
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.generator-handling-axis-parameter.html",
                "href": "",
                "kind": "role_reference",
                "original_target": "generator-handling-axis-parameter",
                "role": "ref",
                "suppress_link": false,
                "target": "generator-handling-axis-parameter",
                "unresolved": false
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Create a "
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                "href": "",
                "kind": "link",
                "target": "random.Generator",
                "text": "flops.random.Generator"
              },
              {
                "kind": "text",
                "text": " instance:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Create a test array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = flops.arange(24).reshape(3, 8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([[ 0,  1,  2,  3,  4,  5,  6,  7],"
              },
              {
                "kind": "output",
                "text": "       [ 8,  9, 10, 11, 12, 13, 14, 15],"
              },
              {
                "kind": "output",
                "text": "       [16, 17, 18, 19, 20, 21, 22, 23]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Shuffle the rows of "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = rng.permuted(x, axis=1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y"
              },
              {
                "kind": "output",
                "text": "array([[ 4,  3,  6,  7,  1,  2,  5,  0],  # random"
              },
              {
                "kind": "output",
                "text": "       [15, 10, 14,  9, 12, 11,  8, 13],"
              },
              {
                "kind": "output",
                "text": "       [17, 16, 20, 21, 18, 22, 23, 19]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " has not been modified:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([[ 0,  1,  2,  3,  4,  5,  6,  7],"
              },
              {
                "kind": "output",
                "text": "       [ 8,  9, 10, 11, 12, 13, 14, 15],"
              },
              {
                "kind": "output",
                "text": "       [16, 17, 18, 19, 20, 21, 22, 23]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "To shuffle the rows of "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " in-place, pass "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " as the "
              },
              {
                "kind": "code",
                "text": "out"
              },
              {
                "kind": "text",
                "text": "\nparameter:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = rng.permuted(x, axis=1, out=x)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([[ 3,  0,  4,  7,  1,  6,  2,  5],  # random"
              },
              {
                "kind": "output",
                "text": "       [ 8, 14, 13,  9, 12, 11, 15, 10],"
              },
              {
                "kind": "output",
                "text": "       [17, 18, 16, 22, 19, 23, 20, 21]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that when the "
              },
              {
                "kind": "code",
                "text": "out"
              },
              {
                "kind": "text",
                "text": " parameter is given, the return\nvalue is "
              },
              {
                "kind": "code",
                "text": "out"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y is x"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
