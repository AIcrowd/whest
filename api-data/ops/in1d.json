  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Test whether each element of a 1-D array is also present in a second array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "argument_inline": [],
            "content_blocks": [],
            "directive": "deprecated",
            "options": [],
            "raw_source": ".. deprecated:: 2.0\n    Use :func:`isin` instead of `in1d` for new code.",
            "supported": true,
            "type": "directive_block",
            "version": "2.0"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns a boolean array the same length as "
              },
              {
                "kind": "code",
                "text": "ar1"
              },
              {
                "kind": "text",
                "text": " that is True\nwhere an element of "
              },
              {
                "kind": "code",
                "text": "ar1"
              },
              {
                "kind": "text",
                "text": " is in "
              },
              {
                "kind": "code",
                "text": "ar2"
              },
              {
                "kind": "text",
                "text": " and False otherwise."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(M,) array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array."
                  }
                ],
                "name": "ar1",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The values against which to test each value of "
                      },
                      {
                        "kind": "code",
                        "text": "ar1"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The values against which to test each value of "
                  },
                  {
                    "kind": "code",
                    "text": "ar1"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "ar2",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, the input arrays are both assumed to be unique, which\ncan speed up the calculation.  Default is False."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, the input arrays are both assumed to be unique, which\ncan speed up the calculation.  Default is False."
                  }
                ],
                "name": "assume_unique",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, the values in the returned array are inverted (that is,\nFalse where an element of "
                      },
                      {
                        "kind": "code",
                        "text": "ar1"
                      },
                      {
                        "kind": "text",
                        "text": " is in "
                      },
                      {
                        "kind": "code",
                        "text": "ar2"
                      },
                      {
                        "kind": "text",
                        "text": " and True otherwise).\nDefault is False. "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.in1d(a, b, invert=True).html",
                        "href": "",
                        "kind": "link",
                        "target": "in1d(a, b, invert=True)",
                        "text": "we.in1d(a, b, invert=True)"
                      },
                      {
                        "kind": "text",
                        "text": " is equivalent\nto (but is faster than) "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.invert(in1d(a, b)).html",
                        "href": "",
                        "kind": "link",
                        "target": "invert(in1d(a, b))",
                        "text": "we.invert(in1d(a, b))"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, the values in the returned array are inverted (that is,\nFalse where an element of "
                  },
                  {
                    "kind": "code",
                    "text": "ar1"
                  },
                  {
                    "kind": "text",
                    "text": " is in "
                  },
                  {
                    "kind": "code",
                    "text": "ar2"
                  },
                  {
                    "kind": "text",
                    "text": " and True otherwise).\nDefault is False. "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.in1d(a, b, invert=True).html",
                    "href": "",
                    "kind": "link",
                    "target": "in1d(a, b, invert=True)",
                    "text": "we.in1d(a, b, invert=True)"
                  },
                  {
                    "kind": "text",
                    "text": " is equivalent\nto (but is faster than) "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.invert(in1d(a, b)).html",
                    "href": "",
                    "kind": "link",
                    "target": "invert(in1d(a, b))",
                    "text": "we.invert(in1d(a, b))"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "invert",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The algorithm to use. This will not affect the final result,\nbut will affect the speed and memory use. The default, None,\nwill select automatically based on memory considerations."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If 'sort', will use a mergesort-based approach. This will have\na memory usage of roughly 6 times the sum of the sizes of\n"
                              },
                              {
                                "kind": "code",
                                "text": "ar1"
                              },
                              {
                                "kind": "text",
                                "text": " and "
                              },
                              {
                                "kind": "code",
                                "text": "ar2"
                              },
                              {
                                "kind": "text",
                                "text": ", not accounting for size of dtypes."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If 'table', will use a lookup table approach similar\nto a counting sort. This is only available for boolean and\ninteger arrays. This will have a memory usage of the\nsize of "
                              },
                              {
                                "kind": "code",
                                "text": "ar1"
                              },
                              {
                                "kind": "text",
                                "text": " plus the max-min value of "
                              },
                              {
                                "kind": "code",
                                "text": "ar2"
                              },
                              {
                                "kind": "text",
                                "text": ". "
                              },
                              {
                                "kind": "code",
                                "text": "assume_unique"
                              },
                              {
                                "kind": "text",
                                "text": "\nhas no effect when the 'table' option is used."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If None, will automatically choose 'table' if\nthe required memory allocation is less than or equal to\n6 times the sum of the sizes of "
                              },
                              {
                                "kind": "code",
                                "text": "ar1"
                              },
                              {
                                "kind": "text",
                                "text": " and "
                              },
                              {
                                "kind": "code",
                                "text": "ar2"
                              },
                              {
                                "kind": "text",
                                "text": ",\notherwise will use 'sort'. This is done to not use\na large amount of memory by default, even though\n'table' may be faster in most cases. If 'table' is chosen,\n"
                              },
                              {
                                "kind": "code",
                                "text": "assume_unique"
                              },
                              {
                                "kind": "text",
                                "text": " will have no effect."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  }
                ],
                "data_type": "{None, 'sort', 'table'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The algorithm to use. This will not affect the final result,\nbut will affect the speed and memory use. The default, None,\nwill select automatically based on memory considerations."
                  }
                ],
                "name": "kind",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
