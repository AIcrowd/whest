        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/in1d",
                "kind": "link",
                "target": "in1d",
                "text": "in1d"
              },
              {
                "kind": "text",
                "text": " can be considered as an element-wise function version of the\npython keyword "
              },
              {
                "kind": "code",
                "text": "in"
              },
              {
                "kind": "text",
                "text": ", for 1-D sequences. "
              },
              {
                "kind": "code",
                "text": "in1d(a, b)"
              },
              {
                "kind": "text",
                "text": " is roughly\nequivalent to "
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.array([item in b for item in a]).html",
                "href": "",
                "kind": "link",
                "target": "array([item in b for item in a])",
                "text": "we.array([item in b for item in a])"
              },
              {
                "kind": "text",
                "text": ".\nHowever, this idea fails if "
              },
              {
                "kind": "code",
                "text": "ar2"
              },
              {
                "kind": "text",
                "text": " is a set, or similar (non-sequence)\ncontainer:  As "
              },
              {
                "kind": "code",
                "text": "ar2"
              },
              {
                "kind": "text",
                "text": " is converted to an array, in those cases\n"
              },
              {
                "kind": "code",
                "text": "asarray(ar2)"
              },
              {
                "kind": "text",
                "text": " is an object array rather than the expected array of\ncontained values."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Using "
              },
              {
                "kind": "code",
                "text": "kind='table'"
              },
              {
                "kind": "text",
                "text": " tends to be faster than "
              },
              {
                "kind": "code",
                "text": "kind='sort'"
              },
              {
                "kind": "text",
                "text": " if the\nfollowing relationship is true:\n"
              },
              {
                "kind": "code",
                "text": "log10(len(ar2)) > (log10(max(ar2)-min(ar2)) - 2.27) / 0.927"
              },
              {
                "kind": "text",
                "text": ",\nbut may use greater memory. The default value for "
              },
              {
                "kind": "code",
                "text": "kind"
              },
              {
                "kind": "text",
                "text": " will\nbe automatically selected based only on memory usage, so one may\nmanually set "
              },
              {
                "kind": "code",
                "text": "kind='table'"
              },
              {
                "kind": "text",
                "text": " if memory constraints can be relaxed."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "test = we.array([0, 1, 2, 5, 0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "states = [0, 2]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "mask = we.in1d(test, states)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "mask"
              },
              {
                "kind": "output",
                "text": "array([ True, False,  True, False,  True])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "test[mask]"
              },
              {
                "kind": "output",
                "text": "array([0, 2, 0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "mask = we.in1d(test, states, invert=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "mask"
              },
              {
                "kind": "output",
                "text": "array([False,  True, False,  True, False])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "test[mask]"
              },
              {
                "kind": "output",
                "text": "array([1, 5])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
