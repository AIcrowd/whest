  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from a uniform distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are uniformly distributed over the half-open interval\n"
              },
              {
                "kind": "code",
                "text": "[low, high)"
              },
              {
                "kind": "text",
                "text": " (includes low, but excludes high).  In other words,\nany value within the given interval is equally likely to be drawn\nby "
              },
              {
                "kind": "code",
                "text": "uniform"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "New code should use the "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.uniform.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator.uniform",
                    "text": "uniform"
                  },
                  {
                    "kind": "text",
                    "text": "\nmethod of a "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator",
                    "text": "Generator"
                  },
                  {
                    "kind": "text",
                    "text": " instance instead;\nplease see the "
                  },
                  {
                    "display_text": "random-quick-start",
                    "explicit_title": false,
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "random-quick-start",
                    "role": "ref",
                    "suppress_link": false,
                    "target": "random-quick-start",
                    "unresolved": false
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "note",
            "options": [],
            "raw_source": ".. note::\n    New code should use the `~we.random.Generator.uniform`\n    method of a `~we.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
            "supported": true,
            "type": "directive_block"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Lower boundary of the output interval.  All values generated will be\ngreater than or equal to low.  The default value is 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Lower boundary of the output interval.  All values generated will be\ngreater than or equal to low.  The default value is 0."
                  }
                ],
                "name": "low",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Upper boundary of the output interval.  All values generated will be\nless than or equal to high.  The high limit may be included in the\nreturned array of floats due to floating-point rounding in the\nequation "
                      },
                      {
                        "kind": "code",
                        "text": "low + (high-low) * random_sample()"
                      },
                      {
                        "kind": "text",
                        "text": ".  The default value\nis 1.0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Upper boundary of the output interval.  All values generated will be\nless than or equal to high.  The high limit may be included in the\nreturned array of floats due to floating-point rounding in the\nequation "
                  },
                  {
                    "kind": "code",
                    "text": "low + (high-low) * random_sample()"
                  },
                  {
                    "kind": "text",
                    "text": ".  The default value\nis 1.0."
                  }
                ],
                "name": "high",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "low"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "high"
                      },
                      {
                        "kind": "text",
                        "text": " are both scalars.\nOtherwise, "
                      },
                      {
                        "kind": "code",
                        "text": "we.broadcast(low, high).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
