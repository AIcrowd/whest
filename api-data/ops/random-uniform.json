        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density function of the uniform distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "p(x) = \\frac{1}{b - a}"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "anywhere within the interval "
              },
              {
                "kind": "code",
                "text": "[a, b)"
              },
              {
                "kind": "text",
                "text": ", and zero elsewhere."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " == "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": ", values of "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": " will be returned.\nIf "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " < "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": ", the results are officially undefined\nand may eventually raise an error, i.e. do not rely on this\nfunction to behave when passed arguments satisfying that\ninequality condition. The "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " limit may be included in the\nreturned array of floats due to floating-point rounding in the\nequation "
              },
              {
                "kind": "code",
                "text": "low + (high-low) * random_sample()"
              },
              {
                "kind": "text",
                "text": ". For example:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.float32(5*0.99999999)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "we.float32(5.0)"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the distribution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = we.random.uniform(-1,0,1000)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "All values are within the given interval:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.all(s >= -1)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.all(s < 0)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Display the histogram of the samples, along with the\nprobability density function:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "count, bins, ignored = plt.hist(s, 15, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(bins, we.ones_like(bins), linewidth=2, color='r')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
