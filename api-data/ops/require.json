            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.arange(6).reshape(2,3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x.flags"
              },
              {
                "kind": "output",
                "text": "  C_CONTIGUOUS : True"
              },
              {
                "kind": "output",
                "text": "  F_CONTIGUOUS : False"
              },
              {
                "kind": "output",
                "text": "  OWNDATA : False"
              },
              {
                "kind": "output",
                "text": "  WRITEABLE : True"
              },
              {
                "kind": "output",
                "text": "  ALIGNED : True"
              },
              {
                "kind": "output",
                "text": "  WRITEBACKIFCOPY : False"
              }
            ],
