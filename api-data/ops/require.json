  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return an ndarray of the provided type that satisfies requirements."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function is useful to be sure that an array with the correct flags\nis returned for passing to compiled code (perhaps through ctypes)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The object to be converted to a type-and-requirement-satisfying array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The object to be converted to a type-and-requirement-satisfying array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The required data-type. If None preserve the current dtype. If your\napplication requires the data to be in native byteorder, include\na byteorder specification as a part of the dtype specification."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "data-type",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The required data-type. If None preserve the current dtype. If your\napplication requires the data to be in native byteorder, include\na byteorder specification as a part of the dtype specification."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The requirements list can be any of the following"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'F_CONTIGUOUS' ('F') - ensure a Fortran-contiguous array"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'C_CONTIGUOUS' ('C') - ensure a C-contiguous array"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'ALIGNED' ('A')      - ensure a data-type aligned array"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'WRITEABLE' ('W')    - ensure a writable array"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'OWNDATA' ('O')      - ensure an array that owns its own data"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'ENSUREARRAY', ('E') - ensure a base array, instead of a subclass"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  }
                ],
                "data_type": "str or sequence of str",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The requirements list can be any of the following"
                  }
                ],
                "name": "requirements",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as "
                      },
                      {
                        "kind": "code",
                        "text": "like"
                      },
                      {
                        "kind": "text",
                        "text": " supports\nthe "
                      },
                      {
                        "kind": "code",
                        "text": "__array_function__"
                      },
                      {
                        "kind": "text",
                        "text": " protocol, the result will be defined\nby it. In this case, it ensures the creation of an array object\ncompatible with that passed in via this argument."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "versionadded",
                    "options": [],
                    "raw_source": ".. versionadded:: 1.20.0",
                    "supported": true,
                    "type": "directive_block",
                    "version": "1.20.0"
                  }
                ],
                "data_type": "array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as "
                  },
                  {
                    "kind": "code",
                    "text": "like"
                  },
                  {
                    "kind": "text",
                    "text": " supports\nthe "
                  },
                  {
                    "kind": "code",
                    "text": "__array_function__"
                  },
                  {
                    "kind": "text",
                    "text": " protocol, the result will be defined\nby it. In this case, it ensures the creation of an array object\ncompatible with that passed in via this argument."
                  }
                ],
                "name": "like",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
