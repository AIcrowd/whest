                "kind": "text",
                "text": "Draw samples from a negative binomial distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from a negative binomial distribution with specified\nparameters, "
              },
              {
                "kind": "code",
                "text": "n"
              },
              {
                "kind": "text",
                "text": " successes and "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " probability of success where "
              },
              {
                "kind": "code",
                "text": "n"
              },
              {
                "kind": "text",
                "text": "\nis > 0 and "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " is in the interval (0, 1]."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Parameter of the distribution, > 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Parameter of the distribution, > 0."
                  }
                ],
                "name": "n",
