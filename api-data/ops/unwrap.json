                  }
                ],
                "name": "p",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Maximum discontinuity between values, default is "
                      },
                      {
                        "kind": "code",
                        "text": "period/2"
                      },
                      {
                        "kind": "text",
                        "text": ".\nValues below "
                      },
                      {
                        "kind": "code",
                        "text": "period/2"
                      },
                      {
                        "kind": "text",
                        "text": " are treated as if they were "
                      },
                      {
                        "kind": "code",
                        "text": "period/2"
                      },
                      {
                        "kind": "text",
                        "text": ".\nTo have an effect different from the default, "
                      },
                      {
                        "kind": "code",
                        "text": "discont"
                      },
                      {
                        "kind": "text",
                        "text": " should be\nlarger than "
                      },
                      {
                        "kind": "code",
                        "text": "period/2"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Maximum discontinuity between values, default is "
                  },
                  {
                    "kind": "code",
                    "text": "period/2"
                  },
                  {
                    "kind": "text",
                    "text": ".\nValues below "
                  },
                  {
                    "kind": "code",
                    "text": "period/2"
                  },
                  {
                    "kind": "text",
                    "text": " are treated as if they were "
                  },
                  {
                    "kind": "code",
                    "text": "period/2"
                  },
                  {
                    "kind": "text",
                    "text": ".\nTo have an effect different from the default, "
                  },
