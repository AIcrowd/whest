            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.eye(2*3*4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a.shape = (2*3, 4, 2, 3, 4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = we.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = rng.normal(size=(2*3, 4))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.linalg.tensorsolve(a, b)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x.shape"
              },
              {
                "kind": "output",
                "text": "(2, 3, 4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.allclose(we.tensordot(a, x, axes=3), b)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
