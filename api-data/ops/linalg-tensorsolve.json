  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Solve the tensor equation "
              },
              {
                "kind": "code",
                "text": "a x = b"
              },
              {
                "kind": "text",
                "text": " for x."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "It is assumed that all indices of "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " are summed over in the product,\ntogether with the rightmost indices of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": ", as is done in, for example,\n"
              },
              {
                "kind": "code",
                "text": "tensordot(a, x, axes=x.ndim)"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Coefficient tensor, of shape "
                      },
                      {
                        "kind": "code",
                        "text": "b.shape + Q"
                      },
                      {
                        "kind": "text",
                        "text": ". "
                      },
                      {
                        "kind": "code",
                        "text": "Q"
                      },
                      {
                        "kind": "text",
                        "text": ", a tuple, equals\nthe shape of that sub-tensor of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " consisting of the appropriate\nnumber of its rightmost indices, and must be such that\n"
                      },
                      {
                        "kind": "code",
                        "text": "prod(Q) == prod(b.shape)"
                      },
                      {
                        "kind": "text",
                        "text": " (in which sense "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is said to be\n'square')."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Coefficient tensor, of shape "
                  },
                  {
                    "kind": "code",
                    "text": "b.shape + Q"
                  },
                  {
                    "kind": "text",
                    "text": ". "
                  },
                  {
                    "kind": "code",
                    "text": "Q"
                  },
                  {
                    "kind": "text",
                    "text": ", a tuple, equals\nthe shape of that sub-tensor of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " consisting of the appropriate\nnumber of its rightmost indices, and must be such that\n"
                  },
                  {
                    "kind": "code",
                    "text": "prod(Q) == prod(b.shape)"
                  },
                  {
                    "kind": "text",
                    "text": " (in which sense "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is said to be\n'square')."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Right-hand tensor, which can be of any shape."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Right-hand tensor, which can be of any shape."
                  }
                ],
                "name": "b",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axes in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " to reorder to the right, before inversion.\nIf None (default), no reordering is done."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "tuple of ints, optional",
