            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Calculate the generalized inverse of a matrix using its\nsingular-value decomposition (SVD) and including all\n"
              },
              {
                "kind": "emphasis",
                "text": "large"
              },
              {
                "kind": "text",
                "text": " singular values."
              }
            ],
            "type": "paragraph"
          }
        ],
