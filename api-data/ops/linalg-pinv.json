        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The following example checks that "
              },
              {
                "kind": "code",
                "text": "a * a+ * a == a"
              },
              {
                "kind": "text",
                "text": " and\n"
              },
              {
                "kind": "code",
                "text": "a+ * a * a+ == a+"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = we.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = rng.normal(size=(9, 6))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "B = we.linalg.pinv(a)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.allclose(a, we.dot(a, we.dot(B, a)))"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.allclose(B, we.dot(B, we.dot(a, B)))"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
