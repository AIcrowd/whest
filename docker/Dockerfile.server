FROM python:3.10-slim
WORKDIR /app

# Install the real flopscope library (src layout)
COPY src/ /app/flopscope-lib/src/
COPY pyproject.toml /app/flopscope-lib/pyproject.toml
COPY README.md /app/flopscope-lib/README.md
RUN pip install --no-cache-dir /app/flopscope-lib/

# Install the server package
COPY flopscope-server/ /app/flopscope-server/
RUN pip install --no-cache-dir /app/flopscope-server/

CMD ["python", "-m", "flopscope_server", "--url", "ipc:///ipc/flopscope.sock"]
