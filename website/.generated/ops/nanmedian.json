    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Given a vector "
            },
            {
              "kind": "code",
              "text": "V"
            },
            {
              "kind": "text",
              "text": " of length "
            },
            {
              "kind": "code",
              "text": "N"
            },
            {
              "kind": "text",
              "text": ", the median of "
            },
            {
              "kind": "code",
              "text": "V"
            },
            {
              "kind": "text",
              "text": " is the\nmiddle value of a sorted copy of "
            },
            {
              "kind": "code",
              "text": "V"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "V_sorted"
            },
            {
              "kind": "text",
              "text": " - i.e.,\n"
            },
            {
              "kind": "code",
              "text": "V_sorted[(N-1)/2]"
            },
            {
              "kind": "text",
              "text": ", when "
            },
            {
              "kind": "code",
              "text": "N"
            },
            {
              "kind": "text",
              "text": " is odd and the average of the two\nmiddle values of "
            },
            {
              "kind": "code",
              "text": "V_sorted"
            },
            {
              "kind": "text",
              "text": " when "
            },
            {
              "kind": "code",
              "text": "N"
            },
            {
              "kind": "text",
              "text": " is even."
            }
          ],
          "type": "paragraph"
        }
      ],
