  "example": {
    "code": "import whest as we\n\na = we.array([[10.0, 7, 4], [3, 2, 1]])\n\na[0, 1] = we.nan\n\na\n\nwe.median(a)\n\nwe.nanmedian(a)\n\nwe.nanmedian(a, axis=0)\n\nwe.median(a, axis=1)\n\nb = a.copy()\n\nwe.nanmedian(b, axis=1, overwrite_input=True)\n\nassert not we.all(a==b)\n\nb = a.copy()\n\nwe.nanmedian(b, axis=None, overwrite_input=True)\n\nassert not we.all(a==b)",
    "output": "array([[10., nan,  4.],\n       [ 3.,  2.,  1.]])\n\nwe.float64(nan)\n\n3.0\n\narray([6.5, 2. , 2.5])\n\narray([nan,  2.])\n\narray([7.,  2.])\n\n3.0",
    "source": "derived"
  },
  "href": "/docs/api/ops/nanmedian/",
  "module": "numpy",
  "name": "nanmedian",
  "next": {
    "href": "/docs/api/ops/nanmin/",
