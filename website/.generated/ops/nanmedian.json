      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[10.0, 7, 4], [3, 2, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[0, 1] = we.nan"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[10., nan,  4.],"
            },
            {
              "kind": "output",
              "text": "       [ 3.,  2.,  1.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.median(a)"
            },
            {
              "kind": "output",
              "text": "we.float64(nan)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmedian(a)"
            },
            {
              "kind": "output",
              "text": "3.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmedian(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([6.5, 2. , 2.5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.median(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([nan,  2.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = a.copy()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmedian(b, axis=1, overwrite_input=True)"
            },
            {
              "kind": "output",
              "text": "array([7.,  2.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "assert not we.all(a==b)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = a.copy()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmedian(b, axis=None, overwrite_input=True)"
            },
            {
              "kind": "output",
              "text": "3.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "assert not we.all(a==b)"
            }
          ],
          "type": "doctest_block"
        }
      ],
