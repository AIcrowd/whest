      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The probability mass function (PMF) of Poisson distribution is"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "f(k; \\lambda)=\\frac{\\lambda^k e^{-\\lambda}}{k!}"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For events with an expected separation "
            },
            {
              "kind": "math",
              "latex": "\\lambda"
            },
            {
              "kind": "text",
              "text": " the Poisson\ndistribution "
            },
            {
              "kind": "math",
              "latex": "f(k; \\lambda)"
            },
            {
              "kind": "text",
              "text": " describes the probability of\n"
            },
            {
              "kind": "math",
              "latex": "k"
            },
            {
              "kind": "text",
              "text": " events occurring within the observed\ninterval "
            },
            {
              "kind": "math",
              "latex": "\\lambda"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Because the output is limited to the range of the C int64 type, a\nValueError is raised when "
            },
            {
              "kind": "code",
              "text": "lam"
            },
            {
              "kind": "text",
              "text": " is within 10 sigma of the maximum\nrepresentable value."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nWeisstein, Eric W. \"Poisson Distribution.\"\nFrom MathWorld--A Wolfram Web Resource.\nhttps://mathworld.wolfram.com/PoissonDistribution.html",
          "type": "raw_block"
        },
        {
          "raw_kind": "footnote",
          "raw_text": "2\n\nWikipedia, \"Poisson distribution\",\nhttps://en.wikipedia.org/wiki/Poisson_distribution",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from the distribution:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = we.random.poisson(5, 10000)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Display histogram of the sample:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "count, bins, ignored = plt.hist(s, 14, density=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw each 100 values for lambda 100 and 500:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = we.random.poisson(lam=(100., 500.), size=(100, 2))"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
