                  "kind": "text",
                  "text": "Expected number of events occurring in a fixed-time interval,\nmust be >= 0. A sequence must be broadcastable over the requested\nsize."
                }
              ],
              "name": "lam",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
