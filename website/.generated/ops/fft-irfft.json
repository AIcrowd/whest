  "canonical_name": "fft.irfft",
  "category": "counted_custom",
  "cost_formula": "5(n/2) * ceil(log2(n))",
  "cost_formula_latex": "$5(n/2) \\cdot \\lceil\\log_2 n\\rceil$",
  "display_type": "custom",
