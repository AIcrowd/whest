  "area": "fft",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Computes the inverse of "
            },
            {
              "kind": "code",
              "text": "rfft"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function computes the inverse of the one-dimensional "
            },
            {
              "kind": "emphasis",
              "text": "n"
            },
            {
              "kind": "text",
              "text": "-point\ndiscrete Fourier Transform of real input computed by "
            },
            {
              "kind": "code",
              "text": "rfft"
            },
            {
              "kind": "text",
              "text": ".\nIn other words, "
            },
            {
              "kind": "code",
              "text": "irfft(rfft(a), len(a)) == a"
            },
            {
              "kind": "text",
              "text": " to within numerical\naccuracy. (See Notes below for why "
            },
            {
              "kind": "code",
              "text": "len(a)"
            },
            {
              "kind": "text",
              "text": " is necessary here.)"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The input is expected to be in the form returned by "
            },
            {
              "kind": "code",
              "text": "rfft"
            },
            {
              "kind": "text",
              "text": ", i.e. the\nreal zero-frequency term followed by the complex positive frequency terms\nin order of increasing frequency.  Since the discrete Fourier Transform of\nreal input is Hermitian-symmetric, the negative frequency terms are taken\nto be the complex conjugates of the corresponding positive frequency terms."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
