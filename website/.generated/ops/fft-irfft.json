          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.fft.ifft([1, -1j, -1, 1j])"
            },
            {
              "kind": "output",
              "text": "array([0.+0.j,  1.+0.j,  0.+0.j,  0.+0.j]) # may vary"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.fft.irfft([1, -1j, -1])"
            },
            {
              "kind": "output",
              "text": "array([0.,  1.,  0.,  0.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Notice how the last term in the input to the ordinary "
            },
            {
              "kind": "code",
              "text": "ifft"
            },
            {
              "kind": "text",
              "text": " is the\ncomplex conjugate of the second term, and the output has zero imaginary\npart everywhere.  When calling "
            },
            {
              "kind": "code",
              "text": "irfft"
            },
            {
              "kind": "text",
              "text": ", the negative frequencies are not\nspecified, and the output array is purely real."
            }
          ],
          "type": "paragraph"
        }
      ],
