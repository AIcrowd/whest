  "example": {
    "code": "import flopscope as fnp\n\nfnp.fft.ifft([1, -1j, -1, 1j])\n\nfnp.fft.irfft([1, -1j, -1])",
    "output": "array([0.+0.j,  1.+0.j,  0.+0.j,  0.+0.j]) # may vary\n\narray([0.,  1.,  0.,  0.])",
    "source": "derived"
