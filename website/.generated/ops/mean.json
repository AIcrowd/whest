  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the arithmetic mean along the specified axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns the average of the array elements.  The average is taken over\nthe flattened array by default, otherwise over the specified axis.\n"
            },
            {
              "kind": "code",
              "text": "float64"
            },
            {
              "kind": "text",
              "text": " intermediate and return values are used for integer inputs."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
