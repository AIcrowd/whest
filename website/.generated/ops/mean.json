    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The arithmetic mean is the sum of the elements along the axis divided\nby the number of elements."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that for floating-point input, the mean is computed using the\nsame precision the input has.  Depending on the input data, this can\ncause the results to be inaccurate, especially for "
            },
            {
              "kind": "code",
              "text": "float32"
            },
            {
              "kind": "text",
              "text": " (see\nexample below).  Specifying a higher-precision accumulator using the\n"
            },
            {
              "kind": "code",
              "text": "dtype"
            },
            {
              "kind": "text",
              "text": " keyword can alleviate this issue."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "By default, "
            },
            {
              "kind": "code",
              "text": "float16"
            },
            {
              "kind": "text",
              "text": " results are computed using "
            },
            {
              "kind": "code",
              "text": "float32"
            },
            {
              "kind": "text",
              "text": " intermediates\nfor extra precision."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 2], [3, 4]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(a)"
            },
            {
              "kind": "output",
              "text": "2.5"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([2., 3.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([1.5, 3.5])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "In single precision, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/mean",
              "kind": "link",
              "target": "mean",
              "text": "mean"
            },
            {
              "kind": "text",
              "text": " can be inaccurate:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((2, 512*512), dtype=we.float32)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[0, :] = 1.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[1, :] = 0.1"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(a)"
            },
            {
              "kind": "output",
              "text": "we.float32(0.54999924)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Computing the mean in float64 is more accurate:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(a, dtype=we.float64)"
            },
            {
              "kind": "output",
              "text": "0.55000000074505806 # may vary"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Computing the mean in timedelta64 is available:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([1, 3], dtype=\"timedelta64[D]\")"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(b)"
            },
            {
              "kind": "output",
              "text": "we.timedelta64(2,'D')"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Specifying a where argument:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[5, 9, 13], [14, 10, 12], [11, 15, 19]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(a)"
            },
            {
              "kind": "output",
              "text": "12.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.mean(a, where=[[True], [False], [False]])"
            },
            {
              "kind": "output",
              "text": "9.0"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
