  "example": {
    "code": "import whest as we\n\na = we.array([[1, 2], [3, 4]])\n\nwe.mean(a)\n\nwe.mean(a, axis=0)\n\nwe.mean(a, axis=1)\n\na = we.zeros((2, 512*512), dtype=we.float32)\n\na[0, :] = 1.0\n\na[1, :] = 0.1\n\nwe.mean(a)\n\nwe.mean(a, dtype=we.float64)\n\nb = we.array([1, 3], dtype=\"timedelta64[D]\")\n\nwe.mean(b)\n\na = we.array([[5, 9, 13], [14, 10, 12], [11, 15, 19]])\n\nwe.mean(a)\n\nwe.mean(a, where=[[True], [False], [False]])",
    "output": "2.5\n\narray([2., 3.])\n\narray([1.5, 3.5])\n\nwe.float32(0.54999924)\n\n0.55000000074505806 # may vary\n\nwe.timedelta64(2,'D')\n\n12.0\n\n9.0",
    "source": "derived"
  },
  "href": "/docs/api/ops/mean/",
