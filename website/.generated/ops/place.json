          "inline": [
            {
              "kind": "text",
              "text": "Change elements of an array based on conditional and input values."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Similar to "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.copyto(arr, vals, where=mask).html",
              "href": "",
              "kind": "link",
              "target": "copyto(arr, vals, where=mask)",
              "text": "we.copyto(arr, vals, where=mask)"
            },
            {
              "kind": "text",
              "text": ", the difference is that\n"
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/place",
              "kind": "link",
              "target": "place",
              "text": "place"
            },
            {
              "kind": "text",
              "text": " uses the first N elements of "
            },
            {
              "kind": "code",
              "text": "vals"
            },
            {
              "kind": "text",
              "text": ", where N is the number of\nTrue values in "
            },
            {
              "kind": "code",
              "text": "mask"
            },
            {
              "kind": "text",
              "text": ", while "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/copyto",
              "kind": "link",
              "target": "copyto",
              "text": "copyto"
            },
            {
              "kind": "text",
              "text": " uses the elements where "
            },
            {
              "kind": "code",
              "text": "mask"
            },
            {
              "kind": "text",
              "text": "\nis True."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/extract",
              "kind": "link",
              "target": "extract",
              "text": "extract"
            },
            {
              "kind": "text",
              "text": " does the exact opposite of "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/place",
              "kind": "link",
              "target": "place",
              "text": "place"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
