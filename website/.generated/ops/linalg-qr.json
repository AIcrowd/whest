  "example": {
    "code": "import flopscope as fnp\n\nrng = fnp.random.default_rng()\n\na = rng.normal(size=(9, 6))\n\nQ, R = fnp.linalg.qr(a)\n\nfnp.allclose(a, fnp.dot(Q, R))  # a does equal QR\n\nR2 = fnp.linalg.qr(a, mode='r')\n\nfnp.allclose(R, R2)  # mode='r' returns the same R as mode='full'\n\na = fnp.random.normal(size=(3, 2, 2)) # Stack of 2 x 2 matrices as input\n\nQ, R = fnp.linalg.qr(a)\n\nQ.shape\n\nR.shape\n\nfnp.allclose(a, fnp.matmul(Q, R))\n\nA = fnp.array([[0, 1], [1, 1], [1, 1], [2, 1]])\n\nA\n\nb = fnp.array([1, 2, 2, 3])\n\nQ, R = fnp.linalg.qr(A)\n\np = fnp.dot(Q.T, b)\n\nfnp.dot(fnp.linalg.inv(R), p)",
    "output": "True\n\nTrue\n\n(3, 2, 2)\n\n(3, 2, 2)\n\nTrue\n\narray([[0, 1],\n       [1, 1],\n       [1, 1],\n       [2, 1]])\n\narray([  1.,   1.])",
    "source": "derived"
  },
