  "example": {
    "code": "loc, scale = 0., 1.\n\nrng = flops.random.default_rng()\n\ns = rng.laplace(loc, scale, 1000)\n\nimport matplotlib.pyplot as plt\n\ncount, bins, _ = plt.hist(s, 30, density=True)\n\nx = flops.arange(-8., 8., .01)\n\npdf = flops.exp(-abs(x-loc)/scale)/(2.*scale)\n\nplt.plot(x, pdf)\n\ng = (1/(scale * flops.sqrt(2 * flops.pi)) *\n     flops.exp(-(x - loc)**2 / (2 * scale**2)))\n\nplt.plot(x,g)",
    "output": "",
