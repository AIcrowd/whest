  "area": "random",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from the Laplace or double exponential distribution with specified location (or mean) and scale (decay)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The Laplace distribution is similar to the Gaussian/normal distribution,\nbut is sharper at the peak and has fatter tails. It represents the\ndifference between two independent, identically distributed exponential\nrandom variables."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The position, "
                    },
                    {
                      "kind": "math",
                      "latex": "\\mu"
                    },
                    {
                      "kind": "text",
                      "text": ", of the distribution peak. Default is 0."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The position, "
                },
                {
                  "kind": "math",
                  "latex": "\\mu"
                },
                {
                  "kind": "text",
                  "text": ", of the distribution peak. Default is 0."
                }
              ],
              "name": "loc",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "math",
                      "latex": "\\lambda"
                    },
                    {
                      "kind": "text",
                      "text": ", the exponential decay. Default is 1. Must be non-\nnegative."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats, optional",
              "inline": [
                {
                  "kind": "math",
                  "latex": "\\lambda"
                },
                {
                  "kind": "text",
                  "text": ", the exponential decay. Default is 1. Must be non-\nnegative."
                }
              ],
              "name": "scale",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "loc"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "scale"
                    },
                    {
                      "kind": "text",
                      "text": " are both scalars.\nOtherwise, "
                    },
                    {
                      "kind": "code",
                      "text": "flops.broadcast(loc, scale).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Output shape.  If the given shape is, e.g., "
                },
                {
                  "kind": "code",
                  "text": "(m, n, k)"
                },
                {
                  "kind": "text",
                  "text": ", then\n"
                },
                {
                  "kind": "code",
                  "text": "m * n * k"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn.  If size is "
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": " (default),\na single value is returned if "
                },
                {
                  "kind": "code",
                  "text": "loc"
                },
                {
                  "kind": "text",
