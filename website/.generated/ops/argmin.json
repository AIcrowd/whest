  "example": {
    "code": "import whest as we\n\na = we.arange(6).reshape(2,3) + 10\n\na\n\nwe.argmin(a)\n\nwe.argmin(a, axis=0)\n\nwe.argmin(a, axis=1)\n\nind = we.unravel_index(we.argmin(a, axis=None), a.shape)\n\nind\n\na[ind]\n\nb = we.arange(6) + 10\n\nb[4] = 10\n\nb\n\nwe.argmin(b)  # Only the first occurrence is returned.\n\nx = we.array([[4,2,3], [1,0,3]])\n\nindex_array = we.argmin(x, axis=-1)\n\nwe.take_along_axis(x, we.expand_dims(index_array, axis=-1), axis=-1)\n\nwe.take_along_axis(x, we.expand_dims(index_array, axis=-1),\n    axis=-1).squeeze(axis=-1)\n\nx = we.arange(24).reshape((2, 3, 4))\n\nres = we.argmin(x, axis=1, keepdims=True)\n\nres.shape",
    "output": "array([[10, 11, 12],\n       [13, 14, 15]])\n\n0\n\narray([0, 0, 0])\n\narray([0, 0])\n\n(0, 0)\n\n10\n\narray([10, 11, 12, 13, 10, 15])\n\n0\n\narray([[2],\n       [0]])\n\narray([2, 0])\n\n(2, 1, 4)",
    "source": "derived"
  },
