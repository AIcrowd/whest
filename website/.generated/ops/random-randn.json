        {
          "inline": [
            {
              "kind": "text",
              "text": "For random samples from the normal distribution with mean "
            },
            {
              "kind": "code",
              "text": "mu"
            },
            {
              "kind": "text",
              "text": " and\nstandard deviation "
            },
            {
              "kind": "code",
              "text": "sigma"
            },
            {
              "kind": "text",
              "text": ", use:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "sigma * fnp.random.randn(...) + mu",
          "type": "literal_block"
        }
