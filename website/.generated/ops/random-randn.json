          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The dimensions of the returned array, must be non-negative.\nIf no argument is given a single Python float is returned."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The dimensions of the returned array, must be non-negative.\nIf no argument is given a single Python float is returned."
