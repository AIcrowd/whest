  "area": "random",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return a sample (or samples) from the \"standard normal\" distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "This is a convenience function for users porting code from Matlab,\nand wraps "
                },
                {
                  "kind": "code",
                  "text": "standard_normal"
                },
                {
                  "kind": "text",
                  "text": ". That function takes a\ntuple to specify the size of the output, which is consistent with\nother NumPy functions like "
                },
                {
                  "external_url": "",
                  "href": "/docs/api/ops/zeros",
                  "kind": "link",
                  "target": "zeros",
                  "text": "fnp.zeros"
                },
                {
                  "kind": "text",
                  "text": " and "
                },
                {
                  "external_url": "",
                  "href": "/docs/api/ops/ones",
                  "kind": "link",
                  "target": "ones",
                  "text": "fnp.ones"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n    This is a convenience function for users porting code from Matlab,\n    and wraps `standard_normal`. That function takes a\n    tuple to specify the size of the output, which is consistent with\n    other NumPy functions like `fnp.zeros` and `fnp.ones`.",
          "supported": true,
          "type": "directive_block"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "New code should use the\n"
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.standard_normal.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator.standard_normal",
                  "text": "standard_normal"
                },
                {
                  "kind": "text",
                  "text": "\nmethod of a "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator",
                  "text": "Generator"
                },
                {
                  "kind": "text",
                  "text": " instance instead;\nplease see the "
                },
                {
                  "display_text": "random-quick-start",
                  "explicit_title": false,
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "random-quick-start",
                  "role": "ref",
                  "suppress_link": false,
                  "target": "random-quick-start",
                  "unresolved": false
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n    New code should use the\n    `~fnp.random.Generator.standard_normal`\n    method of a `~fnp.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
          "supported": true,
          "type": "directive_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If positive int_like arguments are provided, "
            },
            {
              "kind": "code",
              "text": "randn"
            },
            {
              "kind": "text",
              "text": " generates an array\nof shape "
            },
            {
              "kind": "code",
              "text": "(d0, d1, ..., dn)"
            },
            {
              "kind": "text",
              "text": ", filled\nwith random floats sampled from a univariate \"normal\" (Gaussian)\ndistribution of mean 0 and variance 1. A single float randomly sampled\nfrom the distribution is returned if no argument is provided."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
