      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Apply a function to 1-D slices along the given axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Execute "
            },
            {
              "kind": "code",
              "text": "func1d(a, *args, **kwargs)"
            },
            {
              "kind": "text",
              "text": " where "
            },
            {
              "kind": "code",
              "text": "func1d"
            },
            {
              "kind": "text",
              "text": " operates on 1-D arrays\nand "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " is a 1-D slice of "
            },
            {
              "kind": "code",
              "text": "arr"
            },
            {
              "kind": "text",
              "text": " along "
            },
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This is equivalent to (but faster than) the following use of "
            },
            {
              "kind": "code",
              "text": "ndindex"
            },
            {
              "kind": "text",
              "text": " and\n"
            },
            {
              "kind": "code",
              "text": "s_"
            },
            {
              "kind": "text",
              "text": ", which sets each of "
            },
            {
              "kind": "code",
              "text": "ii"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "jj"
            },
            {
              "kind": "text",
              "text": ", and "
            },
            {
              "kind": "code",
              "text": "kk"
            },
            {
              "kind": "text",
              "text": " to a tuple of indices:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "Ni, Nk = a.shape[:axis], a.shape[axis+1:]\nfor ii in ndindex(Ni):\n    for kk in ndindex(Nk):\n        f = func1d(arr[ii + s_[:,] + kk])\n        Nj = f.shape\n        for jj in ndindex(Nj):\n            out[ii + jj + kk] = f[jj]",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Equivalently, eliminating the inner loop, this can be expressed as:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "Ni, Nk = a.shape[:axis], a.shape[axis+1:]\nfor ii in ndindex(Ni):\n    for kk in ndindex(Nk):\n        out[ii + s_[...,] + kk] = func1d(arr[ii + s_[:,] + kk])",
          "type": "literal_block"
        }
      ],
      "title": "Extended Summary"
    },
