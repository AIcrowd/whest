          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "freqs = we.fft.fftfreq(10, 0.1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "freqs"
            },
            {
              "kind": "output",
              "text": "array([ 0.,  1.,  2., ..., -3., -2., -1.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fft.fftshift(freqs)"
            },
            {
              "kind": "output",
              "text": "array([-5., -4., -3., -2., -1.,  0.,  1.,  2.,  3.,  4.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Shift the zero-frequency component only along the second axis:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "freqs = we.fft.fftfreq(9, d=1./9).reshape(3, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "freqs"
            },
            {
              "kind": "output",
              "text": "array([[ 0.,  1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [ 3.,  4., -4.],"
            },
            {
              "kind": "output",
              "text": "       [-3., -2., -1.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fft.fftshift(freqs, axes=(1,))"
            },
            {
              "kind": "output",
              "text": "array([[ 2.,  0.,  1.],"
            },
            {
              "kind": "output",
              "text": "       [-4.,  3.,  4.],"
            },
            {
              "kind": "output",
              "text": "       [-1., -3., -2.]])"
            }
          ],
          "type": "doctest_block"
        }
