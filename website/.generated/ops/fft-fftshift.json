          "inline": [
            {
              "kind": "text",
              "text": "Shift the zero-frequency component to the center of the spectrum."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function swaps half-spaces for all axes listed (defaults to all).\nNote that "
            },
            {
              "kind": "code",
              "text": "y[0]"
            },
            {
              "kind": "text",
              "text": " is the Nyquist component only if "
            },
            {
              "kind": "code",
              "text": "len(x)"
            },
            {
              "kind": "text",
              "text": " is even."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
