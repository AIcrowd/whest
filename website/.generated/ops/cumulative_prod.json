              "kind": "input",
              "prompt": "...",
              "text": "# total product 1*2*3 = 6"
            },
            {
              "kind": "output",
              "text": "array([1, 2, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([1, 2, 3, 4, 5, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.cumulative_prod(a, dtype=float) # specify type of output"
            },
            {
              "kind": "output",
              "text": "array([   1.,    2.,    6.,   24.,  120.,  720.])"
            }
          ],
