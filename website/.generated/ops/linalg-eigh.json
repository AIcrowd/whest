  "example": {
    "code": "import whest as we\n\nfrom numpy import linalg as LA\n\na = we.array([[1, -2j], [2j, 5]])\n\na\n\neigenvalues, eigenvectors = LA.eigh(a)\n\neigenvalues\n\neigenvectors\n\n(we.dot(a, eigenvectors[:, 0]) -\neigenvalues[0] * eigenvectors[:, 0])  # verify 1st eigenval/vec pair\n\n(we.dot(a, eigenvectors[:, 1]) -\neigenvalues[1] * eigenvectors[:, 1])  # verify 2nd eigenval/vec pair\n\nA = we.matrix(a) # what happens if input is a matrix object\n\nA\n\neigenvalues, eigenvectors = LA.eigh(A)\n\neigenvalues\n\neigenvectors\n\na = we.array([[5+2j, 9-2j], [0+2j, 2-1j]])\n\na\n\nb = we.array([[5.+0.j, 0.-2.j], [0.+2.j, 2.-0.j]])\n\nb\n\nwa, va = LA.eigh(a)\n\nwb, vb = LA.eig(b)\n\nwa\n\nwb\n\nva\n\nvb",
    "output": "array([[ 1.+0.j, -0.-2.j],\n       [ 0.+2.j,  5.+0.j]])\n\narray([0.17157288, 5.82842712])\n\narray([[-0.92387953+0.j        , -0.38268343+0.j        ], # may vary\n       [ 0.        +0.38268343j,  0.        -0.92387953j]])\n\narray([5.55111512e-17+0.0000000e+00j, 0.00000000e+00+1.2490009e-16j])\n\narray([0.+0.j, 0.+0.j])\n\nmatrix([[ 1.+0.j, -0.-2.j],\n        [ 0.+2.j,  5.+0.j]])\n\narray([0.17157288, 5.82842712])\n\nmatrix([[-0.92387953+0.j        , -0.38268343+0.j        ], # may vary\n        [ 0.        +0.38268343j,  0.        -0.92387953j]])\n\narray([[5.+2.j, 9.-2.j],\n       [0.+2.j, 2.-1.j]])\n\narray([[5.+0.j, 0.-2.j],\n       [0.+2.j, 2.+0.j]])\n\narray([1., 6.])\n\narray([6.+0.j, 1.+0.j])\n\narray([[-0.4472136 +0.j        , -0.89442719+0.j        ], # may vary\n       [ 0.        +0.89442719j,  0.        -0.4472136j ]])\n\narray([[ 0.89442719+0.j       , -0.        +0.4472136j],\n       [-0.        +0.4472136j,  0.89442719+0.j       ]])",
    "source": "derived"
  },
