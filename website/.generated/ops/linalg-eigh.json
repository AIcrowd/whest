    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Broadcasting rules apply, see the "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.linalg.html",
              "href": "",
              "kind": "link",
              "target": "linalg",
              "text": "we.linalg"
            },
            {
              "kind": "text",
              "text": " documentation for\ndetails."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The eigenvalues/eigenvectors are computed using LAPACK routines "
            },
            {
              "kind": "code",
              "text": "_syevd"
            },
            {
              "kind": "text",
              "text": ",\n"
            },
            {
              "kind": "code",
              "text": "_heevd"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The eigenvalues of real symmetric or complex Hermitian matrices are always\nreal. "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": " The array "
            },
            {
              "kind": "code",
              "text": "eigenvalues"
            },
            {
              "kind": "text",
              "text": " of (column) eigenvectors is unitary and\n"
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "eigenvalues"
            },
            {
              "kind": "text",
              "text": ", and "
            },
            {
              "kind": "code",
              "text": "eigenvectors"
            },
            {
              "kind": "text",
              "text": " satisfy the equations "
            },
            {
              "kind": "code",
              "text": "dot(a,\neigenvectors[:, i]) = eigenvalues[i] * eigenvectors[:, i]"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
