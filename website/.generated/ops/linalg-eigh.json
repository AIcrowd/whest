    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from numpy import linalg as LA"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, -2j], [2j, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[ 1.+0.j, -0.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [ 0.+2.j,  5.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "eigenvalues, eigenvectors = LA.eigh(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "eigenvalues"
            },
            {
              "kind": "output",
              "text": "array([0.17157288, 5.82842712])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "eigenvectors"
            },
            {
              "kind": "output",
              "text": "array([[-0.92387953+0.j        , -0.38268343+0.j        ], # may vary"
            },
            {
              "kind": "output",
              "text": "       [ 0.        +0.38268343j,  0.        -0.92387953j]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "(we.dot(a, eigenvectors[:, 0]) -"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "eigenvalues[0] * eigenvectors[:, 0])  # verify 1st eigenval/vec pair"
            },
            {
              "kind": "output",
              "text": "array([5.55111512e-17+0.0000000e+00j, 0.00000000e+00+1.2490009e-16j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "(we.dot(a, eigenvectors[:, 1]) -"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "eigenvalues[1] * eigenvectors[:, 1])  # verify 2nd eigenval/vec pair"
            },
            {
              "kind": "output",
              "text": "array([0.+0.j, 0.+0.j])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = we.matrix(a) # what happens if input is a matrix object"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A"
            },
            {
              "kind": "output",
              "text": "matrix([[ 1.+0.j, -0.-2.j],"
            },
            {
              "kind": "output",
              "text": "        [ 0.+2.j,  5.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "eigenvalues, eigenvectors = LA.eigh(A)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "eigenvalues"
            },
            {
              "kind": "output",
              "text": "array([0.17157288, 5.82842712])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "eigenvectors"
            },
            {
              "kind": "output",
              "text": "matrix([[-0.92387953+0.j        , -0.38268343+0.j        ], # may vary"
            },
            {
              "kind": "output",
              "text": "        [ 0.        +0.38268343j,  0.        -0.92387953j]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# demonstrate the treatment of the imaginary part of the diagonal"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[5+2j, 9-2j], [0+2j, 2-1j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[5.+2.j, 9.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+2.j, 2.-1.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# with UPLO='L' this is numerically equivalent to using LA.eig() with:"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([[5.+0.j, 0.-2.j], [0.+2.j, 2.-0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([[5.+0.j, 0.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+2.j, 2.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "wa, va = LA.eigh(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "wb, vb = LA.eig(b)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "wa"
            },
            {
              "kind": "output",
              "text": "array([1., 6.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "wb"
            },
            {
              "kind": "output",
              "text": "array([6.+0.j, 1.+0.j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "va"
            },
            {
              "kind": "output",
              "text": "array([[-0.4472136 +0.j        , -0.89442719+0.j        ], # may vary"
            },
            {
              "kind": "output",
              "text": "       [ 0.        +0.89442719j,  0.        -0.4472136j ]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "vb"
            },
            {
              "kind": "output",
              "text": "array([[ 0.89442719+0.j       , -0.        +0.4472136j],"
            },
            {
              "kind": "output",
              "text": "       [-0.        +0.4472136j,  0.89442719+0.j       ]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
