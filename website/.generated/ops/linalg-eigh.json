  "area": "linalg",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the eigenvalues and eigenvectors of a complex Hermitian (conjugate symmetric) or a real symmetric matrix."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns two objects, a 1-D array containing the eigenvalues of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ", and\na 2-D square array or matrix (depending on the input type) of the\ncorresponding eigenvectors (in columns)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Hermitian or real symmetric matrices whose eigenvalues and\neigenvectors are to be computed."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "(..., M, M) array",
              "inline": [
                {
                  "kind": "text",
                  "text": "Hermitian or real symmetric matrices whose eigenvalues and\neigenvectors are to be computed."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Specifies whether the calculation is done with the lower triangular\npart of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " ('L', default) or the upper triangular part ('U').\nIrrespective of this value only the real parts of the diagonal will\nbe considered in the computation to preserve the notion of a Hermitian\nmatrix. It therefore follows that the imaginary part of the diagonal\nwill always be treated as zero."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{'L', 'U'}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Specifies whether the calculation is done with the lower triangular\npart of "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": " ('L', default) or the upper triangular part ('U').\nIrrespective of this value only the real parts of the diagonal will\nbe considered in the computation to preserve the notion of a Hermitian\nmatrix. It therefore follows that the imaginary part of the diagonal\nwill always be treated as zero."
                }
              ],
              "name": "UPLO",
              "type": "field_list"
            }
          ],
