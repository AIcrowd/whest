            },
            {
              "kind": "output",
              "text": "array([8.38434191e+00, 1.64402274e+00, 2.31534378e-16])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.count_nonzero(s > 1e-10)  # Matrix of rank 2"
            },
            {
              "kind": "output",
              "text": "2"
            }
          ],
