          "inline": [
            {
              "kind": "text",
              "text": "Returns the singular values of a matrix (or a stack of matrices) "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": ". When x is a stack of matrices, the function will compute the singular values for each matrix in the stack."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function is Array API compatible."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Calling "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.svdvals(x).html",
              "href": "",
              "kind": "link",
              "target": "svdvals(x)",
              "text": "we.svdvals(x)"
            },
            {
              "kind": "text",
              "text": " to get singular values is the same as\n"
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.svd(x, compute_uv=False, hermitian=False).html",
              "href": "",
