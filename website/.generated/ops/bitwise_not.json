  "example": {
    "code": "import whest as we\n\nx = we.invert(we.array(13, dtype=we.uint8))\n\nx\n\nwe.binary_repr(x, width=8)\n\nx = we.invert(we.array(13, dtype=we.uint16))\n\nx\n\nwe.binary_repr(x, width=16)\n\nwe.invert(we.array([13], dtype=we.int8))\n\nwe.binary_repr(-14, width=8)\n\nwe.invert(we.array([True, False]))\n\nx1 = we.array([True, False])\n\n~x1",
    "output": "we.uint8(242)\n\n'11110010'\n\nwe.uint16(65522)\n\n'1111111111110010'\n\narray([-14], dtype=int8)\n\n'11110010'\n\narray([False,  True])\n\narray([False,  True])",
    "source": "derived"
  },
