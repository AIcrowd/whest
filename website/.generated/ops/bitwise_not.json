      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nWikipedia, \"Two's complement\",\nhttps://en.wikipedia.org/wiki/Two's_complement",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "We've seen that 13 is represented by "
            },
            {
              "kind": "code",
              "text": "00001101"
            },
            {
              "kind": "text",
              "text": ".\nThe invert or bit-wise NOT of 13 is then:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.invert(we.array(13, dtype=we.uint8))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "we.uint8(242)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.binary_repr(x, width=8)"
            },
            {
              "kind": "output",
              "text": "'11110010'"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The result depends on the bit-width:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.invert(we.array(13, dtype=we.uint16))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "we.uint16(65522)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.binary_repr(x, width=16)"
            },
            {
              "kind": "output",
              "text": "'1111111111110010'"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When using signed integer types, the result is the bit-wise NOT of\nthe unsigned type, interpreted as a signed integer:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.invert(we.array([13], dtype=we.int8))"
            },
            {
              "kind": "output",
              "text": "array([-14], dtype=int8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.binary_repr(-14, width=8)"
            },
            {
              "kind": "output",
              "text": "'11110010'"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Booleans are accepted as well:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.invert(we.array([True, False]))"
            },
            {
              "kind": "output",
              "text": "array([False,  True])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "~"
            },
            {
              "kind": "text",
              "text": " operator can be used as a shorthand for "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/invert",
              "kind": "link",
              "target": "invert",
              "text": "we.invert"
            },
            {
              "kind": "text",
              "text": " on\nndarrays."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 = we.array([True, False])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "~x1"
            },
            {
              "kind": "output",
              "text": "array([False,  True])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
