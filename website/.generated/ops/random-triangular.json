      "title": "References"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw values from the distribution and plot the histogram:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "h = plt.hist(we.random.triangular(-3, 0, 8, 100000), bins=200,"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "density=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
