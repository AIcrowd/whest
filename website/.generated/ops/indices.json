  "example": {
    "code": "import whest as we\n\ngrid = we.indices((2, 3))\n\ngrid.shape\n\ngrid[0]        # row indices\n\ngrid[1]        # column indices\n\nx = we.arange(20).reshape(5, 4)\n\nrow, col = we.indices((2, 3))\n\nx[row, col]\n\ni, j = we.indices((2, 3), sparse=True)\n\ni.shape\n\nj.shape\n\ni        # row indices\n\nj        # column indices",
    "output": "(2, 2, 3)\n\narray([[0, 0, 0],\n       [1, 1, 1]])\n\narray([[0, 1, 2],\n       [0, 1, 2]])\n\narray([[0, 1, 2],\n       [4, 5, 6]])\n\n(2, 1)\n\n(1, 3)\n\narray([[0],\n       [1]])\n\narray([[0, 1, 2]])",
    "source": "derived"
  },
