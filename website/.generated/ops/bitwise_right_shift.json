      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Shift the bits of an integer to the right."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Bits are shifted to the right "
            },
            {
              "kind": "code",
              "text": "x2"
            },
            {
              "kind": "text",
              "text": ".  Because the internal\nrepresentation of numbers is in binary format, this operation is\nequivalent to dividing "
            },
            {
              "kind": "code",
              "text": "x1"
            },
            {
              "kind": "text",
              "text": " by "
            },
            {
              "kind": "code",
              "text": "2**x2"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input values."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like, int",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input values."
                }
              ],
              "name": "x1",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Number of bits to remove at the right of "
                    },
                    {
                      "kind": "code",
                      "text": "x1"
                    },
                    {
                      "kind": "text",
                      "text": ".\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "x1.shape != x2.shape"
                    },
                    {
                      "kind": "text",
                      "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like, int",
              "inline": [
                {
                  "kind": "text",
                  "text": "Number of bits to remove at the right of "
                },
                {
                  "kind": "code",
                  "text": "x1"
                },
                {
                  "kind": "text",
                  "text": ".\nIf "
                },
                {
                  "kind": "code",
                  "text": "x1.shape != x2.shape"
                },
                {
                  "kind": "text",
                  "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                }
              ],
              "name": "x2",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, None, or tuple of ndarray and None, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                }
              ],
              "name": "out",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array will be set to the ufunc result.\nElsewhere, the "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array will retain its original value.\nNote that if an uninitialized "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array is created via the default\n"
                    },
                    {
                      "kind": "code",
                      "text": "out=None"
                    },
                    {
                      "kind": "text",
                      "text": ", locations within it where the condition is False will\nremain uninitialized."
                    }
