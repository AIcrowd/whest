              "kind": "input",
              "prompt": ">>>",
              "text": "seed = 4861946401452"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "gen = flops.random.Generator(flops.random.PCG64(seed))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "gen.multivariate_hypergeometric(colors, 6)"
            },
            {
              "kind": "output",
              "text": "array([5, 0, 1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "gen.multivariate_hypergeometric(colors, 6, size=3)"
            },
            {
              "kind": "output",
              "text": "array([[5, 0, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 2, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 3, 0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "gen.multivariate_hypergeometric(colors, 6, size=(2, 2))"
            },
            {
              "kind": "output",
              "text": "array([[[3, 2, 1],"
            },
            {
              "kind": "output",
              "text": "        [3, 2, 1]],"
            },
            {
              "kind": "output",
              "text": "       [[4, 1, 1],"
            },
            {
              "kind": "output",
              "text": "        [3, 2, 1]]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
