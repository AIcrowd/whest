                    },
                    {
                      "kind": "text",
                      "text": ", and the return value\nhas shape "
                    },
                    {
                      "kind": "code",
                      "text": "(k, m, len(colors))"
                    },
                    {
                      "kind": "text",
                      "text": ".  If "
