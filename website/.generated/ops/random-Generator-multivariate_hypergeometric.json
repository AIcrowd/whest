            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The number of variates to generate, either an integer or a tuple\nholding the shape of the array of variates.  If the given size is,\ne.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(k, m)"
                    },
                    {
                      "kind": "text",
                      "text": ", then "
                    },
                    {
                      "kind": "code",
