      "title": "See also"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Create a 4 by 4 array"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(16).reshape(4, 4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[ 0,  1,  2,  3],"
            },
            {
              "kind": "output",
              "text": "       [ 4,  5,  6,  7],"
            },
            {
              "kind": "output",
              "text": "       [ 8,  9, 10, 11],"
            },
            {
              "kind": "output",
              "text": "       [12, 13, 14, 15]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Pass the array to get the indices of the upper triangular elements."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "triui = we.triu_indices_from(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "triui"
            },
            {
              "kind": "output",
              "text": "(array([0, 0, 0, 0, 1, 1, 1, 2, 2, 3]), array([0, 1, 2, 3, 1, 2, 3, 2, 3, 3]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[triui]"
            },
            {
              "kind": "output",
              "text": "array([ 0,  1,  2,  3,  5,  6,  7, 10, 11, 15])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This is syntactic sugar for triu_indices()."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.triu_indices(a.shape[0])"
            },
            {
              "kind": "output",
              "text": "(array([0, 0, 0, 0, 1, 1, 1, 2, 2, 3]), array([0, 1, 2, 3, 1, 2, 3, 2, 3, 3]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Use the "
            },
            {
              "kind": "code",
              "text": "k"
            },
            {
              "kind": "text",
              "text": " parameter to return the indices for the upper triangular array\nfrom the k-th diagonal."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "triuim1 = we.triu_indices_from(a, k=1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[triuim1]"
            },
            {
              "kind": "output",
              "text": "array([ 1,  2,  3,  6,  7, 11])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
