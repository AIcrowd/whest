  "example": {
    "code": "import whest as we\n\na = we.arange(16).reshape(4, 4)\n\na\n\ntriui = we.triu_indices_from(a)\n\ntriui\n\na[triui]\n\nwe.triu_indices(a.shape[0])\n\ntriuim1 = we.triu_indices_from(a, k=1)\n\na[triuim1]",
