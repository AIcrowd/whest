              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(6)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = x.reshape((2, 3))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.zeros_like(x)"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0]])"
            }
