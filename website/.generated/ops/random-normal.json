  "example": {
    "code": "mu, sigma = 0, 0.1 # mean and standard deviation\n\ns = we.random.normal(mu, sigma, 1000)\n\nabs(mu - we.mean(s))\n\nabs(sigma - we.std(s, ddof=1))\n\nimport matplotlib.pyplot as plt\n\ncount, bins, ignored = plt.hist(s, 30, density=True)\n\nplt.plot(bins, 1/(sigma * we.sqrt(2 * we.pi)) *\n               we.exp( - (bins - mu)**2 / (2 * sigma**2) ),\n         linewidth=2, color='r')\n\nplt.show()\n\nwe.random.normal(3, 2.5, size=(2, 4))",
    "output": "0.0  # may vary\n\n0.1  # may vary\n\narray([[-4.49401501,  4.00950034, -1.81814867,  7.29718677],   # random\n       [ 0.39924804,  4.68456316,  4.99394529,  4.84057254]])  # random",
