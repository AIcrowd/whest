              "kind": "text",
              "text": "Check if the array is Fortran contiguous but "
            },
            {
              "kind": "emphasis",
              "text": "not"
            },
            {
              "kind": "text",
              "text": " C contiguous."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function is obsolete. If you only want to check if an array is Fortran\ncontiguous use "
            },
            {
              "kind": "code",
              "text": "a.flags.f_contiguous"
            },
            {
              "kind": "text",
              "text": " instead."
            }
          ],
          "type": "paragraph"
        }
      ],
