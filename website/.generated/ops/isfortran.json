                {
                  "kind": "text",
                  "text": "Returns True if the array is Fortran contiguous but "
                },
                {
                  "kind": "emphasis",
                  "text": "not"
                },
                {
                  "kind": "text",
                  "text": " C contiguous."
                }
              ],
              "name": "isfortran",
