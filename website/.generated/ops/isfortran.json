    "code": "import flopscope as fnp\n\na = fnp.array([[1, 2, 3], [4, 5, 6]], order='C')\n\na\n\nfnp.isfortran(a)\n\nb = fnp.array([[1, 2, 3], [4, 5, 6]], order='F')\n\nb\n\nfnp.isfortran(b)\n\na = fnp.array([[1, 2, 3], [4, 5, 6]], order='C')\n\na\n\nfnp.isfortran(a)\n\nb = a.T\n\nb\n\nfnp.isfortran(b)\n\nfnp.isfortran(fnp.array([1, 2], order='F'))",
