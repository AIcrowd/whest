          "inline": [
            {
              "kind": "text",
              "text": "Return the Hanning window."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The Hanning window is a taper formed by using a weighted cosine."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
