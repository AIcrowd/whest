    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nan_to_num(we.inf)"
            },
            {
              "kind": "output",
              "text": "1.7976931348623157e+308"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nan_to_num(-we.inf)"
            },
            {
              "kind": "output",
              "text": "-1.7976931348623157e+308"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nan_to_num(we.nan)"
            },
            {
              "kind": "output",
              "text": "0.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([we.inf, -we.inf, we.nan, -128, 128])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nan_to_num(x)"
            },
            {
              "kind": "output",
              "text": "array([ 1.79769313e+308, -1.79769313e+308,  0.00000000e+000, # may vary"
            },
            {
              "kind": "output",
              "text": "       -1.28000000e+002,  1.28000000e+002])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nan_to_num(x, nan=-9999, posinf=33333333, neginf=33333333)"
            },
            {
              "kind": "output",
              "text": "array([ 3.3333333e+07,  3.3333333e+07, -9.9990000e+03,"
            },
            {
              "kind": "output",
              "text": "       -1.2800000e+02,  1.2800000e+02])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([complex(we.inf, we.nan), we.nan, complex(we.nan, we.inf)])"
            },
            {
              "kind": "output",
              "text": "array([  1.79769313e+308,  -1.79769313e+308,   0.00000000e+000, # may vary"
            },
            {
              "kind": "output",
              "text": "     -1.28000000e+002,   1.28000000e+002])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nan_to_num(y)"
            },
            {
              "kind": "output",
              "text": "array([  1.79769313e+308 +0.00000000e+000j, # may vary"
            },
            {
              "kind": "output",
              "text": "         0.00000000e+000 +0.00000000e+000j,"
            },
            {
              "kind": "output",
              "text": "         0.00000000e+000 +1.79769313e+308j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nan_to_num(y, nan=111111, posinf=222222)"
            },
            {
              "kind": "output",
              "text": "array([222222.+111111.j, 111111.     +0.j, 111111.+222222.j])"
            }
          ],
          "type": "doctest_block"
        }
      ],
