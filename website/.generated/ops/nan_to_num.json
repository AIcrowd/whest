  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Replace NaN with zero and infinity with large finite numbers (default behaviour) or with the numbers defined by the user using the "
            },
            {
              "kind": "code",
              "text": "nan"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "posinf"
            },
            {
              "kind": "text",
              "text": " and/or "
            },
            {
              "kind": "code",
              "text": "neginf"
            },
            {
              "kind": "text",
              "text": " keywords."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is inexact, NaN is replaced by zero or by the user defined value in\n"
            },
            {
              "kind": "code",
              "text": "nan"
            },
            {
              "kind": "text",
              "text": " keyword, infinity is replaced by the largest finite floating point\nvalues representable by "
            },
            {
              "kind": "code",
              "text": "x.dtype"
            },
            {
              "kind": "text",
              "text": " or by the user defined value in\n"
            },
            {
              "kind": "code",
              "text": "posinf"
            },
            {
              "kind": "text",
              "text": " keyword and -infinity is replaced by the most negative finite\nfloating point values representable by "
            },
            {
              "kind": "code",
              "text": "x.dtype"
            },
            {
              "kind": "text",
              "text": " or by the user defined\nvalue in "
            },
            {
              "kind": "code",
              "text": "neginf"
            },
            {
              "kind": "text",
              "text": " keyword."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For complex dtypes, the above is applied to each of the real and\nimaginary components of "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " separately."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is not inexact, then no replacements are made."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
