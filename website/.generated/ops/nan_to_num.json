  "example": {
    "code": "import whest as we\n\nwe.nan_to_num(we.inf)\n\nwe.nan_to_num(-we.inf)\n\nwe.nan_to_num(we.nan)\n\nx = we.array([we.inf, -we.inf, we.nan, -128, 128])\n\nwe.nan_to_num(x)\n\nwe.nan_to_num(x, nan=-9999, posinf=33333333, neginf=33333333)\n\ny = we.array([complex(we.inf, we.nan), we.nan, complex(we.nan, we.inf)])\n\nwe.nan_to_num(y)\n\nwe.nan_to_num(y, nan=111111, posinf=222222)",
    "output": "1.7976931348623157e+308\n\n-1.7976931348623157e+308\n\n0.0\n\narray([ 1.79769313e+308, -1.79769313e+308,  0.00000000e+000, # may vary\n       -1.28000000e+002,  1.28000000e+002])\n\narray([ 3.3333333e+07,  3.3333333e+07, -9.9990000e+03,\n       -1.2800000e+02,  1.2800000e+02])\n\narray([  1.79769313e+308,  -1.79769313e+308,   0.00000000e+000, # may vary\n     -1.28000000e+002,   1.28000000e+002])\n\narray([  1.79769313e+308 +0.00000000e+000j, # may vary\n         0.00000000e+000 +0.00000000e+000j,\n         0.00000000e+000 +1.79769313e+308j])\n\narray([222222.+111111.j, 111111.     +0.j, 111111.+222222.j])",
