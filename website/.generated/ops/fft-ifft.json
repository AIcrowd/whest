          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.fft.ifft([0, 4, 0, 0])"
            },
            {
              "kind": "output",
              "text": "array([ 1.+0.j,  0.+1.j, -1.+0.j,  0.-1.j]) # may vary"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Create and plot a band-limited signal with random phases:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "t = fnp.arange(400)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "n = fnp.zeros((400,), dtype=complex)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "n[40:60] = fnp.exp(1j*fnp.random.uniform(0, 2*fnp.pi, (20,)))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = fnp.fft.ifft(n)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(t, s.real, label='real')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at ...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(t, s.imag, '--', label='imaginary')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at ...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.legend()"
            },
            {
              "kind": "output",
              "text": "<matplotlib.legend.Legend object at ...>"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
