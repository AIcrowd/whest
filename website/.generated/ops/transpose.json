  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns an array with axes transposed."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "For a 1-D array, this returns an unchanged view of the original array, as a\ntransposed vector is simply the same vector.\nTo convert a 1-D array into a 2-D column vector, an additional dimension\nmust be added, e.g., "
            },
            {
              "kind": "code",
              "text": "fnp.atleast_2d(a).T"
            },
            {
              "kind": "text",
              "text": " achieves this, as does\n"
            },
            {
              "kind": "code",
              "text": "a[:, fnp.newaxis]"
            },
            {
              "kind": "text",
              "text": ".\nFor a 2-D array, this is the standard matrix transpose.\nFor an n-D array, if axes are given, their order indicates how the\naxes are permuted (see Examples). If axes are not provided, then\n"
            },
            {
              "kind": "code",
              "text": "transpose(a).shape == a.shape[::-1]"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If specified, it must be a tuple or list which contains a permutation\nof [0, 1, ..., N-1] where N is the number of axes of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": ". Negative\nindices can also be used to specify axes. The i-th axis of the returned\narray will correspond to the axis numbered "
                    },
                    {
                      "kind": "code",
                      "text": "axes[i]"
                    },
                    {
                      "kind": "text",
                      "text": " of the input.\nIf not specified, defaults to "
                    },
                    {
                      "kind": "code",
                      "text": "range(a.ndim)[::-1]"
                    },
                    {
                      "kind": "text",
                      "text": ", which reverses\nthe order of the axes."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "tuple or list of ints, optional",
              "inline": [
                {
                  "kind": "text",
