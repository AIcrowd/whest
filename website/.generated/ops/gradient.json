{
  "aliases": [],
  "api_docs_html": "",
  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the gradient of an N-dimensional array."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The gradient is computed using second order accurate central differences\nin the interior points and either first or second order accurate one-sides\n(forward or backwards) differences at the boundaries.\nThe returned gradient hence has the same shape as the input array."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "An N-dimensional array containing samples of a scalar function."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "An N-dimensional array containing samples of a scalar function."
                }
              ],
              "name": "f",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Spacing between f values. Default unitary spacing for all dimensions.\nSpacing can be specified using:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "single scalar to specify a sample distance for all dimensions."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "N scalars to specify a constant sample distance for each dimension.\ni.e. "
                            },
                            {
                              "kind": "code",
                              "text": "dx"
                            },
                            {
                              "kind": "text",
                              "text": ", "
                            },
                            {
                              "kind": "code",
                              "text": "dy"
                            },
                            {
                              "kind": "text",
                              "text": ", "
                            },
                            {
                              "kind": "code",
                              "text": "dz"
                            },
                            {
                              "kind": "text",
                              "text": ", ..."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "N arrays to specify the coordinates of the values along each\ndimension of F. The length of the array must match the size of\nthe corresponding dimension"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "Any combination of N scalars/arrays with the meaning of 2. and 3."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    }
                  ],
                  "ordered": true,
                  "type": "list"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "axis"
                    },
                    {
                      "kind": "text",
                      "text": " is given, the number of varargs must equal the number of axes\nspecified in the axis parameter.\nDefault: 1. (see Examples below)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "list of scalar or array, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Spacing between f values. Default unitary spacing for all dimensions.\nSpacing can be specified using:"
                }
              ],
              "name": "varargs",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Gradient is calculated using N-th order accurate differences\nat the boundaries. Default: 1."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{1, 2}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Gradient is calculated using N-th order accurate differences\nat the boundaries. Default: 1."
                }
              ],
              "name": "edge_order",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Gradient is calculated only along the given axis or axes\nThe default (axis = None) is to calculate the gradient for all the axes\nof the input array. axis may be negative, in which case it counts from\nthe last to the first axis."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "None or int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Gradient is calculated only along the given axis or axes\nThe default (axis = None) is to calculate the gradient for all the axes\nof the input array. axis may be negative, in which case it counts from\nthe last to the first axis."
                }
              ],
              "name": "axis",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A tuple of ndarrays (or a single ndarray if there is only one\ndimension) corresponding to the derivatives of f with respect\nto each dimension. Each derivative has the same shape as f."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray or tuple of ndarray",
              "inline": [
                {
                  "kind": "text",
                  "text": "A tuple of ndarrays (or a single ndarray if there is only one\ndimension) corresponding to the derivatives of f with respect\nto each dimension. Each derivative has the same shape as f."
                }
              ],
              "name": "gradient",
              "type": "field_list"
            }
          ],
          "title": "Returns",
          "type": "field_list"
        }
      ],
      "title": "Returns"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Assuming that "
            },
            {
              "kind": "math",
              "latex": "f\\in C^{3}"
            },
            {
              "kind": "text",
              "text": " (i.e., "
            },
            {
              "kind": "math",
              "latex": "f"
            },
            {
              "kind": "text",
              "text": " has at least 3 continuous\nderivatives) and let "
            },
            {
              "kind": "math",
              "latex": "h_{*}"
            },
            {
              "kind": "text",
              "text": " be a non-homogeneous stepsize, we\nminimize the \"consistency error\" "
            },
            {
              "kind": "math",
              "latex": "\\eta_{i}"
            },
            {
              "kind": "text",
              "text": " between the true gradient\nand its estimate from a linear combination of the neighboring grid-points:"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "\\eta_{i} = f_{i}^{\\left(1\\right)} - \\left[ \\alpha f\\left(x_{i}\\right) + \\beta f\\left(x_{i} + h_{d}\\right) + \\gamma f\\left(x_{i}-h_{s}\\right) \\right]"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "By substituting "
            },
            {
              "kind": "math",
              "latex": "f(x_{i} + h_{d})"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "math",
              "latex": "f(x_{i} - h_{s})"
            },
            {
              "kind": "text",
              "text": "\nwith their Taylor series expansion, this translates into solving\nthe following the linear system:"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "\\left\\{ \\begin{array}{r} \\alpha+\\beta+\\gamma=0 \\\\ \\beta h_{d}-\\gamma h_{s}=1 \\\\ \\beta h_{d}^{2}+\\gamma h_{s}^{2}=0 \\end{array} \\right."
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The resulting approximation of "
            },
            {
              "kind": "math",
              "latex": "f_{i}^{(1)}"
            },
            {
              "kind": "text",
              "text": " is the following:"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "\\hat f_{i}^{(1)} = \\frac{ h_{s}^{2}f\\left(x_{i} + h_{d}\\right) + \\left(h_{d}^{2} - h_{s}^{2}\\right)f\\left(x_{i}\\right) - h_{d}^{2}f\\left(x_{i}-h_{s}\\right)} { h_{s}h_{d}\\left(h_{d} + h_{s}\\right)} + \\mathcal{O}\\left(\\frac{h_{d}h_{s}^{2} + h_{s}h_{d}^{2}}{h_{d} + h_{s}}\\right)"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "It is worth noting that if "
            },
            {
              "kind": "math",
              "latex": "h_{s}=h_{d}"
            },
            {
              "kind": "text",
              "text": "\n(i.e., data are evenly spaced)\nwe find the standard second order approximation:"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "\\hat f_{i}^{(1)}= \\frac{f\\left(x_{i+1}\\right) - f\\left(x_{i-1}\\right)}{2h} + \\mathcal{O}\\left(h^{2}\\right)"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "With a similar procedure the forward/backward approximations used for\nboundaries can be derived."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nQuarteroni A., Sacco R., Saleri F. (2007) Numerical Mathematics\n(Texts in Applied Mathematics). New York: Springer.",
          "type": "raw_block"
        },
        {
          "raw_kind": "footnote",
          "raw_text": "2\n\nDurran D. R. (1999) Numerical Methods for Wave Equations\nin Geophysical Fluid Dynamics. New York: Springer.",
          "type": "raw_block"
        },
        {
          "raw_kind": "footnote",
          "raw_text": "3\n\nFornberg B. (1988) Generation of Finite Difference Formulas on\nArbitrarily Spaced Grids,\nMathematics of Computation 51, no. 184 : 699-706.\nPDF.",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "f = fnp.array([1, 2, 4, 7, 11, 16])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(f)"
            },
            {
              "kind": "output",
              "text": "array([1. , 1.5, 2.5, 3.5, 4.5, 5. ])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(f, 2)"
            },
            {
              "kind": "output",
              "text": "array([0.5 ,  0.75,  1.25,  1.75,  2.25,  2.5 ])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Spacing can be also specified with an array that represents the coordinates\nof the values F along the dimensions.\nFor instance a uniform spacing:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.arange(f.size)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(f, x)"
            },
            {
              "kind": "output",
              "text": "array([1. ,  1.5,  2.5,  3.5,  4.5,  5. ])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Or a non uniform one:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([0., 1., 1.5, 3.5, 4., 6.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(f, x)"
            },
            {
              "kind": "output",
              "text": "array([1. ,  3. ,  3.5,  6.7,  6.9,  2.5])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For two dimensional arrays, the return will be two arrays ordered by\naxis. In this example the first array stands for the gradient in\nrows and the second one in columns direction:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(fnp.array([[1, 2, 6], [3, 4, 5]]))"
            },
            {
              "kind": "output",
              "text": "(array([[ 2.,  2., -1.],"
            },
            {
              "kind": "output",
              "text": "        [ 2.,  2., -1.]]),"
            },
            {
              "kind": "output",
              "text": " array([[1. , 2.5, 4. ],"
            },
            {
              "kind": "output",
              "text": "        [1. , 1. , 1. ]]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "In this example the spacing is also specified:\nuniform for axis=0 and non uniform for axis=1"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "dx = 2."
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = [1., 1.5, 3.5]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(fnp.array([[1, 2, 6], [3, 4, 5]]), dx, y)"
            },
            {
              "kind": "output",
              "text": "(array([[ 1. ,  1. , -0.5],"
            },
            {
              "kind": "output",
              "text": "        [ 1. ,  1. , -0.5]]),"
            },
            {
              "kind": "output",
              "text": " array([[2. , 2. , 2. ],"
            },
            {
              "kind": "output",
              "text": "        [2. , 1.7, 0.5]]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "It is possible to specify how boundaries are treated using "
            },
            {
              "kind": "code",
              "text": "edge_order"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([0, 1, 2, 3, 4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "f = x**2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(f, edge_order=1)"
            },
            {
              "kind": "output",
              "text": "array([1.,  2.,  4.,  6.,  7.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(f, edge_order=2)"
            },
            {
              "kind": "output",
              "text": "array([0., 2., 4., 6., 8.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": " keyword can be used to specify a subset of axes of which the\ngradient is calculated"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(fnp.array([[1, 2, 6], [3, 4, 5]]), axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[ 2.,  2., -1.],"
            },
            {
              "kind": "output",
              "text": "       [ 2.,  2., -1.]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "varargs"
            },
            {
              "kind": "text",
              "text": " argument defines the spacing between sample points in the\ninput array. It can take two forms:"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "An array, specifying coordinates, which may be unevenly spaced:"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": true,
          "type": "list"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([0., 2., 3., 6., 8.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = x ** 2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(y, x, edge_order=2)"
            },
            {
              "kind": "output",
              "text": "array([ 0.,  4.,  6., 12., 16.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A scalar, representing the fixed sample distance:"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": true,
          "type": "list"
        },
        {
          "raw_kind": "system_message",
          "raw_text": "<string>:69: (INFO/1) Enumerated list start value not ordinal-1: \"2\" (ordinal 2)",
          "type": "raw_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "dx = 2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([0., 2., 4., 6., 8.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = x ** 2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(y, dx, edge_order=2)"
            },
            {
              "kind": "output",
              "text": "array([ 0.,  4.,  8., 12., 16.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "It's possible to provide different data for spacing along each dimension.\nThe number of arguments must match the number of dimensions in the input\ndata."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "dx = 2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "dy = 3"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.arange(0, 6, dx)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = fnp.arange(0, 9, dy)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "xs, ys = fnp.meshgrid(x, y)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "zs = xs + 2 * ys"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(zs, dy, dx)  # Passing two scalars"
            },
            {
              "kind": "output",
              "text": "(array([[2., 2., 2.],"
            },
            {
              "kind": "output",
              "text": "        [2., 2., 2.],"
            },
            {
              "kind": "output",
              "text": "        [2., 2., 2.]]),"
            },
            {
              "kind": "output",
              "text": " array([[1., 1., 1.],"
            },
            {
              "kind": "output",
              "text": "        [1., 1., 1.],"
            },
            {
              "kind": "output",
              "text": "        [1., 1., 1.]]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Mixing scalars and arrays is also allowed:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.gradient(zs, y, dx)  # Passing one array and one scalar"
            },
            {
              "kind": "output",
              "text": "(array([[2., 2., 2.],"
            },
            {
              "kind": "output",
              "text": "        [2., 2., 2.],"
            },
            {
              "kind": "output",
              "text": "        [2., 2., 2.]]),"
            },
            {
              "kind": "output",
              "text": " array([[1., 1., 1.],"
            },
            {
              "kind": "output",
              "text": "        [1., 1., 1.],"
            },
            {
              "kind": "output",
              "text": "        [1., 1., 1.]]))"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
  "canonical_name": "gradient",
  "category": "counted_custom",
  "cost_formula": "numel(input)",
  "cost_formula_latex": "$\\text{numel}(\\text{input})$",
  "display_type": "custom",
  "doc_coverage": {
    "raw_blocks": [
      {
        "kind": "footnote",
        "raw_text": "1\n\nQuarteroni A., Sacco R., Saleri F. (2007) Numerical Mathematics\n(Texts in Applied Mathematics). New York: Springer."
      },
      {
        "kind": "footnote",
        "raw_text": "2\n\nDurran D. R. (1999) Numerical Methods for Wave Equations\nin Geophysical Fluid Dynamics. New York: Springer."
      },
