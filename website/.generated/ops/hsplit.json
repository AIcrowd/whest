              "kind": "text",
              "text": "Split an array into multiple sub-arrays horizontally (column-wise)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Please refer to the "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/split",
              "kind": "link",
              "target": "split",
              "text": "split"
            },
            {
              "kind": "text",
              "text": " documentation.  "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/hsplit",
              "kind": "link",
              "target": "hsplit",
              "text": "hsplit"
            },
            {
              "kind": "text",
              "text": " is equivalent\nto "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/split",
              "kind": "link",
              "target": "split",
              "text": "split"
            },
            {
              "kind": "text",
              "text": " with "
            },
            {
              "kind": "code",
              "text": "axis=1"
            },
            {
              "kind": "text",
              "text": ", the array is always split along the second\naxis except for 1-D arrays, where it is split at "
            },
            {
              "kind": "code",
              "text": "axis=0"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
