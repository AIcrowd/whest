      "title": "See also"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(16.0).reshape(4, 4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([[ 0.,   1.,   2.,   3.],"
            },
            {
              "kind": "output",
              "text": "       [ 4.,   5.,   6.,   7.],"
            },
            {
              "kind": "output",
              "text": "       [ 8.,   9.,  10.,  11.],"
            },
            {
              "kind": "output",
              "text": "       [12.,  13.,  14.,  15.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.hsplit(x, 2)"
            },
            {
              "kind": "output",
              "text": "[array([[  0.,   1.],"
            },
            {
              "kind": "output",
              "text": "       [  4.,   5.],"
            },
            {
              "kind": "output",
              "text": "       [  8.,   9.],"
            },
            {
              "kind": "output",
              "text": "       [12.,  13.]]),"
            },
            {
              "kind": "output",
              "text": " array([[  2.,   3.],"
            },
            {
              "kind": "output",
              "text": "       [  6.,   7.],"
            },
            {
              "kind": "output",
              "text": "       [10.,  11.],"
            },
            {
              "kind": "output",
              "text": "       [14.,  15.]])]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.hsplit(x, we.array([3, 6]))"
            },
            {
              "kind": "output",
              "text": "[array([[ 0.,   1.,   2.],"
            },
            {
              "kind": "output",
              "text": "       [ 4.,   5.,   6.],"
            },
            {
              "kind": "output",
              "text": "       [ 8.,   9.,  10.],"
            },
            {
              "kind": "output",
              "text": "       [12.,  13.,  14.]]),"
            },
            {
              "kind": "output",
              "text": " array([[ 3.],"
            },
            {
              "kind": "output",
              "text": "       [ 7.],"
            },
            {
              "kind": "output",
              "text": "       [11.],"
            },
            {
              "kind": "output",
              "text": "       [15.]]),"
            },
            {
              "kind": "output",
              "text": " array([], shape=(4, 0), dtype=float64)]"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "With a higher dimensional array the split is still along the second axis."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(8.0).reshape(2, 2, 2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([[[0.,  1.],"
            },
            {
              "kind": "output",
              "text": "        [2.,  3.]],"
            },
            {
              "kind": "output",
              "text": "       [[4.,  5.],"
            },
            {
              "kind": "output",
              "text": "        [6.,  7.]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.hsplit(x, 2)"
            },
            {
              "kind": "output",
              "text": "[array([[[0.,  1.]],"
            },
            {
              "kind": "output",
              "text": "       [[4.,  5.]]]),"
            },
            {
              "kind": "output",
              "text": " array([[[2.,  3.]],"
            },
            {
              "kind": "output",
              "text": "       [[6.,  7.]]])]"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "With a 1-D array, the split is along axis 0."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([0, 1, 2, 3, 4, 5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.hsplit(x, 2)"
            },
            {
              "kind": "output",
              "text": "[array([0, 1, 2]), array([3, 4, 5])]"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
