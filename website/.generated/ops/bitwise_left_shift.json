  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Shift the bits of an integer to the left."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Bits are shifted to the left by appending "
            },
            {
              "kind": "code",
              "text": "x2"
            },
            {
              "kind": "text",
              "text": " 0s at the right of "
            },
            {
              "kind": "code",
              "text": "x1"
            },
            {
              "kind": "text",
              "text": ".\nSince the internal representation of numbers is in binary format, this\noperation is equivalent to multiplying "
            },
            {
              "kind": "code",
              "text": "x1"
            },
            {
              "kind": "text",
              "text": " by "
            },
            {
              "kind": "code",
              "text": "2**x2"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
