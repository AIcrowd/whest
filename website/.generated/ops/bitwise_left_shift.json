    "code": "import whest as we\n\nwe.binary_repr(5)\n\nwe.left_shift(5, 2)\n\nwe.binary_repr(20)\n\nwe.left_shift(5, [1,2,3])\n\na = we.left_shift(we.uint8(255), we.int64(1))  # Expect 254\n\nprint(a, type(a)) # Unexpected result due to upcasting\n\nb = we.left_shift(we.uint8(255), we.uint8(1))\n\nprint(b, type(b))\n\nx1 = 5\n\nx2 = we.array([1, 2, 3])\n\nx1 << x2",
