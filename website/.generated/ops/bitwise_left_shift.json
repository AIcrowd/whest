                      "kind": "code",
                      "text": "x1"
                    },
                    {
                      "kind": "text",
                      "text": ". Has to be non-negative.\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "x1.shape != x2.shape"
                    },
                    {
                      "kind": "text",
                      "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like of integer type",
