          "inline": [
            {
              "kind": "text",
              "text": "Changes elements of an array based on conditional and input values."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Sets "
            },
            {
              "kind": "code",
              "text": "a.flat[n] = values[n]"
            },
            {
              "kind": "text",
              "text": " for each n where "
            },
            {
              "kind": "code",
              "text": "mask.flat[n]==True"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "values"
            },
            {
              "kind": "text",
              "text": " is not the same size as "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "mask"
            },
            {
              "kind": "text",
              "text": " then it will repeat.\nThis gives behavior different from "
            },
            {
              "kind": "code",
              "text": "a[mask] = values"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
