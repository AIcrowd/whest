            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.repeat(3, 4)"
            },
            {
              "kind": "output",
              "text": "array([3, 3, 3, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([[1,2],[3,4]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.repeat(x, 2)"
            },
            {
              "kind": "output",
              "text": "array([1, 1, 2, 2, 3, 3, 4, 4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.repeat(x, 3, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[1, 1, 1, 2, 2, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 3, 3, 4, 4, 4]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.repeat(x, [1, 2], axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4],"
            },
            {
              "kind": "output",
              "text": "       [3, 4]])"
            }
          ],
