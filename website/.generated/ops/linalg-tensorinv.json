          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.eye(4*6)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a.shape = (4, 6, 8, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ainv = we.linalg.tensorinv(a, ind=2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ainv.shape"
            },
            {
              "kind": "output",
              "text": "(8, 3, 4, 6)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = we.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = rng.normal(size=(4, 6))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.allclose(we.tensordot(ainv, b), we.linalg.tensorsolve(a, b))"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
