  "example": {
    "code": "import whest as we\n\na = we.eye(4*6)\n\na.shape = (4, 6, 8, 3)\n\nainv = we.linalg.tensorinv(a, ind=2)\n\nainv.shape\n\nrng = we.random.default_rng()\n\nb = rng.normal(size=(4, 6))\n\nwe.allclose(we.tensordot(ainv, b), we.linalg.tensorsolve(a, b))\n\na = we.eye(4*6)\n\na.shape = (24, 8, 3)\n\nainv = we.linalg.tensorinv(a, ind=1)\n\nainv.shape\n\nrng = we.random.default_rng()\n\nb = rng.normal(size=24)\n\nwe.allclose(we.tensordot(ainv, b, 1), we.linalg.tensorsolve(a, b))",
    "output": "(8, 3, 4, 6)\n\nTrue\n\n(8, 3, 24)\n\nTrue",
    "source": "derived"
  },
