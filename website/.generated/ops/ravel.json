  "returns": [
    {
      "body": [
        "y is a contiguous 1-D array of the same subtype as `a`,",
        "with shape ``(a.size,)``.",
        "Note that matrices are special cased for backward compatibility,",
        "if `a` is a matrix, then y is a 1-D ndarray."
      ],
