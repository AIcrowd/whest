                      "kind": "text",
                      "text": "A Python object that implements the "
                    },
                    {
                      "kind": "code",
                      "text": "__dlpack__"
                    },
                    {
                      "kind": "text",
                      "text": " and\n"
                    },
                    {
                      "kind": "code",
                      "text": "__dlpack_device__"
                    },
                    {
                      "kind": "text",
                      "text": " methods."
                    }
                  ],
