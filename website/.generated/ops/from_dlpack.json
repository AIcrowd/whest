          "inline": [
            {
              "kind": "text",
              "text": "Create a NumPy array from an object implementing the "
            },
            {
              "kind": "code",
              "text": "__dlpack__"
            },
            {
              "kind": "text",
              "text": " protocol. Generally, the returned NumPy array is a view of the input object. See "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "text",
              "text": "[2]_"
            },
            {
              "kind": "text",
              "text": " for more details."
            }
          ],
          "type": "paragraph"
        }
      ],
