              "name": "x",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Device on which to place the created array. Default: "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": ".\nMust be "
                    },
                    {
                      "kind": "code",
                      "text": "\"cpu\""
                    },
                    {
                      "kind": "text",
                      "text": " if passed which may allow importing an array\nthat is not already CPU available."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "device, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Device on which to place the created array. Default: "
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": ".\nMust be "
                },
                {
                  "kind": "code",
                  "text": "\"cpu\""
                },
                {
                  "kind": "text",
                  "text": " if passed which may allow importing an array\nthat is not already CPU available."
                }
              ],
              "name": "device",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Boolean indicating whether or not to copy the input. If "
                    },
                    {
                      "kind": "code",
                      "text": "True"
                    },
                    {
                      "kind": "text",
                      "text": ",\nthe copy will be made. If "
                    },
                    {
                      "kind": "code",
                      "text": "False"
                    },
                    {
                      "kind": "text",
                      "text": ", the function will never copy,\nand will raise "
                    },
                    {
                      "kind": "code",
                      "text": "BufferError"
                    },
                    {
                      "kind": "text",
                      "text": " in case a copy is deemed necessary.\nPassing it requests a copy from the exporter who may or may not\nimplement the capability.\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": ", the function will reuse the existing memory buffer if\npossible and copy otherwise. Default: "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": "."
