          "inline": [
            {
              "kind": "text",
              "text": "Apply a function repeatedly over multiple axes."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "func"
            },
            {
              "kind": "text",
              "text": " is called as "
            },
            {
              "kind": "code",
              "text": "res = func(a, axis)"
            },
            {
              "kind": "text",
              "text": ", where "
            },
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": " is the first\nelement of "
            },
            {
              "kind": "code",
              "text": "axes"
            },
            {
              "kind": "text",
              "text": ".  The result "
            },
            {
              "kind": "code",
              "text": "res"
            },
            {
              "kind": "text",
              "text": " of the function call must have\neither the same dimensions as "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " or one less dimension.  If "
            },
            {
              "kind": "code",
              "text": "res"
            },
            {
              "kind": "text",
              "text": "\nhas one less dimension than "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ", a dimension is inserted before\n"
            },
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": ".  The call to "
            },
            {
              "kind": "code",
              "text": "func"
            },
            {
              "kind": "text",
              "text": " is then repeated for each axis in "
            },
            {
              "kind": "code",
              "text": "axes"
            },
            {
              "kind": "text",
              "text": ",\nwith "
            },
            {
              "kind": "code",
              "text": "res"
            },
            {
              "kind": "text",
              "text": " as the first argument."
            }
          ],
          "type": "paragraph"
        }
      ],
