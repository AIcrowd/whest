          "inline": [
            {
              "kind": "text",
              "text": "Return random floats in the half-open interval [0.0, 1.0)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Results are from the \"continuous uniform\" distribution over the\nstated interval.  To sample "
            },
            {
              "kind": "math",
              "latex": "Unif[a, b), b > a"
            },
            {
              "kind": "text",
              "text": " multiply\nthe output of "
            },
            {
              "kind": "code",
              "text": "random_sample"
            },
            {
              "kind": "text",
              "text": " by "
            },
            {
              "kind": "code",
              "text": "(b-a)"
            },
            {
              "kind": "text",
              "text": " and add "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "(b - a) * random_sample() + a",
          "type": "literal_block"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
