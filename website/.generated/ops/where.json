    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "If all the arrays are 1-D, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/where",
              "kind": "link",
              "target": "where",
              "text": "where"
            },
            {
