    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The behavior depends on the arguments in the following way."
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If both arguments are 2-D they are multiplied like conventional\nmatrices."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If either argument is N-D, N > 2, it is treated as a stack of\nmatrices residing in the last two indexes and broadcast accordingly."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If the first argument is 1-D, it is promoted to a matrix by\nprepending a 1 to its dimensions. After matrix multiplication\nthe prepended 1 is removed. (For stacks of vectors, use "
                    },
                    {
                      "external_url": "",
                      "href": "/docs/api/ops/vecmat",
                      "kind": "link",
                      "target": "vecmat",
                      "text": "vecmat"
                    },
                    {
                      "kind": "text",
                      "text": ".)"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If the second argument is 1-D, it is promoted to a matrix by\nappending a 1 to its dimensions. After matrix multiplication\nthe appended 1 is removed. (For stacks of vectors, use "
                    },
                    {
                      "external_url": "",
                      "href": "/docs/api/ops/matvec",
                      "kind": "link",
                      "target": "matvec",
                      "text": "matvec"
                    },
                    {
                      "kind": "text",
                      "text": ".)"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        },
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/ops/matmul",
              "kind": "link",
              "target": "matmul",
              "text": "matmul"
            },
            {
              "kind": "text",
              "text": " differs from "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/dot",
              "kind": "link",
              "target": "dot",
              "text": "dot"
            },
            {
              "kind": "text",
              "text": " in two important ways:"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Multiplication by scalars is not allowed, use "
                    },
                    {
                      "kind": "code",
                      "text": "*"
                    },
                    {
                      "kind": "text",
                      "text": " instead."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Stacks of matrices are broadcast together as if the matrices\nwere elements, respecting the signature "
                    },
                    {
                      "kind": "code",
                      "text": "(n,k),(k,m)->(n,m)"
                    },
                    {
                      "kind": "text",
                      "text": ":"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "lines": [
                    {
                      "kind": "input",
                      "prompt": ">>>",
                      "text": "a = fnp.ones([9, 5, 7, 4])"
                    },
                    {
                      "kind": "input",
                      "prompt": ">>>",
                      "text": "c = fnp.ones([9, 5, 4, 3])"
                    },
                    {
                      "kind": "input",
                      "prompt": ">>>",
                      "text": "fnp.dot(a, c).shape"
                    },
                    {
                      "kind": "output",
                      "text": "(9, 5, 7, 9, 5, 3)"
                    },
                    {
                      "kind": "input",
                      "prompt": ">>>",
                      "text": "fnp.matmul(a, c).shape"
                    },
                    {
                      "kind": "output",
                      "text": "(9, 5, 7, 3)"
                    },
                    {
                      "kind": "input",
                      "prompt": ">>>",
                      "text": "# n is 7, k is 4, m is 3"
                    }
                  ],
                  "type": "doctest_block"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The matmul function implements the semantics of the "
            },
            {
              "kind": "code",
              "text": "@"
            },
            {
              "kind": "text",
              "text": " operator\ndefined in "
            },
            {
              "display_text": "465",
              "explicit_title": false,
              "external_url": "https://peps.python.org/pep-0465/",
              "href": "",
              "kind": "role_reference",
              "original_target": "465",
              "role": "pep",
              "suppress_link": false,
              "target": "465",
              "unresolved": false
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "It uses an optimized BLAS library when possible (see "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.linalg.html",
              "href": "",
              "kind": "link",
              "target": "linalg",
              "text": "fnp.linalg"
            },
            {
              "kind": "text",
              "text": ")."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "For 2-D arrays it is the matrix product:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([[1, 0],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = fnp.array([[4, 1],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[2, 2]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matmul(a, b)"
            },
            {
              "kind": "output",
              "text": "array([[4, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 2]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For 2-D mixed with 1-D, the result is the usual."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([[1, 0],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = fnp.array([1, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matmul(a, b)"
            },
            {
              "kind": "output",
              "text": "array([1, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matmul(b, a)"
            },
            {
              "kind": "output",
              "text": "array([1, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Broadcasting is conventional for stacks of arrays"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.arange(2 * 2 * 4).reshape((2, 2, 4))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = fnp.arange(2 * 2 * 4).reshape((2, 4, 2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matmul(a,b).shape"
            },
            {
              "kind": "output",
              "text": "(2, 2, 2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matmul(a, b)[0, 1, 1]"
            },
            {
              "kind": "output",
              "text": "98"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sum(a[0, 1, :] * b[0 , :, 1])"
            },
            {
              "kind": "output",
              "text": "98"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Vector, vector returns the scalar inner product, but neither argument\nis complex-conjugated:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matmul([2j, 3j], [2j, 3j])"
            },
            {
              "kind": "output",
              "text": "(-13+0j)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Scalar multiplication raises an error."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matmul([1,2], 3)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "ValueError: matmul: Input operand 1 does not have enough dimensions ..."
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "@"
            },
            {
              "kind": "text",
              "text": " operator can be used as a shorthand for "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/matmul",
              "kind": "link",
              "target": "matmul",
              "text": "fnp.matmul"
            },
            {
              "kind": "text",
              "text": " on\nndarrays."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 = fnp.array([2j, 3j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x2 = fnp.array([2j, 3j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 @ x2"
            },
            {
              "kind": "output",
              "text": "(-13+0j)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
