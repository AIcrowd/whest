  "example": {
    "code": "import flopscope as fnp\n\na = fnp.array([[1, 0],\n              [0, 1]])\n\nb = fnp.array([[4, 1],\n              [2, 2]])\n\nfnp.matmul(a, b)\n\na = fnp.array([[1, 0],\n              [0, 1]])\n\nb = fnp.array([1, 2])\n\nfnp.matmul(a, b)\n\nfnp.matmul(b, a)\n\na = fnp.arange(2 * 2 * 4).reshape((2, 2, 4))\n\nb = fnp.arange(2 * 2 * 4).reshape((2, 4, 2))\n\nfnp.matmul(a,b).shape\n\nfnp.matmul(a, b)[0, 1, 1]\n\nsum(a[0, 1, :] * b[0 , :, 1])\n\nfnp.matmul([2j, 3j], [2j, 3j])\n\nfnp.matmul([1,2], 3)\n\nx1 = fnp.array([2j, 3j])\n\nx2 = fnp.array([2j, 3j])\n\nx1 @ x2",
    "output": "array([[4, 1],\n       [2, 2]])\n\narray([1, 2])\n\narray([1, 2])\n\n(2, 2, 2)\n\n98\n\n98\n\n(-13+0j)\n\nTraceback (most recent call last):\n...\nValueError: matmul: Input operand 1 does not have enough dimensions ...\n\n(-13+0j)",
    "source": "derived"
  },
