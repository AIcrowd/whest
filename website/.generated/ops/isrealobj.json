              "external_url": "",
              "href": "/docs/api/ops/isrealobj",
              "kind": "link",
              "target": "isrealobj",
              "text": "isrealobj"
            },
            {
              "kind": "text",
              "text": " evaluates to False\nif the data type is complex."
            }
