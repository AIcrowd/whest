    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The function is only meant for arrays with numerical values but it\naccepts all other objects. Since it assumes array input, the return\nvalue of other objects may be True."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.isrealobj('A string')"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.isrealobj(False)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.isrealobj(None)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
