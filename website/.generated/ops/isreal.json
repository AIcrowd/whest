              "target": "isreal",
              "text": "isreal"
            },
            {
              "kind": "text",
              "text": " may behave unexpectedly for string or object arrays (see examples)"
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as flops"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = flops.array([1+1j, 1+0j, 4.5, 3, 2, 2j], dtype=complex)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.isreal(a)"
            },
            {
              "kind": "output",
              "text": "array([False,  True,  True,  True,  True, False])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The function does not work on string arrays."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = flops.array([2j, \"a\"], dtype=\"U\")"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.isreal(a)  # Warns about non-elementwise comparison"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns True for all elements in input array of "
            },
            {
              "kind": "code",
              "text": "dtype=object"
            },
            {
              "kind": "text",
              "text": " even if\nany of the elements is complex."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = flops.array([1, \"2\", 3+4j], dtype=object)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.isreal(a)"
            },
            {
              "kind": "output",
              "text": "array([ True,  True,  True])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "isreal should not be used with object arrays"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = flops.array([1+2j, 2+1j], dtype=object)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.isreal(a)"
            },
            {
              "kind": "output",
              "text": "array([ True,  True])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
