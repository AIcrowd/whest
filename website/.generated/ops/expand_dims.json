  "example": {
    "code": "import whest as we\n\nx = we.array([1, 2])\n\nx.shape\n\ny = we.expand_dims(x, axis=0)\n\ny\n\ny.shape\n\ny = we.expand_dims(x, axis=1)\n\ny\n\ny.shape\n\ny = we.expand_dims(x, axis=(0, 1))\n\ny\n\ny = we.expand_dims(x, axis=(2, 0))\n\ny\n\nwe.newaxis is None",
    "output": "(2,)\n\narray([[1, 2]])\n\n(1, 2)\n\narray([[1],\n       [2]])\n\n(2, 1)\n\narray([[[1, 2]]])\n\narray([[[1],\n        [2]]])\n\nTrue",
    "source": "derived"
