    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([1, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x.shape"
            },
            {
              "kind": "output",
              "text": "(2,)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The following is equivalent to "
            },
            {
              "kind": "code",
              "text": "x[we.newaxis, :]"
            },
            {
              "kind": "text",
              "text": " or "
            },
            {
              "kind": "code",
              "text": "x[we.newaxis]"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.expand_dims(x, axis=0)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y"
            },
            {
              "kind": "output",
              "text": "array([[1, 2]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y.shape"
            },
            {
              "kind": "output",
              "text": "(1, 2)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The following is equivalent to "
            },
            {
              "kind": "code",
              "text": "x[:, we.newaxis]"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.expand_dims(x, axis=1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y"
            },
            {
              "kind": "output",
              "text": "array([[1],"
            },
            {
              "kind": "output",
              "text": "       [2]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y.shape"
            },
            {
              "kind": "output",
              "text": "(2, 1)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": " may also be a tuple:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.expand_dims(x, axis=(0, 1))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y"
            },
            {
              "kind": "output",
              "text": "array([[[1, 2]]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.expand_dims(x, axis=(2, 0))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y"
            },
            {
              "kind": "output",
              "text": "array([[[1],"
            },
            {
              "kind": "output",
              "text": "        [2]]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that some examples may use "
            },
            {
              "kind": "code",
              "text": "None"
            },
            {
              "kind": "text",
              "text": " instead of "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.newaxis.html",
              "href": "",
              "kind": "link",
              "target": "newaxis",
              "text": "we.newaxis"
            },
            {
              "kind": "text",
              "text": ".  These\nare the same objects:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.newaxis is None"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
