        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Print sine of one angle:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sin(we.pi/2.)"
            },
            {
              "kind": "output",
              "text": "1.0"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Print sines of an array of angles given in degrees:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sin(we.array((0., 30., 45., 60., 90.)) * we.pi / 180. )"
            },
            {
              "kind": "output",
              "text": "array([ 0.        ,  0.5       ,  0.70710678,  0.8660254 ,  1.        ])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Plot the sine function:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pylab as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.linspace(-we.pi, we.pi, 201)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(x, we.sin(x))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.xlabel('Angle [rad]')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.ylabel('sin(x)')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.axis('tight')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
