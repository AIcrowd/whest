          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([[1,2,3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([[4],[5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.broadcast_arrays(x, y)"
            },
            {
              "kind": "output",
              "text": "(array([[1, 2, 3],"
            },
            {
              "kind": "output",
              "text": "        [1, 2, 3]]),"
            },
            {
              "kind": "output",
              "text": " array([[4, 4, 4],"
            },
            {
              "kind": "output",
              "text": "        [5, 5, 5]]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Here is a useful idiom for getting contiguous copies instead of\nnon-contiguous views."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "[we.array(a) for a in we.broadcast_arrays(x, y)]"
            },
            {
              "kind": "output",
              "text": "[array([[1, 2, 3],"
            },
            {
              "kind": "output",
              "text": "        [1, 2, 3]]),"
            },
            {
              "kind": "output",
              "text": " array([[4, 4, 4],"
            },
            {
              "kind": "output",
              "text": "        [5, 5, 5]])]"
            }
          ],
          "type": "doctest_block"
        }
