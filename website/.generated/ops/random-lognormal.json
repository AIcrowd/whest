  "example": {
    "code": "mu, sigma = 3., 1. # mean and standard deviation\n\ns = fnp.random.lognormal(mu, sigma, 1000)\n\nimport matplotlib.pyplot as plt\n\ncount, bins, ignored = plt.hist(s, 100, density=True, align='mid')\n\nx = fnp.linspace(min(bins), max(bins), 10000)\n\npdf = (fnp.exp(-(fnp.log(x) - mu)**2 / (2 * sigma**2))\n       / (x * sigma * fnp.sqrt(2 * fnp.pi)))\n\nplt.plot(x, pdf, linewidth=2, color='r')\n\nplt.axis('tight')\n\nplt.show()\n\nb = []\n\nfor i in range(1000):\n   a = 10. + fnp.random.standard_normal(100)\n   b.append(fnp.prod(a))\n\nb = fnp.array(b) / fnp.min(b) # scale values to be positive\n\ncount, bins, ignored = plt.hist(b, 100, density=True, align='mid')\n\nsigma = fnp.std(fnp.log(b))\n\nmu = fnp.mean(fnp.log(b))\n\nx = fnp.linspace(min(bins), max(bins), 10000)\n\npdf = (fnp.exp(-(fnp.log(x) - mu)**2 / (2 * sigma**2))\n       / (x * sigma * fnp.sqrt(2 * fnp.pi)))\n\nplt.plot(x, pdf, color='r', linewidth=2)\n\nplt.show()",
    "output": "",
    "source": "derived"
  },
