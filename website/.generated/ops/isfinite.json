      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Not a Number, positive infinity and negative infinity are considered\nto be non-finite."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy uses the IEEE Standard for Binary Floating-Point for Arithmetic\n(IEEE 754). This means that Not a Number is not equivalent to infinity.\nAlso that positive infinity is not equivalent to negative infinity. But\ninfinity is equivalent to positive infinity.  Errors result if the\nsecond argument is also supplied when "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is a scalar input, or if\nfirst and second arguments have different shapes."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isfinite(1)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isfinite(0)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isfinite(fnp.nan)"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isfinite(fnp.inf)"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isfinite(-fnp.inf)"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isfinite([fnp.log(-1.),1.,fnp.log(0)])"
            },
            {
              "kind": "output",
              "text": "array([False,  True, False])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([-fnp.inf, 0., fnp.inf])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = fnp.array([2, 2, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isfinite(x, y)"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 0])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 0])"
            }
          ],
          "type": "doctest_block"
        }
      ],
