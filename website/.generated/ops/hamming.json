              "kind": "text",
              "text": "Return the Hamming window."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The Hamming window is a taper formed by using a weighted cosine."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
