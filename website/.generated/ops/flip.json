  "example": {
    "code": "import whest as we\n\nA = we.arange(8).reshape((2,2,2))\n\nA\n\nwe.flip(A, 0)\n\nwe.flip(A, 1)\n\nwe.flip(A)\n\nwe.flip(A, (0, 2))\n\nrng = we.random.default_rng()\n\nA = rng.normal(size=(3,4,5))\n\nwe.all(we.flip(A,2) == A[:,:,::-1,...])",
    "output": "array([[[0, 1],\n        [2, 3]],\n       [[4, 5],\n        [6, 7]]])\n\narray([[[4, 5],\n        [6, 7]],\n       [[0, 1],\n        [2, 3]]])\n\narray([[[2, 3],\n        [0, 1]],\n       [[6, 7],\n        [4, 5]]])\n\narray([[[7, 6],\n        [5, 4]],\n       [[3, 2],\n        [1, 0]]])\n\narray([[[5, 4],\n        [7, 6]],\n       [[1, 0],\n        [3, 2]]])\n\nTrue",
    "source": "derived"
  },
