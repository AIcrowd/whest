      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "flip(m, 0) is equivalent to flipud(m)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "flip(m, 1) is equivalent to fliplr(m)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "flip(m, n) corresponds to "
            },
            {
              "kind": "code",
              "text": "m[...,::-1,...]"
            },
            {
              "kind": "text",
              "text": " with "
            },
            {
              "kind": "code",
              "text": "::-1"
            },
            {
              "kind": "text",
              "text": " at position n."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "flip(m) corresponds to "
            },
            {
              "kind": "code",
              "text": "m[::-1,::-1,...,::-1]"
            },
            {
              "kind": "text",
              "text": " with "
            },
            {
              "kind": "code",
              "text": "::-1"
            },
            {
              "kind": "text",
              "text": " at all\npositions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "flip(m, (0, 1)) corresponds to "
            },
            {
              "kind": "code",
              "text": "m[::-1,::-1,...]"
            },
            {
              "kind": "text",
              "text": " with "
            },
            {
              "kind": "code",
              "text": "::-1"
            },
            {
              "kind": "text",
              "text": " at\nposition 0 and position 1."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = we.arange(8).reshape((2,2,2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A"
            },
            {
              "kind": "output",
              "text": "array([[[0, 1],"
            },
            {
              "kind": "output",
              "text": "        [2, 3]],"
            },
            {
              "kind": "output",
              "text": "       [[4, 5],"
            },
            {
              "kind": "output",
              "text": "        [6, 7]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.flip(A, 0)"
            },
            {
              "kind": "output",
              "text": "array([[[4, 5],"
            },
            {
              "kind": "output",
              "text": "        [6, 7]],"
            },
            {
              "kind": "output",
              "text": "       [[0, 1],"
            },
            {
              "kind": "output",
              "text": "        [2, 3]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.flip(A, 1)"
            },
            {
              "kind": "output",
              "text": "array([[[2, 3],"
            },
            {
              "kind": "output",
              "text": "        [0, 1]],"
            },
            {
              "kind": "output",
              "text": "       [[6, 7],"
            },
            {
              "kind": "output",
              "text": "        [4, 5]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.flip(A)"
            },
            {
              "kind": "output",
              "text": "array([[[7, 6],"
            },
            {
              "kind": "output",
              "text": "        [5, 4]],"
            },
            {
              "kind": "output",
              "text": "       [[3, 2],"
            },
            {
              "kind": "output",
              "text": "        [1, 0]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.flip(A, (0, 2))"
            },
            {
              "kind": "output",
              "text": "array([[[5, 4],"
            },
            {
              "kind": "output",
              "text": "        [7, 6]],"
            },
            {
              "kind": "output",
              "text": "       [[1, 0],"
            },
            {
              "kind": "output",
              "text": "        [3, 2]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = we.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = rng.normal(size=(3,4,5))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.all(we.flip(A,2) == A[:,:,::-1,...])"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
