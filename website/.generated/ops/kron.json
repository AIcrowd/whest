  "example": {
    "code": "import whest as we\n\nwe.kron([1,10,100], [5,6,7])\n\nwe.kron([5,6,7], [1,10,100])\n\nwe.kron(we.eye(2), we.ones((2,2)))\n\na = we.arange(100).reshape((2,5,2,5))\n\nb = we.arange(24).reshape((2,3,4))\n\nc = we.kron(a,b)\n\nc.shape\n\nI = (1,3,0,2)\n\nJ = (0,2,1)\n\nJ1 = (0,) + J             # extend to ndim=4\n\nS1 = (1,) + b.shape\n\nK = tuple(we.array(I) * we.array(S1) + we.array(J1))\n\nc[K] == a[I]*b[J]",
    "output": "array([  5,   6,   7, ..., 500, 600, 700])\n\narray([  5,  50, 500, ...,   7,  70, 700])\n\narray([[1.,  1.,  0.,  0.],\n       [1.,  1.,  0.,  0.],\n       [0.,  0.,  1.,  1.],\n       [0.,  0.,  1.,  1.]])\n\n(2, 10, 6, 20)\n\nTrue",
    "source": "derived"
  },
