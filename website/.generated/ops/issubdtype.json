    {
      "blocks": [
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/ops/issubdtype",
              "kind": "link",
              "target": "issubdtype",
              "text": "issubdtype"
            },
            {
              "kind": "text",
              "text": " can be used to check the type of arrays:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ints = fnp.array([1, 2, 3], dtype=fnp.int32)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(ints.dtype, fnp.integer)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(ints.dtype, fnp.floating)"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "floats = fnp.array([1, 2, 3], dtype=fnp.float32)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(floats.dtype, fnp.integer)"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(floats.dtype, fnp.floating)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Similar types of different sizes are not subdtypes of each other:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(fnp.float64, fnp.float32)"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(fnp.float32, fnp.float64)"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "but both are subtypes of "
            },
            {
              "kind": "code",
              "text": "floating"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(fnp.float64, fnp.floating)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype(fnp.float32, fnp.floating)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For convenience, dtype-like objects are allowed too:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype('S1', fnp.bytes_)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.issubdtype('i4', fnp.signedinteger)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
