{
  "aliases": [],
  "api_docs_html": "",
  "area": "linalg",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the condition number of a matrix."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function is capable of returning the condition number using\none of seven different norms, depending on the value of "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " (see\nParameters below)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The matrix whose condition number is sought."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "(..., M, N) array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "The matrix whose condition number is sought."
                }
              ],
              "name": "x",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Order of the norm used in the condition number computation:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "raw_kind": "table",
                  "raw_text": "\n\n\n\np\n\nnorm for matrices\n\nNone\n\n2-norm, computed directly using the SVD\n\n'fro'\n\nFrobenius norm\n\ninf\n\nmax(sum(abs(x), axis=1))\n\n-inf\n\nmin(sum(abs(x), axis=1))\n\n1\n\nmax(sum(abs(x), axis=0))\n\n-1\n\nmin(sum(abs(x), axis=0))\n\n2\n\n2-norm (largest sing. value)\n\n-2\n\nsmallest singular value",
                  "type": "raw_block"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "inf means the "
                    },
                    {
                      "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.inf.html",
                      "href": "",
                      "kind": "link",
                      "target": "inf",
                      "text": "we.inf"
                    },
                    {
                      "kind": "text",
                      "text": " object, and the Frobenius norm is\nthe root-of-sum-of-squares norm."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{None, 1, -1, 2, -2, inf, -inf, 'fro'}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Order of the norm used in the condition number computation:"
                }
              ],
              "name": "p",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The condition number of the matrix. May be infinite."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{float, inf}",
              "inline": [
                {
                  "kind": "text",
                  "text": "The condition number of the matrix. May be infinite."
                }
              ],
              "name": "c",
              "type": "field_list"
            }
          ],
          "title": "Returns",
          "type": "field_list"
        }
      ],
      "title": "Returns"
    },
    {
      "blocks": [
        {
          "links": [
            {
              "description": "",
              "description_inline": [],
              "external_url": "",
              "href": "/docs/api/ops/linalg-norm",
              "label": "we.linalg.norm",
              "original_target": "numpy.linalg.norm",
              "role": "",
              "target": "linalg.norm",
              "unresolved": false
            }
          ],
          "type": "link_list"
        }
      ],
      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The condition number of "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is defined as the norm of "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " times the\nnorm of the inverse of "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": "; the norm can be the usual L2-norm\n(root-of-sum-of-squares) or one of a number of other matrix norms."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nG. Strang, Linear Algebra and Its Applications, Orlando, FL,\nAcademic Press, Inc., 1980, pg. 285.",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from numpy import linalg as LA"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 0, -1], [0, 1, 0], [1, 0, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[ 1,  0, -1],"
            },
            {
              "kind": "output",
              "text": "       [ 0,  1,  0],"
            },
            {
              "kind": "output",
              "text": "       [ 1,  0,  1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a)"
            },
            {
              "kind": "output",
              "text": "1.4142135623730951"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a, 'fro')"
            },
            {
              "kind": "output",
              "text": "3.1622776601683795"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a, we.inf)"
            },
            {
              "kind": "output",
              "text": "2.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a, -we.inf)"
            },
            {
              "kind": "output",
              "text": "1.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a, 1)"
            },
            {
              "kind": "output",
              "text": "2.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a, -1)"
            },
            {
              "kind": "output",
              "text": "1.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a, 2)"
            },
            {
              "kind": "output",
              "text": "1.4142135623730951"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.cond(a, -2)"
            },
            {
              "kind": "output",
              "text": "0.70710678118654746 # may vary"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "(min(LA.svd(a, compute_uv=False)) *"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "min(LA.svd(LA.inv(a), compute_uv=False)))"
            },
            {
              "kind": "output",
              "text": "0.70710678118654746 # may vary"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
  "canonical_name": "linalg.cond",
