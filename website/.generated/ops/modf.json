          "inline": [
            {
              "kind": "text",
              "text": "Return the fractional and integral parts of an array, element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The fractional and integral parts are negative if the given number is\nnegative."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
