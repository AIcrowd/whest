      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Assume that the observations are in the columns of the observation\narray "
            },
            {
              "kind": "code",
              "text": "m"
            },
            {
              "kind": "text",
              "text": " and let "
            },
            {
              "kind": "code",
              "text": "f = fweights"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "a = aweights"
            },
            {
              "kind": "text",
              "text": " for brevity. The\nsteps to compute the weighted covariance are as follows:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": ">>> m = fnp.arange(10, dtype=fnp.float64)\n>>> f = fnp.arange(10) * 2\n>>> a = fnp.arange(10) ** 2.\n>>> ddof = 1\n>>> w = f * a\n>>> v1 = fnp.sum(w)\n>>> v2 = fnp.sum(w * a)\n>>> m -= fnp.sum(m * w, axis=None, keepdims=True) / v1\n>>> cov = fnp.dot(m * w, m.T) * v1 / (v1**2 - ddof * v2)",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that when "
            },
            {
              "kind": "code",
              "text": "a == 1"
            },
            {
              "kind": "text",
              "text": ", the normalization factor\n"
            },
            {
              "kind": "code",
              "text": "v1 / (v1**2 - ddof * v2)"
            },
            {
              "kind": "text",
              "text": " goes over to "
            },
            {
              "kind": "code",
              "text": "1 / (fnp.sum(f) - ddof)"
            },
            {
              "kind": "text",
              "text": "\nas it should."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Consider two variables, "
            },
            {
              "kind": "math",
              "latex": "x_0"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "math",
              "latex": "x_1"
            },
            {
              "kind": "text",
              "text": ", which\ncorrelate perfectly, but in opposite directions:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([[0, 2], [1, 1], [2, 0]]).T"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [2, 1, 0]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note how "
            },
            {
              "kind": "math",
              "latex": "x_0"
            },
            {
              "kind": "text",
              "text": " increases while "
            },
            {
              "kind": "math",
              "latex": "x_1"
            },
            {
              "kind": "text",
              "text": " decreases. The covariance\nmatrix shows this clearly:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.cov(x)"
            },
            {
              "kind": "output",
              "text": "array([[ 1., -1.],"
            },
            {
              "kind": "output",
              "text": "       [-1.,  1.]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that element "
            },
            {
              "kind": "math",
              "latex": "C_{0,1}"
            },
            {
              "kind": "text",
              "text": ", which shows the correlation between\n"
            },
            {
              "kind": "math",
              "latex": "x_0"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "math",
              "latex": "x_1"
            },
            {
              "kind": "text",
              "text": ", is negative."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Further, note how "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "y"
            },
            {
              "kind": "text",
              "text": " are combined:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = [-2.1, -1,  4.3]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = [3,  1.1,  0.12]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "X = fnp.stack((x, y), axis=0)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.cov(X)"
            },
            {
              "kind": "output",
              "text": "array([[11.71      , -4.286     ], # may vary"
            },
            {
              "kind": "output",
              "text": "       [-4.286     ,  2.144133]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.cov(x, y)"
            },
            {
              "kind": "output",
              "text": "array([[11.71      , -4.286     ], # may vary"
            },
            {
              "kind": "output",
              "text": "       [-4.286     ,  2.144133]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.cov(x)"
            },
            {
              "kind": "output",
              "text": "array(11.71)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
