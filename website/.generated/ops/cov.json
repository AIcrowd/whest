                      "text": "N"
                    },
                    {
                      "kind": "text",
                      "text": " is the\nnumber of observations given (unbiased estimate). If "
                    },
                    {
                      "kind": "code",
                      "text": "bias"
                    },
                    {
                      "kind": "text",
                      "text": " is True,\nthen normalization is by "
                    },
                    {
                      "kind": "code",
                      "text": "N"
                    },
                    {
                      "kind": "text",
                      "text": ". These values can be overridden by using\nthe keyword "
                    },
                    {
                      "kind": "code",
                      "text": "ddof"
                    },
                    {
                      "kind": "text",
                      "text": " in numpy versions >= 1.5."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
