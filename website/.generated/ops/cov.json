            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "1-D array of observation vector weights. These relative weights are\ntypically large for observations considered \"important\" and smaller for\nobservations considered less \"important\". If "
                    },
                    {
                      "kind": "code",
                      "text": "ddof=0"
                    },
                    {
                      "kind": "text",
                      "text": " the array of\nweights can be used to assign probabilities to observation vectors."
                    }
                  ],
                  "type": "paragraph"
                }
