  "example": {
    "code": "import whest as we\n\nwe.array([1, 2, 3])\n\nwe.array([1, 2, 3.0])\n\nwe.array([[1, 2], [3, 4]])\n\nwe.array([1, 2, 3], ndmin=2)\n\nwe.array([1, 2, 3], dtype=complex)\n\nx = we.array([(1,2),(3,4)],dtype=[('a','<i4'),('b','<i4')])\n\nx['a']\n\nwe.array(we.asmatrix('1 2; 3 4'))\n\nwe.array(we.asmatrix('1 2; 3 4'), subok=True)",
    "output": "array([1, 2, 3])\n\narray([ 1.,  2.,  3.])\n\narray([[1, 2],\n       [3, 4]])\n\narray([[1, 2, 3]])\n\narray([ 1.+0.j,  2.+0.j,  3.+0.j])\n\narray([1, 3], dtype=int32)\n\narray([[1, 2],\n       [3, 4]])\n\nmatrix([[1, 2],\n        [3, 4]])",
