    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array([1, 2, 3])"
            },
            {
              "kind": "output",
              "text": "array([1, 2, 3])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Upcasting:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array([1, 2, 3.0])"
            },
            {
              "kind": "output",
              "text": "array([ 1.,  2.,  3.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "More than one dimension:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array([[1, 2], [3, 4]])"
            },
            {
              "kind": "output",
              "text": "array([[1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Minimum dimensions 2:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array([1, 2, 3], ndmin=2)"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 3]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Type provided:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array([1, 2, 3], dtype=complex)"
            },
            {
              "kind": "output",
              "text": "array([ 1.+0.j,  2.+0.j,  3.+0.j])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Data-type consisting of more than one element:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([(1,2),(3,4)],dtype=[('a','<i4'),('b','<i4')])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x['a']"
            },
            {
              "kind": "output",
              "text": "array([1, 3], dtype=int32)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Creating an array from sub-classes:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array(we.asmatrix('1 2; 3 4'))"
            },
            {
              "kind": "output",
              "text": "array([[1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array(we.asmatrix('1 2; 3 4'), subok=True)"
            },
            {
              "kind": "output",
              "text": "matrix([[1, 2],"
            },
            {
              "kind": "output",
              "text": "        [3, 4]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
