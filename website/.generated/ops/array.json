  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Create an array."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "An array, any object exposing the array interface, an object whose\n"
                    },
                    {
                      "kind": "code",
                      "text": "__array__"
                    },
                    {
                      "kind": "text",
                      "text": " method returns an array, or any (nested) sequence.\nIf object is a scalar, a 0-dimensional array containing object is\nreturned."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "An array, any object exposing the array interface, an object whose\n"
                },
                {
                  "kind": "code",
                  "text": "__array__"
                },
                {
                  "kind": "text",
                  "text": " method returns an array, or any (nested) sequence.\nIf object is a scalar, a 0-dimensional array containing object is\nreturned."
                }
              ],
              "name": "object",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The desired data-type for the array. If not given, NumPy will try to use\na default "
                    },
                    {
                      "kind": "code",
                      "text": "dtype"
                    },
                    {
                      "kind": "text",
                      "text": " that can represent the values (by applying promotion\nrules when necessary.)"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "data-type, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The desired data-type for the array. If not given, NumPy will try to use\na default "
                },
                {
                  "kind": "code",
                  "text": "dtype"
                },
                {
                  "kind": "text",
                  "text": " that can represent the values (by applying promotion\nrules when necessary.)"
                }
              ],
              "name": "dtype",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "True"
                    },
                    {
                      "kind": "text",
                      "text": " (default), then the array data is copied. If "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": ",\na copy will only be made if "
                    },
                    {
                      "kind": "code",
                      "text": "__array__"
                    },
                    {
                      "kind": "text",
                      "text": " returns a copy, if obj is\na nested sequence, or if a copy is needed to satisfy any of the other\nrequirements ("
                    },
                    {
                      "kind": "code",
                      "text": "dtype"
                    },
                    {
                      "kind": "text",
                      "text": ", "
                    },
                    {
                      "kind": "code",
                      "text": "order"
                    },
                    {
                      "kind": "text",
                      "text": ", etc.). Note that any copy of\nthe data is shallow, i.e., for arrays with object dtype, the new\narray will point to the same objects. See Examples for "
                    },
                    {
                      "kind": "code",
                      "text": "ndarray.copy"
                    },
                    {
                      "kind": "text",
                      "text": ".\nFor "
                    },
                    {
                      "kind": "code",
                      "text": "False"
                    },
                    {
                      "kind": "text",
                      "text": " it raises a "
                    },
                    {
                      "kind": "code",
                      "text": "ValueError"
                    },
                    {
                      "kind": "text",
                      "text": " if a copy cannot be avoided.\nDefault: "
                    },
                    {
                      "kind": "code",
                      "text": "True"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If "
                },
                {
                  "kind": "code",
                  "text": "True"
                },
                {
                  "kind": "text",
                  "text": " (default), then the array data is copied. If "
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": ",\na copy will only be made if "
                },
                {
                  "kind": "code",
                  "text": "__array__"
                },
                {
                  "kind": "text",
                  "text": " returns a copy, if obj is\na nested sequence, or if a copy is needed to satisfy any of the other\nrequirements ("
                },
                {
                  "kind": "code",
                  "text": "dtype"
                },
                {
                  "kind": "text",
                  "text": ", "
                },
                {
                  "kind": "code",
                  "text": "order"
                },
                {
                  "kind": "text",
                  "text": ", etc.). Note that any copy of\nthe data is shallow, i.e., for arrays with object dtype, the new\narray will point to the same objects. See Examples for "
                },
                {
                  "kind": "code",
                  "text": "ndarray.copy"
                },
                {
                  "kind": "text",
                  "text": ".\nFor "
                },
                {
                  "kind": "code",
                  "text": "False"
                },
                {
                  "kind": "text",
                  "text": " it raises a "
                },
                {
                  "kind": "code",
                  "text": "ValueError"
                },
                {
                  "kind": "text",
                  "text": " if a copy cannot be avoided.\nDefault: "
                },
                {
                  "kind": "code",
                  "text": "True"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "copy",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Specify the memory layout of the array. If object is not an array, the\nnewly created array will be in C order (row major) unless 'F' is\nspecified, in which case it will be in Fortran order (column major).\nIf object is an array the following holds."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "raw_kind": "table",
                  "raw_text": "\n\n\n\n\n\norder\n\nno copy\n\ncopy=True\n\n'K'\n\nunchanged\n\nF & C order preserved, otherwise most similar order\n\n'A'\n\nunchanged\n\nF order if input is F and not C, otherwise C order\n\n'C'\n\nC order\n\nC order\n\n'F'\n\nF order\n\nF order",
                  "type": "raw_block"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "When "
                    },
                    {
                      "kind": "code",
                      "text": "copy=None"
                    },
                    {
                      "kind": "text",
                      "text": " and a copy is made for other reasons, the result is\nthe same as if "
                    },
                    {
                      "kind": "code",
                      "text": "copy=True"
                    },
                    {
                      "kind": "text",
                      "text": ", with some exceptions for 'A', see the\nNotes section. The default order is 'K'."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{'K', 'A', 'C', 'F'}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Specify the memory layout of the array. If object is not an array, the\nnewly created array will be in C order (row major) unless 'F' is\nspecified, in which case it will be in Fortran order (column major).\nIf object is an array the following holds."
                }
              ],
              "name": "order",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If True, then sub-classes will be passed-through, otherwise\nthe returned array will be forced to be a base-class array (default)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If True, then sub-classes will be passed-through, otherwise\nthe returned array will be forced to be a base-class array (default)."
                }
              ],
              "name": "subok",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Specifies the minimum number of dimensions that the resulting\narray should have.  Ones will be prepended to the shape as\nneeded to meet this requirement."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Specifies the minimum number of dimensions that the resulting\narray should have.  Ones will be prepended to the shape as\nneeded to meet this requirement."
                }
              ],
              "name": "ndmin",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as "
                    },
                    {
                      "kind": "code",
                      "text": "like"
                    },
                    {
                      "kind": "text",
                      "text": " supports\nthe "
                    },
                    {
                      "kind": "code",
                      "text": "__array_function__"
                    },
                    {
                      "kind": "text",
                      "text": " protocol, the result will be defined\nby it. In this case, it ensures the creation of an array object\ncompatible with that passed in via this argument."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "versionadded",
                  "options": [],
                  "raw_source": ".. versionadded:: 1.20.0",
                  "supported": true,
                  "type": "directive_block",
                  "version": "1.20.0"
                }
              ],
              "data_type": "array_like, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as "
                },
                {
                  "kind": "code",
                  "text": "like"
