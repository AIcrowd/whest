    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "A real world example: Assume a company has 10000 customer support\nagents and the average time between customer calls is 4 minutes."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "n = 10000"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "time_between_calls = we.random.default_rng().exponential(scale=4, size=n)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "What is the probability that a customer will call in the next\n4 to 5 minutes?"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = ((time_between_calls < 5).sum())/n"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = ((time_between_calls < 4).sum())/n"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x-y"
            },
            {
              "kind": "output",
              "text": "0.08 # may vary"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
