              "kind": "output",
              "text": "2.1923875335537315 # random"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = rng.standard_normal(8000)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s"
            },
            {
              "kind": "output",
              "text": "array([ 0.6888893 ,  0.78096262, -0.89086505, ...,  0.49876311,  # random"
            },
            {
              "kind": "output",
              "text": "       -0.38672696, -0.4685006 ])                                # random"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s.shape"
            },
            {
              "kind": "output",
              "text": "(8000,)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = rng.standard_normal(size=(3, 4, 2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s.shape"
            },
            {
              "kind": "output",
              "text": "(3, 4, 2)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Two-by-four array of samples from the normal distribution with\nmean 3 and standard deviation 2.5:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "3 + 2.5 * rng.standard_normal(size=(2, 4))"
            },
            {
              "kind": "output",
              "text": "array([[-4.49401501,  4.00950034, -1.81814867,  7.29718677],   # random"
            },
            {
              "kind": "output",
              "text": "       [ 0.39924804,  4.68456316,  4.99394529,  4.84057254]])  # random"
            }
          ],
          "type": "doctest_block"
        }
      ],
