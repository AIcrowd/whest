  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the Heaviside step function."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The Heaviside step function "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": " is defined as:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "                      0   if x1 < 0\nheaviside(x1, x2) =  x2   if x1 == 0\n                      1   if x1 > 0",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "code",
              "text": "x2"
            },
            {
              "kind": "text",
              "text": " is often taken to be 0.5, but 0 and 1 are also sometimes used."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input values."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input values."
                }
              ],
              "name": "x1",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The value of the function when x1 is 0.\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "x1.shape != x2.shape"
                    },
                    {
                      "kind": "text",
                      "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "The value of the function when x1 is 0.\nIf "
                },
                {
                  "kind": "code",
                  "text": "x1.shape != x2.shape"
                },
                {
                  "kind": "text",
                  "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                }
              ],
              "name": "x2",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, None, or tuple of ndarray and None, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                }
              ],
              "name": "out",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array will be set to the ufunc result.\nElsewhere, the "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array will retain its original value.\nNote that if an uninitialized "
