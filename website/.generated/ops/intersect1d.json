  "example": {
    "code": "import whest as we\n\nwe.intersect1d([1, 3, 4, 3], [3, 1, 2, 1])\n\nfrom functools import reduce\n\nreduce(we.intersect1d, ([1, 3, 4, 3], [3, 1, 2, 1], [6, 3, 4, 2]))\n\nx = we.array([1, 1, 2, 3, 4])\n\ny = we.array([2, 1, 4, 6])\n\nxy, x_ind, y_ind = we.intersect1d(x, y, return_indices=True)\n\nx_ind, y_ind\n\nxy, x[x_ind], y[y_ind]",
    "output": "array([1, 3])\n\narray([3])\n\n(array([0, 2, 4]), array([1, 0, 2]))\n\n(array([1, 2, 4]), array([1, 2, 4]), array([1, 2, 4]))",
