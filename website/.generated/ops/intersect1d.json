              "name": "ar1, ar2",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If True, the input arrays are both assumed to be unique, which\ncan speed up the calculation.  If True but "
                    },
                    {
                      "kind": "code",
                      "text": "ar1"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "ar2"
                    },
                    {
                      "kind": "text",
                      "text": " are not\nunique, incorrect results and out-of-bounds indices could result.\nDefault is False."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool",
              "inline": [
