    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "iterable = (x*x for x in range(5))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.fromiter(iterable, float)"
            },
            {
              "kind": "output",
              "text": "array([  0.,   1.,   4.,   9.,  16.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "A carefully constructed subarray dtype will lead to higher dimensional\nresults:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "iterable = ((x+1, x+2) for x in range(5))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.fromiter(iterable, dtype=fnp.dtype((int, 2)))"
            },
            {
              "kind": "output",
              "text": "array([[1, 2],"
            },
            {
              "kind": "output",
              "text": "       [2, 3],"
            },
            {
              "kind": "output",
              "text": "       [3, 4],"
            },
            {
              "kind": "output",
              "text": "       [4, 5],"
            },
            {
              "kind": "output",
              "text": "       [5, 6]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
