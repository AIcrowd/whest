          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Get the projected size along a given normal for an array of vectors."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "v = fnp.array([[0., 5., 0.], [0., 0., 10.], [0., 6., 8.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "n = fnp.array([0., 0.6, 0.8])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.vecdot(v, n)"
            },
            {
              "kind": "output",
              "text": "array([ 3.,  8., 10.])"
            }
          ],
          "type": "doctest_block"
        }
