      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Vector dot product of two arrays."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Let "
            },
            {
              "kind": "math",
              "latex": "\\mathbf{a}"
            },
            {
              "kind": "text",
              "text": " be a vector in "
            },
            {
              "kind": "code",
              "text": "x1"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "math",
              "latex": "\\mathbf{b}"
            },
            {
              "kind": "text",
              "text": " be\na corresponding vector in "
            },
            {
              "kind": "code",
              "text": "x2"
            },
            {
              "kind": "text",
              "text": ". The dot product is defined as:"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "\\mathbf{a} \\cdot \\mathbf{b} = \\sum_{i=0}^{n-1} \\overline{a_i}b_i"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where the sum is over the last dimension (unless "
            },
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": " is specified) and\nwhere "
            },
            {
              "kind": "math",
              "latex": "\\overline{a_i}"
            },
            {
              "kind": "text",
              "text": " denotes the complex conjugate if "
            },
            {
              "kind": "math",
              "latex": "a_i"
            },
            {
              "kind": "text",
              "text": "\nis complex and the identity otherwise."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionadded",
          "options": [],
          "raw_source": ".. versionadded:: 2.0.0",
          "supported": true,
          "type": "directive_block",
          "version": "2.0.0"
        }
      ],
      "title": "Extended Summary"
    },
