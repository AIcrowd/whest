          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from a Gamma distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Samples are drawn from a Gamma distribution with specified parameters,\n"
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/shape",
              "kind": "link",
              "target": "shape",
              "text": "shape"
            },
            {
              "kind": "text",
              "text": " (sometimes designated \"k\") and "
            },
            {
              "kind": "code",
              "text": "scale"
            },
            {
              "kind": "text",
              "text": " (sometimes designated\n\"theta\"), where both parameters are > 0."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "New code should use the "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.gamma.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator.gamma",
                  "text": "gamma"
                },
                {
                  "kind": "text",
                  "text": "\nmethod of a "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator",
                  "text": "Generator"
                },
                {
                  "kind": "text",
                  "text": " instance instead;\nplease see the "
                },
                {
                  "display_text": "random-quick-start",
                  "explicit_title": false,
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "random-quick-start",
                  "role": "ref",
                  "suppress_link": false,
                  "target": "random-quick-start",
                  "unresolved": false
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n    New code should use the `~we.random.Generator.gamma`\n    method of a `~we.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
          "supported": true,
          "type": "directive_block"
        }
      ],
      "title": "Extended Summary"
    },
