          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The shape of the gamma distribution. Must be non-negative."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "The shape of the gamma distribution. Must be non-negative."
                }
              ],
              "name": "shape",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The scale of the gamma distribution. Must be non-negative.\nDefault is equal to 1."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The scale of the gamma distribution. Must be non-negative.\nDefault is equal to 1."
                }
              ],
              "name": "scale",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "external_url": "",
                      "href": "/docs/api/ops/shape",
                      "kind": "link",
                      "target": "shape",
                      "text": "shape"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "scale"
                    },
                    {
                      "kind": "text",
                      "text": " are both scalars.\nOtherwise, "
                    },
                    {
                      "kind": "code",
                      "text": "we.broadcast(shape, scale).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
