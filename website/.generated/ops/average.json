          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Return the average along the specified axis. When "
                    },
                    {
                      "kind": "code",
                      "text": "returned"
                    },
                    {
                      "kind": "text",
                      "text": " is "
                    },
                    {
                      "kind": "code",
                      "text": "True"
                    },
                    {
                      "kind": "text",
                      "text": ",\nreturn a tuple with the average as the first element and the sum\nof the weights as the second element. "
                    },
                    {
                      "kind": "code",
                      "text": "sum_of_weights"
                    },
                    {
                      "kind": "text",
                      "text": " is of the\nsame type as "
                    },
                    {
                      "kind": "code",
                      "text": "retval"
                    },
                    {
                      "kind": "text",
                      "text": ". The result dtype follows a general pattern.\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "weights"
                    },
                    {
                      "kind": "text",
                      "text": " is None, the result dtype will be that of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " , or "
                    },
                    {
                      "kind": "code",
                      "text": "float64"
                    },
                    {
                      "kind": "text",
                      "text": "\nif "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is integral. Otherwise, if "
                    },
                    {
                      "kind": "code",
                      "text": "weights"
                    },
                    {
                      "kind": "text",
                      "text": " is not None and "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is non-\nintegral, the result type will be the type of lowest precision capable of\nrepresenting values of both "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "weights"
                    },
                    {
                      "kind": "text",
                      "text": ". If "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " happens to be\nintegral, the previous rules still applies but the result dtype will\nat least be "
                    },
                    {
                      "kind": "code",
                      "text": "float64"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
