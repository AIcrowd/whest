  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return minimum of an array or minimum along an axis, ignoring any NaNs. When all-NaN slices are encountered a "
            },
            {
              "kind": "code",
              "text": "RuntimeWarning"
            },
            {
              "kind": "text",
              "text": " is raised and Nan is returned for that slice."
            }
          ],
          "type": "paragraph"
        }
      ],
