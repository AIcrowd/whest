      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy uses the IEEE Standard for Binary Floating-Point for Arithmetic\n(IEEE 754). This means that Not a Number is not equivalent to infinity.\nPositive infinity is treated as a very large number and negative\ninfinity is treated as a very small (i.e. negative) number."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If the input has a integer type the function is equivalent to we.min."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 2], [3, we.nan]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmin(a)"
            },
            {
              "kind": "output",
              "text": "1.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmin(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([1.,  2.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmin(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([1.,  3.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When positive infinity and negative infinity are present:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmin([1, 2, we.nan, we.inf])"
            },
            {
              "kind": "output",
              "text": "1.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmin([1, 2, we.nan, -we.inf])"
            },
            {
              "kind": "output",
              "text": "-inf"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
