      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function computes the one-dimensional "
            },
            {
              "kind": "emphasis",
              "text": "n"
            },
            {
              "kind": "text",
              "text": "-point discrete Fourier\nTransform (DFT) with the efficient Fast Fourier Transform (FFT)\nalgorithm [CT]."
            }
          ],
          "type": "paragraph"
        }
      ],
