      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the roots of a polynomial with coefficients given in p."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "This forms part of the old polynomial API. Since version 1.4, the\nnew polynomial API defined in "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.polynomial.html",
                  "href": "",
                  "kind": "link",
                  "target": "polynomial",
                  "text": "fnp.polynomial"
                },
                {
                  "kind": "text",
                  "text": " is preferred.\nA summary of the differences can be found in the\n"
                },
                {
                  "display_text": "transition guide",
                  "explicit_title": true,
                  "external_url": "",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "/reference/routines.polynomials",
                  "role": "doc",
                  "suppress_link": false,
                  "target": "/reference/routines.polynomials",
                  "unresolved": true
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n   This forms part of the old polynomial API. Since version 1.4, the\n   new polynomial API defined in `fnp.polynomial` is preferred.\n   A summary of the differences can be found in the\n   :doc:`transition guide </reference/routines.polynomials>`.",
          "supported": true,
          "type": "directive_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The values in the rank-1 array "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " are coefficients of a polynomial.\nIf the length of "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " is n+1 then the polynomial is described by:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "p[0] * x**n + p[1] * x**(n-1) + ... + p[n-1]*x + p[n]",
          "type": "literal_block"
        }
      ],
