      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Main difference between "
            },
            {
              "kind": "code",
              "text": "eigvals"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "eig"
            },
            {
              "kind": "text",
              "text": ": the eigenvectors aren't\nreturned."
            }
          ],
          "type": "paragraph"
        }
      ],
