  "example": {
    "code": "import flopscope as fnp\n\nfrom numpy import linalg as LA\n\nx = fnp.random.random()\n\nQ = fnp.array([[fnp.cos(x), -fnp.sin(x)], [fnp.sin(x), fnp.cos(x)]])\n\nLA.norm(Q[0, :]), LA.norm(Q[1, :]), fnp.dot(Q[0, :],Q[1, :])\n\nD = fnp.diag((-1,1))\n\nLA.eigvals(D)\n\nA = fnp.dot(Q, D)\n\nA = fnp.dot(A, Q.T)\n\nLA.eigvals(A)",
    "output": "(1.0, 1.0, 0.0)\n\narray([-1.,  1.])\n\narray([ 1., -1.]) # random",
    "source": "derived"
  },
