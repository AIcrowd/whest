          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1,2,3], [4,5,6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.cumsum(a)"
            },
            {
              "kind": "output",
              "text": "array([ 1,  3,  6, 10, 15, 21])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.cumsum(a, dtype=float)     # specifies type of output value(s)"
            },
            {
              "kind": "output",
              "text": "array([  1.,   3.,   6.,  10.,  15.,  21.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.cumsum(a,axis=0)      # sum over rows for each of the 3 columns"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 3],"
            },
            {
              "kind": "output",
              "text": "       [5, 7, 9]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.cumsum(a,axis=1)      # sum over columns for each of the 2 rows"
            },
            {
              "kind": "output",
              "text": "array([[ 1,  3,  6],"
            },
            {
              "kind": "output",
              "text": "       [ 4,  9, 15]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "cumsum(b)[-1]"
            },
            {
              "kind": "text",
              "text": " may not be equal to "
            },
            {
              "kind": "code",
              "text": "sum(b)"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([1, 2e-9, 3e-9] * 1000000)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b.cumsum()[-1]"
            },
            {
              "kind": "output",
              "text": "1000000.0050045159"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b.sum()"
            },
            {
              "kind": "output",
              "text": "1000000.0050000029"
            }
          ],
          "type": "doctest_block"
        }
      ],
