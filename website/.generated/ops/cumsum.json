  "example": {
    "code": "import whest as we\n\na = we.array([[1,2,3], [4,5,6]])\n\na\n\nwe.cumsum(a)\n\nwe.cumsum(a, dtype=float)     # specifies type of output value(s)\n\nwe.cumsum(a,axis=0)      # sum over rows for each of the 3 columns\n\nwe.cumsum(a,axis=1)      # sum over columns for each of the 2 rows\n\nb = we.array([1, 2e-9, 3e-9] * 1000000)\n\nb.cumsum()[-1]\n\nb.sum()",
    "output": "array([[1, 2, 3],\n       [4, 5, 6]])\n\narray([ 1,  3,  6, 10, 15, 21])\n\narray([  1.,   3.,   6.,  10.,  15.,  21.])\n\narray([[1, 2, 3],\n       [5, 7, 9]])\n\narray([[ 1,  3,  6],\n       [ 4,  9, 15]])\n\n1000000.0050045159\n\n1000000.0050000029",
