    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The derivative of the polynomial "
            },
            {
              "kind": "math",
              "latex": "x^3 + x^2 + x^1 + 1"
            },
            {
              "kind": "text",
              "text": " is:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p = we.poly1d([1,1,1,1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p2 = we.polyder(p)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p2"
            },
            {
              "kind": "output",
              "text": "poly1d([3, 2, 1])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "which evaluates to:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p2(2.)"
            },
            {
              "kind": "output",
              "text": "17.0"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "We can verify this, approximating the derivative with\n"
            },
            {
              "kind": "code",
              "text": "(f(x + h) - f(x))/h"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "(p(2. + 0.001) - p(2.)) / 0.001"
            },
            {
              "kind": "output",
              "text": "17.007000999997857"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The fourth-order derivative of a 3rd-order polynomial is zero:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.polyder(p, 2)"
            },
            {
              "kind": "output",
              "text": "poly1d([6, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.polyder(p, 3)"
            },
            {
              "kind": "output",
              "text": "poly1d([6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.polyder(p, 4)"
            },
            {
              "kind": "output",
              "text": "poly1d([0])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
