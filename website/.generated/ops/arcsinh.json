    {
      "blocks": [
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/ops/arcsinh",
              "kind": "link",
              "target": "arcsinh",
              "text": "arcsinh"
            },
            {
              "kind": "text",
              "text": " is a multivalued function: for each "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " there are infinitely\nmany numbers "
            },
            {
              "kind": "code",
              "text": "z"
            },
            {
              "kind": "text",
              "text": " such that "
            },
            {
              "kind": "code",
              "text": "sinh(z) = x"
            },
            {
              "kind": "text",
              "text": ". The convention is to return the\n"
            },
            {
              "kind": "code",
              "text": "z"
            },
            {
              "kind": "text",
              "text": " whose imaginary part lies in "
            },
            {
              "kind": "code",
              "text": "[-pi/2, pi/2]"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For real-valued input data types, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/arcsinh",
              "kind": "link",
              "target": "arcsinh",
              "text": "arcsinh"
            },
            {
              "kind": "text",
              "text": " always returns real output.\nFor each value that cannot be expressed as a real number or infinity, it\nreturns "
            },
            {
              "kind": "code",
              "text": "nan"
            },
            {
              "kind": "text",
              "text": " and sets the "
            },
            {
              "kind": "code",
              "text": "invalid"
            },
            {
              "kind": "text",
              "text": " floating point error flag."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For complex-valued input, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/arcsinh",
              "kind": "link",
              "target": "arcsinh",
              "text": "arcsinh"
            },
            {
              "kind": "text",
              "text": " is a complex analytical function that\nhas branch cuts "
            },
            {
              "kind": "code",
              "text": "[1j, infj]"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "[-1j, -infj]"
            },
            {
              "kind": "text",
              "text": " and is continuous from\nthe right on the former and from the left on the latter."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The inverse hyperbolic sine is also known as "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/arcsinh",
              "kind": "link",
              "target": "arcsinh",
              "text": "asinh"
            },
            {
              "kind": "text",
              "text": " or "
            },
            {
              "kind": "code",
              "text": "sinh^-1"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
