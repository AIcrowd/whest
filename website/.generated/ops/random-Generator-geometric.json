    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nWikipedia, \"Geometric distribution\",\nhttps://en.wikipedia.org/wiki/Geometric_distribution",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw 10,000 values from the geometric distribution, with the\nprobability of an individual success equal to "
            },
            {
              "kind": "code",
              "text": "p = 0.35"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p, size = 0.35, 10000"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = flops.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sample = rng.geometric(p=p, size=size)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "What proportion of trials succeeded after a single run?"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "(sample == 1).sum()/size"
            },
            {
              "kind": "output",
              "text": "0.34889999999999999  # may vary"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The geometric distribution with "
            },
            {
              "kind": "code",
              "text": "p=0.35"
            },
            {
              "kind": "text",
              "text": " looks as follows:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "count, bins, _ = plt.hist(sample, bins=30, density=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(bins, (1-p)**(bins-1)*p)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.xlim([0, 25])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
