  "area": "random",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from the geometric distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Bernoulli trials are experiments with one of two outcomes:\nsuccess or failure (an example of such an experiment is flipping\na coin).  The geometric distribution models the number of trials\nthat must be run in order to achieve success.  It is therefore\nsupported on the positive integers, "
            },
            {
              "kind": "code",
              "text": "k = 1, 2, ..."
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The probability mass function of the geometric distribution is"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "f(k) = (1 - p)^{k - 1} p"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " is the probability of success of an individual trial."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The probability of success of an individual trial."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "The probability of success of an individual trial."
                }
              ],
              "name": "p",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "p"
                    },
                    {
                      "kind": "text",
                      "text": " is a scalar.  Otherwise,\n"
                    },
                    {
                      "kind": "code",
                      "text": "flops.array(p).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Output shape.  If the given shape is, e.g., "
                },
                {
                  "kind": "code",
                  "text": "(m, n, k)"
                },
                {
                  "kind": "text",
                  "text": ", then\n"
                },
                {
                  "kind": "code",
                  "text": "m * n * k"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn.  If size is "
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": " (default),\na single value is returned if "
                },
                {
                  "kind": "code",
                  "text": "p"
                },
                {
                  "kind": "text",
                  "text": " is a scalar.  Otherwise,\n"
                },
                {
                  "kind": "code",
                  "text": "flops.array(p).size"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn."
                }
              ],
              "name": "size",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
