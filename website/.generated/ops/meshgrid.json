  "example": {
    "code": "import flopscope as fnp\n\nnx, ny = (3, 2)\n\nx = fnp.linspace(0, 1, nx)\n\ny = fnp.linspace(0, 1, ny)\n\nxv, yv = fnp.meshgrid(x, y)\n\nxv\n\nyv\n\nimport matplotlib.pyplot as plt\n\nplt.plot(xv, yv, marker='o', color='k', linestyle='none')\n\nplt.show()\n\nxv, yv = fnp.meshgrid(x, y, sparse=True)\n\nxv\n\nyv\n\nx = fnp.linspace(-5, 5, 101)\n\ny = fnp.linspace(-5, 5, 101)\n\nxx, yy = fnp.meshgrid(x, y)\n\nzz = fnp.sqrt(xx**2 + yy**2)\n\nxx.shape, yy.shape, zz.shape\n\nxs, ys = fnp.meshgrid(x, y, sparse=True)\n\nzs = fnp.sqrt(xs**2 + ys**2)\n\nxs.shape, ys.shape, zs.shape\n\nfnp.array_equal(zz, zs)\n\nh = plt.contourf(x, y, zs)\n\nplt.axis('scaled')\n\nplt.colorbar()\n\nplt.show()",
    "output": "array([[0. , 0.5, 1. ],\n       [0. , 0.5, 1. ]])\n\narray([[0.,  0.,  0.],\n       [1.,  1.,  1.]])\n\narray([[0. ,  0.5,  1. ]])\n\narray([[0.],\n       [1.]])\n\n((101, 101), (101, 101), (101, 101))\n\n((1, 101), (101, 1), (101, 101))\n\nTrue",
    "source": "derived"
  },
