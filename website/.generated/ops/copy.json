    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This is equivalent to:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.array(a, copy=True)  #doctest: +SKIP"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The copy made of the data is shallow, i.e., for arrays with object dtype,\nthe new array will point to the same objects.\nSee Examples from "
            },
            {
              "kind": "code",
              "text": "ndarray.copy"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Create an array x, with a reference y and a copy z:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = x"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "z = fnp.copy(x)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that, when we modify x, y changes, but not z:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x[0] = 10"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x[0] == y[0]"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x[0] == z[0]"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that, fnp.copy clears previously set WRITEABLE=False flag."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a.flags[\"WRITEABLE\"] = False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = fnp.copy(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b.flags[\"WRITEABLE\"]"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b[0] = 3"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([3, 2, 3])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
