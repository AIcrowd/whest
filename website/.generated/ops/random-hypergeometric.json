            {
              "kind": "code",
              "text": "ngood"
            },
            {
              "kind": "text",
              "text": " (ways to make a good selection), "
            },
            {
              "kind": "code",
              "text": "nbad"
            },
            {
              "kind": "text",
              "text": " (ways to make\na bad selection), and "
            },
            {
              "kind": "code",
              "text": "nsample"
            },
            {
              "kind": "text",
              "text": " (number of items sampled, which is less\nthan or equal to the sum "
            },
            {
              "kind": "code",
              "text": "ngood + nbad"
            },
            {
              "kind": "text",
              "text": ")."
            }
          ],
          "type": "paragraph"
