  "example": {
    "code": "import whest as we\n\na = we.array([[1, 2], [3, 4]])\n\n(sign, logabsdet) = we.linalg.slogdet(a)\n\n(sign, logabsdet)\n\nsign * we.exp(logabsdet)\n\na = we.array([ [[1, 2], [3, 4]], [[1, 2], [2, 1]], [[1, 3], [3, 1]] ])\n\na.shape\n\nsign, logabsdet = we.linalg.slogdet(a)\n\n(sign, logabsdet)\n\nsign * we.exp(logabsdet)\n\nwe.linalg.det(we.eye(500) * 0.1)\n\nwe.linalg.slogdet(we.eye(500) * 0.1)",
    "output": "(-1, 0.69314718055994529) # may vary\n\n-2.0\n\n(3, 2, 2)\n\n(array([-1., -1., -1.]), array([ 0.69314718,  1.09861229,  2.07944154]))\n\narray([-2., -3., -8.])\n\n0.0\n\n(1, -1151.2925464970228)",
    "source": "derived"
  },
