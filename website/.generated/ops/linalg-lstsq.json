  "area": "linalg",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the least-squares solution to a linear matrix equation."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Computes the vector "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " that approximately solves the equation\n"
            },
            {
              "kind": "code",
              "text": "a @ x = b"
            },
            {
              "kind": "text",
              "text": ". The equation may be under-, well-, or over-determined\n(i.e., the number of linearly independent rows of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " can be less than,\nequal to, or greater than its number of linearly independent columns).\nIf "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " is square and of full rank, then "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " (but for round-off error)\nis the \"exact\" solution of the equation. Else, "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " minimizes the\nEuclidean 2-norm "
            },
            {
              "kind": "math",
              "latex": "||b - ax||"
            },
            {
              "kind": "text",
              "text": ". If there are multiple minimizing\nsolutions, the one with the smallest 2-norm "
            },
            {
              "kind": "math",
              "latex": "||x||"
            },
            {
              "kind": "text",
              "text": " is returned."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
