      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Fit a line, "
            },
            {
              "kind": "code",
              "text": "y = mx + c"
            },
            {
              "kind": "text",
              "text": ", through some noisy data-points:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([0, 1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([-1, 0.2, 0.9, 2.1])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "By examining the coefficients, we see that the line should have a\ngradient of roughly 1 and cut the y-axis at, more or less, -1."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "We can rewrite the line equation as "
            },
            {
              "kind": "code",
              "text": "y = Ap"
            },
            {
              "kind": "text",
              "text": ", where "
            },
            {
              "kind": "code",
              "text": "A = [[x 1]]"
            },
            {
              "kind": "text",
              "text": "\nand "
            },
            {
              "kind": "code",
              "text": "p = [[m], [c]]"
            },
            {
              "kind": "text",
              "text": ".  Now use "
            },
            {
              "kind": "code",
              "text": "lstsq"
            },
            {
              "kind": "text",
              "text": " to solve for "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = we.vstack([x, we.ones(len(x))]).T"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A"
            },
            {
              "kind": "output",
              "text": "array([[ 0.,  1.],"
            },
            {
              "kind": "output",
              "text": "       [ 1.,  1.],"
            },
            {
              "kind": "output",
              "text": "       [ 2.,  1.],"
            },
            {
              "kind": "output",
              "text": "       [ 3.,  1.]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "m, c = we.linalg.lstsq(A, y)[0]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "m, c"
            },
            {
              "kind": "output",
              "text": "(1.0 -0.95) # may vary"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Plot the data along with the fitted line:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "_ = plt.plot(x, y, 'o', label='Original data', markersize=10)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "_ = plt.plot(x, m*x + c, 'r', label='Fitted line')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "_ = plt.legend()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
