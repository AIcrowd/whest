            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Cut-off ratio for small singular values of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": ".\nFor the purposes of rank determination, singular values are treated\nas zero if they are smaller than "
                    },
