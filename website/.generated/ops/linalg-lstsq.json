  "example": {
    "code": "import whest as we\n\nx = we.array([0, 1, 2, 3])\n\ny = we.array([-1, 0.2, 0.9, 2.1])\n\nA = we.vstack([x, we.ones(len(x))]).T\n\nA\n\nm, c = we.linalg.lstsq(A, y)[0]\n\nm, c\n\nimport matplotlib.pyplot as plt\n\n_ = plt.plot(x, y, 'o', label='Original data', markersize=10)\n\n_ = plt.plot(x, m*x + c, 'r', label='Fitted line')\n\n_ = plt.legend()\n\nplt.show()",
    "output": "array([[ 0.,  1.],\n       [ 1.,  1.],\n       [ 2.,  1.],\n       [ 3.,  1.]])\n\n(1.0 -0.95) # may vary",
