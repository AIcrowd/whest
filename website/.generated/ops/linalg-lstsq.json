                    },
                    {
                      "kind": "text",
                      "text": " times the largest singular\nvalue of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": ".\nThe default uses the machine precision times "
                    },
                    {
                      "kind": "code",
                      "text": "max(M, N)"
                    },
                    {
                      "kind": "text",
                      "text": ".  Passing\n"
                    },
                    {
                      "kind": "code",
                      "text": "-1"
                    },
