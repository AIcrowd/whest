  "example": {
    "code": "import whest as we\n\nx = we.array([3, 1, 2])\n\nwe.argsort(x)\n\nx = we.array([[0, 3], [2, 2]])\n\nx\n\nind = we.argsort(x, axis=0)  # sorts along first axis (down)\n\nind\n\nwe.take_along_axis(x, ind, axis=0)  # same as we.sort(x, axis=0)\n\nind = we.argsort(x, axis=1)  # sorts along last axis (across)\n\nind\n\nwe.take_along_axis(x, ind, axis=1)  # same as we.sort(x, axis=1)\n\nind = we.unravel_index(we.argsort(x, axis=None), x.shape)\n\nind\n\nx[ind]  # same as we.sort(x, axis=None)\n\nx = we.array([(1, 0), (0, 1)], dtype=[('x', '<i4'), ('y', '<i4')])\n\nx\n\nwe.argsort(x, order=('x','y'))\n\nwe.argsort(x, order=('y','x'))",
    "output": "array([1, 2, 0])\n\narray([[0, 3],\n       [2, 2]])\n\narray([[0, 1],\n       [1, 0]])\n\narray([[0, 2],\n       [2, 3]])\n\narray([[0, 1],\n       [0, 1]])\n\narray([[0, 3],\n       [2, 2]])\n\n(array([0, 1, 1, 0]), array([0, 0, 1, 1]))\n\narray([0, 2, 2, 3])\n\narray([(1, 0), (0, 1)],\n      dtype=[('x', '<i4'), ('y', '<i4')])\n\narray([1, 0])\n\narray([0, 1])",
    "source": "derived"
  },
  "href": "/docs/api/ops/argsort/",
  "module": "numpy",
  "name": "argsort",
