                    },
                    {
                      "kind": "text",
                      "text": ", the returned array will maintain\nthe relative order of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " values which compare as equal.\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "False"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": ", this is not guaranteed. Internally,\nthis option selects "
                    },
                    {
                      "kind": "code",
                      "text": "kind='stable'"
                    },
                    {
                      "kind": "text",
                      "text": ". Default: "
