  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns the indices that would sort an array."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Perform an indirect sort along the given axis using the algorithm specified\nby the "
            },
            {
              "kind": "code",
              "text": "kind"
            },
            {
              "kind": "text",
              "text": " keyword. It returns an array of indices of the same shape as\n"
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " that index data along the given axis in sorted order."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Array to sort."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Array to sort."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axis along which to sort.  The default is -1 (the last axis). If None,\nthe flattened array is used."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or None, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Axis along which to sort.  The default is -1 (the last axis). If None,\nthe flattened array is used."
                }
              ],
              "name": "axis",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Sorting algorithm. The default is 'quicksort'. Note that both 'stable'\nand 'mergesort' use timsort under the covers and, in general, the\nactual implementation will vary with data type. The 'mergesort' option\nis retained for backwards compatibility."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{'quicksort', 'mergesort', 'heapsort', 'stable'}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Sorting algorithm. The default is 'quicksort'. Note that both 'stable'\nand 'mergesort' use timsort under the covers and, in general, the\nactual implementation will vary with data type. The 'mergesort' option\nis retained for backwards compatibility."
                }
              ],
              "name": "kind",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "When "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is an array with fields defined, this argument specifies\nwhich fields to compare first, second, etc.  A single field can\nbe specified as a string, and not all fields need be specified,\nbut unspecified fields will still be used, in the order in which\nthey come up in the dtype, to break ties."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "str or list of str, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "When "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": " is an array with fields defined, this argument specifies\nwhich fields to compare first, second, etc.  A single field can\nbe specified as a string, and not all fields need be specified,\nbut unspecified fields will still be used, in the order in which\nthey come up in the dtype, to break ties."
                }
              ],
              "name": "order",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Sort stability. If "
