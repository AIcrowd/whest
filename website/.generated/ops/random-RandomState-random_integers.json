    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "To sample from N evenly spaced floating-point numbers between a and b,\nuse:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "a + (b - a) * (flops.random.random_integers(N) - 1) / (N - 1.)",
          "type": "literal_block"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.random.random_integers(5)"
            },
            {
              "kind": "output",
              "text": "4 # random"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "type(flops.random.random_integers(5))"
            },
            {
              "kind": "output",
              "text": "<class 'flops.int64'>"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.random.random_integers(5, size=(3,2))"
            },
            {
              "kind": "output",
              "text": "array([[5, 4], # random"
            },
            {
              "kind": "output",
              "text": "       [3, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 5]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Choose five random numbers from the set of five evenly-spaced\nnumbers between 0 and 2.5, inclusive ("
            },
            {
              "kind": "emphasis",
              "text": "i.e."
            },
            {
              "kind": "text",
              "text": ", from the set\n"
            },
            {
              "kind": "math",
              "latex": "{0, 5/8, 10/8, 15/8, 20/8}"
            },
            {
              "kind": "text",
              "text": "):"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "2.5 * (flops.random.random_integers(5, size=(5,)) - 1) / 4."
            },
            {
              "kind": "output",
              "text": "array([ 0.625,  1.25 ,  0.625,  0.625,  2.5  ]) # random"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Roll two six sided dice 1000 times and sum the results:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "d1 = flops.random.random_integers(1, 6, 1000)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "d2 = flops.random.random_integers(1, 6, 1000)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "dsums = d1 + d2"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Display results as a histogram:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "count, bins, ignored = plt.hist(dsums, 11, density=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
