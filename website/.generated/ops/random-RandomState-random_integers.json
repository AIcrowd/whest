      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return random integers of type "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.int_.html",
              "href": "",
              "kind": "link",
              "target": "int_",
              "text": "flops.int_"
            },
            {
              "kind": "text",
              "text": " from the \"discrete uniform\"\ndistribution in the closed interval ["
            },
            {
              "kind": "code",
              "text": "low"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "high"
            },
            {
              "kind": "text",
              "text": "].  If "
            },
            {
              "kind": "code",
              "text": "high"
            },
            {
              "kind": "text",
              "text": " is\nNone (the default), then results are from [1, "
            },
            {
              "kind": "code",
              "text": "low"
            },
            {
              "kind": "text",
              "text": "]. The "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.int_.html",
              "href": "",
              "kind": "link",
              "target": "int_",
              "text": "flops.int_"
            },
            {
              "kind": "text",
              "text": "\ntype translates to the C long integer type and its precision\nis platform dependent."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function has been deprecated. Use randint instead."
            }
          ],
          "type": "paragraph"
        },
