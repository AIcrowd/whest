{
  "aliases": [],
  "api_docs_html": "",
  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the indices to access the main diagonal of an array."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This returns a tuple of indices that can be used to access the main\ndiagonal of an array "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " with "
            },
            {
              "kind": "code",
              "text": "a.ndim >= 2"
            },
            {
              "kind": "text",
              "text": " dimensions and shape\n(n, n, ..., n). For "
            },
            {
              "kind": "code",
              "text": "a.ndim = 2"
            },
            {
              "kind": "text",
              "text": " this is the usual diagonal, for\n"
            },
            {
              "kind": "code",
              "text": "a.ndim > 2"
            },
            {
              "kind": "text",
              "text": " this is the set of indices to access "
            },
            {
              "kind": "code",
              "text": "a[i, i, ..., i]"
            },
            {
              "kind": "text",
              "text": "\nfor "
            },
            {
              "kind": "code",
              "text": "i = [0..n-1]"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The size, along each dimension, of the arrays for which the returned\nindices can be used."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int",
              "inline": [
                {
                  "kind": "text",
                  "text": "The size, along each dimension, of the arrays for which the returned\nindices can be used."
                }
              ],
              "name": "n",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The number of dimensions."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The number of dimensions."
                }
              ],
              "name": "ndim",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "links": [
            {
              "description": "",
              "description_inline": [],
              "external_url": "",
