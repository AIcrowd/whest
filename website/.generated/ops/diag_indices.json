            }
          ],
          "type": "link_list"
        }
      ],
      "title": "See also"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Create a set of indices to access the diagonal of a (4, 4) array:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "di = we.diag_indices(4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "di"
            },
            {
              "kind": "output",
              "text": "(array([0, 1, 2, 3]), array([0, 1, 2, 3]))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(16).reshape(4, 4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[ 0,  1,  2,  3],"
            },
            {
              "kind": "output",
              "text": "       [ 4,  5,  6,  7],"
            },
            {
              "kind": "output",
              "text": "       [ 8,  9, 10, 11],"
            },
            {
              "kind": "output",
              "text": "       [12, 13, 14, 15]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[di] = 100"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[100,   1,   2,   3],"
            },
            {
              "kind": "output",
              "text": "       [  4, 100,   6,   7],"
            },
            {
              "kind": "output",
              "text": "       [  8,   9, 100,  11],"
            },
            {
              "kind": "output",
              "text": "       [ 12,  13,  14, 100]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Now, we create indices to manipulate a 3-D array:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "d3 = we.diag_indices(2, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "d3"
            },
            {
              "kind": "output",
              "text": "(array([0, 1]), array([0, 1]), array([0, 1]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "And use it to set the diagonal of an array of zeros to 1:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((2, 2, 2), dtype=int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[d3] = 1"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[[1, 0],"
            },
            {
              "kind": "output",
              "text": "        [0, 0]],"
            },
            {
              "kind": "output",
              "text": "       [[0, 0],"
            },
            {
              "kind": "output",
              "text": "        [0, 1]]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
