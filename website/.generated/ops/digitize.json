  "example": {
    "code": "import whest as we\n\nx = we.array([0.2, 6.4, 3.0, 1.6])\n\nbins = we.array([0.0, 1.0, 2.5, 4.0, 10.0])\n\ninds = we.digitize(x, bins)\n\ninds\n\nfor n in range(x.size):\n  print(bins[inds[n]-1], \"<=\", x[n], \"<\", bins[inds[n]])\n\nx = we.array([1.2, 10.0, 12.4, 15.5, 20.])\n\nbins = we.array([0, 5, 10, 15, 20])\n\nwe.digitize(x,bins,right=True)\n\nwe.digitize(x,bins,right=False)",
    "output": "array([1, 4, 3, 2])\n\n0.0 <= 0.2 < 1.0\n4.0 <= 6.4 < 10.0\n2.5 <= 3.0 < 4.0\n1.0 <= 1.6 < 2.5\n\narray([1, 2, 3, 4, 4])\n\narray([1, 3, 3, 4, 5])",
