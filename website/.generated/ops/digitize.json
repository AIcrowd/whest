    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "If values in "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " are such that they fall outside the bin range,\nattempting to index "
            },
            {
              "kind": "code",
              "text": "bins"
            },
            {
              "kind": "text",
              "text": " with the indices that "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/digitize",
              "kind": "link",
              "target": "digitize",
              "text": "digitize"
            },
            {
              "kind": "text",
              "text": " returns\nwill result in an IndexError."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionadded",
          "options": [],
          "raw_source": ".. versionadded:: 1.10.0",
          "supported": true,
          "type": "directive_block",
          "version": "1.10.0"
        },
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/ops/digitize",
              "kind": "link",
              "target": "digitize",
              "text": "we.digitize"
            },
            {
              "kind": "text",
              "text": " is  implemented in terms of "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/searchsorted",
              "kind": "link",
              "target": "searchsorted",
              "text": "we.searchsorted"
            },
            {
              "kind": "text",
              "text": ".\nThis means that a binary search is used to bin the values, which scales\nmuch better for larger number of bins than the previous linear search.\nIt also removes the requirement for the input array to be 1-dimensional."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For monotonically "
            },
            {
              "kind": "emphasis",
              "text": "increasing"
            },
            {
              "kind": "text",
              "text": " "
            },
            {
              "kind": "code",
              "text": "bins"
            },
            {
              "kind": "text",
              "text": ", the following are equivalent:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "we.digitize(x, bins, right=True)\nwe.searchsorted(bins, x, side='left')",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that as the order of the arguments are reversed, the side must be too.\nThe "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/searchsorted",
              "kind": "link",
              "target": "searchsorted",
              "text": "searchsorted"
            },
            {
              "kind": "text",
              "text": " call is marginally faster, as it does not do any\nmonotonicity checks. Perhaps more importantly, it supports all dtypes."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([0.2, 6.4, 3.0, 1.6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "bins = we.array([0.0, 1.0, 2.5, 4.0, 10.0])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "inds = we.digitize(x, bins)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "inds"
            },
            {
              "kind": "output",
              "text": "array([1, 4, 3, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "for n in range(x.size):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "print(bins[inds[n]-1], \"<=\", x[n], \"<\", bins[inds[n]])"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "0.0 <= 0.2 < 1.0"
            },
            {
              "kind": "output",
              "text": "4.0 <= 6.4 < 10.0"
            },
            {
              "kind": "output",
              "text": "2.5 <= 3.0 < 4.0"
            },
            {
              "kind": "output",
              "text": "1.0 <= 1.6 < 2.5"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([1.2, 10.0, 12.4, 15.5, 20.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "bins = we.array([0, 5, 10, 15, 20])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.digitize(x,bins,right=True)"
            },
            {
              "kind": "output",
              "text": "array([1, 2, 3, 4, 4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.digitize(x,bins,right=False)"
            },
            {
              "kind": "output",
              "text": "array([1, 3, 3, 4, 5])"
            }
          ],
          "type": "doctest_block"
        }
      ],
