              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sign([-5., 4.5])"
            },
            {
              "kind": "output",
              "text": "array([-1.,  1.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sign(0)"
            },
            {
              "kind": "output",
              "text": "0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sign([3-4j, 8j])"
            },
            {
              "kind": "output",
              "text": "array([0.6-0.8j, 0. +1.j ])"
            }
          ],
