          "inline": [
            {
              "kind": "text",
              "text": "Returns an element-wise indication of the sign of a number."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/sign",
              "kind": "link",
              "target": "sign",
              "text": "sign"
            },
            {
              "kind": "text",
              "text": " function returns "
            },
            {
              "kind": "code",
              "text": "-1 if x < 0, 0 if x==0, 1 if x > 0"
            },
            {
              "kind": "text",
              "text": ".  nan\nis returned for nan inputs."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For complex inputs, the "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/sign",
              "kind": "link",
              "target": "sign",
              "text": "sign"
            },
            {
              "kind": "text",
              "text": " function returns "
            },
            {
              "kind": "code",
              "text": "x / abs(x)"
            },
            {
              "kind": "text",
              "text": ", the\ngeneralization of the above (and "
            },
            {
              "kind": "code",
              "text": "0 if x==0"
            },
            {
              "kind": "text",
              "text": ")."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionchanged",
          "options": [],
          "raw_source": ".. versionchanged:: 2.0.0\n    Definition of complex sign changed to follow the Array API standard.",
          "supported": true,
