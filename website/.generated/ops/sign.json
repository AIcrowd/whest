    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "There is more than one definition of sign in common use for complex\nnumbers.  The definition used here, "
            },
            {
              "kind": "math",
              "latex": "x/|x|"
            },
            {
              "kind": "text",
              "text": ", is the more common\nand useful one, but is different from the one used in numpy prior to\nversion 2.0, "
            },
            {
              "kind": "math",
              "latex": "x/\\sqrt{x*x}"
            },
            {
              "kind": "text",
              "text": ", which is equivalent to\n"
            },
            {
              "kind": "code",
              "text": "sign(x.real) + 0j if x.real != 0 else sign(x.imag) + 0j"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
