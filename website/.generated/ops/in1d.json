            },
            {
              "kind": "output",
              "text": "array([ True, False,  True, False,  True])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "test[mask]"
            },
            {
              "kind": "output",
              "text": "array([0, 2, 0])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "mask = we.in1d(test, states, invert=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "mask"
            },
            {
              "kind": "output",
              "text": "array([False,  True, False,  True, False])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "test[mask]"
            },
            {
              "kind": "output",
              "text": "array([1, 5])"
            }
          ],
          "type": "doctest_block"
        }
      ],
