    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Beginning with an array of integers from 0 to 5 (inclusive),\nelements less than "
            },
            {
              "kind": "code",
              "text": "3"
            },
            {
              "kind": "text",
              "text": " are negated, elements greater than "
            },
            {
              "kind": "code",
              "text": "3"
            },
            {
              "kind": "text",
              "text": "\nare squared, and elements not meeting either of these conditions\n(exactly "
            },
            {
              "kind": "code",
              "text": "3"
            },
            {
              "kind": "text",
              "text": ") are replaced with a "
            },
            {
              "kind": "code",
              "text": "default"
            },
            {
              "kind": "text",
              "text": " value of "
            },
            {
              "kind": "code",
              "text": "42"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(6)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "condlist = [x<3, x>3]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "choicelist = [x, x**2]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.select(condlist, choicelist, 42)"
            },
            {
              "kind": "output",
              "text": "array([ 0,  1,  2, 42, 16, 25])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When multiple conditions are satisfied, the first one encountered in\n"
            },
            {
              "kind": "code",
              "text": "condlist"
            },
            {
              "kind": "text",
              "text": " is used."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "condlist = [x<=4, x>3]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "choicelist = [x, x**2]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.select(condlist, choicelist, 55)"
            },
            {
              "kind": "output",
              "text": "array([ 0,  1,  2,  3,  4, 25])"
            }
          ],
          "type": "doctest_block"
        }
      ],
