      ],
      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This functionality can be obtained via "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/diag_indices",
              "kind": "link",
              "target": "diag_indices",
              "text": "diag_indices"
            },
            {
              "kind": "text",
              "text": ", but internally\nthis version uses a much faster implementation that never constructs the\nindices and uses simple slicing."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((3, 3), int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fill_diagonal(a, 5)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[5, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 5, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 5]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The same function can operate on a 4-D array:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((3, 3, 3, 3), int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fill_diagonal(a, 4)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "We only show a few blocks for clarity:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[0, 0]"
            },
            {
              "kind": "output",
              "text": "array([[4, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[1, 1]"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 4, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[2, 2]"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 4]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The wrap option affects only tall matrices:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# tall matrices no wrap"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((5, 3), int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fill_diagonal(a, 4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[4, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 4, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 4],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# tall matrices wrap"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((5, 3), int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fill_diagonal(a, 4, wrap=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[4, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 4, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 4],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [4, 0, 0]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# wide matrices"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((3, 5), int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fill_diagonal(a, 4, wrap=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[4, 0, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 4, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 4, 0, 0]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The anti-diagonal can be filled by reversing the order of elements\nusing either "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/flipud",
              "kind": "link",
              "target": "flipud",
              "text": "we.flipud"
            },
            {
              "kind": "text",
              "text": " or "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/fliplr",
              "kind": "link",
              "target": "fliplr",
              "text": "we.fliplr"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.zeros((3, 3), int);"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fill_diagonal(we.fliplr(a), [1,2,3])  # Horizontal flip"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 1],"
            },
            {
              "kind": "output",
              "text": "       [0, 2, 0],"
            },
            {
              "kind": "output",
              "text": "       [3, 0, 0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fill_diagonal(we.flipud(a), [1,2,3])  # Vertical flip"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 3],"
            },
            {
              "kind": "output",
              "text": "       [0, 2, 0],"
            },
            {
              "kind": "output",
              "text": "       [1, 0, 0]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that the order in which the diagonal is filled varies depending\non the flip function."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Examples"
    }
  ],
