  "example": {
    "code": "import whest as we\n\na = we.zeros((3, 3), int)\n\nwe.fill_diagonal(a, 5)\n\na\n\na = we.zeros((3, 3, 3, 3), int)\n\nwe.fill_diagonal(a, 4)\n\na[0, 0]\n\na[1, 1]\n\na[2, 2]\n\na = we.zeros((5, 3), int)\n\nwe.fill_diagonal(a, 4)\n\na\n\na = we.zeros((5, 3), int)\n\nwe.fill_diagonal(a, 4, wrap=True)\n\na\n\na = we.zeros((3, 5), int)\n\nwe.fill_diagonal(a, 4, wrap=True)\n\na\n\na = we.zeros((3, 3), int);\n\nwe.fill_diagonal(we.fliplr(a), [1,2,3])  # Horizontal flip\n\na\n\nwe.fill_diagonal(we.flipud(a), [1,2,3])  # Vertical flip\n\na",
    "output": "array([[5, 0, 0],\n       [0, 5, 0],\n       [0, 0, 5]])\n\narray([[4, 0, 0],\n       [0, 0, 0],\n       [0, 0, 0]])\n\narray([[0, 0, 0],\n       [0, 4, 0],\n       [0, 0, 0]])\n\narray([[0, 0, 0],\n       [0, 0, 0],\n       [0, 0, 4]])\n\narray([[4, 0, 0],\n       [0, 4, 0],\n       [0, 0, 4],\n       [0, 0, 0],\n       [0, 0, 0]])\n\narray([[4, 0, 0],\n       [0, 4, 0],\n       [0, 0, 4],\n       [0, 0, 0],\n       [4, 0, 0]])\n\narray([[4, 0, 0, 0, 0],\n       [0, 4, 0, 0, 0],\n       [0, 0, 4, 0, 0]])\n\narray([[0, 0, 1],\n       [0, 2, 0],\n       [3, 0, 0]])\n\narray([[0, 0, 3],\n       [0, 2, 0],\n       [1, 0, 0]])",
    "source": "derived"
  },
