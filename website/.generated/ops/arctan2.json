    "code": "import whest as we\n\nx = we.array([-1, +1, +1, -1])\n\ny = we.array([-1, -1, +1, +1])\n\nwe.arctan2(y, x) * 180 / we.pi\n\nwe.arctan2([1., -1.], [0., 0.])\n\nwe.arctan2([0., 0., we.inf], [+0., -0., we.inf])",
