              "kind": "text",
              "text": "Compute hyperbolic tangent element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Equivalent to "
            },
            {
              "kind": "code",
              "text": "fnp.sinh(x)/fnp.cosh(x)"
            },
            {
              "kind": "text",
              "text": " or "
            },
            {
              "kind": "code",
              "text": "-1j * fnp.tan(1j*x)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
