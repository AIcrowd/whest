    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.tanh((0, fnp.pi*1j, fnp.pi*1j/2))"
            },
            {
              "kind": "output",
              "text": "array([ 0. +0.00000000e+00j,  0. -1.22460635e-16j,  0. +1.63317787e+16j])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Example of providing the optional output parameter illustrating"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# that what is returned is a reference to said parameter"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out1 = fnp.array([0], dtype='d')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out2 = fnp.tanh([0.1], out1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out2 is out1"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Example of ValueError due to provision of shape mis-matched `out`"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.tanh(fnp.zeros((3,3)),fnp.zeros((2,2)))"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "output",
              "text": "  File \"<stdin>\", line 1, in <module>"
            },
            {
              "kind": "output",
              "text": "ValueError: operands could not be broadcast together with shapes (3,3) (2,2)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
