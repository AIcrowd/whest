              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanvar(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([1.,  0.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanvar(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([0.,  0.25])  # may vary"
            }
          ],
          "type": "doctest_block"
        }
