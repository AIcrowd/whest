  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the qth percentile of the data along the specified axis, while ignoring nan values."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns the qth percentile(s) of the array elements."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array or object that can be converted to an array, containing\nnan values to be ignored."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array or object that can be converted to an array, containing\nnan values to be ignored."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Percentile or sequence of percentiles to compute, which must be\nbetween 0 and 100 inclusive."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like of float",
              "inline": [
                {
                  "kind": "text",
                  "text": "Percentile or sequence of percentiles to compute, which must be\nbetween 0 and 100 inclusive."
                }
              ],
              "name": "q",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axis or axes along which the percentiles are computed. The default\nis to compute the percentile(s) along a flattened version of the\narray."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{int, tuple of int, None}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Axis or axes along which the percentiles are computed. The default\nis to compute the percentile(s) along a flattened version of the\narray."
                }
              ],
              "name": "axis",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Alternative output array in which to place the result. It must have\nthe same shape and buffer length as the expected output, but the\ntype (of the output) will be cast if necessary."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Alternative output array in which to place the result. It must have\nthe same shape and buffer length as the expected output, but the\ntype (of the output) will be cast if necessary."
                }
              ],
              "name": "out",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If True, then allow the input array "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " to be modified by\nintermediate calculations, to save memory. In this case, the\ncontents of the input "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " after this function completes is\nundefined."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If True, then allow the input array "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": " to be modified by\nintermediate calculations, to save memory. In this case, the\ncontents of the input "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": " after this function completes is\nundefined."
                }
              ],
              "name": "overwrite_input",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "This parameter specifies the method to use for estimating the\npercentile.  There are many different methods, some unique to NumPy.\nSee the notes for explanation.  The options sorted by their R type\nas summarized in the H&F paper "
                    },
                    {
                      "kind": "text",
                      "text": "[1]_"
                    },
                    {
                      "kind": "text",
                      "text": " are:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'inverted_cdf'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'averaged_inverted_cdf'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'closest_observation'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'interpolated_inverted_cdf'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'hazen'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'weibull'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'linear'  (default)"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'median_unbiased'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'normal_unbiased'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    }
                  ],
                  "ordered": true,
                  "type": "list"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The first three methods are discontinuous.  NumPy further defines the\nfollowing discontinuous variations of the default 'linear' (7.) option:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'lower'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'higher',"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'midpoint'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'nearest'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    }
                  ],
                  "ordered": false,
                  "type": "list"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "versionchanged",
                  "options": [],
                  "raw_source": ".. versionchanged:: 1.22.0\n    This argument was previously called \"interpolation\" and only\n    offered the \"linear\" default and last four options.",
                  "supported": true,
                  "type": "directive_block",
