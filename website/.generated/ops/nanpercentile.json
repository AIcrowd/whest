  "example": {
    "code": "import whest as we\n\na = we.array([[10., 7., 4.], [3., 2., 1.]])\n\na[0][1] = we.nan\n\na\n\nwe.percentile(a, 50)\n\nwe.nanpercentile(a, 50)\n\nwe.nanpercentile(a, 50, axis=0)\n\nwe.nanpercentile(a, 50, axis=1, keepdims=True)\n\nm = we.nanpercentile(a, 50, axis=0)\n\nout = we.zeros_like(m)\n\nwe.nanpercentile(a, 50, axis=0, out=out)\n\nm\n\nb = a.copy()\n\nwe.nanpercentile(b, 50, axis=1, overwrite_input=True)\n\nassert not we.all(a==b)",
    "output": "array([[10.,  nan,   4.],\n      [ 3.,   2.,   1.]])\n\nwe.float64(nan)\n\n3.0\n\narray([6.5, 2. , 2.5])\n\narray([[7.],\n       [2.]])\n\narray([6.5, 2. , 2.5])\n\narray([6.5,  2. ,  2.5])\n\narray([7., 2.])",
