    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw ten thousand values from the geometric distribution,\nwith the probability of an individual success equal to 0.35:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "z = flops.random.geometric(p=0.35, size=10000)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "How many trials succeeded after a single run?"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "(z == 1).sum() / 10000."
            },
            {
              "kind": "output",
              "text": "0.34889999999999999 #random"
            }
          ],
          "type": "doctest_block"
        }
      ],
