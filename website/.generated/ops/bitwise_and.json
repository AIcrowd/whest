  "example": {
    "code": "import whest as we\n\nwe.bitwise_and(13, 17)\n\nwe.bitwise_and(14, 13)\n\nwe.binary_repr(12)\n\nwe.bitwise_and([14,3], 13)\n\nwe.bitwise_and([11,7], [4,25])\n\nwe.bitwise_and(we.array([2,5,255]), we.array([3,14,16]))\n\nwe.bitwise_and([True, True], [False, True])\n\nx1 = we.array([2, 5, 255])\n\nx2 = we.array([3, 14, 16])\n\nx1 & x2",
    "output": "1\n\n12\n\n'1100'\n\narray([12,  1])\n\narray([0, 1])\n\narray([ 2,  4, 16])\n\narray([False,  True])\n\narray([ 2,  4, 16])",
