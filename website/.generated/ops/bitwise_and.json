    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The number 13 is represented by "
            },
            {
              "kind": "code",
              "text": "00001101"
            },
            {
              "kind": "text",
              "text": ".  Likewise, 17 is\nrepresented by "
            },
            {
              "kind": "code",
              "text": "00010001"
            },
            {
              "kind": "text",
              "text": ".  The bit-wise AND of 13 and 17 is\ntherefore "
            },
            {
              "kind": "code",
              "text": "000000001"
            },
            {
              "kind": "text",
              "text": ", or 1:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bitwise_and(13, 17)"
            },
            {
              "kind": "output",
              "text": "1"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bitwise_and(14, 13)"
            },
            {
              "kind": "output",
              "text": "12"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.binary_repr(12)"
            },
            {
              "kind": "output",
              "text": "'1100'"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bitwise_and([14,3], 13)"
            },
            {
              "kind": "output",
              "text": "array([12,  1])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bitwise_and([11,7], [4,25])"
            },
            {
              "kind": "output",
              "text": "array([0, 1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bitwise_and(we.array([2,5,255]), we.array([3,14,16]))"
            },
            {
              "kind": "output",
              "text": "array([ 2,  4, 16])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bitwise_and([True, True], [False, True])"
            },
            {
              "kind": "output",
              "text": "array([False,  True])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "&"
            },
            {
              "kind": "text",
              "text": " operator can be used as a shorthand for "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/bitwise_and",
              "kind": "link",
              "target": "bitwise_and",
              "text": "we.bitwise_and"
            },
            {
              "kind": "text",
              "text": " on\nndarrays."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 = we.array([2, 5, 255])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x2 = we.array([3, 14, 16])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 & x2"
            },
            {
              "kind": "output",
              "text": "array([ 2,  4, 16])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
