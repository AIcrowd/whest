              "name": "x1",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The direction where to look for the next representable value of "
                    },
                    {
                      "kind": "code",
                      "text": "x1"
                    },
                    {
                      "kind": "text",
                      "text": ".\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "x1.shape != x2.shape"
                    },
                    {
                      "kind": "text",
                      "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
