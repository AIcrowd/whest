    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The variable obtained by summing the squares of "
            },
            {
              "kind": "code",
              "text": "df"
            },
            {
              "kind": "text",
              "text": " independent,\nstandard normally distributed random variables:"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "Q = \\sum_{i=1}^{\\mathtt{df}} X^2_i"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "is chi-square distributed, denoted"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "Q \\sim \\chi^2_k."
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The probability density function of the chi-squared distribution is"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "p(x) = \\frac{(1/2)^{k/2}}{\\Gamma(k/2)} x^{k/2 - 1} e^{-x/2},"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "math",
              "latex": "\\Gamma"
            },
            {
              "kind": "text",
              "text": " is the gamma function,"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "\\Gamma(x) = \\int_0^{-\\infty} t^{x - 1} e^{-t} dt."
          ],
          "type": "math_block"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nNIST \"Engineering Statistics Handbook\"\nhttps://www.itl.nist.gov/div898/handbook/eda/section3/eda3666.htm",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = flops.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng.chisquare(2,4)"
            },
            {
              "kind": "output",
              "text": "array([ 1.89920014,  9.00867716,  3.13710533,  5.62318272]) # random"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The distribution of a chi-square random variable\nwith 20 degrees of freedom looks as follows:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import scipy.stats as stats"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = rng.chisquare(20, 10000)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "count, bins, _ = plt.hist(s, 30, density=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = flops.linspace(0, 60, 1000)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(x, stats.chi2.pdf(x, df=20))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.xlim([0, 60])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
