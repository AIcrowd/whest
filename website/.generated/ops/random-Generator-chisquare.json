        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Number of degrees of freedom, must be > 0."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "Number of degrees of freedom, must be > 0."
                }
              ],
              "name": "df",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "df"
                    },
                    {
                      "kind": "text",
                      "text": " is a scalar.  Otherwise,\n"
                    },
                    {
                      "kind": "code",
                      "text": "flops.array(df).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
