    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "To reduce the chance of misinterpretation, even though the following\n\"abuse\" is nominally supported, "
            },
            {
              "kind": "code",
              "text": "choices"
            },
            {
              "kind": "text",
              "text": " should neither be, nor be\nthought of as, a single array, i.e., the outermost sequence-like container\nshould be either a list or a tuple."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "choices = [[0, 1, 2, 3], [10, 11, 12, 13],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[20, 21, 22, 23], [30, 31, 32, 33]]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.choose([2, 3, 1, 0], choices"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "# the first element of the result will be the first element of the"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "# third (2+1) \"array\" in choices, namely, 20; the second element"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "# will be the second element of the fourth (3+1) choice array, i.e.,"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "# 31, etc."
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ")"
            },
            {
              "kind": "output",
              "text": "array([20, 31, 12,  3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.choose([2, 4, 1, 0], choices, mode='clip') # 4 goes to 3 (4-1)"
            },
            {
              "kind": "output",
              "text": "array([20, 31, 12,  3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# because there are 4 choice arrays"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.choose([2, 4, 1, 0], choices, mode='wrap') # 4 goes to (4 mod 4)"
            },
            {
              "kind": "output",
              "text": "array([20,  1, 12,  3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# i.e., 0"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "A couple examples illustrating how choose broadcasts:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = [[1, 0, 1], [0, 1, 0], [1, 0, 1]]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "choices = [-10, 10]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.choose(a, choices)"
            },
            {
              "kind": "output",
              "text": "array([[ 10, -10,  10],"
            },
            {
              "kind": "output",
              "text": "       [-10,  10, -10],"
            },
            {
              "kind": "output",
              "text": "       [ 10, -10,  10]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# With thanks to Anne Archibald"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([0, 1]).reshape((2,1,1))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c1 = we.array([1, 2, 3]).reshape((1,3,1))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c2 = we.array([-1, -2, -3, -4, -5]).reshape((1,1,5))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.choose(a, (c1, c2)) # result is 2x3x5, res[0,:,:]=c1, res[1,:,:]=c2"
            },
            {
              "kind": "output",
              "text": "array([[[ 1,  1,  1,  1,  1],"
            },
            {
              "kind": "output",
              "text": "        [ 2,  2,  2,  2,  2],"
            },
            {
              "kind": "output",
              "text": "        [ 3,  3,  3,  3,  3]],"
            },
            {
              "kind": "output",
              "text": "       [[-1, -2, -3, -4, -5],"
            },
            {
              "kind": "output",
              "text": "        [-1, -2, -3, -4, -5],"
            },
            {
              "kind": "output",
              "text": "        [-1, -2, -3, -4, -5]]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
