      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "A special case of the hyperbolic distribution.  As "
            },
            {
              "kind": "code",
              "text": "df"
            },
            {
              "kind": "text",
              "text": " gets\nlarge, the result resembles that of the standard normal\ndistribution ("
            },
            {
              "kind": "code",
              "text": "standard_normal"
            },
            {
              "kind": "text",
              "text": ")."
            }
          ],
          "type": "paragraph"
