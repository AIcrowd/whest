            {
              "kind": "text",
              "text": "Trigonometric inverse cosine, element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The inverse of "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/cos",
              "kind": "link",
              "target": "cos",
              "text": "cos"
            },
            {
              "kind": "text",
              "text": " so that, if "
            },
            {
              "kind": "code",
              "text": "y = cos(x)"
            },
            {
              "kind": "text",
              "text": ", then "
            },
            {
              "kind": "code",
              "text": "x = arccos(y)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
