      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the absolute values element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function returns the absolute values (positive magnitude) of the\ndata in "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": ". Complex values are not handled, use "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/absolute",
              "kind": "link",
              "target": "absolute",
              "text": "absolute"
            },
            {
              "kind": "text",
              "text": " to find the\nabsolute values of complex data."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The array of numbers for which the absolute values are required. If\n"
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " is a scalar, the result "
                    },
                    {
                      "kind": "code",
                      "text": "y"
                    },
                    {
                      "kind": "text",
                      "text": " will also be a scalar."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "The array of numbers for which the absolute values are required. If\n"
                },
                {
                  "kind": "code",
                  "text": "x"
                },
                {
                  "kind": "text",
                  "text": " is a scalar, the result "
                },
                {
                  "kind": "code",
                  "text": "y"
                },
                {
                  "kind": "text",
                  "text": " will also be a scalar."
                }
              ],
              "name": "x",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, None, or tuple of ndarray and None, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                }
              ],
              "name": "out",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array will be set to the ufunc result.\nElsewhere, the "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array will retain its original value.\nNote that if an uninitialized "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " array is created via the default\n"
                    },
                    {
                      "kind": "code",
                      "text": "out=None"
                    },
                    {
                      "kind": "text",
                      "text": ", locations within it where the condition is False will\nremain uninitialized."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
