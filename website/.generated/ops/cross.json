              "kind": "text",
              "text": "Dimension-2 input arrays were deprecated in 2.0.0. If you do need this\nfunctionality, you can use:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "def cross2d(x, y):\n    return x[..., 0] * y[..., 1] - x[..., 1] * y[..., 0]",
          "type": "literal_block"
        }
      ],
