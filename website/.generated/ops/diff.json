  "example": {
    "code": "import whest as we\n\nx = we.array([1, 2, 4, 7, 0])\n\nwe.diff(x)\n\nwe.diff(x, n=2)\n\nx = we.array([[1, 3, 6, 10], [0, 5, 6, 8]])\n\nwe.diff(x)\n\nwe.diff(x, axis=0)\n\nx = we.arange('1066-10-13', '1066-10-16', dtype=we.datetime64)\n\nwe.diff(x)",
    "output": "array([ 1,  2,  3, -7])\n\narray([  1,   1, -10])\n\narray([[2, 3, 4],\n       [5, 1, 2]])\n\narray([[-1,  2,  0, -2]])\n\narray([1, 1], dtype='timedelta64[D]')",
