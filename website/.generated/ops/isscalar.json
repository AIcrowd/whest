        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isscalar(3.1)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isscalar(fnp.array(3.1))"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isscalar([3.1])"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isscalar(False)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isscalar('numpy')"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy supports PEP 3141 numbers:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from fractions import Fraction"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isscalar(Fraction(5, 17))"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from numbers import Number"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isscalar(Number())"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
