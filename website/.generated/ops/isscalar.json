  "example": {
    "code": "import whest as we\n\nwe.isscalar(3.1)\n\nwe.isscalar(we.array(3.1))\n\nwe.isscalar([3.1])\n\nwe.isscalar(False)\n\nwe.isscalar('numpy')\n\nfrom fractions import Fraction\n\nwe.isscalar(Fraction(5, 17))\n\nfrom numbers import Number\n\nwe.isscalar(Number())",
