          "inline": [
            {
              "kind": "text",
              "text": "Return the product of array elements over a given axis treating Not a Numbers (NaNs) as ones."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "One is returned for slices that are all-NaN or empty."
            }
          ],
          "type": "paragraph"
        }
      ],
