  "example": {
    "code": "import whest as we\n\nwe.logspace(2.0, 3.0, num=4)\n\nwe.logspace(2.0, 3.0, num=4, endpoint=False)\n\nwe.logspace(2.0, 3.0, num=4, base=2.0)\n\nwe.logspace(2.0, 3.0, num=4, base=[2.0, 3.0], axis=-1)\n\nimport matplotlib.pyplot as plt\n\nN = 10\n\nx1 = we.logspace(0.1, 1, N, endpoint=True)\n\nx2 = we.logspace(0.1, 1, N, endpoint=False)\n\ny = we.zeros(N)\n\nplt.plot(x1, y, 'o')\n\nplt.plot(x2, y + 0.5, 'o')\n\nplt.ylim([-0.5, 1])\n\nplt.show()",
    "output": "array([ 100.        ,  215.443469  ,  464.15888336, 1000.        ])\n\narray([100.        ,  177.827941  ,  316.22776602,  562.34132519])\n\narray([4.        ,  5.0396842 ,  6.34960421,  8.        ])\n\narray([[ 4.        ,  5.0396842 ,  6.34960421,  8.        ],\n       [ 9.        , 12.98024613, 18.72075441, 27.        ]])\n\n[<matplotlib.lines.Line2D object at 0x...>]\n\n[<matplotlib.lines.Line2D object at 0x...>]\n\n(-0.5, 1)",
    "source": "derived"
