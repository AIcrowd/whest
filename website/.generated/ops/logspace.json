  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return numbers spaced evenly on a log scale."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "In linear space, the sequence starts at "
            },
            {
              "kind": "code",
              "text": "base ** start"
            },
            {
              "kind": "text",
              "text": "\n("
            },
            {
              "kind": "code",
              "text": "base"
            },
            {
              "kind": "text",
              "text": " to the power of "
            },
            {
              "kind": "code",
              "text": "start"
            },
            {
              "kind": "text",
              "text": ") and ends with "
            },
            {
              "kind": "code",
              "text": "base ** stop"
            },
            {
              "kind": "text",
              "text": "\n(see "
            },
            {
              "kind": "code",
              "text": "endpoint"
            },
            {
              "kind": "text",
              "text": " below)."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionchanged",
          "options": [],
          "raw_source": ".. versionchanged:: 1.25.0\n    Non-scalar 'base` is now supported",
          "supported": true,
          "type": "directive_block",
          "version": "1.25.0"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
