          "inline": [
            {
              "kind": "text",
              "text": "If base is a scalar, logspace is equivalent to the code"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.linspace(start, stop, num=num, endpoint=endpoint)"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "# doctest: +SKIP"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "power(base, y).astype(dtype)"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "# doctest: +SKIP"
            }
          ],
          "type": "doctest_block"
        }
