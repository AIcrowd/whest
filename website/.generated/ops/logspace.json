    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.logspace(2.0, 3.0, num=4)"
            },
            {
              "kind": "output",
              "text": "array([ 100.        ,  215.443469  ,  464.15888336, 1000.        ])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.logspace(2.0, 3.0, num=4, endpoint=False)"
            },
            {
              "kind": "output",
              "text": "array([100.        ,  177.827941  ,  316.22776602,  562.34132519])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.logspace(2.0, 3.0, num=4, base=2.0)"
            },
            {
              "kind": "output",
              "text": "array([4.        ,  5.0396842 ,  6.34960421,  8.        ])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.logspace(2.0, 3.0, num=4, base=[2.0, 3.0], axis=-1)"
            },
            {
              "kind": "output",
              "text": "array([[ 4.        ,  5.0396842 ,  6.34960421,  8.        ],"
            },
            {
              "kind": "output",
              "text": "       [ 9.        , 12.98024613, 18.72075441, 27.        ]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Graphical illustration:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "N = 10"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 = we.logspace(0.1, 1, N, endpoint=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x2 = we.logspace(0.1, 1, N, endpoint=False)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.zeros(N)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(x1, y, 'o')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at 0x...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(x2, y + 0.5, 'o')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at 0x...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.ylim([-0.5, 1])"
            },
            {
              "kind": "output",
              "text": "(-0.5, 1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
