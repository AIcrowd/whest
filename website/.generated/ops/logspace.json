                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "code",
                  "text": "base ** start"
                },
                {
                  "kind": "text",
                  "text": " is the starting value of the sequence."
                }
              ],
