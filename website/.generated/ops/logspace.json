                  "kind": "code",
                  "text": "stop"
                },
                {
                  "kind": "text",
                  "text": " is the last sample. Otherwise, it is not included.\nDefault is True."
                }
              ],
              "name": "endpoint",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The base of the log space. The step size between the elements in\n"
                    },
                    {
                      "kind": "code",
                      "text": "ln(samples) / ln(base)"
                    },
                    {
                      "kind": "text",
                      "text": " (or "
                    },
                    {
                      "kind": "code",
                      "text": "log_base(samples)"
                    },
                    {
                      "kind": "text",
                      "text": ") is uniform.\nDefault is 10.0."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The base of the log space. The step size between the elements in\n"
                },
                {
                  "kind": "code",
                  "text": "ln(samples) / ln(base)"
                },
                {
                  "kind": "text",
                  "text": " (or "
                },
                {
                  "kind": "code",
                  "text": "log_base(samples)"
                },
                {
                  "kind": "text",
                  "text": ") is uniform.\nDefault is 10.0."
                }
              ],
              "name": "base",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The type of the output array.  If "
                    },
                    {
                      "kind": "code",
                      "text": "dtype"
                    },
                    {
                      "kind": "text",
                      "text": " is not given, the data type\nis inferred from "
                    },
                    {
                      "kind": "code",
                      "text": "start"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "stop"
                    },
                    {
                      "kind": "text",
                      "text": ". The inferred type will never be\nan integer; "
                    },
                    {
                      "kind": "code",
                      "text": "float"
                    },
                    {
                      "kind": "text",
                      "text": " is chosen even if the arguments would produce an\narray of integers."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "dtype",
              "inline": [
                {
                  "kind": "text",
                  "text": "The type of the output array.  If "
                },
                {
                  "kind": "code",
                  "text": "dtype"
                },
                {
                  "kind": "text",
                  "text": " is not given, the data type\nis inferred from "
                },
