{
  "aliases": [],
  "api_docs_html": "",
  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return Pearson product-moment correlation coefficients."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Please refer to the documentation for "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/cov",
              "kind": "link",
              "target": "cov",
              "text": "cov"
            },
            {
              "kind": "text",
              "text": " for more detail.  The\nrelationship between the correlation coefficient matrix, "
            },
            {
              "kind": "code",
              "text": "R"
            },
            {
              "kind": "text",
              "text": ", and the\ncovariance matrix, "
            },
            {
              "kind": "code",
              "text": "C"
            },
            {
              "kind": "text",
              "text": ", is"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "R_{ij} = \\frac{ C_{ij} } { \\sqrt{ C_{ii} C_{jj} } }"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The values of "
            },
            {
              "kind": "code",
              "text": "R"
            },
            {
              "kind": "text",
              "text": " are between -1 and 1, inclusive."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A 1-D or 2-D array containing multiple variables and observations.\nEach row of "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " represents a variable, and each column a single\nobservation of all those variables. Also see "
                    },
                    {
                      "kind": "code",
                      "text": "rowvar"
                    },
                    {
                      "kind": "text",
                      "text": " below."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "A 1-D or 2-D array containing multiple variables and observations.\nEach row of "
                },
                {
                  "kind": "code",
                  "text": "x"
                },
                {
                  "kind": "text",
                  "text": " represents a variable, and each column a single\nobservation of all those variables. Also see "
                },
                {
                  "kind": "code",
                  "text": "rowvar"
                },
                {
                  "kind": "text",
                  "text": " below."
                }
              ],
              "name": "x",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "An additional set of variables and observations. "
                    },
                    {
                      "kind": "code",
                      "text": "y"
                    },
                    {
                      "kind": "text",
                      "text": " has the same\nshape as "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "An additional set of variables and observations. "
                },
                {
                  "kind": "code",
                  "text": "y"
                },
                {
                  "kind": "text",
                  "text": " has the same\nshape as "
                },
                {
                  "kind": "code",
                  "text": "x"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "y",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "rowvar"
                    },
                    {
                      "kind": "text",
                      "text": " is True (default), then each row represents a\nvariable, with observations in the columns. Otherwise, the relationship\nis transposed: each column represents a variable, while the rows\ncontain observations."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If "
                },
                {
                  "kind": "code",
                  "text": "rowvar"
                },
                {
                  "kind": "text",
                  "text": " is True (default), then each row represents a\nvariable, with observations in the columns. Otherwise, the relationship\nis transposed: each column represents a variable, while the rows\ncontain observations."
                }
              ],
              "name": "rowvar",
              "type": "field_list"
            },
            {
              "body_blocks": [
