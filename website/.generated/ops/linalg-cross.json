      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Vector cross-product."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([4, 5, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.cross(x, y)"
            },
            {
              "kind": "output",
              "text": "array([-3,  6, -3])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Multiple vector cross-products. Note that the direction of the cross\nproduct vector is defined by the "
            },
            {
              "kind": "emphasis",
              "text": "right-hand rule"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([[1,2,3], [4,5,6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([[4,5,6], [1,2,3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.cross(x, y)"
            },
            {
              "kind": "output",
              "text": "array([[-3,  6, -3],"
            },
            {
              "kind": "output",
              "text": "       [ 3, -6,  3]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([[1, 2], [3, 4], [5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([[4, 5], [6, 1], [2, 3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.cross(x, y, axis=0)"
