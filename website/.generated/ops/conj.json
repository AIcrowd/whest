              "kind": "text",
              "text": "Return the complex conjugate, element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The complex conjugate of a complex number is obtained by changing the\nsign of its imaginary part."
            }
          ],
          "type": "paragraph"
        }
      ],
