  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the outer product of two vectors."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Given two vectors "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "b"
            },
            {
              "kind": "text",
              "text": " of length "
            },
            {
              "kind": "code",
              "text": "M"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "N"
            },
            {
              "kind": "text",
              "text": ", respectively,\nthe outer product "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": " is:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "[[a_0*b_0  a_0*b_1 ... a_0*b_{N-1} ]\n [a_1*b_0    .\n [ ...          .\n [a_{M-1}*b_0            a_{M-1}*b_{N-1} ]]",
          "type": "literal_block"
        }
      ],
      "title": "Extended Summary"
    },
