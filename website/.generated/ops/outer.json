    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nG. H. Golub and C. F. Van Loan, Matrix Computations, 3rd\ned., Baltimore, MD, Johns Hopkins University Press, 1996,\npg. 8.",
