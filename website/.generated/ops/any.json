      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.any([[True, False], [True, True]])"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.any([[True,  False, True ],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[False, False, False]], axis=0)"
            },
            {
              "kind": "output",
              "text": "array([ True, False, True])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.any([-1, 0, 5])"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.any([[fnp.nan], [fnp.inf]], axis=1, keepdims=True)"
            },
            {
              "kind": "output",
              "text": "array([[ True],"
            },
            {
              "kind": "output",
              "text": "       [ True]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.any([[True, False], [False, False]], where=[[False], [True]])"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([[1, 0, 0],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0, 0, 1],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0, 0, 0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.any(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([ True, False,  True])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.any(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([ True,  True, False])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "o=fnp.array(False)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "z=fnp.any([-1, 4, 5], out=o)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "z, o"
            },
            {
              "kind": "output",
              "text": "(array(True), array(True))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Check now that z is a reference to o"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "z is o"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "id(z), id(o) # identity of z and o              # doctest: +SKIP"
            },
            {
              "kind": "output",
              "text": "(191614240, 191614240)"
            }
          ],
          "type": "doctest_block"
        }
      ],
