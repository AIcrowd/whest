                      "text": "any"
                    },
                    {
                      "kind": "text",
                      "text": " method of sub-classes of\n"
                    },
                    {
                      "kind": "code",
                      "text": "ndarray"
                    },
                    {
                      "kind": "text",
                      "text": ", however any non-default value will be.  If the\nsub-class' method does not implement "
                    },
                    {
                      "kind": "code",
                      "text": "keepdims"
                    },
                    {
                      "kind": "text",
                      "text": " any\nexceptions will be raised."
                    }
