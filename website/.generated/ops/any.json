  "example": {
    "code": "import flopscope as fnp\n\nfnp.any([[True, False], [True, True]])\n\nfnp.any([[True,  False, True ],\n        [False, False, False]], axis=0)\n\nfnp.any([-1, 0, 5])\n\nfnp.any([[fnp.nan], [fnp.inf]], axis=1, keepdims=True)\n\nfnp.any([[True, False], [False, False]], where=[[False], [True]])\n\na = fnp.array([[1, 0, 0],\n              [0, 0, 1],\n              [0, 0, 0]])\n\nfnp.any(a, axis=0)\n\nfnp.any(a, axis=1)\n\no=fnp.array(False)\n\nz=fnp.any([-1, 4, 5], out=o)\n\nz, o\n\nz is o\n\nid(z), id(o) # identity of z and o              # doctest: +SKIP",
    "output": "True\n\narray([ True, False, True])\n\nTrue\n\narray([[ True],\n       [ True]])\n\nFalse\n\narray([ True, False,  True])\n\narray([ True,  True, False])\n\n(array(True), array(True))\n\nTrue\n\n(191614240, 191614240)",
    "source": "derived"
  },
