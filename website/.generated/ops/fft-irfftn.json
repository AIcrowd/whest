              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The truncated or zero-padded input, transformed along the axes\nindicated by "
                    },
                    {
                      "kind": "code",
                      "text": "axes"
                    },
                    {
                      "kind": "text",
                      "text": ", or by a combination of "
                    },
                    {
                      "kind": "code",
                      "text": "s"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": ",\nas explained in the parameters section above.\nThe length of each transformed axis is as given by the corresponding\nelement of "
                    },
                    {
                      "kind": "code",
                      "text": "s"
                    },
                    {
                      "kind": "text",
                      "text": ", or the length of the input in every axis except for the\nlast one if "
                    },
                    {
                      "kind": "code",
                      "text": "s"
                    },
                    {
                      "kind": "text",
                      "text": " is not given.  In the final transformed axis the length\nof the output when "
                    },
                    {
                      "kind": "code",
                      "text": "s"
                    },
                    {
                      "kind": "text",
                      "text": " is not given is "
                    },
                    {
                      "kind": "code",
                      "text": "2*(m-1)"
                    },
                    {
                      "kind": "text",
                      "text": " where "
                    },
                    {
                      "kind": "code",
                      "text": "m"
                    },
                    {
                      "kind": "text",
                      "text": " is the\nlength of the final transformed axis of the input.  To get an odd\nnumber of output points in the final axis, "
                    },
                    {
                      "kind": "code",
                      "text": "s"
                    },
                    {
                      "kind": "text",
                      "text": " must be specified."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
