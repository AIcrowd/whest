  "example": {
    "code": "a = 5. # shape\n\ns = we.random.weibull(a, 1000)\n\nimport matplotlib.pyplot as plt\n\nx = we.arange(1,100.)/50.\n\ndef weib(x,n,a):\n    return (a / n) * (x / n)**(a - 1) * we.exp(-(x / n)**a)\n\ncount, bins, ignored = plt.hist(we.random.weibull(5.,1000))\n\nx = we.arange(1,100.)/50.\n\nscale = count.max()/weib(x, 1., 5.).max()\n\nplt.plot(x, weib(x, 1., 5.)*scale)\n\nplt.show()",
