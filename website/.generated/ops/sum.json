  "example": {
    "code": "import whest as we\n\nwe.sum([0.5, 1.5])\n\nwe.sum([0.5, 0.7, 0.2, 1.5], dtype=we.int32)\n\nwe.sum([[0, 1], [0, 5]])\n\nwe.sum([[0, 1], [0, 5]], axis=0)\n\nwe.sum([[0, 1], [0, 5]], axis=1)\n\nwe.sum([[0, 1], [we.nan, 5]], where=[False, True], axis=1)\n\nwe.ones(128, dtype=we.int8).sum(dtype=we.int8)\n\nwe.sum([10], initial=5)",
    "output": "2.0\n\nwe.int32(1)\n\n6\n\narray([0, 6])\n\narray([1, 5])\n\narray([1., 5.])\n\nwe.int8(-128)\n\n15",
