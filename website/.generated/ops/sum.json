                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": "\nhas an integer dtype of less precision than the default platform\ninteger.  In that case, if "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is signed then the platform integer\nis used while if "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is unsigned then an unsigned integer of the\nsame precision as the platform integer is used."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "dtype, optional",
              "inline": [
