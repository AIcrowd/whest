    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([[4, 9, 2, 10],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[6, 9, 7, 12]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ptp(x, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([8, 6])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ptp(x, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([2, 0, 5, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ptp(x)"
            },
            {
              "kind": "output",
              "text": "10"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This example shows that a negative value can be returned when\nthe input is an array of signed integers."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([[1, 127],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0, 127],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[-1, 127],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[-2, 127]], dtype=we.int8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ptp(y, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([ 126,  127, -128, -127], dtype=int8)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "A work-around is to use the "
            },
            {
              "kind": "code",
              "text": "view()"
            },
            {
              "kind": "text",
              "text": " method to view the result as\nunsigned integers with the same bit width:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ptp(y, axis=1).view(we.uint8)"
            },
            {
              "kind": "output",
              "text": "array([126, 127, 128, 129], dtype=uint8)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
