  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Range of values (maximum - minimum) along an axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The name of the function comes from the acronym for 'peak to peak'."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "external_url": "",
                  "href": "/docs/api/ops/ptp",
                  "kind": "link",
                  "target": "ptp",
                  "text": "ptp"
                },
                {
                  "kind": "text",
                  "text": " preserves the data type of the array. This means the\nreturn value for an input of signed integers with n bits\n(e.g. "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.int8.html",
                  "href": "",
                  "kind": "link",
                  "target": "int8",
                  "text": "we.int8"
                },
                {
                  "kind": "text",
                  "text": ", "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.int16.html",
                  "href": "",
                  "kind": "link",
                  "target": "int16",
                  "text": "we.int16"
                },
                {
                  "kind": "text",
                  "text": ", etc) is also a signed integer\nwith n bits.  In that case, peak-to-peak values greater than\n"
                },
                {
                  "kind": "code",
                  "text": "2**(n-1)-1"
                },
                {
                  "kind": "text",
                  "text": " will be returned as negative values. An example\nwith a work-around is shown below."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "warning",
          "options": [],
          "raw_source": ".. warning::\n    `ptp` preserves the data type of the array. This means the\n    return value for an input of signed integers with n bits\n    (e.g. `we.int8`, `we.int16`, etc) is also a signed integer\n    with n bits.  In that case, peak-to-peak values greater than\n    ``2**(n-1)-1`` will be returned as negative values. An example\n    with a work-around is shown below.",
          "supported": true,
          "type": "directive_block"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input values."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input values."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axis along which to find the peaks.  By default, flatten the\narray.  "
                    },
                    {
                      "kind": "code",
                      "text": "axis"
                    },
                    {
                      "kind": "text",
                      "text": " may be negative, in\nwhich case it counts from the last to the first axis.\nIf this is a tuple of ints, a reduction is performed on multiple\naxes, instead of a single axis or all the axes as before."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "None or int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Axis along which to find the peaks.  By default, flatten the\narray.  "
                },
                {
                  "kind": "code",
                  "text": "axis"
                },
                {
                  "kind": "text",
                  "text": " may be negative, in\nwhich case it counts from the last to the first axis.\nIf this is a tuple of ints, a reduction is performed on multiple\naxes, instead of a single axis or all the axes as before."
                }
              ],
              "name": "axis",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Alternative output array in which to place the result. It must\nhave the same shape and buffer length as the expected output,\nbut the type of the output values will be cast if necessary."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Alternative output array in which to place the result. It must\nhave the same shape and buffer length as the expected output,\nbut the type of the output values will be cast if necessary."
                }
              ],
              "name": "out",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the input array."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If the default value is passed, then "
                    },
                    {
                      "kind": "code",
                      "text": "keepdims"
                    },
                    {
                      "kind": "text",
                      "text": " will not be\npassed through to the "
                    },
                    {
                      "external_url": "",
                      "href": "/docs/api/ops/ptp",
                      "kind": "link",
                      "target": "ptp",
                      "text": "ptp"
                    },
                    {
                      "kind": "text",
                      "text": " method of sub-classes of\n"
                    },
                    {
                      "kind": "code",
                      "text": "ndarray"
                    },
                    {
                      "kind": "text",
                      "text": ", however any non-default value will be.  If the\nsub-class' method does not implement "
                    },
                    {
                      "kind": "code",
                      "text": "keepdims"
                    },
                    {
                      "kind": "text",
                      "text": " any\nexceptions will be raised."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the input array."
                }
              ],
              "name": "keepdims",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
