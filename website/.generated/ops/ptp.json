  "example": {
    "code": "import whest as we\n\nx = we.array([[4, 9, 2, 10],\n              [6, 9, 7, 12]])\n\nwe.ptp(x, axis=1)\n\nwe.ptp(x, axis=0)\n\nwe.ptp(x)\n\ny = we.array([[1, 127],\n              [0, 127],\n              [-1, 127],\n              [-2, 127]], dtype=we.int8)\n\nwe.ptp(y, axis=1)\n\nwe.ptp(y, axis=1).view(we.uint8)",
    "output": "array([8, 6])\n\narray([2, 0, 5, 2])\n\n10\n\narray([ 126,  127, -128, -127], dtype=int8)\n\narray([126, 127, 128, 129], dtype=uint8)",
