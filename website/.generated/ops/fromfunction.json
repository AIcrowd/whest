          "inline": [
            {
              "kind": "text",
              "text": "Construct an array by executing a function over each coordinate."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The resulting array therefore has a value "
            },
            {
              "kind": "code",
              "text": "fn(x, y, z)"
            },
            {
              "kind": "text",
              "text": " at\ncoordinate "
            },
            {
              "kind": "code",
              "text": "(x, y, z)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
