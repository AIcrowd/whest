                      "external_url": "",
                      "href": "/docs/api/ops/shape",
                      "kind": "link",
                      "target": "shape",
                      "text": "shape"
                    },
                    {
                      "kind": "text",
                      "text": ".  Each parameter represents the coordinates of the array\nvarying along a specific axis.  For example, if "
                    },
                    {
                      "external_url": "",
                      "href": "/docs/api/ops/shape",
                      "kind": "link",
                      "target": "shape",
                      "text": "shape"
                    },
                    {
                      "kind": "text",
                      "text": "\nwere "
                    },
                    {
                      "kind": "code",
                      "text": "(2, 2)"
                    },
                    {
                      "kind": "text",
                      "text": ", then the parameters would be\n"
                    },
                    {
                      "kind": "code",
                      "text": "array([[0, 0], [1, 1]])"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "array([[0, 1], [0, 1]])"
                    }
                  ],
                  "type": "paragraph"
                }
