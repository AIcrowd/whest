              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.count_nonzero(fnp.eye(4))"
            },
            {
              "kind": "output",
              "text": "fnp.int64(4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([[0, 1, 7, 0],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[3, 0, 2, 19]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.count_nonzero(a)"
            },
            {
              "kind": "output",
              "text": "fnp.int64(5)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.count_nonzero(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([1, 1, 2, 1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.count_nonzero(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.count_nonzero(a, axis=1, keepdims=True)"
            },
            {
              "kind": "output",
              "text": "array([[2],"
            },
            {
              "kind": "output",
              "text": "       [3]])"
            }
