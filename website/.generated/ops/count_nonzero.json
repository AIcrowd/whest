  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Counts the number of non-zero values in the array "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The word \"non-zero\" is in reference to the Python 2.x\nbuilt-in method "
            },
            {
              "kind": "code",
              "text": "__nonzero__()"
            },
            {
              "kind": "text",
              "text": " (renamed "
            },
            {
              "kind": "code",
              "text": "__bool__()"
            },
            {
              "kind": "text",
              "text": "\nin Python 3.x) of Python objects that tests an object's\n\"truthfulness\". For example, any number is considered\ntruthful if it is nonzero, whereas any string is considered\ntruthful if it is not the empty string. Thus, this function\n(recursively) counts how many elements in "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " (and in\nsub-arrays thereof) have their "
            },
            {
              "kind": "code",
              "text": "__nonzero__()"
            },
            {
              "kind": "text",
              "text": " or "
            },
            {
              "kind": "code",
              "text": "__bool__()"
            },
            {
              "kind": "text",
              "text": "\nmethod evaluated to "
            },
            {
              "kind": "code",
              "text": "True"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The array for which to count non-zeros."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "The array for which to count non-zeros."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axis or tuple of axes along which to count non-zeros.\nDefault is None, meaning that non-zeros will be counted\nalong a flattened version of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Axis or tuple of axes along which to count non-zeros.\nDefault is None, meaning that non-zeros will be counted\nalong a flattened version of "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "axis",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If this is set to True, the axes that are counted are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the input array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If this is set to True, the axes that are counted are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the input array."
                }
              ],
              "name": "keepdims",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
