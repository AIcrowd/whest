    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "NaN values are propagated, that is if at least one item is NaN, the\ncorresponding min value will be NaN as well. To ignore NaN values\n(MATLAB behavior), please use nanmin."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Don't use "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/min",
              "kind": "link",
              "target": "min",
              "text": "min"
            },
            {
              "kind": "text",
              "text": " for element-wise comparison of 2 arrays; when\n"
            },
            {
              "kind": "code",
              "text": "a.shape[0]"
            },
            {
              "kind": "text",
              "text": " is 2, "
            },
            {
              "kind": "code",
              "text": "minimum(a[0], a[1])"
            },
            {
              "kind": "text",
              "text": " is faster than\n"
            },
            {
              "kind": "code",
              "text": "min(a, axis=0)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.arange(4).reshape((2,2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min(a)           # Minimum of the flattened array"
            },
            {
              "kind": "output",
              "text": "0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min(a, axis=0)   # Minima along the first axis"
            },
            {
              "kind": "output",
              "text": "array([0, 1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min(a, axis=1)   # Minima along the second axis"
            },
            {
              "kind": "output",
              "text": "array([0, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min(a, where=[False, True], initial=10, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([10,  1])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = fnp.arange(5, dtype=float)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b[2] = fnp.nan"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min(b)"
            },
            {
              "kind": "output",
              "text": "fnp.float64(nan)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min(b, where=~fnp.isnan(b), initial=10)"
            },
            {
              "kind": "output",
              "text": "0.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.nanmin(b)"
            },
            {
              "kind": "output",
              "text": "0.0"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min([[-50], [10]], axis=-1, initial=0)"
            },
            {
              "kind": "output",
              "text": "array([-50,   0])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Notice that the initial value is used as one of the elements for which the\nminimum is determined, unlike for the default argument Python's max\nfunction, which is only used for empty iterables."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Notice that this isn't the same as Python's "
            },
            {
              "kind": "code",
              "text": "default"
            },
            {
              "kind": "text",
              "text": " argument."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.min([6], initial=5)"
            },
            {
              "kind": "output",
              "text": "5"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "min([6], default=5)"
            },
            {
              "kind": "output",
              "text": "6"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
