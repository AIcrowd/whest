  "example": {
    "code": "import flopscope as fnp\n\na = fnp.arange(4).reshape((2,2))\n\na\n\nfnp.min(a)           # Minimum of the flattened array\n\nfnp.min(a, axis=0)   # Minima along the first axis\n\nfnp.min(a, axis=1)   # Minima along the second axis\n\nfnp.min(a, where=[False, True], initial=10, axis=0)\n\nb = fnp.arange(5, dtype=float)\n\nb[2] = fnp.nan\n\nfnp.min(b)\n\nfnp.min(b, where=~fnp.isnan(b), initial=10)\n\nfnp.nanmin(b)\n\nfnp.min([[-50], [10]], axis=-1, initial=0)\n\nfnp.min([6], initial=5)\n\nmin([6], default=5)",
    "output": "array([[0, 1],\n       [2, 3]])\n\n0\n\narray([0, 1])\n\narray([0, 2])\n\narray([10,  1])\n\nfnp.float64(nan)\n\n0.0\n\n0.0\n\narray([-50,   0])\n\n5\n\n6",
    "source": "derived"
  },
