          "inline": [
            {
              "kind": "text",
              "text": "Return the indices of the maximum values in the specified axis ignoring NaNs. For all-NaN slices "
            },
            {
              "kind": "code",
              "text": "ValueError"
            },
            {
              "kind": "text",
              "text": " is raised. Warning: the results cannot be trusted if a slice contains only NaNs and -Infs."
            }
          ],
          "type": "paragraph"
        }
