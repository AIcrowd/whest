                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "((before_1, after_1), ... (before_N, after_N))"
                    },
                    {
                      "kind": "text",
                      "text": " unique pad constants\nfor each axis."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "(before, after)"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "((before, after),)"
                    },
                    {
                      "kind": "text",
                      "text": " yields same before\nand after constants for each axis."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "(constant,)"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "constant"
