                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "((before, after),)"
                    },
                    {
                      "kind": "text",
                      "text": " yields same before\nand after end values for each axis."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "(constant,)"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "constant"
                    },
                    {
                      "kind": "text",
                      "text": " is a shortcut for\n"
                    },
                    {
                      "kind": "code",
                      "text": "before = after = constant"
                    },
                    {
                      "kind": "text",
                      "text": " for all axes."
                    }
