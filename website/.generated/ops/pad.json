                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "Pads with the minimum value of all or part of the\nvector along each axis."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ],
                      "term_inline": [
                        {
                          "kind": "text",
                          "text": "'minimum'"
