    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The array to pad."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like of rank N",
              "inline": [
                {
                  "kind": "text",
                  "text": "The array to pad."
