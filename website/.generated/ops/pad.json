                {
                  "kind": "code",
                  "text": "(before, after)"
                },
                {
                  "kind": "text",
                  "text": " or "
                },
                {
                  "kind": "code",
                  "text": "((before, after),)"
                },
                {
                  "kind": "text",
                  "text": " yields same before\nand after pad for each axis.\n"
                },
                {
                  "kind": "code",
                  "text": "(pad,)"
