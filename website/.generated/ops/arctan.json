          "inline": [
            {
              "kind": "text",
              "text": "Trigonometric inverse tangent, element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The inverse of tan, so that if "
            },
            {
              "kind": "code",
              "text": "y = tan(x)"
            },
            {
              "kind": "text",
              "text": " then "
            },
            {
              "kind": "code",
              "text": "x = arctan(y)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
