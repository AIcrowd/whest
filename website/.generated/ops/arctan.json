    "code": "import whest as we\n\nwe.arctan([0, 1])\n\nwe.pi/4\n\nimport matplotlib.pyplot as plt\n\nx = we.linspace(-10, 10)\n\nplt.plot(x, we.arctan(x))\n\nplt.axis('tight')\n\nplt.show()",
