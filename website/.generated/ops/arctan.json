            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "We expect the arctan of 0 to be 0, and of 1 to be pi/4:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.arctan([0, 1])"
            },
            {
              "kind": "output",
              "text": "array([ 0.        ,  0.78539816])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.pi/4"
            },
            {
              "kind": "output",
              "text": "0.78539816339744828"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Plot arctan:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.linspace(-10, 10)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(x, we.arctan(x))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.axis('tight')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
