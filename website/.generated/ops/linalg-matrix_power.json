  "area": "linalg",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Raise a square matrix to the (integer) power "
            },
            {
              "kind": "code",
              "text": "n"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "For positive integers "
            },
            {
              "kind": "code",
              "text": "n"
            },
            {
              "kind": "text",
              "text": ", the power is computed by repeated matrix\nsquarings and matrix multiplications. If "
            },
            {
              "kind": "code",
              "text": "n == 0"
            },
            {
              "kind": "text",
              "text": ", the identity matrix\nof the same shape as M is returned. If "
            },
            {
              "kind": "code",
              "text": "n < 0"
            },
            {
              "kind": "text",
              "text": ", the inverse\nis computed and then raised to the "
            },
            {
              "kind": "code",
              "text": "abs(n)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [
            {
              "kind": "text",
              "text": "Stacks of object matrices are not currently supported."
            }
          ],
          "content_blocks": [],
          "directive": "note",
          "options": [],
          "raw_source": ".. note:: Stacks of object matrices are not currently supported.",
          "supported": true,
          "type": "directive_block"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Matrix to be \"powered\"."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "(..., M, M) array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Matrix to be \"powered\"."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The exponent can be any integer or long integer, positive,\nnegative, or zero."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int",
              "inline": [
                {
                  "kind": "text",
                  "text": "The exponent can be any integer or long integer, positive,\nnegative, or zero."
                }
              ],
              "name": "n",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The return value is the same shape and type as "
                    },
                    {
                      "kind": "code",
                      "text": "M"
                    },
                    {
                      "kind": "text",
                      "text": ";\nif the exponent is positive or zero then the type of the\nelements is the same as those of "
                    },
                    {
                      "kind": "code",
                      "text": "M"
                    },
                    {
                      "kind": "text",
                      "text": ". If the exponent is\nnegative the elements are floating-point."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
