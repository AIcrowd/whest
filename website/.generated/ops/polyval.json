  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Evaluate a polynomial at specific values."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "This forms part of the old polynomial API. Since version 1.4, the\nnew polynomial API defined in "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.polynomial.html",
                  "href": "",
                  "kind": "link",
                  "target": "polynomial",
                  "text": "we.polynomial"
                },
                {
                  "kind": "text",
                  "text": " is preferred.\nA summary of the differences can be found in the\n"
                },
                {
                  "display_text": "transition guide",
                  "explicit_title": true,
                  "external_url": "",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "/reference/routines.polynomials",
                  "role": "doc",
                  "suppress_link": false,
                  "target": "/reference/routines.polynomials",
                  "unresolved": true
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n   This forms part of the old polynomial API. Since version 1.4, the\n   new polynomial API defined in `we.polynomial` is preferred.\n   A summary of the differences can be found in the\n   :doc:`transition guide </reference/routines.polynomials>`.",
          "supported": true,
          "type": "directive_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " is of length N, this function returns the value:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "p[0]*x**(N-1) + p[1]*x**(N-2) + ... + p[N-2]*x + p[N-1]",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is a sequence, then "
            },
            {
              "kind": "code",
              "text": "p(x)"
            },
            {
              "kind": "text",
              "text": " is returned for each element of "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": ".\nIf "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is another polynomial then the composite polynomial "
            },
            {
              "kind": "code",
              "text": "p(x(t))"
            },
            {
              "kind": "text",
              "text": "\nis returned."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "1D array of polynomial coefficients (including coefficients equal\nto zero) from highest degree to the constant term, or an\ninstance of poly1d."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like or poly1d object",
              "inline": [
                {
                  "kind": "text",
                  "text": "1D array of polynomial coefficients (including coefficients equal\nto zero) from highest degree to the constant term, or an\ninstance of poly1d."
                }
              ],
              "name": "p",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A number, an array of numbers, or an instance of poly1d, at\nwhich to evaluate "
                    },
                    {
                      "kind": "code",
                      "text": "p"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like or poly1d object",
              "inline": [
                {
                  "kind": "text",
                  "text": "A number, an array of numbers, or an instance of poly1d, at\nwhich to evaluate "
                },
                {
                  "kind": "code",
                  "text": "p"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "x",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " is a poly1d instance, the result is the composition of the two\npolynomials, i.e., "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " is \"substituted\" in "
                    },
                    {
                      "kind": "code",
                      "text": "p"
                    },
                    {
                      "kind": "text",
                      "text": " and the simplified\nresult is returned. In addition, the type of "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " - array_like or\npoly1d - governs the type of the output: "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " array_like => "
                    },
                    {
                      "kind": "code",
                      "text": "values"
                    },
                    {
                      "kind": "text",
                      "text": "\narray_like, "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " a poly1d object => "
                    },
                    {
                      "kind": "code",
                      "text": "values"
                    },
                    {
                      "kind": "text",
                      "text": " is also."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
