  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Dot product of two arrays. Specifically,"
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If both "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": " are 1-D arrays, it is inner product of vectors\n(without complex conjugation)."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If both "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": " are 2-D arrays, it is matrix multiplication,\nbut using "
                    },
                    {
                      "display_text": "matmul",
                      "explicit_title": false,
                      "external_url": "",
                      "href": "/docs/api/ops/matmul",
                      "kind": "role_reference",
                      "original_target": "matmul",
                      "role": "func",
                      "suppress_link": false,
                      "target": "matmul",
                      "unresolved": false
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "a @ b"
                    },
                    {
                      "kind": "text",
                      "text": " is preferred."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If either "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": " is 0-D (scalar), it is equivalent to\n"
                    },
                    {
                      "display_text": "multiply",
                      "explicit_title": false,
                      "external_url": "",
                      "href": "/docs/api/ops/multiply",
                      "kind": "role_reference",
                      "original_target": "multiply",
                      "role": "func",
                      "suppress_link": false,
                      "target": "multiply",
                      "unresolved": false
                    },
                    {
                      "kind": "text",
                      "text": " and using "
                    },
                    {
                      "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.multiply(a, b).html",
                      "href": "",
                      "kind": "link",
                      "target": "multiply(a, b)",
                      "text": "we.multiply(a, b)"
                    },
                    {
                      "kind": "text",
                      "text": " or "
                    },
                    {
                      "kind": "code",
                      "text": "a * b"
                    },
                    {
                      "kind": "text",
                      "text": " is\npreferred."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is an N-D array and "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": " is a 1-D array, it is a sum product over\nthe last axis of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is an N-D array and "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": " is an M-D array (where "
                    },
                    {
                      "kind": "code",
                      "text": "M>=2"
                    },
                    {
                      "kind": "text",
                      "text": "), it is a\nsum product over the last axis of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " and the second-to-last axis of\n"
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": ":"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "language": null,
                  "text": "dot(a, b)[i,j,k,m] = sum(a[i,j,:] * b[k,:,m])",
                  "type": "literal_block"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "It uses an optimized BLAS library when possible (see "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.linalg.html",
              "href": "",
              "kind": "link",
              "target": "linalg",
              "text": "we.linalg"
            },
            {
              "kind": "text",
              "text": ")."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "First argument."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "First argument."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Second argument."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Second argument."
                }
              ],
              "name": "b",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output argument. This must have the exact kind that would be returned\nif it was not used. In particular, it must have the right type, must be\nC-contiguous, and its dtype must be the dtype that would be returned\nfor "
                    },
                    {
                      "kind": "code",
                      "text": "dot(a,b)"
                    },
                    {
                      "kind": "text",
                      "text": ". This is a performance feature. Therefore, if these\nconditions are not met, an exception is raised, instead of attempting\nto be flexible."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Output argument. This must have the exact kind that would be returned\nif it was not used. In particular, it must have the right type, must be\nC-contiguous, and its dtype must be the dtype that would be returned\nfor "
                },
                {
                  "kind": "code",
                  "text": "dot(a,b)"
                },
                {
                  "kind": "text",
                  "text": ". This is a performance feature. Therefore, if these\nconditions are not met, an exception is raised, instead of attempting\nto be flexible."
                }
              ],
              "name": "out",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
