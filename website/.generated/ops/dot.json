                  "inline": [
                    {
                      "kind": "text",
                      "text": "Returns the dot product of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": ".  If "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "b"
                    },
                    {
                      "kind": "text",
                      "text": " are both\nscalars or both 1-D arrays then a scalar is returned; otherwise\nan array is returned.\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "out"
                    },
                    {
                      "kind": "text",
                      "text": " is given, then it is returned."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
