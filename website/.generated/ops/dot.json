    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.dot(3, 4)"
            },
            {
              "kind": "output",
              "text": "12"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Neither argument is complex-conjugated:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.dot([2j, 3j], [2j, 3j])"
            },
            {
              "kind": "output",
              "text": "(-13+0j)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For 2-D arrays it is the matrix product:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = [[1, 0], [0, 1]]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = [[4, 1], [2, 2]]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.dot(a, b)"
            },
            {
              "kind": "output",
              "text": "array([[4, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 2]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(3*4*5*6).reshape((3,4,5,6))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.arange(3*4*5*6)[::-1].reshape((5,4,6,3))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.dot(a, b)[2,3,2,1,2,2]"
            },
            {
              "kind": "output",
              "text": "499128"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sum(a[2,3,2,:] * b[1,2,:,2])"
            },
            {
              "kind": "output",
              "text": "499128"
            }
          ],
          "type": "doctest_block"
        }
      ],
