  "example": {
    "code": "import whest as we\n\nwe.dot(3, 4)\n\nwe.dot([2j, 3j], [2j, 3j])\n\na = [[1, 0], [0, 1]]\n\nb = [[4, 1], [2, 2]]\n\nwe.dot(a, b)\n\na = we.arange(3*4*5*6).reshape((3,4,5,6))\n\nb = we.arange(3*4*5*6)[::-1].reshape((5,4,6,3))\n\nwe.dot(a, b)[2,3,2,1,2,2]\n\nsum(a[2,3,2,:] * b[1,2,:,2])",
