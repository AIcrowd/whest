  "example": {
    "code": "import whest as we\n\nwe.prod([1.,2.])\n\na = we.array([[1., 2.], [3., 4.]])\n\nwe.prod(a)\n\nwe.prod(a, axis=1)\n\nwe.prod(a, axis=0)\n\nwe.prod([1., we.nan, 3.], where=[True, False, True])\n\nx = we.array([1, 2, 3], dtype=we.uint8)\n\nwe.prod(x).dtype == we.uint\n\nx = we.array([1, 2, 3], dtype=we.int8)\n\nwe.prod(x).dtype == int\n\nwe.prod([1, 2], initial=5)",
    "output": "2.0\n\n24.0\n\narray([  2.,  12.])\n\narray([3., 8.])\n\n3.0\n\nTrue\n\nTrue\n\n10",
    "source": "derived"
  },
