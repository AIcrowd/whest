{
  "aliases": [],
  "api_docs_html": "",
  "area": "linalg",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute tensor dot product along specified axes."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Given two tensors, "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "b"
            },
            {
              "kind": "text",
              "text": ", and an array_like object containing\ntwo array_like objects, "
            },
            {
              "kind": "code",
              "text": "(a_axes, b_axes)"
            },
            {
              "kind": "text",
              "text": ", sum the products of\n"
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": "'s and "
            },
            {
              "kind": "code",
              "text": "b"
            },
            {
              "kind": "text",
              "text": "'s elements (components) over the axes specified by\n"
            },
            {
              "kind": "code",
              "text": "a_axes"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "b_axes"
            },
            {
              "kind": "text",
              "text": ". The third argument can be a single non-negative\ninteger_like scalar, "
            },
            {
              "kind": "code",
              "text": "N"
            },
            {
              "kind": "text",
              "text": "; if it is such, then the last "
            },
            {
              "kind": "code",
              "text": "N"
            },
            {
              "kind": "text",
              "text": " dimensions\nof "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " and the first "
            },
            {
              "kind": "code",
              "text": "N"
            },
            {
              "kind": "text",
              "text": " dimensions of "
            },
            {
              "kind": "code",
              "text": "b"
            },
            {
              "kind": "text",
              "text": " are summed over."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Tensors to \"dot\"."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Tensors to \"dot\"."
                }
              ],
              "name": "a, b",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "integer_like\nIf an int N, sum over the last N axes of "
                            },
                            {
                              "kind": "code",
                              "text": "a"
                            },
                            {
                              "kind": "text",
                              "text": " and the first N axes\nof "
                            },
                            {
                              "kind": "code",
                              "text": "b"
                            },
                            {
                              "kind": "text",
                              "text": " in order. The sizes of the corresponding axes must match."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "(2,) array_like\nOr, a list of axes to be summed over, first sequence applying to "
                            },
                            {
                              "kind": "code",
                              "text": "a"
                            },
                            {
                              "kind": "text",
                              "text": ",\nsecond to "
                            },
                            {
                              "kind": "code",
                              "text": "b"
                            },
                            {
                              "kind": "text",
                              "text": ". Both elements array_like must be of the same length."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    }
                  ],
                  "ordered": false,
                  "type": "list"
                }
              ],
              "data_type": "int or (2,) array_like",
              "inline": [],
              "name": "axes",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The tensor dot product of the input."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray",
              "inline": [
                {
                  "kind": "text",
                  "text": "The tensor dot product of the input."
                }
              ],
              "name": "output",
              "type": "field_list"
            }
          ],
          "title": "Returns",
          "type": "field_list"
        }
      ],
      "title": "Returns"
    },
