          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n    This is a convenience function for users porting code from Matlab,\n    and wraps `random_sample`. That function takes a\n    tuple to specify the size of the output, which is consistent with\n    other NumPy functions like `fnp.zeros` and `fnp.ones`.",
          "supported": true,
          "type": "directive_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Create an array of the given shape and populate it with\nrandom samples from a uniform distribution\nover "
            },
            {
              "kind": "code",
              "text": "[0, 1)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
