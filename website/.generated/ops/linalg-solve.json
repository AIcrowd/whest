          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Computes the \"exact\" solution, "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": ", of the well-determined, i.e., full\nrank, linear matrix equation "
            },
            {
              "kind": "code",
              "text": "ax = b"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
