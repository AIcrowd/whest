              "explicit_title": false,
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.seeding_and_entropy.html",
              "href": "",
              "kind": "role_reference",
              "original_target": "seeding_and_entropy",
              "role": "ref",
              "suppress_link": false,
