  "example": {
    "code": "import whest as we\n\nrng = we.random.default_rng(12345)\n\nprint(rng)\n\nrfloat = rng.random()\n\nrfloat\n\ntype(rfloat)\n\nimport whest as we\n\nrng = we.random.default_rng(12345)\n\nrints = rng.integers(low=0, high=10, size=3)\n\nrints\n\ntype(rints[0])\n\nimport whest as we\n\nrng = we.random.default_rng(seed=42)\n\nprint(rng)\n\narr1 = rng.random((3, 3))\n\narr1\n\nimport whest as we\n\nrng = we.random.default_rng(seed=42)\n\narr2 = rng.random((3, 3))\n\narr2",
    "output": "Generator(PCG64)\n\n0.22733602246716966\n\n<class 'float'>\n\narray([6, 2, 7])\n\n<class 'we.int64'>\n\nGenerator(PCG64)\n\narray([[0.77395605, 0.43887844, 0.85859792],\n       [0.69736803, 0.09417735, 0.97562235],\n       [0.7611397 , 0.78606431, 0.12811363]])\n\narray([[0.77395605, 0.43887844, 0.85859792],\n       [0.69736803, 0.09417735, 0.97562235],\n       [0.7611397 , 0.78606431, 0.12811363]])",
    "source": "derived"
