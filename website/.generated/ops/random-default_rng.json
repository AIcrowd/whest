        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "default_rng"
            },
            {
              "kind": "text",
              "text": " is the recommended constructor for the random number class\n"
            },
            {
              "kind": "code",
              "text": "Generator"
            },
            {
              "kind": "text",
              "text": ". Here are several ways we can construct a random\nnumber generator using "
            },
            {
              "kind": "code",
              "text": "default_rng"
            },
            {
              "kind": "text",
              "text": " and the "
            },
            {
              "kind": "code",
              "text": "Generator"
            },
            {
              "kind": "text",
              "text": " class."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Here we use "
            },
            {
              "kind": "code",
              "text": "default_rng"
            },
            {
              "kind": "text",
              "text": " to generate a random float:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = we.random.default_rng(12345)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "print(rng)"
            },
            {
              "kind": "output",
              "text": "Generator(PCG64)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rfloat = rng.random()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rfloat"
            },
            {
              "kind": "output",
              "text": "0.22733602246716966"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "type(rfloat)"
            },
            {
              "kind": "output",
              "text": "<class 'float'>"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Here we use "
            },
            {
              "kind": "code",
              "text": "default_rng"
            },
            {
              "kind": "text",
              "text": " to generate 3 random integers between 0\n(inclusive) and 10 (exclusive):"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = we.random.default_rng(12345)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rints = rng.integers(low=0, high=10, size=3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rints"
            },
            {
              "kind": "output",
              "text": "array([6, 2, 7])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "type(rints[0])"
            },
            {
              "kind": "output",
              "text": "<class 'we.int64'>"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Here we specify a seed so that we have reproducible results:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = we.random.default_rng(seed=42)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "print(rng)"
            },
            {
              "kind": "output",
              "text": "Generator(PCG64)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr1 = rng.random((3, 3))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr1"
            },
            {
              "kind": "output",
              "text": "array([[0.77395605, 0.43887844, 0.85859792],"
            },
            {
              "kind": "output",
              "text": "       [0.69736803, 0.09417735, 0.97562235],"
            },
            {
              "kind": "output",
              "text": "       [0.7611397 , 0.78606431, 0.12811363]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If we exit and restart our Python interpreter, we'll see that we\ngenerate the same random numbers again:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = we.random.default_rng(seed=42)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr2 = rng.random((3, 3))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr2"
            },
            {
              "kind": "output",
              "text": "array([[0.77395605, 0.43887844, 0.85859792],"
            },
            {
              "kind": "output",
              "text": "       [0.69736803, 0.09417735, 0.97562235],"
            },
            {
              "kind": "output",
              "text": "       [0.7611397 , 0.78606431, 0.12811363]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
