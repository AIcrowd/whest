    {
      "blocks": [
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/ops/arcsin",
              "kind": "link",
              "target": "arcsin",
              "text": "arcsin"
            },
            {
              "kind": "text",
              "text": " is a multivalued function: for each "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " there are infinitely\nmany numbers "
            },
            {
              "kind": "code",
              "text": "z"
            },
            {
              "kind": "text",
              "text": " such that "
            },
            {
              "kind": "math",
              "latex": "sin(z) = x"
            },
            {
              "kind": "text",
              "text": ".  The convention is to\nreturn the angle "
            },
            {
              "kind": "code",
              "text": "z"
            },
            {
              "kind": "text",
              "text": " whose real part lies in [-pi/2, pi/2]."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For real-valued input data types, "
            },
            {
              "kind": "emphasis",
              "text": "arcsin"
            },
            {
              "kind": "text",
              "text": " always returns real output.\nFor each value that cannot be expressed as a real number or infinity,\nit yields "
            },
            {
              "kind": "code",
              "text": "nan"
            },
            {
              "kind": "text",
              "text": " and sets the "
            },
            {
              "kind": "code",
              "text": "invalid"
            },
            {
              "kind": "text",
              "text": " floating point error flag."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For complex-valued input, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/arcsin",
              "kind": "link",
              "target": "arcsin",
              "text": "arcsin"
            },
            {
              "kind": "text",
              "text": " is a complex analytic function that\nhas, by convention, the branch cuts [-inf, -1] and [1, inf]  and is\ncontinuous from above on the former and from below on the latter."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The inverse sine is also known as "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/arcsin",
              "kind": "link",
              "target": "arcsin",
              "text": "asin"
            },
            {
              "kind": "text",
              "text": " or sin^{-1}."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
