      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "For 2-D arrays it is the matrix product:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 0],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([[4, 1],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[2, 2]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.matmul(a, b)"
            },
            {
              "kind": "output",
              "text": "array([[4, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 2]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For 2-D mixed with 1-D, the result is the usual."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 0],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([1, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.matmul(a, b)"
            },
            {
              "kind": "output",
              "text": "array([1, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.matmul(b, a)"
            },
            {
              "kind": "output",
              "text": "array([1, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Broadcasting is conventional for stacks of arrays"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(2 * 2 * 4).reshape((2, 2, 4))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.arange(2 * 2 * 4).reshape((2, 4, 2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.matmul(a,b).shape"
            },
            {
              "kind": "output",
              "text": "(2, 2, 2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.matmul(a, b)[0, 1, 1]"
            },
            {
              "kind": "output",
              "text": "98"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sum(a[0, 1, :] * b[0 , :, 1])"
            },
            {
              "kind": "output",
              "text": "98"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Vector, vector returns the scalar inner product, but neither argument\nis complex-conjugated:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.matmul([2j, 3j], [2j, 3j])"
            },
            {
              "kind": "output",
              "text": "(-13+0j)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Scalar multiplication raises an error."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.matmul([1,2], 3)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "ValueError: matmul: Input operand 1 does not have enough dimensions ..."
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
