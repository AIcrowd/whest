      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "hfft"
            },
            {
              "kind": "text",
              "text": "/"
            },
            {
              "kind": "code",
              "text": "ihfft"
            },
            {
              "kind": "text",
              "text": " are a pair analogous to "
            },
            {
              "kind": "code",
              "text": "rfft"
            },
            {
              "kind": "text",
              "text": "/"
            },
            {
              "kind": "code",
              "text": "irfft"
            },
            {
              "kind": "text",
              "text": ", but for the\nopposite case: here the signal has Hermitian symmetry in the time\ndomain and is real in the frequency domain. So here it's "
            },
            {
              "kind": "code",
              "text": "hfft"
            },
            {
              "kind": "text",
              "text": " for\nwhich you must supply the length of the result if it is to be odd:"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "even: "
                    },
                    {
                      "kind": "code",
                      "text": "ihfft(hfft(a, 2*len(a) - 2)) == a"
                    },
                    {
                      "kind": "text",
                      "text": ", within roundoff error,"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "odd: "
                    },
                    {
                      "kind": "code",
                      "text": "ihfft(hfft(a, 2*len(a) - 1)) == a"
                    },
                    {
                      "kind": "text",
                      "text": ", within roundoff error."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "spectrum = we.array([ 15, -4, 0, -1, 0, -4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fft.ifft(spectrum)"
            },
            {
              "kind": "output",
              "text": "array([1.+0.j,  2.+0.j,  3.+0.j,  4.+0.j,  3.+0.j,  2.+0.j]) # may vary"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fft.ihfft(spectrum)"
            },
            {
              "kind": "output",
              "text": "array([ 1.-0.j,  2.-0.j,  3.-0.j,  4.-0.j]) # may vary"
            }
          ],
          "type": "doctest_block"
        }
      ],
