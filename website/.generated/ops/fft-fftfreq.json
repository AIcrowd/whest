  "area": "fft",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the Discrete Fourier Transform sample frequencies."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The returned float array "
            },
            {
              "kind": "code",
              "text": "f"
            },
            {
              "kind": "text",
              "text": " contains the frequency bin centers in cycles\nper unit of the sample spacing (with zero at the start).  For instance, if\nthe sample spacing is in seconds, then the frequency unit is cycles/second."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Given a window length "
            },
            {
              "kind": "code",
              "text": "n"
            },
            {
              "kind": "text",
              "text": " and a sample spacing "
            },
            {
              "kind": "code",
              "text": "d"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "f = [0, 1, ...,   n/2-1,     -n/2, ..., -1] / (d*n)   if n is even\nf = [0, 1, ..., (n-1)/2, -(n-1)/2, ..., -1] / (d*n)   if n is odd",
          "type": "literal_block"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Window length."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int",
              "inline": [
                {
                  "kind": "text",
                  "text": "Window length."
                }
              ],
              "name": "n",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Sample spacing (inverse of the sampling rate). Defaults to 1."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "scalar, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Sample spacing (inverse of the sampling rate). Defaults to 1."
                }
              ],
              "name": "d",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The device on which to place the created array. Default: "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": ".\nFor Array-API interoperability only, so must be "
                    },
                    {
                      "kind": "code",
                      "text": "\"cpu\""
                    },
                    {
                      "kind": "text",
                      "text": " if passed."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
