              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "signal = we.array([-2, 8, 6, 4, 1, 0, 3, 5], dtype=float)"
