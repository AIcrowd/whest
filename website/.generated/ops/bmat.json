          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "All the following expressions construct the same block matrix:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bmat([[A, B], [C, D]])"
            },
            {
              "kind": "output",
              "text": "matrix([[1, 1, 2, 2],"
            },
            {
              "kind": "output",
              "text": "        [1, 1, 2, 2],"
            },
            {
              "kind": "output",
              "text": "        [3, 4, 7, 8],"
            },
            {
              "kind": "output",
              "text": "        [5, 6, 9, 0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bmat(we.r_[we.c_[A, B], we.c_[C, D]])"
            },
            {
              "kind": "output",
              "text": "matrix([[1, 1, 2, 2],"
            },
            {
              "kind": "output",
              "text": "        [1, 1, 2, 2],"
            },
            {
              "kind": "output",
              "text": "        [3, 4, 7, 8],"
            },
            {
              "kind": "output",
              "text": "        [5, 6, 9, 0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.bmat('A,B; C,D')"
            },
            {
              "kind": "output",
              "text": "matrix([[1, 1, 2, 2],"
            },
            {
              "kind": "output",
              "text": "        [1, 1, 2, 2],"
