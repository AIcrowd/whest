  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from a multinomial distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The multinomial distribution is a multivariate generalization of the\nbinomial distribution.  Take an experiment with one of "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": "\npossible outcomes.  An example of such an experiment is throwing a dice,\nwhere the outcome can be 1 through 6.  Each sample drawn from the\ndistribution represents "
            },
            {
              "kind": "code",
              "text": "n"
            },
            {
              "kind": "text",
              "text": " such experiments.  Its values,\n"
            },
            {
              "kind": "code",
              "text": "X_i = [X_0, X_1, ..., X_p]"
            },
            {
              "kind": "text",
              "text": ", represent the number of times the\noutcome was "
            },
            {
              "kind": "code",
              "text": "i"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "New code should use the "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.multinomial.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator.multinomial",
                  "text": "multinomial"
                },
                {
                  "kind": "text",
                  "text": "\nmethod of a "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator",
                  "text": "Generator"
                },
                {
                  "kind": "text",
                  "text": " instance instead;\nplease see the "
                },
                {
                  "display_text": "random-quick-start",
                  "explicit_title": false,
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "random-quick-start",
                  "role": "ref",
                  "suppress_link": false,
                  "target": "random-quick-start",
                  "unresolved": false
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n    New code should use the `~we.random.Generator.multinomial`\n    method of a `~we.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
          "supported": true,
          "type": "directive_block"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "This function defaults to the C-long dtype, which is 32bit on windows\nand otherwise 64bit on 64bit platforms (and 32bit on 32bit ones).\nSince NumPy 2.0, NumPy's default integer is 32bit on 32bit platforms\nand 64bit on 64bit platforms."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "warning",
          "options": [],
          "raw_source": ".. warning::\n  This function defaults to the C-long dtype, which is 32bit on windows\n  and otherwise 64bit on 64bit platforms (and 32bit on 32bit ones).\n  Since NumPy 2.0, NumPy's default integer is 32bit on 32bit platforms\n  and 64bit on 64bit platforms.",
          "supported": true,
          "type": "directive_block"
        }
      ],
