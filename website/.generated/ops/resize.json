  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return a new array with the specified shape."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "If the new array is larger than the original array, then the new\narray is filled with repeated copies of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ".  Note that this behavior\nis different from a.resize(new_shape) which fills with zeros instead\nof repeated copies of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Array to be resized."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Array to be resized."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Shape of resized array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of int",
              "inline": [
                {
                  "kind": "text",
                  "text": "Shape of resized array."
                }
              ],
              "name": "new_shape",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The new array is formed from the data in the old array, repeated\nif necessary to fill out the required number of elements.  The\ndata are repeated iterating over the array in C-order."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray",
              "inline": [
                {
                  "kind": "text",
                  "text": "The new array is formed from the data in the old array, repeated\nif necessary to fill out the required number of elements.  The\ndata are repeated iterating over the array in C-order."
                }
              ],
              "name": "reshaped_array",
              "type": "field_list"
            }
          ],
          "title": "Returns",
          "type": "field_list"
        }
      ],
      "title": "Returns"
    },
