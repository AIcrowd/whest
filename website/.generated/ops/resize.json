        }
      ],
      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "When the total size of the array does not change "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/reshape",
              "kind": "link",
              "target": "reshape",
              "text": "reshape"
            },
            {
              "kind": "text",
              "text": " should\nbe used.  In most other cases either indexing (to reduce the size)\nor padding (to increase the size) may be a more appropriate solution."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Warning: This functionality does "
            },
            {
              "kind": "strong",
              "text": "not"
            },
            {
              "kind": "text",
              "text": " consider axes separately,\ni.e. it does not apply interpolation/extrapolation.\nIt fills the return array with the required number of elements, iterating\nover "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " in C-order, disregarding axes (and cycling back from the start if\nthe new shape is larger).  This functionality is therefore not suitable to\nresize images, or data where each axis represents a separate and distinct\nentity."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[0,1],[2,3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.resize(a,(2,3))"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 0, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.resize(a,(1,4))"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2, 3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.resize(a,(2,4))"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2, 3],"
            },
            {
              "kind": "output",
              "text": "       [0, 1, 2, 3]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
