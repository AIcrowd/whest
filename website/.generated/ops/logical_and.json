          "inline": [
            {
              "kind": "text",
              "text": "Compute the truth value of x1 AND x2 element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input arrays.\nIf "
                    },
                    {
                      "kind": "code",
                      "text": "x1.shape != x2.shape"
                    },
                    {
                      "kind": "text",
                      "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input arrays.\nIf "
                },
                {
                  "kind": "code",
                  "text": "x1.shape != x2.shape"
                },
                {
                  "kind": "text",
                  "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                }
              ],
              "name": "x1, x2",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, None, or tuple of ndarray and None, optional",
              "inline": [
