{
  "aliases": [],
  "api_docs_html": "",
  "area": "linalg",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns specified diagonals of a matrix (or a stack of matrices) "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function is Array API compatible, contrary to\n"
            },
            {
              "display_text": "we.diagonal",
              "explicit_title": false,
              "external_url": "",
              "href": "/docs/api/ops/diagonal",
              "kind": "role_reference",
              "original_target": "we.diagonal",
              "role": "py:func",
              "suppress_link": false,
              "target": "diagonal",
              "unresolved": false
            },
            {
              "kind": "text",
              "text": ", the matrix is assumed\nto be defined by the last two dimensions."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array having shape (..., M, N) and whose innermost two\ndimensions form MxN matrices."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "(...,M,N) array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array having shape (..., M, N) and whose innermost two\ndimensions form MxN matrices."
                }
              ],
              "name": "x",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Offset specifying the off-diagonal relative to the main diagonal,\nwhere:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "language": null,
                  "text": "* offset = 0: the main diagonal.\n* offset > 0: off-diagonal above the main diagonal.\n* offset < 0: off-diagonal below the main diagonal.",
                  "type": "literal_block"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Offset specifying the off-diagonal relative to the main diagonal,\nwhere:"
                }
              ],
              "name": "offset",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "An array containing the diagonals and whose shape is determined by\nremoving the last two dimensions and appending a dimension equal to\nthe size of the resulting diagonals. The returned array must have\nthe same data type as "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "(...,min(N,M)) ndarray",
              "inline": [
                {
                  "kind": "text",
                  "text": "An array containing the diagonals and whose shape is determined by\nremoving the last two dimensions and appending a dimension equal to\nthe size of the resulting diagonals. The returned array must have\nthe same data type as "
                },
                {
                  "kind": "code",
                  "text": "x"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "out",
              "type": "field_list"
            }
          ],
          "title": "Returns",
          "type": "field_list"
        }
      ],
      "title": "Returns"
    },
