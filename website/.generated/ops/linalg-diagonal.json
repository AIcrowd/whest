        }
      ],
      "title": "See also"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(4).reshape(2, 2); a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(a)"
            },
            {
              "kind": "output",
              "text": "array([0, 3])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "A 3-D example:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(8).reshape(2, 2, 2); a"
            },
            {
              "kind": "output",
              "text": "array([[[0, 1],"
            },
            {
              "kind": "output",
              "text": "        [2, 3]],"
            },
            {
              "kind": "output",
              "text": "       [[4, 5],"
            },
            {
              "kind": "output",
              "text": "        [6, 7]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(a)"
            },
            {
              "kind": "output",
              "text": "array([[0, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 7]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Diagonals adjacent to the main diagonal can be obtained by using the\n"
            },
            {
              "kind": "code",
              "text": "offset"
            },
            {
              "kind": "text",
              "text": " argument:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(9).reshape(3, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 5],"
            },
            {
              "kind": "output",
              "text": "       [6, 7, 8]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(a, offset=1)  # First superdiagonal"
            },
            {
              "kind": "output",
              "text": "array([1, 5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(a, offset=2)  # Second superdiagonal"
            },
            {
              "kind": "output",
              "text": "array([2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(a, offset=-1)  # First subdiagonal"
            },
            {
              "kind": "output",
              "text": "array([3, 7])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(a, offset=-2)  # Second subdiagonal"
            },
            {
              "kind": "output",
              "text": "array([6])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The anti-diagonal can be obtained by reversing the order of elements\nusing either "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/flipud",
              "kind": "link",
              "target": "flipud",
              "text": "we.flipud"
            },
            {
              "kind": "text",
              "text": " or "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/fliplr",
              "kind": "link",
              "target": "fliplr",
              "text": "we.fliplr"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(9).reshape(3, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 5],"
            },
            {
              "kind": "output",
              "text": "       [6, 7, 8]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(we.fliplr(a))  # Horizontal flip"
            },
            {
              "kind": "output",
              "text": "array([2, 4, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.diagonal(we.flipud(a))  # Vertical flip"
            },
            {
              "kind": "output",
              "text": "array([6, 4, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that the order in which the diagonal is retrieved varies depending\non the flip function."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Examples"
    }
  ],
  "canonical_name": "linalg.diagonal",
