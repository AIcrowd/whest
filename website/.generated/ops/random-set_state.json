      ],
      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "set_state"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "get_state"
            },
            {
              "kind": "text",
              "text": " are not needed to work with any of the\nrandom distributions in NumPy. If the internal state is manually altered,\nthe user should know exactly what he/she is doing."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For backwards compatibility, the form (str, array of 624 uints, int) is\nalso accepted although it is missing some information about the cached\nGaussian value: "
            },
            {
              "kind": "code",
              "text": "state = ('MT19937', keys, pos)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nM. Matsumoto and T. Nishimura, \"Mersenne Twister: A\n623-dimensionally equidistributed uniform pseudorandom number\ngenerator,\" ACM Trans. on Modeling and Computer Simulation,\nVol. 8, No. 1, pp. 3-30, Jan. 1998.",
          "type": "raw_block"
        }
