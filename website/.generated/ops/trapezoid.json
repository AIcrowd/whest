    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Definite integral of "
                    },
                    {
                      "kind": "code",
                      "text": "y"
                    },
                    {
                      "kind": "text",
                      "text": " = n-dimensional array as approximated along\na single axis by the trapezoidal rule. If "
                    },
                    {
                      "kind": "code",
                      "text": "y"
                    },
                    {
                      "kind": "text",
                      "text": " is a 1-dimensional array,\nthen the result is a float. If "
                    },
                    {
                      "kind": "code",
                      "text": "n"
                    },
                    {
                      "kind": "text",
                      "text": " is greater than 1, then the result\nis an "
                    },
                    {
                      "kind": "code",
                      "text": "n"
                    },
                    {
                      "kind": "text",
                      "text": "-1 dimensional array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or ndarray",
              "inline": [
                {
                  "kind": "text",
                  "text": "Definite integral of "
                },
                {
                  "kind": "code",
                  "text": "y"
                },
                {
                  "kind": "text",
                  "text": " = n-dimensional array as approximated along\na single axis by the trapezoidal rule. If "
                },
                {
                  "kind": "code",
                  "text": "y"
                },
                {
                  "kind": "text",
                  "text": " is a 1-dimensional array,\nthen the result is a float. If "
                },
                {
                  "kind": "code",
                  "text": "n"
                },
                {
                  "kind": "text",
                  "text": " is greater than 1, then the result\nis an "
                },
                {
