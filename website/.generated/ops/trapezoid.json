  "api_docs_html": "",
  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Integrate along the given axis using the composite trapezoidal rule."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is provided, the integration happens in sequence along its\nelements - they are not sorted."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Integrate "
            },
            {
              "kind": "code",
              "text": "y"
            },
            {
              "kind": "text",
              "text": " ("
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": ") along each 1d slice on the given axis, compute\n"
            },
            {
              "kind": "math",
              "latex": "\\int y(x) dx"
            },
            {
              "kind": "text",
              "text": ".\nWhen "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is specified, this integrates along the parametric curve,\ncomputing "
            },
            {
              "kind": "math",
              "latex": "\\int_t y(t) dt =\n\\int_t y(t) \\left.\\frac{dx}{dt}\\right|_{x=x(t)} dt"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionadded",
          "options": [],
          "raw_source": ".. versionadded:: 2.0.0",
          "supported": true,
          "type": "directive_block",
          "version": "2.0.0"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array to integrate."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array to integrate."
                }
              ],
              "name": "y",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The sample points corresponding to the "
                    },
                    {
                      "kind": "code",
                      "text": "y"
                    },
                    {
                      "kind": "text",
                      "text": " values. If "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " is None,\nthe sample points are assumed to be evenly spaced "
                    },
                    {
                      "kind": "code",
                      "text": "dx"
                    },
                    {
                      "kind": "text",
                      "text": " apart. The\ndefault is None."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The sample points corresponding to the "
                },
                {
                  "kind": "code",
                  "text": "y"
                },
                {
                  "kind": "text",
                  "text": " values. If "
                },
                {
                  "kind": "code",
                  "text": "x"
                },
                {
                  "kind": "text",
                  "text": " is None,\nthe sample points are assumed to be evenly spaced "
                },
                {
                  "kind": "code",
                  "text": "dx"
                },
                {
                  "kind": "text",
                  "text": " apart. The\ndefault is None."
                }
              ],
              "name": "x",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The spacing between sample points when "
                    },
                    {
                      "kind": "code",
                      "text": "x"
                    },
                    {
                      "kind": "text",
                      "text": " is None. The default is 1."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "scalar, optional",
              "inline": [
                {
                  "kind": "text",
