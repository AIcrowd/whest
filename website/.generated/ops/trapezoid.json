  "example": {
    "code": "import whest as we\n\nwe.trapezoid([1, 2, 3])\n\nwe.trapezoid([1, 2, 3], x=[4, 6, 8])\n\nwe.trapezoid([1, 2, 3], dx=2)\n\nwe.trapezoid([1, 2, 3], x=[8, 6, 4])\n\nx = we.linspace(0, 1, num=50)\n\ny = x**2\n\nwe.trapezoid(y, x)\n\ntheta = we.linspace(0, 2 * we.pi, num=1000, endpoint=True)\n\nwe.trapezoid(we.cos(theta), x=we.sin(theta))\n\na = we.arange(6).reshape(2, 3)\n\na\n\nwe.trapezoid(a, axis=0)\n\nwe.trapezoid(a, axis=1)",
    "output": "4.0\n\n8.0\n\n8.0\n\n-8.0\n\n0.33340274885464394\n\n3.141571941375841\n\narray([[0, 1, 2],\n       [3, 4, 5]])\n\narray([1.5, 2.5, 3.5])\n\narray([2.,  8.])",
    "source": "derived"
  },
