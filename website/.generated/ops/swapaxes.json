                  "inline": [
                    {
                      "kind": "text",
                      "text": "For NumPy >= 1.10.0, if "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is an ndarray, then a view of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is\nreturned; otherwise a new array is created. For earlier NumPy\nversions a view of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is returned only if the order of the\naxes is changed, otherwise the input array is returned."
                    }
                  ],
