  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the normalized sinc function."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The sinc function is equal to "
            },
            {
              "kind": "math",
              "latex": "\\sin(\\pi x)/(\\pi x)"
            },
            {
              "kind": "text",
              "text": " for any argument\n"
            },
            {
              "kind": "math",
              "latex": "x\\ne 0"
            },
            {
              "kind": "text",
              "text": ". "
            },
            {
              "kind": "code",
              "text": "sinc(0)"
            },
            {
              "kind": "text",
              "text": " takes the limit value 1, making "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/sinc",
              "kind": "link",
              "target": "sinc",
              "text": "sinc"
            },
            {
              "kind": "text",
              "text": " not\nonly everywhere continuous but also infinitely differentiable."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "Note the normalization factor of "
                },
                {
                  "kind": "code",
                  "text": "pi"
                },
                {
                  "kind": "text",
                  "text": " used in the definition.\nThis is the most commonly used definition in signal processing.\nUse "
                },
                {
                  "kind": "code",
                  "text": "sinc(x / we.pi)"
                },
                {
                  "kind": "text",
                  "text": " to obtain the unnormalized sinc function\n"
                },
                {
                  "kind": "math",
                  "latex": "\\sin(x)/x"
                },
                {
                  "kind": "text",
                  "text": " that is more common in mathematics."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n\n    Note the normalization factor of ``pi`` used in the definition.\n    This is the most commonly used definition in signal processing.\n    Use ``sinc(x / we.pi)`` to obtain the unnormalized sinc function\n    :math:`\\sin(x)/x` that is more common in mathematics.",
          "supported": true,
          "type": "directive_block"
        }
      ],
      "title": "Extended Summary"
    },
