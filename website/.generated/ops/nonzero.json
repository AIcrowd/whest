{
  "aliases": [],
  "api_docs_html": "",
  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the indices of the elements that are non-zero."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns a tuple of arrays, one for each dimension of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ",\ncontaining the indices of the non-zero elements in that\ndimension. The values in "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " are always tested and returned in\nrow-major, C-style order."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "To group the indices by element, rather than dimension, use "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/argwhere",
              "kind": "link",
              "target": "argwhere",
              "text": "argwhere"
            },
            {
              "kind": "text",
              "text": ",\nwhich returns a row for each non-zero element."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "When called on a zero-d array or scalar, "
                },
                {
                  "kind": "code",
                  "text": "nonzero(a)"
                },
                {
                  "kind": "text",
                  "text": " is treated\nas "
                },
                {
                  "kind": "code",
                  "text": "nonzero(atleast_1d(a))"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            },
            {
              "raw_kind": "system_message",
              "raw_text": "<string>:4: (INFO/1) No directive entry for \"deprecated\" in module \"docutils.parsers.rst.languages.en\".\nTrying \"deprecated\" as canonical directive name.",
              "type": "raw_block"
            },
            {
              "raw_kind": "system_message",
              "raw_text": "<string>:4: (ERROR/3) Unknown directive type \"deprecated\".\n\n.. deprecated:: 1.17.0\n\n   Use `atleast_1d` explicitly if this behavior is deliberate.",
              "type": "raw_block"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n\n   When called on a zero-d array or scalar, ``nonzero(a)`` is treated\n   as ``nonzero(atleast_1d(a))``.\n\n   .. deprecated:: 1.17.0\n\n      Use `atleast_1d` explicitly if this behavior is deliberate.",
          "supported": true,
          "type": "directive_block"
        }
      ],
