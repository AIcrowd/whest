  "example": {
    "code": "import whest as we\n\na = we.array([[10, 30, 20], [60, 40, 50]])\n\nwe.sort(a, axis=1)\n\nai = we.argsort(a, axis=1)\n\nai\n\nwe.take_along_axis(a, ai, axis=1)\n\nwe.max(a, axis=1, keepdims=True)\n\nai = we.argmax(a, axis=1, keepdims=True)\n\nai\n\nwe.take_along_axis(a, ai, axis=1)\n\nai_min = we.argmin(a, axis=1, keepdims=True)\n\nai_max = we.argmax(a, axis=1, keepdims=True)\n\nai = we.concatenate([ai_min, ai_max], axis=1)\n\nai\n\nwe.take_along_axis(a, ai, axis=1)",
    "output": "array([[10, 20, 30],\n       [40, 50, 60]])\n\narray([[0, 2, 1],\n       [1, 2, 0]])\n\narray([[10, 20, 30],\n       [40, 50, 60]])\n\narray([[30],\n       [60]])\n\narray([[1],\n       [0]])\n\narray([[30],\n       [60]])\n\narray([[0, 1],\n       [1, 0]])\n\narray([[10, 30],\n       [40, 60]])",
    "source": "derived"
