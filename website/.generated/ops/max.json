  "example": {
    "code": "import whest as we\n\na = we.arange(4).reshape((2,2))\n\na\n\nwe.max(a)           # Maximum of the flattened array\n\nwe.max(a, axis=0)   # Maxima along the first axis\n\nwe.max(a, axis=1)   # Maxima along the second axis\n\nwe.max(a, where=[False, True], initial=-1, axis=0)\n\nb = we.arange(5, dtype=float)\n\nb[2] = we.nan\n\nwe.max(b)\n\nwe.max(b, where=~we.isnan(b), initial=-1)\n\nwe.nanmax(b)\n\nwe.max([[-50], [10]], axis=-1, initial=0)\n\nwe.max([5], initial=6)\n\nmax([5], default=6)",
    "output": "array([[0, 1],\n       [2, 3]])\n\n3\n\narray([2, 3])\n\narray([1, 3])\n\narray([-1,  3])\n\nwe.float64(nan)\n\n4.0\n\n4.0\n\narray([ 0, 10])\n\n6\n\n5",
    "source": "derived"
  },
