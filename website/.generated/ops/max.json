      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "NaN values are propagated, that is if at least one item is NaN, the\ncorresponding max value will be NaN as well. To ignore NaN values\n(MATLAB behavior), please use nanmax."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Don't use "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/max",
              "kind": "link",
              "target": "max",
              "text": "max"
            },
            {
              "kind": "text",
              "text": " for element-wise comparison of 2 arrays; when\n"
            },
            {
              "kind": "code",
              "text": "a.shape[0]"
            },
            {
              "kind": "text",
              "text": " is 2, "
            },
            {
              "kind": "code",
              "text": "maximum(a[0], a[1])"
            },
            {
              "kind": "text",
              "text": " is faster than\n"
            },
            {
              "kind": "code",
              "text": "max(a, axis=0)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(4).reshape((2,2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max(a)           # Maximum of the flattened array"
            },
            {
              "kind": "output",
              "text": "3"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max(a, axis=0)   # Maxima along the first axis"
            },
            {
              "kind": "output",
              "text": "array([2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max(a, axis=1)   # Maxima along the second axis"
            },
            {
              "kind": "output",
              "text": "array([1, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max(a, where=[False, True], initial=-1, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([-1,  3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.arange(5, dtype=float)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b[2] = we.nan"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max(b)"
            },
            {
              "kind": "output",
              "text": "we.float64(nan)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max(b, where=~we.isnan(b), initial=-1)"
            },
            {
              "kind": "output",
              "text": "4.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nanmax(b)"
            },
            {
              "kind": "output",
              "text": "4.0"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "You can use an initial value to compute the maximum of an empty slice, or\nto initialize it to a different value:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max([[-50], [10]], axis=-1, initial=0)"
            },
            {
              "kind": "output",
              "text": "array([ 0, 10])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Notice that the initial value is used as one of the elements for which the\nmaximum is determined, unlike for the default argument Python's max\nfunction, which is only used for empty iterables."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.max([5], initial=6)"
            },
            {
              "kind": "output",
              "text": "6"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "max([5], default=6)"
            },
            {
              "kind": "output",
              "text": "5"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
