            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Size of the range over which the input wraps. By default, it is\n"
                    },
                    {
                      "kind": "code",
                      "text": "2 pi"
                    },
                    {
                      "kind": "text",
