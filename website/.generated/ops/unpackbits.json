  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Unpacks elements of a uint8 array into a binary-valued output array."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Each element of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " represents a bit-field that should be unpacked\ninto a binary-valued output array. The shape of the output array is\neither 1-D (if "
            },
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": " is "
            },
            {
              "kind": "code",
              "text": "None"
            },
            {
              "kind": "text",
              "text": ") or the same shape as the input\narray with unpacking done along the axis specified."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, uint8 type",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The dimension over which bit-unpacking is done.\n"
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " implies unpacking the flattened array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The dimension over which bit-unpacking is done.\n"
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": " implies unpacking the flattened array."
                }
              ],
              "name": "axis",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The number of elements to unpack along "
                    },
                    {
                      "kind": "code",
                      "text": "axis"
                    },
                    {
                      "kind": "text",
                      "text": ", provided as a way\nof undoing the effect of packing a size that is not a multiple\nof eight. A non-negative number means to only unpack "
                    },
                    {
                      "kind": "code",
                      "text": "count"
                    },
                    {
                      "kind": "text",
                      "text": "\nbits. A negative number means to trim off that many bits from\nthe end. "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " means to unpack the entire array (the\ndefault). Counts larger than the available number of bits will\nadd zero padding to the output. Negative counts must not\nexceed the available number of bits."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or None, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The number of elements to unpack along "
                },
                {
                  "kind": "code",
                  "text": "axis"
                },
                {
                  "kind": "text",
                  "text": ", provided as a way\nof undoing the effect of packing a size that is not a multiple\nof eight. A non-negative number means to only unpack "
                },
                {
                  "kind": "code",
                  "text": "count"
                },
                {
                  "kind": "text",
                  "text": "\nbits. A negative number means to trim off that many bits from\nthe end. "
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": " means to unpack the entire array (the\ndefault). Counts larger than the available number of bits will\nadd zero padding to the output. Negative counts must not\nexceed the available number of bits."
                }
              ],
              "name": "count",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The order of the returned bits. 'big' will mimic bin(val),\n"
                    },
                    {
                      "kind": "code",
                      "text": "3 = 0b00000011 => [0, 0, 0, 0, 0, 0, 1, 1]"
                    },
                    {
                      "kind": "text",
                      "text": ", 'little' will reverse\nthe order to "
                    },
                    {
                      "kind": "code",
                      "text": "[1, 1, 0, 0, 0, 0, 0, 0]"
                    },
                    {
                      "kind": "text",
                      "text": ".\nDefaults to 'big'."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{'big', 'little'}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The order of the returned bits. 'big' will mimic bin(val),\n"
                },
                {
                  "kind": "code",
                  "text": "3 = 0b00000011 => [0, 0, 0, 0, 0, 0, 1, 1]"
                },
                {
                  "kind": "text",
                  "text": ", 'little' will reverse\nthe order to "
                },
                {
                  "kind": "code",
                  "text": "[1, 1, 0, 0, 0, 0, 0, 0]"
                },
                {
                  "kind": "text",
                  "text": ".\nDefaults to 'big'."
                }
              ],
              "name": "bitorder",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
