    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[2], [7], [23]], dtype=we.uint8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[ 2],"
            },
            {
              "kind": "output",
              "text": "       [ 7],"
            },
            {
              "kind": "output",
              "text": "       [23]], dtype=uint8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.unpackbits(a, axis=1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 0, 0, 0, 0, 1, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0, 1, 1, 1],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 1, 0, 1, 1, 1]], dtype=uint8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c = we.unpackbits(a, axis=1, count=-3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 1, 0]], dtype=uint8)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p = we.packbits(b, axis=0)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.unpackbits(p, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 0, 0, 0, 0, 1, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0, 1, 1, 1],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 1, 0, 1, 1, 1],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 0, 0, 0, 0, 0, 0]], dtype=uint8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array_equal(b, we.unpackbits(p, axis=0, count=b.shape[0]))"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
