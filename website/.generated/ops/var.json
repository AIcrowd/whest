  "example": {
    "code": "import whest as we\n\na = we.array([[1, 2], [3, 4]])\n\nwe.var(a)\n\nwe.var(a, axis=0)\n\nwe.var(a, axis=1)\n\na = we.zeros((2, 512*512), dtype=we.float32)\n\na[0, :] = 1.0\n\na[1, :] = 0.1\n\nwe.var(a)\n\nwe.var(a, dtype=we.float64)\n\n((1-0.55)**2 + (0.1-0.55)**2)/2\n\na = we.array([[14, 8, 11, 10], [7, 9, 10, 11], [10, 15, 5, 10]])\n\nwe.var(a)\n\nwe.var(a, where=[[True], [True], [False]])\n\nimport whest as we\n\nfrom timeit import timeit\n\na = we.array([[14, 8, 11, 10], [7, 9, 10, 11], [10, 15, 5, 10]])\n\nmean = we.mean(a, axis=1, keepdims=True)\n\ng = globals()\n\nn = 10000\n\nt1 = timeit(\"var = we.var(a, axis=1, mean=mean)\", globals=g, number=n)\n\nt2 = timeit(\"var = we.var(a, axis=1)\", globals=g, number=n)\n\nprint(f'Percentage execution time saved {100*(t2-t1)/t2:.0f}%')",
