  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the variance along the specified axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns the variance of the array elements, a measure of the spread of a\ndistribution.  The variance is computed for the flattened array by\ndefault, otherwise over the specified axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Array containing numbers whose variance is desired.  If "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": " is not an\narray, a conversion is attempted."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Array containing numbers whose variance is desired.  If "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": " is not an\narray, a conversion is attempted."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axis or axes along which the variance is computed.  The default is to\ncompute the variance of the flattened array.\nIf this is a tuple of ints, a variance is performed over multiple axes,\ninstead of a single axis or all the axes as before."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "None or int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Axis or axes along which the variance is computed.  The default is to\ncompute the variance of the flattened array.\nIf this is a tuple of ints, a variance is performed over multiple axes,\ninstead of a single axis or all the axes as before."
                }
              ],
              "name": "axis",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Type to use in computing the variance.  For arrays of integer type\nthe default is "
                    },
                    {
                      "kind": "code",
                      "text": "float64"
                    },
                    {
                      "kind": "text",
                      "text": "; for arrays of float types it is the same as\nthe array type."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "data-type, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Type to use in computing the variance.  For arrays of integer type\nthe default is "
                },
                {
                  "kind": "code",
                  "text": "float64"
                },
                {
                  "kind": "text",
                  "text": "; for arrays of float types it is the same as\nthe array type."
                }
              ],
              "name": "dtype",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Alternate output array in which to place the result.  It must have\nthe same shape as the expected output, but the type is cast if\nnecessary."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Alternate output array in which to place the result.  It must have\nthe same shape as the expected output, but the type is cast if\nnecessary."
                }
              ],
              "name": "out",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "\"Delta Degrees of Freedom\": the divisor used in the calculation is\n"
                    },
                    {
                      "kind": "code",
                      "text": "N - ddof"
                    },
                    {
                      "kind": "text",
                      "text": ", where "
                    },
                    {
                      "kind": "code",
                      "text": "N"
                    },
                    {
                      "kind": "text",
                      "text": " represents the number of elements. By\ndefault "
                    },
                    {
                      "kind": "code",
                      "text": "ddof"
                    },
                    {
                      "kind": "text",
                      "text": " is zero. See notes for details about use of "
                    },
                    {
                      "kind": "code",
                      "text": "ddof"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{int, float}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "\"Delta Degrees of Freedom\": the divisor used in the calculation is\n"
                },
                {
                  "kind": "code",
                  "text": "N - ddof"
                },
                {
                  "kind": "text",
                  "text": ", where "
                },
                {
                  "kind": "code",
                  "text": "N"
                },
                {
                  "kind": "text",
                  "text": " represents the number of elements. By\ndefault "
                },
                {
                  "kind": "code",
                  "text": "ddof"
                },
                {
                  "kind": "text",
                  "text": " is zero. See notes for details about use of "
                },
                {
                  "kind": "code",
                  "text": "ddof"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "ddof",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the input array."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If the default value is passed, then "
                    },
                    {
                      "kind": "code",
                      "text": "keepdims"
                    },
                    {
                      "kind": "text",
                      "text": " will not be\npassed through to the "
                    },
                    {
                      "external_url": "",
                      "href": "/docs/api/ops/var",
                      "kind": "link",
                      "target": "var",
                      "text": "var"
                    },
                    {
                      "kind": "text",
                      "text": " method of sub-classes of\n"
                    },
                    {
                      "kind": "code",
                      "text": "ndarray"
                    },
                    {
                      "kind": "text",
                      "text": ", however any non-default value will be.  If the\nsub-class' method does not implement "
                    },
                    {
                      "kind": "code",
                      "text": "keepdims"
                    },
                    {
                      "kind": "text",
                      "text": " any\nexceptions will be raised."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the input array."
