    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The maximum is equivalent to "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.where(x1 >= x2, x1, x2).html",
              "href": "",
              "kind": "link",
              "target": "where(x1 >= x2, x1, x2)",
              "text": "we.where(x1 >= x2, x1, x2)"
            },
            {
              "kind": "text",
              "text": " when\nneither x1 nor x2 are nans, but it is faster and does proper\nbroadcasting."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.maximum([2, 3, 4], [1, 5, 2])"
            },
            {
              "kind": "output",
              "text": "array([2, 5, 4])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.maximum(we.eye(2), [0.5, 2]) # broadcasting"
            },
            {
              "kind": "output",
              "text": "array([[ 1. ,  2. ],"
            },
            {
              "kind": "output",
              "text": "       [ 0.5,  2. ]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.maximum([we.nan, 0, we.nan], [0, we.nan, we.nan])"
            },
            {
              "kind": "output",
              "text": "array([nan, nan, nan])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.maximum(we.inf, 1)"
            },
            {
              "kind": "output",
              "text": "inf"
            }
          ],
          "type": "doctest_block"
        }
      ],
