    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.polymul([1, 2, 3], [9, 5, 1])"
            },
            {
              "kind": "output",
              "text": "array([ 9, 23, 38, 17,  3])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Using poly1d objects:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p1 = we.poly1d([1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p2 = we.poly1d([9, 5, 1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "print(p1)"
            },
            {
              "kind": "output",
              "text": "   2"
            },
            {
              "kind": "output",
              "text": "1 x + 2 x + 3"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "print(p2)"
            },
            {
              "kind": "output",
              "text": "   2"
            },
            {
              "kind": "output",
              "text": "9 x + 5 x + 1"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "print(we.polymul(p1, p2))"
            },
            {
              "kind": "output",
              "text": "   4      3      2"
            },
            {
              "kind": "output",
              "text": "9 x + 23 x + 38 x + 17 x + 3"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
