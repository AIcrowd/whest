      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Make a ("
            },
            {
              "kind": "emphasis",
              "text": "very"
            },
            {
              "kind": "text",
              "text": " coarse) grid for computing a Mandelbrot set:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rl = we.linalg.outer(we.ones((5,)), we.linspace(-2, 2, 5))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rl"
            },
            {
              "kind": "output",
              "text": "array([[-2., -1.,  0.,  1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [-2., -1.,  0.,  1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [-2., -1.,  0.,  1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [-2., -1.,  0.,  1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [-2., -1.,  0.,  1.,  2.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "im = we.linalg.outer(1j*we.linspace(2, -2, 5), we.ones((5,)))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "im"
            },
            {
              "kind": "output",
              "text": "array([[0.+2.j, 0.+2.j, 0.+2.j, 0.+2.j, 0.+2.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+1.j, 0.+1.j, 0.+1.j, 0.+1.j, 0.+1.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+0.j, 0.+0.j, 0.+0.j, 0.+0.j, 0.+0.j],"
            },
            {
              "kind": "output",
              "text": "       [0.-1.j, 0.-1.j, 0.-1.j, 0.-1.j, 0.-1.j],"
            },
            {
              "kind": "output",
              "text": "       [0.-2.j, 0.-2.j, 0.-2.j, 0.-2.j, 0.-2.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "grid = rl + im"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "grid"
            },
            {
              "kind": "output",
              "text": "array([[-2.+2.j, -1.+2.j,  0.+2.j,  1.+2.j,  2.+2.j],"
            },
            {
              "kind": "output",
              "text": "       [-2.+1.j, -1.+1.j,  0.+1.j,  1.+1.j,  2.+1.j],"
            },
            {
              "kind": "output",
              "text": "       [-2.+0.j, -1.+0.j,  0.+0.j,  1.+0.j,  2.+0.j],"
            },
            {
              "kind": "output",
              "text": "       [-2.-1.j, -1.-1.j,  0.-1.j,  1.-1.j,  2.-1.j],"
            },
            {
              "kind": "output",
              "text": "       [-2.-2.j, -1.-2.j,  0.-2.j,  1.-2.j,  2.-2.j]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "An example using a \"vector\" of letters:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array(['a', 'b', 'c'], dtype=object)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.outer(x, [1, 2, 3])"
            },
            {
              "kind": "output",
              "text": "array([['a', 'aa', 'aaa'],"
            },
            {
              "kind": "output",
              "text": "       ['b', 'bb', 'bbb'],"
            },
            {
              "kind": "output",
              "text": "       ['c', 'cc', 'ccc']], dtype=object)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
