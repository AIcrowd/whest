            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The Cholesky decomposition is often used as a fast way of solving"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "A \\mathbf{x} = \\mathbf{b}"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "(when "
            },
            {
              "kind": "code",
              "text": "A"
            },
            {
              "kind": "text",
              "text": " is both Hermitian/symmetric and positive-definite)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "First, we solve for "
            },
            {
              "kind": "math",
              "latex": "\\mathbf{y}"
            },
            {
              "kind": "text",
              "text": " in"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "L \\mathbf{y} = \\mathbf{b},"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "and then for "
            },
            {
              "kind": "math",
              "latex": "\\mathbf{x}"
            },
            {
              "kind": "text",
              "text": " in"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "L^{H} \\mathbf{x} = \\mathbf{y}."
          ],
          "type": "math_block"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = we.array([[1,-2j],[2j,5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A"
            },
            {
              "kind": "output",
              "text": "array([[ 1.+0.j, -0.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [ 0.+2.j,  5.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "L = we.linalg.cholesky(A)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "L"
            },
            {
              "kind": "output",
              "text": "array([[1.+0.j, 0.+0.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+2.j, 1.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.dot(L, L.T.conj()) # verify that L * L.H = A"
            },
            {
              "kind": "output",
              "text": "array([[1.+0.j, 0.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+2.j, 5.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = [[1,-2j],[2j,5]] # what happens if A is only array_like?"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.cholesky(A) # an ndarray object is returned"
            },
            {
              "kind": "output",
              "text": "array([[1.+0.j, 0.+0.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+2.j, 1.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# But a matrix object is returned if A is a matrix object"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.cholesky(we.matrix(A))"
            },
            {
              "kind": "output",
              "text": "matrix([[ 1.+0.j,  0.+0.j],"
            },
            {
              "kind": "output",
              "text": "        [ 0.+2.j,  1.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# The upper-triangular Cholesky factor can also be obtained."
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.linalg.cholesky(A, upper=True)"
            },
            {
              "kind": "output",
              "text": "array([[1.-0.j, 0.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [0.-0.j, 1.-0.j]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
