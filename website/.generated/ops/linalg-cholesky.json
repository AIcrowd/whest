  "example": {
    "code": "import whest as we\n\nA = we.array([[1,-2j],[2j,5]])\n\nA\n\nL = we.linalg.cholesky(A)\n\nL\n\nwe.dot(L, L.T.conj()) # verify that L * L.H = A\n\nA = [[1,-2j],[2j,5]] # what happens if A is only array_like?\n\nwe.linalg.cholesky(A) # an ndarray object is returned\n\nwe.linalg.cholesky(we.matrix(A))\n\nwe.linalg.cholesky(A, upper=True)",
    "output": "array([[ 1.+0.j, -0.-2.j],\n       [ 0.+2.j,  5.+0.j]])\n\narray([[1.+0.j, 0.+0.j],\n       [0.+2.j, 1.+0.j]])\n\narray([[1.+0.j, 0.-2.j],\n       [0.+2.j, 5.+0.j]])\n\narray([[1.+0.j, 0.+0.j],\n       [0.+2.j, 1.+0.j]])\n\nmatrix([[ 1.+0.j,  0.+0.j],\n        [ 0.+2.j,  1.+0.j]])\n\narray([[1.-0.j, 0.-2.j],\n       [0.-0.j, 1.-0.j]])",
    "source": "derived"
  },
