                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Tolerance in machine epsilons for the complex part of the elements\nin the array. If the tolerance is <=1, then the absolute tolerance\nis used."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float",
              "inline": [
                {
                  "kind": "text",
                  "text": "Tolerance in machine epsilons for the complex part of the elements\nin the array. If the tolerance is <=1, then the absolute tolerance\nis used."
