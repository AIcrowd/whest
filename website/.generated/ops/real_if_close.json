    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Machine epsilon varies from machine to machine and between data types\nbut Python floats on most platforms have a machine epsilon equal to\n2.2204460492503131e-16.  You can use 'we.finfo(float).eps' to print\nout the machine epsilon for floats."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.finfo(float).eps"
            },
            {
              "kind": "output",
              "text": "2.2204460492503131e-16 # may vary"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.real_if_close([2.1 + 4e-14j, 5.2 + 3e-15j], tol=1000)"
            },
            {
              "kind": "output",
              "text": "array([2.1, 5.2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.real_if_close([2.1 + 4e-13j, 5.2 + 3e-15j], tol=1000)"
            },
            {
              "kind": "output",
              "text": "array([2.1+4.e-13j, 5.2 + 3e-15j])"
            }
          ],
          "type": "doctest_block"
