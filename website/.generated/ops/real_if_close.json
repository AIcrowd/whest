          "inline": [
            {
              "kind": "text",
              "text": "If input is complex with all imaginary parts close to zero, return real parts."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "\"Close to zero\" is defined as "
            },
            {
              "kind": "code",
              "text": "tol"
            },
            {
              "kind": "text",
              "text": " * (machine epsilon of the type for\n"
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ")."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
