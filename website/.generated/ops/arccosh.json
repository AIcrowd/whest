    {
      "blocks": [
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/ops/arccosh",
              "kind": "link",
              "target": "arccosh",
              "text": "arccosh"
            },
            {
              "kind": "text",
              "text": " is a multivalued function: for each "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " there are infinitely\nmany numbers "
            },
            {
              "kind": "code",
              "text": "z"
            },
            {
              "kind": "text",
              "text": " such that "
            },
            {
              "kind": "code",
              "text": "cosh(z) = x"
            },
            {
              "kind": "text",
              "text": ". The convention is to return the\n"
            },
            {
              "kind": "code",
              "text": "z"
            },
            {
              "kind": "text",
              "text": " whose imaginary part lies in "
            },
            {
              "kind": "code",
              "text": "[-pi, pi]"
            },
            {
              "kind": "text",
              "text": " and the real part in\n"
            },
            {
              "kind": "code",
              "text": "[0, inf]"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For real-valued input data types, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/arccosh",
              "kind": "link",
              "target": "arccosh",
              "text": "arccosh"
            },
            {
              "kind": "text",
              "text": " always returns real output.\nFor each value that cannot be expressed as a real number or infinity, it\nyields "
            },
            {
              "kind": "code",
              "text": "nan"
            },
            {
              "kind": "text",
              "text": " and sets the "
            },
            {
              "kind": "code",
              "text": "invalid"
            },
            {
              "kind": "text",
              "text": " floating point error flag."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For complex-valued input, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/arccosh",
              "kind": "link",
              "target": "arccosh",
              "text": "arccosh"
            },
            {
              "kind": "text",
              "text": " is a complex analytical function that\nhas a branch cut "
            },
            {
              "kind": "code",
              "text": "[-inf, 1]"
            },
            {
              "kind": "text",
              "text": " and is continuous from above on it."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
