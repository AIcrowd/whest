          "raw_text": "1\n\nM. Abramowitz and I.A. Stegun, \"Handbook of Mathematical Functions\",\n10th printing, 1964, pp. 86.\nhttps://personal.math.ubc.ca/~cbm/aands/page_86.htm",
          "type": "raw_block"
        },
        {
          "raw_kind": "footnote",
          "raw_text": "2\n\nWikipedia, \"Inverse hyperbolic function\",\nhttps://en.wikipedia.org/wiki/Arccosh",
          "type": "raw_block"
        }
      ],
