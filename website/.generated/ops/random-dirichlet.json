      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The Dirichlet distribution is a distribution over vectors\n"
            },
            {
              "kind": "math",
              "latex": "x"
            },
            {
              "kind": "text",
              "text": " that fulfil the conditions "
            },
            {
              "kind": "math",
              "latex": "x_i>0"
            },
            {
              "kind": "text",
              "text": " and\n"
            },
            {
              "kind": "math",
              "latex": "\\sum_{i=1}^k x_i = 1"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The probability density function "
            },
            {
              "kind": "math",
              "latex": "p"
            },
            {
              "kind": "text",
              "text": " of a\nDirichlet-distributed random vector "
            },
            {
              "kind": "math",
              "latex": "X"
            },
            {
              "kind": "text",
              "text": " is\nproportional to"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "p(x) \\propto \\prod_{i=1}^{k}{x^{\\alpha_i-1}_i},"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "math",
              "latex": "\\alpha"
            },
            {
              "kind": "text",
              "text": " is a vector containing the positive\nconcentration parameters."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The method uses the following property for computation: let "
            },
            {
              "kind": "math",
              "latex": "Y"
            },
            {
              "kind": "text",
              "text": "\nbe a random vector which has components that follow a standard gamma\ndistribution, then "
            },
            {
              "kind": "math",
              "latex": "X = \\frac{1}{\\sum_{i=1}^k{Y_i}} Y"
            },
            {
              "kind": "text",
              "text": "\nis Dirichlet-distributed"
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nDavid McKay, \"Information Theory, Inference and Learning\nAlgorithms,\" chapter 23,\nhttps://www.inference.org.uk/mackay/itila/",
          "type": "raw_block"
        },
        {
          "raw_kind": "footnote",
          "raw_text": "2\n\nWikipedia, \"Dirichlet distribution\",\nhttps://en.wikipedia.org/wiki/Dirichlet_distribution",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Taking an example cited in Wikipedia, this distribution can be used if\none wanted to cut strings (each of initial length 1.0) into K pieces\nwith different lengths, where each piece had, on average, a designated\naverage length, but allowing some variation in the relative sizes of\nthe pieces."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = we.random.dirichlet((10, 5, 3), 20).transpose()"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.barh(range(20), s[0])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.barh(range(20), s[1], left=s[0], color='g')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.barh(range(20), s[2], left=s[0]+s[1], color='r')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.title(\"Lengths of Strings\")"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
