  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Find indices where elements should be inserted to maintain order."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Find the indices into a sorted array "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " such that, if the\ncorresponding elements in "
            },
            {
              "kind": "code",
              "text": "v"
            },
            {
              "kind": "text",
              "text": " were inserted before the indices, the\norder of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " would be preserved."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Assuming that "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " is sorted:"
            }
          ],
          "type": "paragraph"
        },
        {
          "raw_kind": "table",
          "raw_text": "\n\n\n\nside\n\nreturned index i satisfies\n\nleft\n\na[i-1] < v <= a[i]\n\nright\n\na[i-1] <= v < a[i]",
          "type": "raw_block"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array. If "
                    },
                    {
                      "kind": "code",
                      "text": "sorter"
                    },
                    {
                      "kind": "text",
                      "text": " is None, then it must be sorted in\nascending order, otherwise "
                    },
                    {
                      "kind": "code",
                      "text": "sorter"
                    },
                    {
                      "kind": "text",
                      "text": " must be an array of indices\nthat sort it."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "1-D array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array. If "
                },
                {
                  "kind": "code",
                  "text": "sorter"
                },
                {
                  "kind": "text",
                  "text": " is None, then it must be sorted in\nascending order, otherwise "
                },
                {
                  "kind": "code",
                  "text": "sorter"
                },
                {
                  "kind": "text",
                  "text": " must be an array of indices\nthat sort it."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Values to insert into "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Values to insert into "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "v",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If 'left', the index of the first suitable location found is given.\nIf 'right', return the last such index.  If there is no suitable\nindex, return either 0 or N (where N is the length of "
                    },
                    {
                      "kind": "code",
                      "text": "a"
                    },
                    {
                      "kind": "text",
                      "text": ")."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{'left', 'right'}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If 'left', the index of the first suitable location found is given.\nIf 'right', return the last such index.  If there is no suitable\nindex, return either 0 or N (where N is the length of "
                },
                {
                  "kind": "code",
                  "text": "a"
                },
                {
                  "kind": "text",
                  "text": ")."
                }
              ],
              "name": "side",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Optional array of integer indices that sort array a into ascending\norder. They are typically the result of argsort."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "1-D array_like, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Optional array of integer indices that sort array a into ascending\norder. They are typically the result of argsort."
                }
              ],
              "name": "sorter",
              "type": "field_list"
            }
          ],
