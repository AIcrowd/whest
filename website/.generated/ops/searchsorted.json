      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Binary search is used to find the required insertion points."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "As of NumPy 1.4.0 "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/searchsorted",
              "kind": "link",
              "target": "searchsorted",
              "text": "searchsorted"
            },
            {
              "kind": "text",
              "text": " works with real/complex arrays containing\n"
            },
            {
              "kind": "code",
              "text": "nan"
            },
            {
              "kind": "text",
              "text": " values. The enhanced sort order is documented in "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/sort",
              "kind": "link",
              "target": "sort",
              "text": "sort"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function uses the same algorithm as the builtin python\n"
            },
            {
              "kind": "code",
              "text": "bisect.bisect_left"
            },
            {
              "kind": "text",
              "text": " ("
            },
            {
              "kind": "code",
              "text": "side='left'"
            },
            {
              "kind": "text",
              "text": ") and "
            },
            {
              "kind": "code",
              "text": "bisect.bisect_right"
            },
            {
              "kind": "text",
              "text": "\n("
            },
            {
              "kind": "code",
              "text": "side='right'"
            },
            {
              "kind": "text",
              "text": ") functions, which is also vectorized\nin the "
            },
            {
              "kind": "code",
              "text": "v"
            },
            {
              "kind": "text",
              "text": " argument."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.searchsorted([11,12,13,14,15], 13)"
            },
            {
              "kind": "output",
              "text": "2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.searchsorted([11,12,13,14,15], 13, side='right')"
            },
            {
              "kind": "output",
              "text": "3"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.searchsorted([11,12,13,14,15], [-10, 20, 12, 13])"
            },
            {
              "kind": "output",
              "text": "array([0, 5, 1, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When "
            },
            {
              "kind": "code",
              "text": "sorter"
            },
            {
              "kind": "text",
              "text": " is used, the returned indices refer to the sorted\narray of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " and not "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " itself:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([40, 10, 20, 30])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sorter = we.argsort(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sorter"
            },
            {
              "kind": "output",
              "text": "array([1, 2, 3, 0])  # Indices that would sort the array 'a'"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "result = we.searchsorted(a, 25, sorter=sorter)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "result"
            },
            {
              "kind": "output",
              "text": "2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[sorter[result]]"
            },
            {
              "kind": "output",
              "text": "30  # The element at index 2 of the sorted array is 30."
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
