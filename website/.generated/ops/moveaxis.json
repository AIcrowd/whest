          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.zeros((3, 4, 5))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.moveaxis(x, 0, -1).shape"
            },
            {
              "kind": "output",
              "text": "(4, 5, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.moveaxis(x, -1, 0).shape"
            },
            {
              "kind": "output",
              "text": "(5, 3, 4)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "These all achieve the same result:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.transpose(x).shape"
            },
            {
              "kind": "output",
              "text": "(5, 4, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.swapaxes(x, 0, -1).shape"
            },
            {
              "kind": "output",
              "text": "(5, 4, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.moveaxis(x, [0, 1], [-1, -2]).shape"
            },
            {
              "kind": "output",
              "text": "(5, 4, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.moveaxis(x, [0, 1, 2], [-1, -2, -3]).shape"
            },
            {
              "kind": "output",
              "text": "(5, 4, 3)"
            }
          ],
          "type": "doctest_block"
        }
      ],
