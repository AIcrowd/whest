          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([1, 2], dtype=int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c = we.append(a, [])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c"
            },
            {
              "kind": "output",
              "text": "array([1., 2.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c.dtype"
            },
            {
              "kind": "output",
              "text": "float64"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Default dtype for empty ndarrays is "
