  "example": {
    "code": "import whest as we\n\nA = we.eye(2) * 2\n\nB = we.eye(3) * 3\n\nwe.block([\n    [A,               we.zeros((2, 3))],\n    [we.ones((3, 2)), B               ]\n])\n\nwe.block([1, 2, 3])              # hstack([1, 2, 3])\n\na = we.array([1, 2, 3])\n\nb = we.array([4, 5, 6])\n\nwe.block([a, b, 10])             # hstack([a, b, 10])\n\nA = we.ones((2, 2), int)\n\nB = 2 * A\n\nwe.block([A, B])                 # hstack([A, B])\n\na = we.array([1, 2, 3])\n\nb = we.array([4, 5, 6])\n\nwe.block([[a], [b]])             # vstack([a, b])\n\nA = we.ones((2, 2), int)\n\nB = 2 * A\n\nwe.block([[A], [B]])             # vstack([A, B])\n\na = we.array(0)\n\nb = we.array([1])\n\nwe.block([a])                    # atleast_1d(a)\n\nwe.block([b])                    # atleast_1d(b)\n\nwe.block([[a]])                  # atleast_2d(a)\n\nwe.block([[b]])                  # atleast_2d(b)",
    "output": "array([[2., 0., 0., 0., 0.],\n       [0., 2., 0., 0., 0.],\n       [1., 1., 3., 0., 0.],\n       [1., 1., 0., 3., 0.],\n       [1., 1., 0., 0., 3.]])\n\narray([1, 2, 3])\n\narray([ 1,  2,  3,  4,  5,  6, 10])\n\narray([[1, 1, 2, 2],\n       [1, 1, 2, 2]])\n\narray([[1, 2, 3],\n       [4, 5, 6]])\n\narray([[1, 1],\n       [1, 1],\n       [2, 2],\n       [2, 2]])\n\narray([0])\n\narray([1])\n\narray([[0]])\n\narray([[1]])",
    "source": "derived"
  },
