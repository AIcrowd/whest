      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "When called with only scalars, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/block",
              "kind": "link",
              "target": "block",
              "text": "we.block"
            },
            {
              "kind": "text",
              "text": " is equivalent to an ndarray\ncall. So "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.block([[1, 2], [3, 4]]).html",
              "href": "",
              "kind": "link",
              "target": "block([[1, 2], [3, 4]])",
              "text": "we.block([[1, 2], [3, 4]])"
            },
            {
              "kind": "text",
              "text": " is equivalent to\n"
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.array([[1, 2], [3, 4]]).html",
              "href": "",
              "kind": "link",
              "target": "array([[1, 2], [3, 4]])",
              "text": "we.array([[1, 2], [3, 4]])"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function does not enforce that the blocks lie on a fixed grid.\n"
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.block([[a, b], [c, d]]).html",
              "href": "",
              "kind": "link",
              "target": "block([[a, b], [c, d]])",
              "text": "we.block([[a, b], [c, d]])"
            },
            {
              "kind": "text",
              "text": " is not restricted to arrays of the form:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "AAAbb\nAAAbb\ncccDD",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "But is also allowed to produce, for some "
            },
            {
              "kind": "code",
              "text": "a, b, c, d"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "AAAbb\nAAAbb\ncDDDD",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Since concatenation happens along the last axis first, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/block",
              "kind": "link",
              "target": "block",
              "text": "block"
            },
            {
              "kind": "text",
              "text": " is "
            },
            {
              "kind": "emphasis",
              "text": "not"
            },
            {
              "kind": "text",
              "text": "\ncapable of producing the following directly:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "AAAbb\ncccbb\ncccDD",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Matlab's \"square bracket stacking\", "
            },
            {
              "kind": "code",
              "text": "[A, B, ...; p, q, ...]"
            },
            {
              "kind": "text",
              "text": ", is\nequivalent to "
            },
            {
              "kind": "code",
              "text": "we.block([[A, B, ...], [p, q, ...]])"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The most common use of this function is to build a block matrix:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = we.eye(2) * 2"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "B = we.eye(3) * 3"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block(["
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[A,               we.zeros((2, 3))],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[we.ones((3, 2)), B               ]"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "])"
            },
            {
              "kind": "output",
              "text": "array([[2., 0., 0., 0., 0.],"
            },
            {
              "kind": "output",
              "text": "       [0., 2., 0., 0., 0.],"
            },
            {
              "kind": "output",
              "text": "       [1., 1., 3., 0., 0.],"
            },
            {
              "kind": "output",
              "text": "       [1., 1., 0., 3., 0.],"
            },
            {
              "kind": "output",
              "text": "       [1., 1., 0., 0., 3.]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "With a list of depth 1, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/block",
              "kind": "link",
              "target": "block",
              "text": "block"
            },
            {
              "kind": "text",
              "text": " can be used as "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/hstack",
              "kind": "link",
              "target": "hstack",
              "text": "hstack"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([1, 2, 3])              # hstack([1, 2, 3])"
            },
            {
              "kind": "output",
              "text": "array([1, 2, 3])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([4, 5, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([a, b, 10])             # hstack([a, b, 10])"
            },
            {
              "kind": "output",
              "text": "array([ 1,  2,  3,  4,  5,  6, 10])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = we.ones((2, 2), int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "B = 2 * A"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([A, B])                 # hstack([A, B])"
            },
            {
              "kind": "output",
              "text": "array([[1, 1, 2, 2],"
            },
            {
              "kind": "output",
              "text": "       [1, 1, 2, 2]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "With a list of depth 2, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/block",
              "kind": "link",
              "target": "block",
              "text": "block"
            },
            {
              "kind": "text",
              "text": " can be used in place of "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/vstack",
              "kind": "link",
              "target": "vstack",
              "text": "vstack"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([4, 5, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([[a], [b]])             # vstack([a, b])"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 5, 6]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "A = we.ones((2, 2), int)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "B = 2 * A"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([[A], [B]])             # vstack([A, B])"
            },
            {
              "kind": "output",
              "text": "array([[1, 1],"
            },
            {
              "kind": "output",
              "text": "       [1, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 2],"
            },
            {
              "kind": "output",
              "text": "       [2, 2]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "It can also be used in place of "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/atleast_1d",
              "kind": "link",
              "target": "atleast_1d",
              "text": "atleast_1d"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/atleast_2d",
              "kind": "link",
              "target": "atleast_2d",
              "text": "atleast_2d"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array(0)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([a])                    # atleast_1d(a)"
            },
            {
              "kind": "output",
              "text": "array([0])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([b])                    # atleast_1d(b)"
            },
            {
              "kind": "output",
              "text": "array([1])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([[a]])                  # atleast_2d(a)"
            },
            {
              "kind": "output",
              "text": "array([[0]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.block([[b]])                  # atleast_2d(b)"
            },
            {
              "kind": "output",
              "text": "array([[1]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
