          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.promote_types('f4', 'f8')"
            },
            {
              "kind": "output",
              "text": "dtype('float64')"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.promote_types('i8', 'f4')"
            },
            {
              "kind": "output",
              "text": "dtype('float64')"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.promote_types('>i8', '<c8')"
            },
            {
              "kind": "output",
              "text": "dtype('complex128')"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.promote_types('i4', 'S8')"
            },
            {
              "kind": "output",
              "text": "dtype('S11')"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "An example of a non-associative case:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p = we.promote_types"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p('S', p('i1', 'u1'))"
            },
            {
              "kind": "output",
              "text": "dtype('S6')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "p(p('S', 'i1'), 'u1')"
            },
            {
              "kind": "output",
              "text": "dtype('S4')"
            }
          ],
          "type": "doctest_block"
        }
