          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr = we.arange(12).reshape((3, 4))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr"
            },
            {
              "kind": "output",
              "text": "array([[ 0,  1,  2,  3],"
            },
            {
              "kind": "output",
              "text": "       [ 4,  5,  6,  7],"
            },
            {
              "kind": "output",
              "text": "       [ 8,  9, 10, 11]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "condition = we.mod(arr, 3)==0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "condition"
            },
            {
              "kind": "output",
              "text": "array([[ True, False, False,  True],"
            },
            {
              "kind": "output",
              "text": "       [False, False,  True, False],"
            },
            {
              "kind": "output",
              "text": "       [False,  True, False, False]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.extract(condition, arr)"
            },
            {
              "kind": "output",
              "text": "array([0, 3, 6, 9])"
            }
          ],
          "type": "doctest_block"
        },
