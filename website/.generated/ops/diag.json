          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(9).reshape((3,3))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 5],"
            },
            {
              "kind": "output",
              "text": "       [6, 7, 8]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.diag(x)"
            },
            {
              "kind": "output",
              "text": "array([0, 4, 8])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.diag(x, k=1)"
            },
            {
              "kind": "output",
              "text": "array([1, 5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.diag(x, k=-1)"
            },
            {
              "kind": "output",
              "text": "array([3, 7])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.diag(we.diag(x))"
            },
            {
              "kind": "output",
              "text": "array([[0, 0, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 4, 0],"
            },
            {
              "kind": "output",
              "text": "       [0, 0, 8]])"
            }
          ],
          "type": "doctest_block"
        }
