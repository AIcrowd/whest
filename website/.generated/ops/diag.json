    "code": "import whest as we\n\nx = we.arange(9).reshape((3,3))\n\nx\n\nwe.diag(x)\n\nwe.diag(x, k=1)\n\nwe.diag(x, k=-1)\n\nwe.diag(we.diag(x))",
