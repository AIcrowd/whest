  "example": {
    "code": "import whest as we\n\na = we.array([[1, 2], [3, 4]])\n\nb = we.array([[5, 6]])\n\nwe.concatenate((a, b), axis=0)\n\nwe.concatenate((a, b.T), axis=1)\n\nwe.concatenate((a, b), axis=None)\n\na = we.ma.arange(3)\n\na[1] = we.ma.masked\n\nb = we.arange(2, 5)\n\na\n\nb\n\nwe.concatenate([a, b])\n\nwe.ma.concatenate([a, b])",
    "output": "array([[1, 2],\n       [3, 4],\n       [5, 6]])\n\narray([[1, 2, 5],\n       [3, 4, 6]])\n\narray([1, 2, 3, 4, 5, 6])\n\nmasked_array(data=[0, --, 2],\n             mask=[False,  True, False],\n       fill_value=999999)\n\narray([2, 3, 4])\n\nmasked_array(data=[0, 1, 2, 2, 3, 4],\n             mask=False,\n       fill_value=999999)\n\nmasked_array(data=[0, --, 2, 2, 3, 4],\n             mask=[False,  True, False, False, False, False],\n       fill_value=999999)",
    "source": "derived"
