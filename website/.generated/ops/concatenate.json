    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "When one or more of the arrays to be concatenated is a MaskedArray,\nthis function will return a MaskedArray object instead of an ndarray,\nbut the input masks are "
            },
            {
              "kind": "emphasis",
              "text": "not"
            },
            {
              "kind": "text",
              "text": " preserved. In cases where a MaskedArray\nis expected as input, use the ma.concatenate function from the masked\narray module instead."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 2], [3, 4]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([[5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.concatenate((a, b), axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4],"
            },
            {
              "kind": "output",
              "text": "       [5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.concatenate((a, b.T), axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 5],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.concatenate((a, b), axis=None)"
            },
            {
              "kind": "output",
              "text": "array([1, 2, 3, 4, 5, 6])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function will not preserve masking of MaskedArray inputs."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.ma.arange(3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[1] = we.ma.masked"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.arange(2, 5)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "masked_array(data=[0, --, 2],"
            },
            {
              "kind": "output",
              "text": "             mask=[False,  True, False],"
            },
            {
              "kind": "output",
              "text": "       fill_value=999999)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([2, 3, 4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.concatenate([a, b])"
            },
            {
              "kind": "output",
              "text": "masked_array(data=[0, 1, 2, 2, 3, 4],"
            },
            {
              "kind": "output",
              "text": "             mask=False,"
            },
            {
              "kind": "output",
              "text": "       fill_value=999999)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ma.concatenate([a, b])"
            },
            {
              "kind": "output",
              "text": "masked_array(data=[0, --, 2, 2, 3, 4],"
            },
            {
              "kind": "output",
              "text": "             mask=[False,  True, False, False, False, False],"
            },
            {
              "kind": "output",
              "text": "       fill_value=999999)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
