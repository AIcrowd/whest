              "kind": "text",
              "text": " behaves very different\nfrom "
            },
            {
              "kind": "code",
              "text": "obj=[0]"
            },
            {
              "kind": "text",
              "text": " just like "
            },
            {
              "kind": "code",
              "text": "arr[:,0,:] = values"
            },
            {
              "kind": "text",
              "text": " is different from\n"
            },
            {
              "kind": "code",
              "text": "arr[:,[0],:] = values"
            },
            {
              "kind": "text",
              "text": ". This is because of the difference between basic\nand advanced "
