  "example": {
    "code": "import whest as we\n\na = we.arange(6).reshape(3, 2)\n\na\n\nwe.insert(a, 1, 6)\n\nwe.insert(a, 1, 6, axis=1)\n\nwe.insert(a, [1], [[7],[8],[9]], axis=1)\n\nwe.insert(a, 1, [[7],[8],[9]], axis=1)\n\nwe.array_equal(we.insert(a, 1, [7, 8, 9], axis=1),\n               we.insert(a, [1], [[7],[8],[9]], axis=1))\n\nb = a.flatten()\n\nb\n\nwe.insert(b, [2, 2], [6, 7])\n\nwe.insert(b, slice(2, 4), [7, 8])\n\nwe.insert(b, [2, 2], [7.13, False]) # type casting\n\nx = we.arange(8).reshape(2, 4)\n\nidx = (1, 3)\n\nwe.insert(x, idx, 999, axis=1)",
    "output": "array([[0, 1],\n       [2, 3],\n       [4, 5]])\n\narray([0, 6, 1, 2, 3, 4, 5])\n\narray([[0, 6, 1],\n       [2, 6, 3],\n       [4, 6, 5]])\n\narray([[0, 7, 1],\n       [2, 8, 3],\n       [4, 9, 5]])\n\narray([[0, 7, 8, 9, 1],\n       [2, 7, 8, 9, 3],\n       [4, 7, 8, 9, 5]])\n\nTrue\n\narray([0, 1, 2, 3, 4, 5])\n\narray([0, 1, 6, 7, 2, 3, 4, 5])\n\narray([0, 1, 7, 2, 8, 3, 4, 5])\n\narray([0, 1, 7, 0, 2, 3, 4, 5])\n\narray([[  0, 999,   1,   2, 999,   3],\n       [  4, 999,   5,   6, 999,   7]])",
    "source": "derived"
  },
