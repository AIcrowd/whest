      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(6).reshape(3, 2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(a, 1, 6)"
            },
            {
              "kind": "output",
              "text": "array([0, 6, 1, 2, 3, 4, 5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(a, 1, 6, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[0, 6, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 6, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 6, 5]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Difference between sequence and scalars,\nshowing how "
            },
            {
              "kind": "code",
              "text": "obj=[1]"
            },
            {
              "kind": "text",
              "text": " behaves different from "
            },
            {
              "kind": "code",
              "text": "obj=1"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(a, [1], [[7],[8],[9]], axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[0, 7, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 8, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 9, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(a, 1, [[7],[8],[9]], axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[0, 7, 8, 9, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 7, 8, 9, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 7, 8, 9, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array_equal(we.insert(a, 1, [7, 8, 9], axis=1),"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "we.insert(a, [1], [[7],[8],[9]], axis=1))"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = a.flatten()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 2, 3, 4, 5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(b, [2, 2], [6, 7])"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 6, 7, 2, 3, 4, 5])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(b, slice(2, 4), [7, 8])"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 7, 2, 8, 3, 4, 5])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(b, [2, 2], [7.13, False]) # type casting"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 7, 0, 2, 3, 4, 5])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(8).reshape(2, 4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "idx = (1, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.insert(x, idx, 999, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[  0, 999,   1,   2, 999,   3],"
            },
            {
              "kind": "output",
              "text": "       [  4, 999,   5,   6, 999,   7]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
