    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Broadcasting rules apply, see the "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.linalg.html",
              "href": "",
              "kind": "link",
              "target": "linalg",
              "text": "we.linalg"
            },
            {
              "kind": "text",
              "text": " documentation for\ndetails."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The eigenvalues are computed using LAPACK routines "
            },
            {
              "kind": "code",
              "text": "_syevd"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "_heevd"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from numpy import linalg as LA"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, -2j], [2j, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.eigvalsh(a)"
            },
            {
              "kind": "output",
              "text": "array([ 0.17157288,  5.82842712]) # may vary"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# demonstrate the treatment of the imaginary part of the diagonal"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[5+2j, 9-2j], [0+2j, 2-1j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[5.+2.j, 9.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+2.j, 2.-1.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# with UPLO='L' this is numerically equivalent to using LA.eigvals()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# with:"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([[5.+0.j, 0.-2.j], [0.+2.j, 2.-0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([[5.+0.j, 0.-2.j],"
            },
            {
              "kind": "output",
              "text": "       [0.+2.j, 2.+0.j]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "wa = LA.eigvalsh(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "wb = LA.eigvals(b)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "wa; wb"
            },
            {
              "kind": "output",
              "text": "array([1., 6.])"
            },
            {
              "kind": "output",
              "text": "array([6.+0.j, 1.+0.j])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
