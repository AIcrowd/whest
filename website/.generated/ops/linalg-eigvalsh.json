  "example": {
    "code": "import whest as we\n\nfrom numpy import linalg as LA\n\na = we.array([[1, -2j], [2j, 5]])\n\nLA.eigvalsh(a)\n\na = we.array([[5+2j, 9-2j], [0+2j, 2-1j]])\n\na\n\nb = we.array([[5.+0.j, 0.-2.j], [0.+2.j, 2.-0.j]])\n\nb\n\nwa = LA.eigvalsh(a)\n\nwb = LA.eigvals(b)\n\nwa; wb",
    "output": "array([ 0.17157288,  5.82842712]) # may vary\n\narray([[5.+2.j, 9.-2.j],\n       [0.+2.j, 2.-1.j]])\n\narray([[5.+0.j, 0.-2.j],\n       [0.+2.j, 2.+0.j]])\n\narray([1., 6.])\narray([6.+0.j, 1.+0.j])",
