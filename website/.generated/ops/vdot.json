    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([1+2j,3+4j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([5+6j,7+8j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.vdot(a, b)"
            },
            {
              "kind": "output",
              "text": "(70-8j)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.vdot(b, a)"
            },
            {
              "kind": "output",
              "text": "(70+8j)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that higher-dimensional arrays are flattened!"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 4], [5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([[4, 1], [2, 2]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.vdot(a, b)"
            },
            {
              "kind": "output",
              "text": "30"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.vdot(b, a)"
            },
            {
              "kind": "output",
              "text": "30"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "1*4 + 4*1 + 5*2 + 6*2"
            },
            {
              "kind": "output",
              "text": "30"
            }
          ],
          "type": "doctest_block"
        }
      ],
