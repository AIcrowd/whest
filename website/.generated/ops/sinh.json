    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sinh(0)"
            },
            {
              "kind": "output",
              "text": "0.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sinh(we.pi*1j/2)"
            },
            {
              "kind": "output",
              "text": "1j"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sinh(we.pi*1j) # (exact value is 0)"
            },
            {
              "kind": "output",
              "text": "1.2246063538223773e-016j"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Discrepancy due to vagaries of floating point arithmetic."
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Example of providing the optional output parameter"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out1 = we.array([0], dtype='d')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out2 = we.sinh([0.1], out1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out2 is out1"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Example of ValueError due to provision of shape mis-matched `out`"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sinh(we.zeros((3,3)),we.zeros((2,2)))"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "output",
              "text": "  File \"<stdin>\", line 1, in <module>"
            },
            {
              "kind": "output",
              "text": "ValueError: operands could not be broadcast together with shapes (3,3) (2,2)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
