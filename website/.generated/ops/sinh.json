              "kind": "text",
              "text": "Hyperbolic sine, element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Equivalent to "
            },
            {
              "kind": "code",
              "text": "1/2 * (we.exp(x) - we.exp(-x))"
            },
            {
              "kind": "text",
              "text": " or\n"
            },
            {
              "kind": "code",
              "text": "-1j * we.sin(1j*x)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
