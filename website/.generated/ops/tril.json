      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return a copy of an array with elements above the "
            },
            {
              "kind": "code",
              "text": "k"
            },
            {
              "kind": "text",
              "text": "-th diagonal zeroed.\nFor arrays with "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/ndim",
              "kind": "link",
              "target": "ndim",
              "text": "ndim"
            },
            {
              "kind": "text",
              "text": " exceeding 2, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/tril",
              "kind": "link",
              "target": "tril",
              "text": "tril"
            },
            {
              "kind": "text",
              "text": " will apply to the final two\naxes."
            }
          ],
          "type": "paragraph"
        }
      ],
