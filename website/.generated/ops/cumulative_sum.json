  "example": {
    "code": "a = we.array([1, 2, 3, 4, 5, 6])\n\na\n\nwe.cumulative_sum(a)\n\nwe.cumulative_sum(a, dtype=float)  # specifies type of output value(s)\n\nb = we.array([[1, 2, 3], [4, 5, 6]])\n\nwe.cumulative_sum(b,axis=0)  # sum over rows for each of the 3 columns\n\nwe.cumulative_sum(b,axis=1)  # sum over columns for each of the 2 rows\n\nc = we.array([1, 2e-9, 3e-9] * 1000000)\n\nwe.cumulative_sum(c)[-1]\n\nc.sum()",
