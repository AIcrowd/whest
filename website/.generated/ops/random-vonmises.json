                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "mu"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "kappa"
                    },
                    {
                      "kind": "text",
                      "text": " are both scalars.\nOtherwise, "
                    },
                    {
                      "kind": "code",
                      "text": "we.broadcast(mu, kappa).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
