  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from a von Mises distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Samples are drawn from a von Mises distribution with specified mode\n(mu) and concentration (kappa), on the interval [-pi, pi]."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The von Mises distribution (also known as the circular normal\ndistribution) is a continuous probability distribution on the unit\ncircle.  It may be thought of as the circular analogue of the normal\ndistribution."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "New code should use the "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.vonmises.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator.vonmises",
                  "text": "vonmises"
                },
                {
                  "kind": "text",
                  "text": "\nmethod of a "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator",
                  "text": "Generator"
                },
                {
                  "kind": "text",
                  "text": " instance instead;\nplease see the "
                },
                {
                  "display_text": "random-quick-start",
                  "explicit_title": false,
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "random-quick-start",
                  "role": "ref",
                  "suppress_link": false,
                  "target": "random-quick-start",
                  "unresolved": false
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n    New code should use the `~we.random.Generator.vonmises`\n    method of a `~we.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
          "supported": true,
          "type": "directive_block"
        }
