            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as "
                    },
                    {
                      "kind": "code",
                      "text": "like"
                    },
                    {
                      "kind": "text",
