            },
            {
              "kind": "output",
              "text": "array([-2, -1,  0,  1,  2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.flatnonzero(x)"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 3, 4])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Use the indices of the non-zero elements as an index array to extract\nthese elements:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x.ravel()[fnp.flatnonzero(x)]"
            },
            {
              "kind": "output",
              "text": "array([-2, -1,  1,  2])"
            }
