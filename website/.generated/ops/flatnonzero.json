              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.arange(-2, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
