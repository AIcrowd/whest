  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from a Wald, or inverse Gaussian, distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "As the scale approaches infinity, the distribution becomes more like a\nGaussian. Some references claim that the Wald is an inverse Gaussian\nwith mean equal to 1, but this is by no means universal."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The inverse Gaussian distribution was first studied in relationship to\nBrownian motion. In 1956 M.C.K. Tweedie used the name inverse Gaussian\nbecause there is an inverse relationship between the time to cover a\nunit distance and distance covered in unit time."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "New code should use the "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.wald.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator.wald",
                  "text": "wald"
                },
                {
                  "kind": "text",
                  "text": "\nmethod of a "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                  "href": "",
                  "kind": "link",
                  "target": "random.Generator",
                  "text": "Generator"
                },
                {
                  "kind": "text",
                  "text": " instance instead;\nplease see the "
                },
                {
                  "display_text": "random-quick-start",
                  "explicit_title": false,
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "random-quick-start",
                  "role": "ref",
                  "suppress_link": false,
                  "target": "random-quick-start",
                  "unresolved": false
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n    New code should use the `~we.random.Generator.wald`\n    method of a `~we.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
          "supported": true,
          "type": "directive_block"
        }
      ],
