                }
              ],
              "name": "mean",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Scale parameter, must be > 0."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "Scale parameter, must be > 0."
                }
              ],
              "name": "scale",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "external_url": "",
                      "href": "/docs/api/ops/mean",
                      "kind": "link",
                      "target": "mean",
                      "text": "mean"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "scale"
                    },
                    {
                      "kind": "text",
                      "text": " are both scalars.\nOtherwise, "
                    },
                    {
                      "kind": "code",
                      "text": "we.broadcast(mean, scale).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
