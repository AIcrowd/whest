  "notes": "Return array with sub-arrays deleted along axis. Cost: num deleted.",
  "notes_sections": [
    "Often it is preferable to use a boolean mask. For example:",
    ">>> arr = we.arange(12) + 1 >>> mask = we.ones(len(arr), dtype=bool) >>> mask[[0,2,4]] = False >>> result = arr[mask,...]",
    "Is equivalent to ``we.delete(arr, [0,2,4], axis=0)``, but allows further use of `mask`."
  ],
  "numpy_ref": "np.delete",
  "parameters": [
    {
      "body": [
        "Input array."
      ],
      "name": "arr",
      "type": "array_like"
    },
    {
      "body": [
        "Indicate indices of sub-arrays to remove along the specified axis.",
        "",
        ".. versionchanged:: 1.19.0",
        "    Boolean indices are now treated as a mask of elements to remove,",
        "    rather than being cast to the integers 0 and 1."
      ],
      "name": "obj",
      "type": "slice, int, array-like of ints or bools"
    },
    {
      "body": [
        "The axis along which to delete the subarray defined by `obj`.",
        "If `axis` is None, `obj` is applied to the flattened array."
      ],
      "name": "axis",
      "type": "int, optional"
    }
  ],
