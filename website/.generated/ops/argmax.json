  "example": {
    "code": "import flopscope as fnp\n\na = fnp.arange(6).reshape(2,3) + 10\n\na\n\nfnp.argmax(a)\n\nfnp.argmax(a, axis=0)\n\nfnp.argmax(a, axis=1)\n\na.flat[fnp.argmax(a)]\n\nind = fnp.unravel_index(fnp.argmax(a, axis=None), a.shape)\n\nind\n\na[ind]\n\nb = fnp.arange(6)\n\nb[1] = 5\n\nb\n\nfnp.argmax(b)  # Only the first occurrence is returned.\n\nx = fnp.array([[4,2,3], [1,0,3]])\n\nindex_array = fnp.argmax(x, axis=-1)\n\nfnp.take_along_axis(x, fnp.expand_dims(index_array, axis=-1), axis=-1)\n\nfnp.take_along_axis(x, fnp.expand_dims(index_array, axis=-1),\n    axis=-1).squeeze(axis=-1)\n\nx = fnp.arange(24).reshape((2, 3, 4))\n\nres = fnp.argmax(x, axis=1, keepdims=True)\n\nres.shape",
    "output": "array([[10, 11, 12],\n       [13, 14, 15]])\n\n5\n\narray([1, 1, 1])\n\narray([2, 2])\n\n15\n\n(1, 2)\n\n15\n\narray([0, 5, 2, 3, 4, 5])\n\n1\n\narray([[4],\n       [3]])\n\narray([4, 3])\n\n(2, 1, 4)",
    "source": "derived"
  },
