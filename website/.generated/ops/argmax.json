    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.arange(6).reshape(2,3) + 10"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[10, 11, 12],"
            },
            {
              "kind": "output",
              "text": "       [13, 14, 15]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.argmax(a)"
            },
            {
              "kind": "output",
              "text": "5"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.argmax(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([1, 1, 1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.argmax(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([2, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Indexes of the maximal elements of a N-dimensional array:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a.flat[fnp.argmax(a)]"
            },
            {
              "kind": "output",
              "text": "15"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ind = fnp.unravel_index(fnp.argmax(a, axis=None), a.shape)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ind"
            },
            {
              "kind": "output",
              "text": "(1, 2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[ind]"
            },
            {
              "kind": "output",
              "text": "15"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = fnp.arange(6)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b[1] = 5"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([0, 5, 2, 3, 4, 5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.argmax(b)  # Only the first occurrence is returned."
            },
            {
              "kind": "output",
              "text": "1"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.array([[4,2,3], [1,0,3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "index_array = fnp.argmax(x, axis=-1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Same as fnp.amax(x, axis=-1, keepdims=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.take_along_axis(x, fnp.expand_dims(index_array, axis=-1), axis=-1)"
            },
            {
              "kind": "output",
              "text": "array([[4],"
            },
            {
              "kind": "output",
              "text": "       [3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "# Same as fnp.amax(x, axis=-1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.take_along_axis(x, fnp.expand_dims(index_array, axis=-1),"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "axis=-1).squeeze(axis=-1)"
            },
            {
              "kind": "output",
              "text": "array([4, 3])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Setting "
            },
            {
              "kind": "code",
              "text": "keepdims"
            },
            {
              "kind": "text",
              "text": " to "
            },
            {
              "kind": "code",
              "text": "True"
            },
            {
              "kind": "text",
              "text": ","
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.arange(24).reshape((2, 3, 4))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "res = fnp.argmax(x, axis=1, keepdims=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "res.shape"
            },
            {
              "kind": "output",
              "text": "(2, 1, 4)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
