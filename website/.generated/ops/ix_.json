    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(10).reshape(2, 5)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2, 3, 4],"
            },
            {
              "kind": "output",
              "text": "       [5, 6, 7, 8, 9]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ixgrid = we.ix_([0, 1], [2, 4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ixgrid"
            },
            {
              "kind": "output",
              "text": "(array([[0],"
            },
            {
              "kind": "output",
              "text": "       [1]]), array([[2, 4]]))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ixgrid[0].shape, ixgrid[1].shape"
            },
            {
              "kind": "output",
              "text": "((2, 1), (1, 2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[ixgrid]"
            },
            {
              "kind": "output",
              "text": "array([[2, 4],"
            },
            {
              "kind": "output",
              "text": "       [7, 9]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ixgrid = we.ix_([True, True], [2, 4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[ixgrid]"
            },
            {
              "kind": "output",
              "text": "array([[2, 4],"
            },
            {
              "kind": "output",
              "text": "       [7, 9]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "ixgrid = we.ix_([True, True], [False, False, True, False, True])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[ixgrid]"
            },
            {
              "kind": "output",
              "text": "array([[2, 4],"
            },
            {
              "kind": "output",
              "text": "       [7, 9]])"
            }
