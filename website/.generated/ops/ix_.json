                      "text": "we.nonzero(boolean_sequence)"
                    },
                    {
                      "kind": "text",
                      "text": ")."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "1-D sequences",
              "inline": [
