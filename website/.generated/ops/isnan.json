            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isnan(fnp.inf)"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.isnan([fnp.log(-1.),1.,fnp.log(0)])"
            },
            {
              "kind": "output",
              "text": "array([ True, False, False])"
