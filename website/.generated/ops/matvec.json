                      "text": "x1"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "x2"
                    },
                    {
                      "kind": "text",
                      "text": " with the summation axis\nremoved. If not provided or None, a freshly-allocated array is used."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, optional",
