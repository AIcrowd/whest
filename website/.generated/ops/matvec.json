              "kind": "text",
              "text": "Rotate a set of vectors from Y to X along Z."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([[0., 1., 0.],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[-1., 0., 0.],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0., 0., 1.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "v = fnp.array([[1., 0., 0.],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0., 1., 0.],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0., 0., 1.],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[0., 6., 8.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.matvec(a, v)"
            },
            {
              "kind": "output",
