      "title": "See also"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([1, 2, 3, 4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.shares_memory(x, we.array([5, 6, 7]))"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.shares_memory(x[::2], x)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.shares_memory(x[::2], x[1::2])"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Checking whether two arrays share memory is NP-complete, and\nruntime may increase exponentially in the number of\ndimensions. Hence, "
            },
            {
              "kind": "code",
              "text": "max_work"
            },
            {
              "kind": "text",
              "text": " should generally be set to a finite\nnumber, as it is possible to construct examples that take\nextremely long to run:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from we.lib.stride_tricks import as_strided"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.zeros([192163377], dtype=we.int8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 = as_strided("
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "x, strides=(36674, 61119, 85569), shape=(1049, 1049, 1049))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x2 = as_strided("
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "x[64023025:], strides=(12223, 12224, 1), shape=(1049, 1049, 1))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.shares_memory(x1, x2, max_work=1000)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "we.exceptions.TooHardError: Exceeded max_work"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Running "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.shares_memory(x1, x2).html",
              "href": "",
              "kind": "link",
              "target": "shares_memory(x1, x2)",
              "text": "we.shares_memory(x1, x2)"
            },
            {
              "kind": "text",
              "text": " without "
            },
            {
              "kind": "code",
              "text": "max_work"
            },
            {
              "kind": "text",
              "text": " set takes\naround 1 minute for this case. It is possible to find problems\nthat take still significantly longer."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Examples"
    }
