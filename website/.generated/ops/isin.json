            {
              "kind": "text",
              "text": "Calculates "
            },
            {
              "kind": "code",
              "text": "element in test_elements"
            },
            {
              "kind": "text",
              "text": ", broadcasting over "
            },
            {
              "kind": "code",
              "text": "element"
            },
            {
              "kind": "text",
              "text": " only. Returns a boolean array of the same shape as "
            },
            {
              "kind": "code",
              "text": "element"
            },
            {
              "kind": "text",
              "text": " that is True where an element of "
            },
            {
              "kind": "code",
              "text": "element"
            },
            {
              "kind": "text",
              "text": " is in "
            },
            {
              "kind": "code",
              "text": "test_elements"
            },
            {
              "kind": "text",
              "text": " and False otherwise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
