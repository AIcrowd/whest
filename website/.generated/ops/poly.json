  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Find the coefficients of a polynomial with the given sequence of roots."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "This forms part of the old polynomial API. Since version 1.4, the\nnew polynomial API defined in "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.polynomial.html",
                  "href": "",
                  "kind": "link",
                  "target": "polynomial",
                  "text": "fnp.polynomial"
                },
                {
                  "kind": "text",
                  "text": " is preferred.\nA summary of the differences can be found in the\n"
                },
                {
                  "display_text": "transition guide",
                  "explicit_title": true,
                  "external_url": "",
                  "href": "",
                  "kind": "role_reference",
                  "original_target": "/reference/routines.polynomials",
                  "role": "doc",
                  "suppress_link": false,
                  "target": "/reference/routines.polynomials",
                  "unresolved": true
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "note",
          "options": [],
          "raw_source": ".. note::\n   This forms part of the old polynomial API. Since version 1.4, the\n   new polynomial API defined in `fnp.polynomial` is preferred.\n   A summary of the differences can be found in the\n   :doc:`transition guide </reference/routines.polynomials>`.",
          "supported": true,
          "type": "directive_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns the coefficients of the polynomial whose leading coefficient\nis one for the given sequence of zeros (multiple roots must be included\nin the sequence as many times as their multiplicity; see Examples).\nA square matrix (or array, which will be treated as a matrix) can also\nbe given, in which case the coefficients of the characteristic polynomial\nof the matrix are returned."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A sequence of polynomial roots, or a square array or matrix object."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like, shape (N,) or (N, N)",
              "inline": [
                {
                  "kind": "text",
                  "text": "A sequence of polynomial roots, or a square array or matrix object."
                }
              ],
              "name": "seq_of_zeros",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "1D array of polynomial coefficients from highest to lowest degree:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "c[0] * x**(N) + c[1] * x**(N-1) + ... + c[N-1] * x + c[N]"
                    },
                    {
                      "kind": "text",
                      "text": "\nwhere c[0] always equals 1."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray",
              "inline": [
                {
                  "kind": "text",
                  "text": "1D array of polynomial coefficients from highest to lowest degree:"
                }
              ],
              "name": "c",
              "type": "field_list"
            }
          ],
          "title": "Returns",
          "type": "field_list"
        }
      ],
