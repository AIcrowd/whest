        "computation on empty slice. See `~we.ufunc.reduce` for details.",
        "",
        ".. versionadded:: 1.22.0"
      ],
      "name": "initial",
      "type": "scalar, optional"
    },
    {
      "body": [
        "Elements to compare for the maximum. See `~we.ufunc.reduce`",
        "for details.",
        "",
        ".. versionadded:: 1.22.0"
      ],
