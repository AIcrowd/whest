  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the maximum of an array or maximum along an axis, ignoring any NaNs.  When all-NaN slices are encountered a "
            },
            {
              "kind": "code",
              "text": "RuntimeWarning"
            },
            {
              "kind": "text",
              "text": " is raised and NaN is returned for that slice."
            }
          ],
          "type": "paragraph"
        }
      ],
