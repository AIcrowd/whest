          "type": "paragraph"
        },
        {
          "language": null,
          "text": "fnp.unique(x, return_index=True, return_inverse=True,\n          return_counts=True, equal_nan=False, sorted=False)",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "but returns a namedtuple for easier access to each output."
            }
          ],
          "type": "paragraph"
        },
        {
