          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.all([[True,False],[True,True]])"
            },
            {
              "kind": "output",
              "text": "False"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.all([[True,False],[True,True]], axis=0)"
            },
            {
              "kind": "output",
              "text": "array([ True, False])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.all([-1, 4, 5])"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.all([1.0, fnp.nan])"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.all([[True, True], [False, True]], where=[[True], [False]])"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "o=fnp.array(False)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "z=fnp.all([-1, 4, 5], out=o)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "id(z), id(o), z"
            },
            {
              "kind": "output",
              "text": "(28293632, 28293632, array(True)) # may vary"
            }
          ],
          "type": "doctest_block"
        }
