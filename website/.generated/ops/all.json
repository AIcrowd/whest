                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array or object that can be converted to an array."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axis or axes along which a logical AND reduction is performed.\nThe default ("
                    },
                    {
                      "kind": "code",
                      "text": "axis=None"
                    },
                    {
                      "kind": "text",
                      "text": ") is to perform a logical AND over all\nthe dimensions of the input array. "
                    },
                    {
                      "kind": "code",
                      "text": "axis"
                    },
                    {
                      "kind": "text",
                      "text": " may be negative, in\nwhich case it counts from the last to the first axis. If this\nis a tuple of ints, a reduction is performed on multiple\naxes, instead of a single axis or all the axes as before."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "None or int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Axis or axes along which a logical AND reduction is performed.\nThe default ("
                },
                {
                  "kind": "code",
                  "text": "axis=None"
                },
                {
                  "kind": "text",
                  "text": ") is to perform a logical AND over all\nthe dimensions of the input array. "
                },
                {
                  "kind": "code",
                  "text": "axis"
                },
                {
                  "kind": "text",
                  "text": " may be negative, in\nwhich case it counts from the last to the first axis. If this\nis a tuple of ints, a reduction is performed on multiple\naxes, instead of a single axis or all the axes as before."
                }
              ],
              "name": "axis",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Alternate output array in which to place the result.\nIt must have the same shape as the expected output and its\ntype is preserved (e.g., if "
                    },
                    {
                      "kind": "code",
                      "text": "dtype(out)"
                    },
                    {
                      "kind": "text",
                      "text": " is float, the result\nwill consist of 0.0's and 1.0's). See "
                    },
                    {
                      "display_text": "ufuncs-output-type",
                      "explicit_title": false,
                      "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.ufuncs-output-type.html",
                      "href": "",
                      "kind": "role_reference",
                      "original_target": "ufuncs-output-type",
                      "role": "ref",
                      "suppress_link": false,
                      "target": "ufuncs-output-type",
                      "unresolved": false
                    },
                    {
                      "kind": "text",
                      "text": "\nfor more details."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Alternate output array in which to place the result.\nIt must have the same shape as the expected output and its\ntype is preserved (e.g., if "
                },
                {
                  "kind": "code",
                  "text": "dtype(out)"
                },
                {
                  "kind": "text",
                  "text": " is float, the result\nwill consist of 0.0's and 1.0's). See "
                },
                {
                  "display_text": "ufuncs-output-type",
                  "explicit_title": false,
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.ufuncs-output-type.html",
                  "href": "",
                  "kind": "role_reference",
