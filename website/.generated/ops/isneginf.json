      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "NumPy uses the IEEE Standard for Binary Floating-Point for Arithmetic\n(IEEE 754)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Errors result if the second argument is also supplied when x is a scalar\ninput, if first and second arguments have different shapes, or if the\nfirst argument has complex values."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.isneginf(-we.inf)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.isneginf(we.inf)"
            },
            {
              "kind": "output",
              "text": "False"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.isneginf([-we.inf, 0., we.inf])"
            },
            {
              "kind": "output",
              "text": "array([ True, False, False])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([-we.inf, 0., we.inf])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([2, 2, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.isneginf(x, y)"
            },
            {
              "kind": "output",
              "text": "array([1, 0, 0])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y"
            },
            {
              "kind": "output",
              "text": "array([1, 0, 0])"
            }
          ],
          "type": "doctest_block"
        }
