      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The pseudo-inverse of a matrix A, denoted "
            },
            {
              "kind": "math",
              "latex": "A^+"
            },
            {
              "kind": "text",
              "text": ", is\ndefined as: \"the matrix that 'solves' [the least-squares problem]\n"
            },
            {
              "kind": "math",
              "latex": "Ax = b"
            },
            {
              "kind": "text",
              "text": ",\" i.e., if "
            },
            {
              "kind": "math",
              "latex": "\\bar{x}"
            },
            {
              "kind": "text",
              "text": " is said solution, then\n"
            },
            {
              "kind": "math",
              "latex": "A^+"
            },
            {
              "kind": "text",
              "text": " is that matrix such that "
            },
            {
              "kind": "math",
              "latex": "\\bar{x} = A^+b"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "It can be shown that if "
            },
            {
              "kind": "math",
              "latex": "Q_1 \\Sigma Q_2^T = A"
            },
            {
              "kind": "text",
              "text": " is the singular\nvalue decomposition of A, then\n"
            },
            {
              "kind": "math",
              "latex": "A^+ = Q_2 \\Sigma^+ Q_1^T"
            },
            {
              "kind": "text",
              "text": ", where "
            },
            {
              "kind": "math",
              "latex": "Q_{1,2}"
            },
            {
              "kind": "text",
              "text": " are\northogonal matrices, "
            },
            {
              "kind": "math",
              "latex": "\\Sigma"
            },
            {
              "kind": "text",
              "text": " is a diagonal matrix consisting\nof A's so-called singular values, (followed, typically, by\nzeros), and then "
            },
            {
              "kind": "math",
              "latex": "\\Sigma^+"
            },
            {
              "kind": "text",
              "text": " is simply the diagonal matrix\nconsisting of the reciprocals of A's singular values\n(again, followed by zeros). "
            },
            {
              "kind": "text",
              "text": "[1]_"
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nG. Strang, Linear Algebra and Its Applications, 2nd Ed., Orlando,\nFL, Academic Press, Inc., 1980, pp. 139-142.",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The following example checks that "
            },
            {
              "kind": "code",
              "text": "a * a+ * a == a"
            },
            {
              "kind": "text",
              "text": " and\n"
            },
            {
              "kind": "code",
              "text": "a+ * a * a+ == a+"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = we.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = rng.normal(size=(9, 6))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "B = we.linalg.pinv(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.allclose(a, we.dot(a, we.dot(B, a)))"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.allclose(B, we.dot(B, we.dot(a, B)))"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
