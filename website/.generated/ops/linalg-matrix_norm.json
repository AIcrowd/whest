              "kind": "input",
              "prompt": ">>>",
              "text": "from numpy import linalg as LA"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(9) - 4"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([-4, -3, -2, ...,  2,  3,  4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = a.reshape((3, 3))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b"
            },
            {
              "kind": "output",
              "text": "array([[-4, -3, -2],"
            },
            {
              "kind": "output",
              "text": "       [-1,  0,  1],"
            },
            {
              "kind": "output",
              "text": "       [ 2,  3,  4]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "LA.matrix_norm(b)"
