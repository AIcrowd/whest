    "code": "from numpy import linalg as LA\n\na = we.arange(9) - 4\n\na\n\nb = a.reshape((3, 3))\n\nb\n\nLA.matrix_norm(b)\n\nLA.matrix_norm(b, ord='fro')\n\nLA.matrix_norm(b, ord=we.inf)\n\nLA.matrix_norm(b, ord=-we.inf)\n\nLA.matrix_norm(b, ord=1)\n\nLA.matrix_norm(b, ord=-1)\n\nLA.matrix_norm(b, ord=2)\n\nLA.matrix_norm(b, ord=-2)",
