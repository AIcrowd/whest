    "code": "import whest as we\n\nwe.isclose([1e10,1e-7], [1.00001e10,1e-8])\n\nwe.isclose([1e10,1e-8], [1.00001e10,1e-9])\n\nwe.isclose([1e10,1e-8], [1.0001e10,1e-9])\n\nwe.isclose([1.0, we.nan], [1.0, we.nan])\n\nwe.isclose([1.0, we.nan], [1.0, we.nan], equal_nan=True)\n\nwe.isclose([1e-8, 1e-7], [0.0, 0.0])\n\nwe.isclose([1e-100, 1e-7], [0.0, 0.0], atol=0.0)\n\nwe.isclose([1e-10, 1e-10], [1e-20, 0.0])\n\nwe.isclose([1e-10, 1e-10], [1e-20, 0.999999e-10], atol=0.0)",
