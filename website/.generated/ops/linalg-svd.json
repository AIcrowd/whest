  "example": {
    "code": "import flopscope as fnp\n\nrng = fnp.random.default_rng()\n\na = rng.normal(size=(9, 6)) + 1j*rng.normal(size=(9, 6))\n\nb = rng.normal(size=(2, 7, 8, 3)) + 1j*rng.normal(size=(2, 7, 8, 3))\n\nU, S, Vh = fnp.linalg.svd(a, full_matrices=True)\n\nU.shape, S.shape, Vh.shape\n\nfnp.allclose(a, fnp.dot(U[:, :6] * S, Vh))\n\nsmat = fnp.zeros((9, 6), dtype=complex)\n\nsmat[:6, :6] = fnp.diag(S)\n\nfnp.allclose(a, fnp.dot(U, fnp.dot(smat, Vh)))\n\nU, S, Vh = fnp.linalg.svd(a, full_matrices=False)\n\nU.shape, S.shape, Vh.shape\n\nfnp.allclose(a, fnp.dot(U * S, Vh))\n\nsmat = fnp.diag(S)\n\nfnp.allclose(a, fnp.dot(U, fnp.dot(smat, Vh)))\n\nU, S, Vh = fnp.linalg.svd(b, full_matrices=True)\n\nU.shape, S.shape, Vh.shape\n\nfnp.allclose(b, fnp.matmul(U[..., :3] * S[..., None, :], Vh))\n\nfnp.allclose(b, fnp.matmul(U[..., :3], S[..., None] * Vh))\n\nU, S, Vh = fnp.linalg.svd(b, full_matrices=False)\n\nU.shape, S.shape, Vh.shape\n\nfnp.allclose(b, fnp.matmul(U * S[..., None, :], Vh))\n\nfnp.allclose(b, fnp.matmul(U, S[..., None] * Vh))",
