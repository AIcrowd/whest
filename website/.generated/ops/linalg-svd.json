  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Singular Value Decomposition."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "When "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " is a 2D array, and "
            },
            {
              "kind": "code",
              "text": "full_matrices=False"
            },
            {
              "kind": "text",
              "text": ", then it is\nfactorized as "
            },
            {
              "kind": "code",
              "text": "u @ fnp.diag(s) @ vh = (u * s) @ vh"
            },
            {
              "kind": "text",
              "text": ", where\n"
            },
            {
              "kind": "code",
              "text": "u"
            },
            {
              "kind": "text",
              "text": " and the Hermitian transpose of "
            },
            {
              "kind": "code",
              "text": "vh"
            },
            {
              "kind": "text",
              "text": " are 2D arrays with\northonormal columns and "
            },
            {
              "kind": "code",
              "text": "s"
            },
            {
              "kind": "text",
              "text": " is a 1D array of "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": "'s singular\nvalues. When "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " is higher-dimensional, SVD is applied in\nstacked mode as explained below."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
