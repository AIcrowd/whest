          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumprod(1)"
            },
            {
              "kind": "output",
              "text": "array([1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumprod([1])"
            },
            {
              "kind": "output",
              "text": "array([1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumprod([1, we.nan])"
            },
            {
              "kind": "output",
              "text": "array([1.,  1.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 2], [3, we.nan]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumprod(a)"
            },
            {
              "kind": "output",
              "text": "array([1.,  2.,  6.,  6.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumprod(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [3.,  2.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumprod(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [3.,  3.]])"
            }
