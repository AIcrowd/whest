      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The x-coordinate sequence is expected to be increasing, but this is not\nexplicitly enforced.  However, if the sequence "
            },
            {
              "kind": "code",
              "text": "xp"
            },
            {
              "kind": "text",
              "text": " is non-increasing,\ninterpolation results are meaningless."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that, since NaN is unsortable, "
            },
            {
              "kind": "code",
              "text": "xp"
            },
            {
              "kind": "text",
              "text": " also cannot contain NaNs."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "A simple check for "
            },
            {
              "kind": "code",
              "text": "xp"
            },
            {
              "kind": "text",
              "text": " being strictly increasing is:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "we.all(we.diff(xp) > 0)",
          "type": "literal_block"
        }
      ],
      "title": "Warnings"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "xp = [1, 2, 3]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fp = [3, 2, 0]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.interp(2.5, xp, fp)"
            },
            {
              "kind": "output",
              "text": "1.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.interp([0, 1, 1.5, 2.72, 3.14], xp, fp)"
            },
            {
              "kind": "output",
              "text": "array([3.  , 3.  , 2.5 , 0.56, 0.  ])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "UNDEF = -99.0"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.interp(3.14, xp, fp, right=UNDEF)"
            },
            {
              "kind": "output",
              "text": "-99.0"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Plot an interpolant to the sine function:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.linspace(0, 2*we.pi, 10)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.sin(x)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "xvals = we.linspace(0, 2*we.pi, 50)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "yinterp = we.interp(xvals, x, y)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(x, y, 'o')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at 0x...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(xvals, yinterp, '-x')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at 0x...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Interpolation with periodic x-coordinates:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = [-180, -170, -185, 185, -10, -5, 0, 365]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "xp = [190, -190, 350, -350]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fp = [5, 10, 3, 4]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.interp(x, xp, fp, period=360)"
            },
            {
              "kind": "output",
              "text": "array([7.5 , 5.  , 8.75, 6.25, 3.  , 3.25, 3.5 , 3.75])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Complex interpolation:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = [1.5, 4.0]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "xp = [2,3,5]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fp = [1.0j, 0, 2+3j]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.interp(x, xp, fp)"
            },
            {
              "kind": "output",
              "text": "array([0.+1.j , 1.+1.5j])"
            }
          ],
          "type": "doctest_block"
        }
      ],
