            {
              "kind": "text",
              "text": "One-dimensional linear interpolation for monotonically increasing sample points."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns the one-dimensional piecewise linear interpolant to a function\nwith given discrete data points ("
            },
            {
              "kind": "code",
              "text": "xp"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "fp"
            },
            {
              "kind": "text",
              "text": "), evaluated at "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
