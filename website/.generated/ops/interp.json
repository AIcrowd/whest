                      "kind": "code",
                      "text": "xp"
                    },
                    {
                      "kind": "text",
                      "text": " is internally sorted after\nnormalizing the periodic boundaries with "
                    },
                    {
                      "kind": "code",
                      "text": "xp = xp % period"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
