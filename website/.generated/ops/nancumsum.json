          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumsum(1)"
            },
            {
              "kind": "output",
              "text": "array([1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumsum([1])"
            },
            {
              "kind": "output",
              "text": "array([1])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumsum([1, we.nan])"
            },
            {
              "kind": "output",
              "text": "array([1.,  1.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 2], [3, we.nan]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumsum(a)"
            },
            {
              "kind": "output",
              "text": "array([1.,  3.,  6.,  6.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumsum(a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[1.,  2.],"
            },
            {
              "kind": "output",
              "text": "       [4.,  2.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.nancumsum(a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[1.,  3.],"
            },
            {
              "kind": "output",
              "text": "       [3.,  3.]])"
            }
          ],
