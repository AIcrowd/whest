              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr = we.array([[3,6,6],[4,5,1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ravel_multi_index(arr, (7,6))"
            },
            {
              "kind": "output",
              "text": "array([22, 41, 37])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ravel_multi_index(arr, (7,6), order='F')"
            },
            {
              "kind": "output",
              "text": "array([31, 41, 13])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ravel_multi_index(arr, (4,6), mode='clip')"
            },
            {
              "kind": "output",
              "text": "array([22, 23, 19])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.ravel_multi_index(arr, (4,4), mode=('clip','wrap'))"
            },
            {
              "kind": "output",
              "text": "array([12, 13, 13])"
