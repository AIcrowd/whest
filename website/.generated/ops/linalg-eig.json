  "example": {
    "code": "import whest as we\n\nfrom numpy import linalg as LA\n\neigenvalues, eigenvectors = LA.eig(we.diag((1, 2, 3)))\n\neigenvalues\n\neigenvectors\n\neigenvalues, eigenvectors = LA.eig(we.array([[1, -1], [1, 1]]))\n\neigenvalues\n\neigenvectors\n\na = we.array([[1, 1j], [-1j, 1]])\n\neigenvalues, eigenvectors = LA.eig(a)\n\neigenvalues\n\neigenvectors\n\na = we.array([[1 + 1e-9, 0], [0, 1 - 1e-9]])\n\neigenvalues, eigenvectors = LA.eig(a)\n\neigenvalues\n\neigenvectors",
    "output": "array([1., 2., 3.])\n\narray([[1., 0., 0.],\n       [0., 1., 0.],\n       [0., 0., 1.]])\n\narray([1.+1.j, 1.-1.j])\n\narray([[0.70710678+0.j        , 0.70710678-0.j        ],\n       [0.        -0.70710678j, 0.        +0.70710678j]])\n\narray([2.+0.j, 0.+0.j])\n\narray([[ 0.        +0.70710678j,  0.70710678+0.j        ], # may vary\n       [ 0.70710678+0.j        , -0.        +0.70710678j]])\n\narray([1., 1.])\n\narray([[1., 0.],\n       [0., 1.]])",
    "source": "derived"
  },
