  "example": {
    "code": "import flopscope as fnp\n\nfrom fnp.linalg import multi_dot\n\nA = fnp.random.random((10000, 100))\n\nB = fnp.random.random((100, 1000))\n\nC = fnp.random.random((1000, 5))\n\nD = fnp.random.random((5, 333))\n\n_ = multi_dot([A, B, C, D])\n\n_ = fnp.dot(fnp.dot(fnp.dot(A, B), C), D)\n\n_ = A.dot(B).dot(C).dot(D)",
