  "area": "linalg",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the dot product of two or more arrays in a single function call, while automatically selecting the fastest evaluation order."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "multi_dot"
            },
            {
              "kind": "text",
              "text": " chains "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/dot",
              "kind": "link",
              "target": "dot",
              "text": "fnp.dot"
            },
            {
              "kind": "text",
              "text": " and uses optimal parenthesization\nof the matrices "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": " "
            },
            {
              "kind": "text",
              "text": "[2]_"
            },
            {
              "kind": "text",
              "text": ". Depending on the shapes of the matrices,\nthis can speed up the multiplication a lot."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If the first argument is 1-D it is treated as a row vector.\nIf the last argument is 1-D it is treated as a column vector.\nThe other arguments must be 2-D."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Think of "
            },
            {
              "kind": "code",
              "text": "multi_dot"
            },
            {
              "kind": "text",
              "text": " as:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "def multi_dot(arrays): return functools.reduce(fnp.dot, arrays)",
          "type": "literal_block"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If the first argument is 1-D it is treated as row vector.\nIf the last argument is 1-D it is treated as column vector.\nThe other arguments must be 2-D."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "sequence of array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "If the first argument is 1-D it is treated as row vector.\nIf the last argument is 1-D it is treated as column vector.\nThe other arguments must be 2-D."
                }
              ],
              "name": "arrays",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output argument. This must have the exact kind that would be returned\nif it was not used. In particular, it must have the right type, must be\nC-contiguous, and its dtype must be the dtype that would be returned\nfor "
                    },
                    {
                      "kind": "code",
                      "text": "dot(a, b)"
                    },
                    {
                      "kind": "text",
                      "text": ". This is a performance feature. Therefore, if these\nconditions are not met, an exception is raised, instead of attempting\nto be flexible."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, optional",
              "inline": [
                {
                  "kind": "text",
