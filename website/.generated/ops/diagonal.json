    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.arange(4).reshape(2,2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a.diagonal()"
            },
            {
              "kind": "output",
              "text": "array([0, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a.diagonal(1)"
            },
            {
              "kind": "output",
              "text": "array([1])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "A 3-D example:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.arange(8).reshape(2,2,2); a"
            },
            {
              "kind": "output",
              "text": "array([[[0, 1],"
            },
            {
              "kind": "output",
              "text": "        [2, 3]],"
            },
            {
              "kind": "output",
              "text": "       [[4, 5],"
            },
            {
              "kind": "output",
              "text": "        [6, 7]]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a.diagonal(0,  # Main diagonals of two arrays created by skipping"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "0,  # across the outer(left)-most axis last and"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "1)  # the \"middle\" (row) axis first."
            },
            {
              "kind": "output",
              "text": "array([[0, 6],"
            },
            {
              "kind": "output",
              "text": "       [1, 7]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The sub-arrays whose main diagonals we just obtained; note that each\ncorresponds to fixing the right-most (column) axis, and that the\ndiagonals are \"packed\" in rows."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[:,:,0]  # main diagonal is [0 6]"
            },
            {
              "kind": "output",
              "text": "array([[0, 2],"
            },
            {
              "kind": "output",
              "text": "       [4, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[:,:,1]  # main diagonal is [1 7]"
            },
            {
              "kind": "output",
              "text": "array([[1, 3],"
            },
            {
              "kind": "output",
              "text": "       [5, 7]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The anti-diagonal can be obtained by reversing the order of elements\nusing either "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/flipud",
              "kind": "link",
              "target": "flipud",
              "text": "fnp.flipud"
            },
            {
              "kind": "text",
              "text": " or "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/fliplr",
              "kind": "link",
              "target": "fliplr",
              "text": "fnp.fliplr"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.arange(9).reshape(3, 3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 5],"
            },
            {
              "kind": "output",
              "text": "       [6, 7, 8]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.fliplr(a).diagonal()  # Horizontal flip"
            },
            {
              "kind": "output",
              "text": "array([2, 4, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.flipud(a).diagonal()  # Vertical flip"
            },
            {
              "kind": "output",
              "text": "array([6, 4, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that the order in which the diagonal is retrieved varies depending\non the flip function."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Examples"
    }
