  "example": {
    "code": "import whest as we\n\nx = we.array([1, 2, 3, 5])\n\nN = 3\n\nwe.vander(x, N)\n\nwe.column_stack([x**(N-1-i) for i in range(N)])\n\nx = we.array([1, 2, 3, 5])\n\nwe.vander(x)\n\nwe.vander(x, increasing=True)\n\nwe.linalg.det(we.vander(x))\n\n(5-3)*(5-2)*(5-1)*(3-2)*(3-1)*(2-1)",
    "output": "array([[ 1,  1,  1],\n       [ 4,  2,  1],\n       [ 9,  3,  1],\n       [25,  5,  1]])\n\narray([[ 1,  1,  1],\n       [ 4,  2,  1],\n       [ 9,  3,  1],\n       [25,  5,  1]])\n\narray([[  1,   1,   1,   1],\n       [  8,   4,   2,   1],\n       [ 27,   9,   3,   1],\n       [125,  25,   5,   1]])\n\narray([[  1,   1,   1,   1],\n       [  1,   2,   4,   8],\n       [  1,   3,   9,  27],\n       [  1,   5,  25, 125]])\n\n48.000000000000043 # may vary\n\n48",
    "source": "derived"
  },
