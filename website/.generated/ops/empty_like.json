            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Overrides the memory layout of the result. 'C' means C-order,\n'F' means F-order, 'A' means 'F' if "
                    },
                    {
                      "kind": "code",
                      "text": "prototype"
                    },
                    {
                      "kind": "text",
                      "text": " is Fortran\ncontiguous, 'C' otherwise. 'K' means match the layout of "
                    },
                    {
                      "kind": "code",
                      "text": "prototype"
                    },
                    {
                      "kind": "text",
                      "text": "\nas closely as possible."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{'C', 'F', 'A', or 'K'}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Overrides the memory layout of the result. 'C' means C-order,\n'F' means F-order, 'A' means 'F' if "
