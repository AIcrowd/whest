                {
                  "kind": "code",
                  "text": "prototype"
                },
                {
                  "kind": "text",
                  "text": " is Fortran\ncontiguous, 'C' otherwise. 'K' means match the layout of "
                },
                {
                  "kind": "code",
                  "text": "prototype"
                },
                {
                  "kind": "text",
                  "text": "\nas closely as possible."
                }
              ],
              "name": "order",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If True, then the newly created array will use the sub-class\ntype of "
                    },
                    {
                      "kind": "code",
                      "text": "prototype"
                    },
                    {
                      "kind": "text",
                      "text": ", otherwise it will be a base-class array. Defaults\nto True."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional.",
              "inline": [
                {
                  "kind": "text",
                  "text": "If True, then the newly created array will use the sub-class\ntype of "
