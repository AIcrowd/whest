          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = ([1,2,3], [4,5,6])                         # a is array-like"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.empty_like(a)"
            },
            {
              "kind": "output",
              "text": "array([[-1073741821, -1073741821,           3],    # uninitialized"
            },
            {
              "kind": "output",
              "text": "       [          0,           0, -1073741821]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1., 2., 3.],[4.,5.,6.]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.empty_like(a)"
            },
            {
              "kind": "output",
              "text": "array([[ -2.00000715e+000,   1.48219694e-323,  -2.00000572e+000], # uninitialized"
            },
            {
              "kind": "output",
              "text": "       [  4.38791518e-305,  -2.00000715e+000,   4.17269252e-309]])"
            }
          ],
