  "example": {
    "code": "import whest as we\n\na = we.array((0, 0, 0, 1, 2, 3, 0, 2, 1, 0))\n\nwe.trim_zeros(a)\n\nwe.trim_zeros(a, trim='b')\n\nb = we.array([[0, 0, 2, 3, 0, 0],\n              [0, 1, 0, 3, 0, 0],\n              [0, 0, 0, 0, 0, 0]])\n\nwe.trim_zeros(b)\n\nwe.trim_zeros(b, axis=-1)\n\nwe.trim_zeros([0, 1, 2, 0])",
    "output": "array([1, 2, 3, 0, 2, 1])\n\narray([0, 0, 0, ..., 0, 2, 1])\n\narray([[0, 2, 3],\n       [1, 0, 3]])\n\narray([[0, 2, 3],\n       [1, 0, 3],\n       [0, 0, 0]])\n\n[1, 2]",
