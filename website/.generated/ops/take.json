      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "By eliminating the inner loop in the description above, and using "
            },
            {
              "kind": "code",
              "text": "s_"
            },
            {
              "kind": "text",
              "text": " to\nbuild simple slice objects, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/take",
              "kind": "link",
              "target": "take",
              "text": "take"
            },
            {
              "kind": "text",
              "text": " can be expressed  in terms of applying\nfancy indexing to each 1-d slice:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "Ni, Nk = a.shape[:axis], a.shape[axis+1:]\nfor ii in ndindex(Ni):\n    for kk in ndindex(Nk):\n        out[ii + s_[...,] + kk] = a[ii + s_[:,] + kk][indices]",
          "type": "literal_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For this reason, it is equivalent to (but faster than) the following use\nof "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/apply_along_axis",
              "kind": "link",
              "target": "apply_along_axis",
              "text": "apply_along_axis"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "out = fnp.apply_along_axis(lambda a_1d: a_1d[indices], axis, a)",
          "type": "literal_block"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
