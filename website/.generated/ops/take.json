          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = [4, 3, 5, 7, 6, 8]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "indices = [0, 1, 4]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.take(a, indices)"
            },
            {
              "kind": "output",
              "text": "array([4, 3, 6])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "In this example if "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": " is an ndarray, \"fancy\" indexing can be used."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array(a)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[indices]"
            },
            {
              "kind": "output",
              "text": "array([4, 3, 6])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/indices",
              "kind": "link",
              "target": "indices",
              "text": "indices"
            },
            {
              "kind": "text",
              "text": " is not one dimensional, the output also has these dimensions."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.take(a, [[0, 1], [2, 3]])"
            },
            {
              "kind": "output",
              "text": "array([[4, 3],"
            },
            {
              "kind": "output",
              "text": "       [5, 7]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
