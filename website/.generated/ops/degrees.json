    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Convert a radian array to degrees"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rad = fnp.arange(12.)*fnp.pi/6"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.degrees(rad)"
            },
            {
              "kind": "output",
              "text": "array([   0.,   30.,   60.,   90.,  120.,  150.,  180.,  210.,  240.,"
            },
            {
              "kind": "output",
              "text": "        270.,  300.,  330.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out = fnp.zeros((rad.shape))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "r = fnp.degrees(rad, out)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.all(r == out)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
