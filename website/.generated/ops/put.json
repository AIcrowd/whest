            {
              "external_url": "",
              "href": "/docs/api/ops/put",
              "kind": "link",
              "target": "put",
              "text": "put"
            },
            {
              "kind": "text",
              "text": " is roughly\nequivalent to:"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "a.flat[ind] = v",
          "type": "literal_block"
        }
