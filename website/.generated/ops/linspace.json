  "example": {
    "code": "import whest as we\n\nwe.linspace(2.0, 3.0, num=5)\n\nwe.linspace(2.0, 3.0, num=5, endpoint=False)\n\nwe.linspace(2.0, 3.0, num=5, retstep=True)\n\nimport matplotlib.pyplot as plt\n\nN = 8\n\ny = we.zeros(N)\n\nx1 = we.linspace(0, 10, N, endpoint=True)\n\nx2 = we.linspace(0, 10, N, endpoint=False)\n\nplt.plot(x1, y, 'o')\n\nplt.plot(x2, y + 0.5, 'o')\n\nplt.ylim([-0.5, 1])\n\nplt.show()",
