  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return evenly spaced numbers over a specified interval."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns "
            },
            {
              "kind": "code",
              "text": "num"
            },
            {
              "kind": "text",
              "text": " evenly spaced samples, calculated over the\ninterval ["
            },
            {
              "kind": "code",
              "text": "start"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "stop"
            },
            {
              "kind": "text",
              "text": "]."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The endpoint of the interval can optionally be excluded."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionchanged",
          "options": [],
          "raw_source": ".. versionchanged:: 1.20.0\n    Values are rounded towards ``-inf`` instead of ``0`` when an\n    integer ``dtype`` is specified. The old behavior can\n    still be obtained with ``we.linspace(start, stop, num).astype(int)``",
          "supported": true,
          "type": "directive_block",
          "version": "1.20.0"
        }
      ],
      "title": "Extended Summary"
    },
