  "notes": "Return evenly spaced numbers over interval. Cost: numel(output).",
  "notes_sections": [],
  "numpy_ref": "np.linspace",
  "parameters": [
    {
      "body": [
        "The starting value of the sequence."
      ],
      "name": "start",
      "type": "array_like"
    },
    {
      "body": [
        "The end value of the sequence, unless `endpoint` is set to False.",
        "In that case, the sequence consists of all but the last of ``num + 1``",
        "evenly spaced samples, so that `stop` is excluded.  Note that the step",
        "size changes when `endpoint` is False."
      ],
      "name": "stop",
      "type": "array_like"
    },
    {
      "body": [
        "Number of samples to generate. Default is 50. Must be non-negative."
      ],
      "name": "num",
      "type": "int, optional"
    },
    {
      "body": [
        "If True, `stop` is the last sample. Otherwise, it is not included.",
        "Default is True."
      ],
      "name": "endpoint",
      "type": "bool, optional"
    },
    {
      "body": [
        "If True, return (`samples`, `step`), where `step` is the spacing",
        "between samples."
      ],
      "name": "retstep",
      "type": "bool, optional"
    },
    {
      "body": [
        "The type of the output array.  If `dtype` is not given, the data type",
        "is inferred from `start` and `stop`. The inferred dtype will never be",
        "an integer; `float` is chosen even if the arguments would produce an",
        "array of integers."
      ],
      "name": "dtype",
      "type": "dtype, optional"
    },
    {
      "body": [
        "The axis in the result to store the samples.  Relevant only if start",
        "or stop are array-like.  By default (0), the samples will be along a",
        "new axis inserted at the beginning. Use -1 to get an axis at the end."
      ],
      "name": "axis",
      "type": "int, optional"
    },
    {
      "body": [
        "The device on which to place the created array. Default: None.",
        "For Array-API interoperability only, so must be ``\"cpu\"`` if passed.",
        "",
        ".. versionadded:: 2.0.0"
      ],
      "name": "device",
      "type": "str, optional"
    }
  ],
  "previous": {
    "href": "/docs/api/ops/linalg-vector_norm/",
    "label": "we.linalg.vector_norm"
  },
  "provenance_label": "Adapted from NumPy docs",
  "provenance_url": "https://numpy.org/doc/stable/reference/generated/numpy.linspace.html",
  "returns": [
    {
      "body": [
        "There are `num` equally spaced samples in the closed interval",
        "``[start, stop]`` or the half-open interval ``[start, stop)``",
        "(depending on whether `endpoint` is True or False)."
      ],
      "name": "samples",
      "type": "ndarray"
