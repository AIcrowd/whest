      "title": "See also"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute two different sets of indices to access 4x4 arrays, one for the\nupper triangular part starting at the main diagonal, and one starting two\ndiagonals further right:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "iu1 = we.triu_indices(4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "iu1"
            },
            {
              "kind": "output",
              "text": "(array([0, 0, 0, 0, 1, 1, 1, 2, 2, 3]), array([0, 1, 2, 3, 1, 2, 3, 2, 3, 3]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that row indices (first array) are non-decreasing, and the corresponding\ncolumn indices (second array) are strictly increasing for each row."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Here is how they can be used with a sample array:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(16).reshape(4, 4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[ 0,  1,  2,  3],"
            },
            {
              "kind": "output",
              "text": "       [ 4,  5,  6,  7],"
            },
            {
              "kind": "output",
              "text": "       [ 8,  9, 10, 11],"
            },
            {
              "kind": "output",
              "text": "       [12, 13, 14, 15]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Both for indexing:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[iu1]"
            },
            {
              "kind": "output",
              "text": "array([ 0,  1,  2, ..., 10, 11, 15])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "And for assigning values:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[iu1] = -1"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[-1, -1, -1, -1],"
            },
            {
              "kind": "output",
              "text": "       [ 4, -1, -1, -1],"
            },
            {
              "kind": "output",
              "text": "       [ 8,  9, -1, -1],"
            },
            {
              "kind": "output",
              "text": "       [12, 13, 14, -1]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "These cover only a small part of the whole array (two diagonals right\nof the main one):"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "iu2 = we.triu_indices(4, 2)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a[iu2] = -10"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[ -1,  -1, -10, -10],"
            },
            {
              "kind": "output",
              "text": "       [  4,  -1,  -1, -10],"
            },
            {
              "kind": "output",
              "text": "       [  8,   9,  -1,  -1],"
            },
            {
              "kind": "output",
              "text": "       [ 12,  13,  14,  -1]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
