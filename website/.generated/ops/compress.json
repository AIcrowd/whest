              "kind": "text",
              "text": "Return selected slices of an array along given axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "When working along a given axis, a slice along that axis is returned in\n"
            },
            {
              "kind": "code",
              "text": "output"
            },
            {
              "kind": "text",
              "text": " for each index where "
            },
            {
              "kind": "code",
              "text": "condition"
            },
            {
              "kind": "text",
              "text": " evaluates to True. When\nworking on a 1-D array, "
            },
            {
              "external_url": "",
              "href": "/docs/api/ops/compress",
              "kind": "link",
              "target": "compress",
              "text": "compress"
            },
            {
              "kind": "text",
              "text": " is equivalent to "
            },
            {
