          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([[1, 2], [3, 4], [5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4],"
            },
            {
              "kind": "output",
              "text": "       [5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.compress([0, 1], a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[3, 4]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.compress([False, True, True], a, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([[3, 4],"
            },
            {
              "kind": "output",
              "text": "       [5, 6]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.compress([False, True], a, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([[2],"
            },
            {
              "kind": "output",
              "text": "       [4],"
            },
            {
              "kind": "output",
              "text": "       [6]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Working on the flattened array does not return slices along an axis but\nselects elements."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.compress([False, True], a)"
            },
            {
              "kind": "output",
              "text": "array([2])"
            }
          ],
          "type": "doctest_block"
        }
      ],
