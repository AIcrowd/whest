    {
      "blocks": [
        {
          "inline": [
            {
              "external_url": "",
              "href": "/docs/api/ops/unstack",
              "kind": "link",
              "target": "unstack",
              "text": "unstack"
            },
            {
              "kind": "text",
              "text": " serves as the reverse operation of "
            },
            {
              "display_text": "stack",
              "explicit_title": false,
              "external_url": "",
              "href": "/docs/api/ops/stack",
              "kind": "role_reference",
              "original_target": "stack",
              "role": "py:func",
              "suppress_link": false,
              "target": "stack",
              "unresolved": false
            },
            {
              "kind": "text",
              "text": ", i.e.,\n"
            },
            {
              "kind": "code",
              "text": "stack(unstack(x, axis=axis), axis=axis) == x"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function is equivalent to "
            },
            {
              "kind": "code",
              "text": "tuple(fnp.moveaxis(x, axis, 0))"
            },
            {
              "kind": "text",
              "text": ", since\niterating on an array iterates along the first axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr = fnp.arange(24).reshape((2, 3, 4))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.unstack(arr)"
            },
            {
              "kind": "output",
              "text": "(array([[ 0,  1,  2,  3],"
            },
            {
              "kind": "output",
              "text": "        [ 4,  5,  6,  7],"
            },
            {
              "kind": "output",
              "text": "        [ 8,  9, 10, 11]]),"
            },
            {
              "kind": "output",
              "text": " array([[12, 13, 14, 15],"
            },
            {
              "kind": "output",
              "text": "        [16, 17, 18, 19],"
            },
            {
              "kind": "output",
              "text": "        [20, 21, 22, 23]]))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.unstack(arr, axis=1)"
            },
            {
              "kind": "output",
              "text": "(array([[ 0,  1,  2,  3],"
            },
            {
              "kind": "output",
              "text": "        [12, 13, 14, 15]]),"
            },
            {
              "kind": "output",
              "text": " array([[ 4,  5,  6,  7],"
            },
            {
              "kind": "output",
              "text": "        [16, 17, 18, 19]]),"
            },
            {
              "kind": "output",
              "text": " array([[ 8,  9, 10, 11],"
            },
            {
              "kind": "output",
              "text": "        [20, 21, 22, 23]]))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr2 = fnp.stack(fnp.unstack(arr, axis=1), axis=1)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arr2.shape"
            },
            {
              "kind": "output",
              "text": "(2, 3, 4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.all(arr == arr2)"
            },
            {
              "kind": "output",
              "text": "fnp.True_"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
