  "area": "core",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Construct an array by repeating A the number of times given by reps."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "reps"
            },
            {
              "kind": "text",
              "text": " has length "
            },
            {
              "kind": "code",
              "text": "d"
            },
            {
              "kind": "text",
              "text": ", the result will have dimension of\n"
            },
            {
              "kind": "code",
              "text": "max(d, A.ndim)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "A.ndim < d"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "A"
            },
            {
              "kind": "text",
              "text": " is promoted to be d-dimensional by prepending new\naxes. So a shape (3,) array is promoted to (1, 3) for 2-D replication,\nor shape (1, 1, 3) for 3-D replication. If this is not the desired\nbehavior, promote "
            },
            {
              "kind": "code",
              "text": "A"
            },
            {
              "kind": "text",
              "text": " to d-dimensions manually before calling this\nfunction."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "If "
            },
            {
              "kind": "code",
              "text": "A.ndim > d"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "reps"
            },
            {
              "kind": "text",
              "text": " is promoted to "
            },
            {
              "kind": "code",
              "text": "A"
            },
            {
              "kind": "text",
              "text": ".ndim by prepending 1's to it.\nThus for an "
            },
            {
              "kind": "code",
              "text": "A"
            },
            {
              "kind": "text",
              "text": " of shape (2, 3, 4, 5), a "
            },
            {
              "kind": "code",
              "text": "reps"
            },
            {
              "kind": "text",
              "text": " of (2, 2) is treated as\n(1, 1, 2, 2)."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note : Although tile may be used for broadcasting, it is strongly\nrecommended to use numpy's broadcasting operations and functions."
            }
          ],
          "type": "paragraph"
        }
      ],
