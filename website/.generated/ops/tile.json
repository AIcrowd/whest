    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.array([0, 1, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.tile(a, 2)"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 2, 0, 1, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.tile(a, (2, 2))"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2, 0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [0, 1, 2, 0, 1, 2]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.tile(a, (2, 1, 2))"
            },
            {
              "kind": "output",
              "text": "array([[[0, 1, 2, 0, 1, 2]],"
            },
            {
              "kind": "output",
              "text": "       [[0, 1, 2, 0, 1, 2]]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.array([[1, 2], [3, 4]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.tile(b, 2)"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 3, 4]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.tile(b, (2, 1))"
            },
            {
              "kind": "output",
              "text": "array([[1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4],"
            },
            {
              "kind": "output",
              "text": "       [1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "c = we.array([1,2,3,4])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.tile(c,(4,1))"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 3, 4],"
            },
            {
              "kind": "output",
              "text": "       [1, 2, 3, 4],"
            },
            {
              "kind": "output",
              "text": "       [1, 2, 3, 4],"
            },
            {
              "kind": "output",
              "text": "       [1, 2, 3, 4]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
