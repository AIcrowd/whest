  "example": {
    "code": "import flopscope as fnp\n\nrng = fnp.random.default_rng()\n\narrays = [rng.normal(size=(3,4)) for _ in range(10)]\n\nfnp.stack(arrays, axis=0).shape\n\nfnp.stack(arrays, axis=1).shape\n\nfnp.stack(arrays, axis=2).shape\n\na = fnp.array([1, 2, 3])\n\nb = fnp.array([4, 5, 6])\n\nfnp.stack((a, b))\n\nfnp.stack((a, b), axis=-1)",
    "output": "(10, 3, 4)\n\n(3, 10, 4)\n\n(3, 4, 10)\n\narray([[1, 2, 3],\n       [4, 5, 6]])\n\narray([[1, 4],\n       [2, 5],\n       [3, 6]])",
