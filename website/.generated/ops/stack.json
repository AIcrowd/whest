    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = fnp.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "arrays = [rng.normal(size=(3,4)) for _ in range(10)]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.stack(arrays, axis=0).shape"
            },
            {
              "kind": "output",
              "text": "(10, 3, 4)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.stack(arrays, axis=1).shape"
            },
            {
              "kind": "output",
              "text": "(3, 10, 4)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.stack(arrays, axis=2).shape"
            },
            {
              "kind": "output",
              "text": "(3, 4, 10)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = fnp.array([1, 2, 3])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = fnp.array([4, 5, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.stack((a, b))"
            },
            {
              "kind": "output",
              "text": "array([[1, 2, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 5, 6]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fnp.stack((a, b), axis=-1)"
            },
            {
              "kind": "output",
              "text": "array([[1, 4],"
            },
            {
              "kind": "output",
              "text": "       [2, 5],"
            },
            {
              "kind": "output",
              "text": "       [3, 6]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
