{
  "aliases": [],
  "api_docs_html": "",
  "area": "fft",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the 2-dimensional discrete Fourier Transform."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function computes the "
            },
            {
              "kind": "emphasis",
              "text": "n"
            },
            {
              "kind": "text",
              "text": "-dimensional discrete Fourier Transform\nover any axes in an "
            },
            {
              "kind": "emphasis",
              "text": "M"
            },
            {
              "kind": "text",
              "text": "-dimensional array by means of the\nFast Fourier Transform (FFT).  By default, the transform is computed over\nthe last two axes of the input array, i.e., a 2-dimensional FFT."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array, can be complex"
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array, can be complex"
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Shape (length of each transformed axis) of the output\n("
                    },
                    {
                      "kind": "code",
                      "text": "s[0]"
                    },
                    {
                      "kind": "text",
                      "text": " refers to axis 0, "
                    },
                    {
                      "kind": "code",
                      "text": "s[1]"
                    },
                    {
                      "kind": "text",
                      "text": " to axis 1, etc.).\nThis corresponds to "
                    },
                    {
                      "kind": "code",
                      "text": "n"
                    },
                    {
                      "kind": "text",
                      "text": " for "
                    },
                    {
                      "kind": "code",
                      "text": "fft(x, n)"
                    },
                    {
                      "kind": "text",
                      "text": ".\nAlong each axis, if the given shape is smaller than that of the input,\nthe input is cropped. If it is larger, the input is padded with zeros."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "versionchanged",
                  "options": [],
                  "raw_source": ".. versionchanged:: 2.0\n\n    If it is ``-1``, the whole input is used (no padding/trimming).",
                  "supported": true,
                  "type": "directive_block",
                  "version": "2.0"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If "
                    },
                    {
                      "kind": "code",
                      "text": "s"
                    },
                    {
                      "kind": "text",
                      "text": " is not given, the shape of the input along the axes specified\nby "
                    },
                    {
                      "kind": "code",
                      "text": "axes"
                    },
                    {
                      "kind": "text",
                      "text": " is used."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "deprecated",
                  "options": [],
                  "raw_source": ".. deprecated:: 2.0\n\n    If `s` is not ``None``, `axes` must not be ``None`` either.",
                  "supported": true,
                  "type": "directive_block",
                  "version": "2.0"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "deprecated",
                  "options": [],
                  "raw_source": ".. deprecated:: 2.0\n\n    `s` must contain only ``int`` s, not ``None`` values. ``None``\n    values currently mean that the default value for ``n`` is used\n    in the corresponding 1-D transform, but this behaviour is\n    deprecated.",
                  "supported": true,
                  "type": "directive_block",
                  "version": "2.0"
                }
              ],
              "data_type": "sequence of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Shape (length of each transformed axis) of the output\n("
                },
                {
                  "kind": "code",
                  "text": "s[0]"
                },
                {
                  "kind": "text",
                  "text": " refers to axis 0, "
                },
                {
                  "kind": "code",
                  "text": "s[1]"
                },
                {
                  "kind": "text",
                  "text": " to axis 1, etc.).\nThis corresponds to "
                },
                {
                  "kind": "code",
                  "text": "n"
                },
                {
                  "kind": "text",
                  "text": " for "
                },
                {
                  "kind": "code",
                  "text": "fft(x, n)"
                },
                {
                  "kind": "text",
                  "text": ".\nAlong each axis, if the given shape is smaller than that of the input,\nthe input is cropped. If it is larger, the input is padded with zeros."
                }
              ],
              "name": "s",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axes over which to compute the FFT.  If not given, the last two\naxes are used.  A repeated index in "
                    },
                    {
                      "kind": "code",
                      "text": "axes"
                    },
                    {
                      "kind": "text",
                      "text": " means the transform over\nthat axis is performed multiple times.  A one-element sequence means\nthat a one-dimensional FFT is performed. Default: "
                    },
                    {
                      "kind": "code",
                      "text": "(-2, -1)"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "deprecated",
                  "options": [],
                  "raw_source": ".. deprecated:: 2.0\n\n    If `s` is specified, the corresponding `axes` to be transformed\n    must not be ``None``.",
                  "supported": true,
                  "type": "directive_block",
                  "version": "2.0"
                }
              ],
              "data_type": "sequence of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Axes over which to compute the FFT.  If not given, the last two\naxes are used.  A repeated index in "
                },
                {
                  "kind": "code",
                  "text": "axes"
                },
                {
                  "kind": "text",
                  "text": " means the transform over\nthat axis is performed multiple times.  A one-element sequence means\nthat a one-dimensional FFT is performed. Default: "
                },
                {
                  "kind": "code",
                  "text": "(-2, -1)"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "axes",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Normalization mode (see "
                    },
                    {
                      "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                      "href": "",
                      "kind": "link",
                      "target": "fft",
                      "text": "fnp.fft"
                    },
                    {
                      "kind": "text",
                      "text": "). Default is \"backward\".\nIndicates which direction of the forward/backward pair of transforms\nis scaled and with what normalization factor."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "versionadded",
                  "options": [],
                  "raw_source": ".. versionadded:: 1.20.0\n\n    The \"backward\", \"forward\" values were added.",
                  "supported": true,
                  "type": "directive_block",
                  "version": "1.20.0"
                }
              ],
              "data_type": "{\"backward\", \"ortho\", \"forward\"}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Normalization mode (see "
                },
                {
                  "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                  "href": "",
                  "kind": "link",
                  "target": "fft",
                  "text": "fnp.fft"
                },
                {
                  "kind": "text",
                  "text": "). Default is \"backward\".\nIndicates which direction of the forward/backward pair of transforms\nis scaled and with what normalization factor."
                }
              ],
              "name": "norm",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If provided, the result will be placed in this array. It should be\nof the appropriate shape and dtype for all axes (and hence only the\nlast axis can have "
                    },
                    {
                      "kind": "code",
                      "text": "s"
                    },
                    {
                      "kind": "text",
                      "text": " not equal to the shape at that axis)."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "versionadded",
                  "options": [],
                  "raw_source": ".. versionadded:: 2.0.0",
                  "supported": true,
                  "type": "directive_block",
                  "version": "2.0.0"
                }
              ],
              "data_type": "complex ndarray, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If provided, the result will be placed in this array. It should be\nof the appropriate shape and dtype for all axes (and hence only the\nlast axis can have "
                },
                {
                  "kind": "code",
                  "text": "s"
                },
                {
                  "kind": "text",
                  "text": " not equal to the shape at that axis)."
                }
              ],
              "name": "out",
              "type": "field_list"
            }
          ],
