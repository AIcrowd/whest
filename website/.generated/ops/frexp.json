              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = fnp.arange(9)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y1, y2 = fnp.frexp(x)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y1"
            },
            {
              "kind": "output",
              "text": "array([ 0.   ,  0.5  ,  0.5  ,  0.75 ,  0.5  ,  0.625,  0.75 ,  0.875,"
            },
            {
              "kind": "output",
              "text": "        0.5  ])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y2"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 2, 2, 3, 3, 3, 3, 4], dtype=int32)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y1 * 2**y2"
            },
            {
              "kind": "output",
              "text": "array([ 0.,  1.,  2.,  3.,  4.,  5.,  6.,  7.,  8.])"
