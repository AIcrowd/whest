  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Decompose the elements of x into mantissa and twos exponent."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns ("
            },
            {
              "kind": "code",
              "text": "mantissa"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "exponent"
            },
            {
              "kind": "text",
              "text": "), where "
            },
            {
              "kind": "code",
              "text": "x = mantissa * 2**exponent"
            },
            {
              "kind": "text",
              "text": ".\nThe mantissa lies in the open interval(-1, 1), while the twos\nexponent is a signed integer."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
