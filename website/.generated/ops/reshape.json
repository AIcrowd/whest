    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "It is not always possible to change the shape of an array without copying\nthe data."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "order"
            },
            {
              "kind": "text",
              "text": " keyword gives the index ordering both for "
            },
            {
              "kind": "emphasis",
              "text": "fetching"
            },
            {
              "kind": "text",
              "text": "\nthe values from "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ", and then "
            },
            {
              "kind": "emphasis",
              "text": "placing"
            },
            {
              "kind": "text",
              "text": " the values into the output\narray. For example, let's say you have an array:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = we.arange(6).reshape((3, 2))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[0, 1],"
            },
            {
              "kind": "output",
              "text": "       [2, 3],"
            },
            {
              "kind": "output",
              "text": "       [4, 5]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "You can think of reshaping as first raveling the array (using the given\nindex order), then inserting the elements from the raveled array into the\nnew array using the same kind of index ordering as was used for the\nraveling."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.reshape(a, (2, 3)) # C-like index ordering"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.reshape(we.ravel(a), (2, 3)) # equivalent to C ravel then C reshape"
            },
            {
              "kind": "output",
              "text": "array([[0, 1, 2],"
            },
            {
              "kind": "output",
              "text": "       [3, 4, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.reshape(a, (2, 3), order='F') # Fortran-like index ordering"
            },
            {
              "kind": "output",
              "text": "array([[0, 4, 3],"
            },
            {
              "kind": "output",
              "text": "       [2, 1, 5]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.reshape(we.ravel(a, order='F'), (2, 3), order='F')"
            },
            {
              "kind": "output",
              "text": "array([[0, 4, 3],"
            },
            {
              "kind": "output",
              "text": "       [2, 1, 5]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
