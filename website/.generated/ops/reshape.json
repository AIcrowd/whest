  "example": {
    "code": "import whest as we\n\na = we.array([[1,2,3], [4,5,6]])\n\nwe.reshape(a, 6)\n\nwe.reshape(a, 6, order='F')\n\nwe.reshape(a, (3,-1))       # the unspecified value is inferred to be 2",
