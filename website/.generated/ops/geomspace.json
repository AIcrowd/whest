    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "If the inputs or dtype are complex, the output will follow a logarithmic\nspiral in the complex plane.  (There are an infinite number of spirals\npassing through two points; the output will follow the shortest such path.)"
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(1, 1000, num=4)"
            },
            {
              "kind": "output",
              "text": "array([    1.,    10.,   100.,  1000.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(1, 1000, num=3, endpoint=False)"
            },
            {
              "kind": "output",
              "text": "array([   1.,   10.,  100.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(1, 1000, num=4, endpoint=False)"
            },
            {
              "kind": "output",
              "text": "array([   1.        ,    5.62341325,   31.6227766 ,  177.827941  ])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(1, 256, num=9)"
            },
            {
              "kind": "output",
              "text": "array([   1.,    2.,    4.,    8.,   16.,   32.,   64.,  128.,  256.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that the above may not produce exact integers:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(1, 256, num=9, dtype=int)"
            },
            {
              "kind": "output",
              "text": "array([  1,   2,   4,   7,  16,  32,  63, 127, 256])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.around(we.geomspace(1, 256, num=9)).astype(int)"
            },
            {
              "kind": "output",
              "text": "array([  1,   2,   4,   8,  16,  32,  64, 128, 256])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Negative, decreasing, and complex inputs are allowed:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(1000, 1, num=4)"
            },
            {
              "kind": "output",
              "text": "array([1000.,  100.,   10.,    1.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(-1000, -1, num=4)"
            },
            {
              "kind": "output",
              "text": "array([-1000.,  -100.,   -10.,    -1.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(1j, 1000j, num=4)  # Straight line"
            },
            {
              "kind": "output",
              "text": "array([0.   +1.j, 0.  +10.j, 0. +100.j, 0.+1000.j])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geomspace(-1+0j, 1+0j, num=5)  # Circle"
            },
            {
              "kind": "output",
              "text": "array([-1.00000000e+00+1.22464680e-16j, -7.07106781e-01+7.07106781e-01j,"
            },
            {
              "kind": "output",
              "text": "        6.12323400e-17+1.00000000e+00j,  7.07106781e-01+7.07106781e-01j,"
            },
            {
              "kind": "output",
              "text": "        1.00000000e+00+0.00000000e+00j])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Graphical illustration of "
            },
            {
              "kind": "code",
              "text": "endpoint"
            },
            {
              "kind": "text",
              "text": " parameter:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "N = 10"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.zeros(N)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.semilogx(we.geomspace(1, 1000, N, endpoint=True), y + 1, 'o')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at 0x...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.semilogx(we.geomspace(1, 1000, N, endpoint=False), y + 2, 'o')"
            },
            {
              "kind": "output",
              "text": "[<matplotlib.lines.Line2D object at 0x...>]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.axis([0.5, 2000, 0, 3])"
            },
            {
              "kind": "output",
              "text": "[0.5, 2000, 0, 3]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.grid(True, color='0.7', linestyle='-', which='both', axis='both')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
