          "inline": [
            {
              "kind": "text",
              "text": "Reverse the order of elements along axis 0 (up/down)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "For a 2-D array, this flips the entries in each column in the up/down\ndirection. Rows are preserved, but appear in a different order than before."
            }
          ],
          "type": "paragraph"
        }
      ],
