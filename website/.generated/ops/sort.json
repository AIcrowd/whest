  "example": {
    "code": "import whest as we\n\na = we.array([[1,4],[3,1]])\n\nwe.sort(a)                # sort along the last axis\n\nwe.sort(a, axis=None)     # sort the flattened array\n\nwe.sort(a, axis=0)        # sort along the first axis\n\ndtype = [('name', 'S10'), ('height', float), ('age', int)]\n\nvalues = [('Arthur', 1.8, 41), ('Lancelot', 1.9, 38),\n          ('Galahad', 1.7, 38)]\n\na = we.array(values, dtype=dtype)       # create a structured array\n\nwe.sort(a, order='height')                        # doctest: +SKIP\n\nwe.sort(a, order=['age', 'height'])               # doctest: +SKIP",
    "output": "array([[1, 4],\n       [1, 3]])\n\narray([1, 1, 3, 4])\n\narray([[1, 1],\n       [3, 4]])\n\narray([('Galahad', 1.7, 38), ('Arthur', 1.8, 41),\n       ('Lancelot', 1.8999999999999999, 38)],\n      dtype=[('name', '|S10'), ('height', '<f8'), ('age', '<i4')])\n\narray([('Galahad', 1.7, 38), ('Lancelot', 1.8999999999999999, 38),\n       ('Arthur', 1.8, 41)],\n      dtype=[('name', '|S10'), ('height', '<f8'), ('age', '<i4')])",
