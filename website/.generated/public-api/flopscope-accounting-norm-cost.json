      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Cost depends on the "
            },
            {
              "kind": "code",
              "text": "ord"
            },
            {
              "kind": "text",
              "text": " parameter and input dimensionality."
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Elementwise norms (Frobenius, L1, Linf, etc.): "
                    },
                    {
                      "kind": "code",
                      "text": "numel"
                    },
                    {
                      "kind": "text",
                      "text": " (weight=1 baked in)."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "SVD-based norms (2-norm, nuclear norm): "
                    },
                    {
                      "kind": "code",
                      "text": "4 * m * n * min(m, n)"
                    },
                    {
                      "kind": "text",
                      "text": "\n(weight=4 baked in, consistent with linalg.svd weight=4)."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        }
