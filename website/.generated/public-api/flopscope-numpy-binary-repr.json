  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return the binary representation of the input number as a string."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "For negative numbers, if width is not given, a minus sign is added to the\nfront. If width is given, the two's complement of the number is\nreturned, with respect to that width."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "In a two's-complement system negative numbers are represented by the two's\ncomplement of the absolute value. This is the most common method of\nrepresenting signed integers on computers "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": ". A N-bit two's-complement\nsystem can represent every integer in the range\n"
            },
            {
              "kind": "math",
              "latex": "-2^{N-1}"
            },
            {
              "kind": "text",
              "text": " to "
            },
            {
              "kind": "math",
              "latex": "+2^{N-1}-1"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Only an integer decimal number can be used."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int",
              "inline": [
                {
                  "kind": "text",
                  "text": "Only an integer decimal number can be used."
                }
              ],
              "name": "num",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The length of the returned string if "
                    },
                    {
                      "kind": "code",
                      "text": "num"
                    },
                    {
                      "kind": "text",
                      "text": " is positive, or the length\nof the two's complement if "
                    },
                    {
                      "kind": "code",
                      "text": "num"
                    },
                    {
                      "kind": "text",
                      "text": " is negative, provided that "
                    },
                    {
                      "kind": "code",
                      "text": "width"
                    },
                    {
                      "kind": "text",
                      "text": " is\nat least a sufficient number of bits for "
                    },
                    {
                      "kind": "code",
                      "text": "num"
                    },
                    {
                      "kind": "text",
                      "text": " to be represented in\nthe designated form. If the "
                    },
                    {
                      "kind": "code",
                      "text": "width"
                    },
                    {
                      "kind": "text",
                      "text": " value is insufficient, an error is\nraised."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
