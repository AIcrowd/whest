          "inline": [
            {
              "kind": "text",
              "text": "Return element-wise quotient and remainder simultaneously."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.divmod(x, y).html",
              "href": "",
              "kind": "link",
              "target": "divmod(x, y)",
              "text": "flops.divmod(x, y)"
            },
            {
              "kind": "text",
              "text": " is equivalent to "
            },
            {
              "kind": "code",
              "text": "(x // y, x % y)"
            },
            {
              "kind": "text",
              "text": ", but faster\nbecause it avoids redundant work. It is used to implement the Python\nbuilt-in function "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/floor-divide/",
              "kind": "link",
              "target": "floor_divide",
              "text": "divmod"
            },
            {
              "kind": "text",
              "text": " on NumPy arrays."
            }
          ],
          "type": "paragraph"
        }
      ],
