        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Samples raw values from the selected distribution."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Applies "
                    },
                    {
                      "display_text": "flops.symmetrize",
                      "explicit_title": false,
                      "external_url": "",
                      "href": "/docs/api/flopscope/symmetrize/",
                      "kind": "role_reference",
                      "original_target": "flops.symmetrize",
                      "role": "func",
                      "suppress_link": false,
                      "target": "flopscope.symmetrize",
                      "unresolved": false
                    },
                    {
                      "kind": "text",
                      "text": " to project into the symmetry-invariant\nsubspace."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": true,
          "type": "list"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Estimated FLOP cost is approximately:"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "C_dist(n_elem) + |G| * n_elem + n_elem"
            },
            {
              "kind": "text",
              "text": " (+ validation),"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "code",
              "text": "n_elem"
            },
            {
              "kind": "text",
              "text": " is the sampled array size, "
            },
            {
              "kind": "code",
              "text": "|G|"
            },
            {
              "kind": "text",
              "text": " is the group order, and\n"
            },
            {
              "kind": "code",
              "text": "C_dist(n_elem)"
            },
            {
              "kind": "text",
              "text": " is the cost of the chosen sampling distribution.\nThe default "
            },
            {
              "kind": "code",
              "text": "distribution='randn'"
            },
            {
              "kind": "text",
              "text": " corresponds to "
            },
            {
              "kind": "code",
              "text": "C_dist(n_elem)\u2248n_elem"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For existing data, use "
