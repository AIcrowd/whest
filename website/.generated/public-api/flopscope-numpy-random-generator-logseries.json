      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from a logarithmic series distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Samples are drawn from a log series distribution with specified\nshape parameter, 0 <= "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " < 1."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Shape parameter for the distribution.  Must be in the range [0, 1)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "Shape parameter for the distribution.  Must be in the range [0, 1)."
                }
              ],
              "name": "p",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "p"
                    },
                    {
                      "kind": "text",
                      "text": " is a scalar.  Otherwise,\n"
                    },
                    {
                      "kind": "code",
                      "text": "flops.array(p).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
