      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For "
            },
            {
              "kind": "code",
              "text": "p=None"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "p=2"
            },
            {
              "kind": "text",
              "text": ", or "
            },
            {
              "kind": "code",
              "text": "p=-2"
            },
            {
              "kind": "text",
              "text": ", computed via SVD (cost m*n*min(m,n)).\nFor "
            },
            {
              "kind": "code",
              "text": "p=1"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "p=-1"
            },
            {
              "kind": "text",
              "text": ", "
            },
            {
              "kind": "code",
              "text": "p=inf"
            },
            {
              "kind": "text",
              "text": ", or "
            },
            {
              "kind": "code",
              "text": "p=-inf"
            },
            {
              "kind": "text",
              "text": ", computed via LU factorization\n(cost ~min(m,n)^3 + m*n for norm)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    }
