          "inline": [
            {
              "kind": "text",
              "text": "Take a sequence of 1-D arrays and stack them as columns\nto make a single 2-D array. 2-D arrays are stacked as-is,\njust like with "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/hstack/",
              "kind": "link",
              "target": "hstack",
              "text": "hstack"
            },
            {
              "kind": "text",
              "text": ".  1-D arrays are turned into 2-D columns\nfirst."
            }
          ],
          "type": "paragraph"
        }
      ],
