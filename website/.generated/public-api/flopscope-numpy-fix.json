          "inline": [
            {
              "kind": "text",
              "text": "Round an array of floats element-wise to nearest integer towards zero.\nThe rounded values have the same data-type as the input."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
