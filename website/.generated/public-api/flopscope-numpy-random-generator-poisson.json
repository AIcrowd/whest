  "area": "random",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from a Poisson distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The Poisson distribution is the limit of the binomial distribution\nfor large N."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Expected number of events occurring in a fixed-time interval,\nmust be >= 0. A sequence must be broadcastable over the requested\nsize."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "Expected number of events occurring in a fixed-time interval,\nmust be >= 0. A sequence must be broadcastable over the requested\nsize."
                }
              ],
              "name": "lam",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "lam"
                    },
                    {
                      "kind": "text",
                      "text": " is a scalar. Otherwise,\n"
                    },
                    {
                      "kind": "code",
                      "text": "flops.array(lam).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Output shape.  If the given shape is, e.g., "
                },
                {
                  "kind": "code",
                  "text": "(m, n, k)"
                },
                {
                  "kind": "text",
                  "text": ", then\n"
                },
                {
                  "kind": "code",
                  "text": "m * n * k"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn.  If size is "
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": " (default),\na single value is returned if "
                },
                {
                  "kind": "code",
                  "text": "lam"
                },
                {
                  "kind": "text",
                  "text": " is a scalar. Otherwise,\n"
                },
                {
                  "kind": "code",
                  "text": "flops.array(lam).size"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn."
                }
              ],
              "name": "size",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Drawn samples from the parameterized Poisson distribution."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray or scalar",
              "inline": [
                {
                  "kind": "text",
                  "text": "Drawn samples from the parameterized Poisson distribution."
                }
              ],
              "name": "out",
              "type": "field_list"
            }
          ],
          "title": "Returns",
          "type": "field_list"
        }
      ],
      "title": "Returns"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The probability mass function (PMF) of Poisson distribution is"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "f(k; \\lambda)=\\frac{\\lambda^k e^{-\\lambda}}{k!}"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For events with an expected separation "
            },
            {
              "kind": "math",
              "latex": "\\lambda"
            },
            {
              "kind": "text",
              "text": " the Poisson\ndistribution "
            },
            {
              "kind": "math",
              "latex": "f(k; \\lambda)"
            },
            {
              "kind": "text",
              "text": " describes the probability of\n"
            },
            {
              "kind": "math",
              "latex": "k"
            },
            {
              "kind": "text",
              "text": " events occurring within the observed\ninterval "
            },
            {
              "kind": "math",
              "latex": "\\lambda"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Because the output is limited to the range of the C int64 type, a\nValueError is raised when "
            },
            {
              "kind": "code",
              "text": "lam"
            },
            {
              "kind": "text",
              "text": " is within 10 sigma of the maximum\nrepresentable value."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nWeisstein, Eric W. \"Poisson Distribution.\"\nFrom MathWorld--A Wolfram Web Resource.\nhttps://mathworld.wolfram.com/PoissonDistribution.html",
          "type": "raw_block"
        },
        {
          "raw_kind": "footnote",
          "raw_text": "2\n\nWikipedia, \"Poisson distribution\",\nhttps://en.wikipedia.org/wiki/Poisson_distribution",
          "type": "raw_block"
        }
      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from the distribution:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = flops.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "lam, size = 5, 10000"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = rng.poisson(lam=lam, size=size)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Verify the mean and variance, which should be approximately "
            },
            {
              "kind": "code",
              "text": "lam"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s.mean(), s.var()"
            },
            {
              "kind": "output",
              "text": "(4.9917 5.1088311)  # may vary"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Display the histogram and probability mass function:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from scipy import stats"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = flops.arange(0, 21)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "pmf = stats.poisson.pmf(x, mu=lam)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.hist(s, bins=x, density=True, width=0.5)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.stem(x, pmf, 'C1-')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw each 100 values for lambda 100 and 500:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = rng.poisson(lam=(100., 500.), size=(100, 2))"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
