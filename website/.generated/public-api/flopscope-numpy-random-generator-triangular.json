  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from the triangular distribution over the interval "
            },
            {
              "kind": "code",
              "text": "[left, right]"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The triangular distribution is a continuous probability\ndistribution with lower limit left, peak at mode, and upper\nlimit right. Unlike the other distributions, these parameters\ndirectly define the shape of the pdf."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Lower limit."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "Lower limit."
                }
              ],
              "name": "left",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The value where the peak of the distribution occurs.\nThe value must fulfill the condition "
                    },
                    {
                      "kind": "code",
                      "text": "left <= mode <= right"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "The value where the peak of the distribution occurs.\nThe value must fulfill the condition "
                },
                {
                  "kind": "code",
                  "text": "left <= mode <= right"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "mode",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Upper limit, must be larger than "
                    },
                    {
                      "kind": "code",
                      "text": "left"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
                {
                  "kind": "text",
                  "text": "Upper limit, must be larger than "
                },
                {
                  "kind": "code",
                  "text": "left"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "right",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "left"
                    },
                    {
                      "kind": "text",
                      "text": ", "
                    },
                    {
                      "kind": "code",
                      "text": "mode"
                    },
                    {
                      "kind": "text",
                      "text": ", and "
                    },
                    {
                      "kind": "code",
                      "text": "right"
                    },
                    {
                      "kind": "text",
                      "text": "\nare all scalars.  Otherwise, "
                    },
                    {
                      "kind": "code",
                      "text": "flops.broadcast(left, mode, right).size"
                    },
                    {
                      "kind": "text",
                      "text": "\nsamples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
