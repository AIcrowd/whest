      ],
      "title": "References"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope.numpy as fnp"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "We've seen that 13 is represented by "
            },
            {
              "kind": "code",
              "text": "00001101"
            },
            {
              "kind": "text",
              "text": ".\nThe invert or bit-wise NOT of 13 is then:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = flops.invert(flops.array(13, dtype=flops.uint8))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "flops.uint8(242)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.binary_repr(x, width=8)"
            },
            {
              "kind": "output",
              "text": "'11110010'"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The result depends on the bit-width:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = flops.invert(flops.array(13, dtype=flops.uint16))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "flops.uint16(65522)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.binary_repr(x, width=16)"
            },
            {
              "kind": "output",
              "text": "'1111111111110010'"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When using signed integer types, the result is the bit-wise NOT of\nthe unsigned type, interpreted as a signed integer:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.invert(flops.array([13], dtype=flops.int8))"
            },
            {
              "kind": "output",
              "text": "array([-14], dtype=int8)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.binary_repr(-14, width=8)"
            },
            {
              "kind": "output",
              "text": "'11110010'"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Booleans are accepted as well:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.invert(flops.array([True, False]))"
            },
            {
              "kind": "output",
              "text": "array([False,  True])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "~"
            },
            {
              "kind": "text",
              "text": " operator can be used as a shorthand for "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/invert/",
              "kind": "link",
              "target": "invert",
              "text": "flops.invert"
            },
            {
              "kind": "text",
              "text": " on\nndarrays."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x1 = flops.array([True, False])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "~x1"
            },
            {
              "kind": "output",
              "text": "array([False,  True])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
