  "area": "numpy",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute bit-wise inversion, or bit-wise NOT, element-wise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Computes the bit-wise NOT of the underlying binary representation of\nthe integers in the input arrays. This ufunc implements the C/Python\noperator "
            },
            {
              "kind": "code",
              "text": "~"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For signed integer inputs, the bit-wise NOT of the absolute value is\nreturned. In a two's-complement system, this operation effectively flips\nall the bits, resulting in a representation that corresponds to the\nnegative of the input plus one. This is the most common method of\nrepresenting signed integers on computers "
            },
            {
              "kind": "text",
              "text": "[1]_"
            },
            {
              "kind": "text",
              "text": ". A N-bit two's-complement\nsystem can represent every integer in the range "
            },
            {
              "kind": "math",
              "latex": "-2^{N-1}"
            },
            {
              "kind": "text",
              "text": " to\n"
            },
            {
              "kind": "math",
              "latex": "+2^{N-1}-1"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Only integer and boolean types are handled."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like",
              "inline": [
                {
                  "kind": "text",
                  "text": "Only integer and boolean types are handled."
                }
              ],
              "name": "x",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "ndarray, None, or tuple of ndarray and None, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                }
              ],
              "name": "out",
              "type": "field_list"
            },
            {
              "body_blocks": [
