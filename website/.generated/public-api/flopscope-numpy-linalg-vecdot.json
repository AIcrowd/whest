      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Computes the vector dot product."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This function is restricted to arguments compatible with the Array API,\ncontrary to "
            },
            {
              "display_text": "flops.vecdot",
              "explicit_title": false,
              "external_url": "",
              "href": "/docs/api/numpy/vecdot/",
              "kind": "role_reference",
              "original_target": "flops.vecdot",
              "role": "func",
              "suppress_link": false,
              "target": "vecdot",
              "unresolved": false
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Let "
            },
            {
              "kind": "math",
              "latex": "\\mathbf{a}"
            },
            {
              "kind": "text",
              "text": " be a vector in "
            },
            {
              "kind": "code",
              "text": "x1"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "math",
              "latex": "\\mathbf{b}"
            },
            {
              "kind": "text",
              "text": " be\na corresponding vector in "
            },
            {
              "kind": "code",
              "text": "x2"
            },
            {
              "kind": "text",
              "text": ". The dot product is defined as:"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "\\mathbf{a} \\cdot \\mathbf{b} = \\sum_{i=0}^{n-1} \\overline{a_i}b_i"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "over the dimension specified by "
            },
            {
              "kind": "code",
              "text": "axis"
            },
            {
              "kind": "text",
              "text": " and where "
            },
            {
              "kind": "math",
              "latex": "\\overline{a_i}"
            },
            {
              "kind": "text",
              "text": "\ndenotes the complex conjugate if "
            },
            {
              "kind": "math",
              "latex": "a_i"
            },
            {
              "kind": "text",
              "text": " is complex and the identity\notherwise."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
