    "code": "mu, sigma = 0, 0.1 # mean and standard deviation\n\nrng = flops.random.default_rng()\n\ns = rng.normal(mu, sigma, 1000)\n\nabs(mu - flops.mean(s))\n\nabs(sigma - flops.std(s, ddof=1))\n\nimport matplotlib.pyplot as plt\n\ncount, bins, _ = plt.hist(s, 30, density=True)\n\nplt.plot(bins, 1/(sigma * flops.sqrt(2 * flops.pi)) *\n               flops.exp( - (bins - mu)**2 / (2 * sigma**2) ),\n         linewidth=2, color='r')\n\nplt.show()\n\nrng = flops.random.default_rng()\n\nrng.normal(3, 2.5, size=(2, 4))",
