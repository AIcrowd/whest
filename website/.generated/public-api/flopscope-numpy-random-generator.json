          "inline": [
            {
              "kind": "text",
              "text": "Container for the BitGenerators."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "Generator"
            },
            {
              "kind": "text",
              "text": " exposes a number of methods for generating random\nnumbers drawn from a variety of probability distributions. In addition to\nthe distribution-specific arguments, each method takes a keyword argument\n"
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/size/",
              "kind": "link",
              "target": "size",
              "text": "size"
            },
            {
              "kind": "text",
              "text": " that defaults to "
            },
            {
              "kind": "code",
              "text": "None"
            },
            {
              "kind": "text",
              "text": ". If "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/size/",
              "kind": "link",
              "target": "size",
              "text": "size"
            },
            {
              "kind": "text",
              "text": " is "
            },
            {
              "kind": "code",
              "text": "None"
            },
            {
              "kind": "text",
              "text": ", then a single\nvalue is generated and returned. If "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/size/",
              "kind": "link",
              "target": "size",
              "text": "size"
            },
            {
              "kind": "text",
              "text": " is an integer, then a 1-D\narray filled with generated values is returned. If "
            },
            {
              "external_url": "",
              "href": "/docs/api/numpy/size/",
              "kind": "link",
              "target": "size",
              "text": "size"
            },
            {
              "kind": "text",
              "text": " is a tuple,\nthen an array with that shape is filled and returned."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The function "
            },
            {
              "display_text": "flops.random.default_rng",
              "explicit_title": false,
              "external_url": "",
              "href": "/docs/api/numpy/random/default-rng/",
              "kind": "role_reference",
              "original_target": "flops.random.default_rng",
              "role": "func",
              "suppress_link": false,
              "target": "random.default_rng",
              "unresolved": false
            },
            {
              "kind": "text",
              "text": " will instantiate\na "
            },
            {
              "kind": "code",
              "text": "Generator"
            },
            {
              "kind": "text",
              "text": " with numpy's default "
            },
            {
              "kind": "code",
              "text": "BitGenerator"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "strong",
              "text": "No Compatibility Guarantee"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "Generator"
            },
            {
              "kind": "text",
              "text": " does not provide a version compatibility guarantee. In\nparticular, as better algorithms evolve the bit stream may change."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
