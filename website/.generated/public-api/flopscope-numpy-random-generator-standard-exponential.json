          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from the standard exponential distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "standard_exponential"
            },
            {
              "kind": "text",
              "text": " is identical to the exponential distribution\nwith a scale parameter of 1."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Output shape.  If the given shape is, e.g., "
                },
                {
                  "kind": "code",
                  "text": "(m, n, k)"
                },
                {
                  "kind": "text",
                  "text": ", then\n"
                },
                {
                  "kind": "code",
                  "text": "m * n * k"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                }
              ],
              "name": "size",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Desired dtype of the result, only "
                    },
                    {
                      "kind": "code",
                      "text": "float64"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "float32"
                    },
                    {
                      "kind": "text",
                      "text": " are supported.\nByteorder must be native. The default value is flops.float64."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "dtype, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Desired dtype of the result, only "
                },
                {
                  "kind": "code",
                  "text": "float64"
                },
                {
                  "kind": "text",
                  "text": " and "
                },
                {
                  "kind": "code",
                  "text": "float32"
                },
                {
                  "kind": "text",
                  "text": " are supported.\nByteorder must be native. The default value is flops.float64."
                }
              ],
              "name": "dtype",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Either 'inv' or 'zig'. 'inv' uses the default inverse CDF method.\n'zig' uses the much faster Ziggurat method of Marsaglia and Tsang."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "str, optional",
              "inline": [
