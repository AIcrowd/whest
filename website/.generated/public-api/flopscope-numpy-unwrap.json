  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Unwrap by taking the complement of large deltas with respect to the period."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This unwraps a signal "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " by changing elements which have an absolute\ndifference from their predecessor of more than "
            },
            {
              "kind": "code",
              "text": "max(discont, period/2)"
            },
            {
              "kind": "text",
              "text": "\nto their "
            },
            {
              "kind": "code",
              "text": "period"
            },
            {
              "kind": "text",
              "text": "-complementary values."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "For the default case where "
            },
            {
              "kind": "code",
              "text": "period"
            },
            {
              "kind": "text",
              "text": " is "
            },
            {
              "kind": "math",
              "latex": "2\\pi"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "discont"
            },
            {
              "kind": "text",
              "text": " is\n"
            },
            {
              "kind": "math",
              "latex": "\\pi"
            },
            {
              "kind": "text",
              "text": ", this unwraps a radian phase "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " such that adjacent differences\nare never greater than "
            },
            {
              "kind": "math",
              "latex": "\\pi"
            },
            {
              "kind": "text",
              "text": " by adding "
            },
            {
              "kind": "math",
              "latex": "2k\\pi"
            },
            {
              "kind": "text",
              "text": " for some\ninteger "
            },
            {
              "kind": "math",
              "latex": "k"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
