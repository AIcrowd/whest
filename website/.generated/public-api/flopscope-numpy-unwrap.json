          "inline": [
            {
              "kind": "text",
              "text": "If the discontinuity in "
            },
            {
              "kind": "code",
              "text": "p"
            },
            {
              "kind": "text",
              "text": " is smaller than "
            },
            {
              "kind": "code",
              "text": "period/2"
            },
            {
              "kind": "text",
              "text": ",\nbut larger than "
            },
            {
              "kind": "code",
              "text": "discont"
            },
            {
              "kind": "text",
              "text": ", no unwrapping is done because taking\nthe complement would only make the discontinuity larger."
            }
          ],
