      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from a Rayleigh distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "math",
              "latex": "\\chi"
            },
            {
              "kind": "text",
              "text": " and Weibull distributions are generalizations of the\nRayleigh."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Scale, also equals the mode. Must be non-negative. Default is 1."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Scale, also equals the mode. Must be non-negative. Default is 1."
                }
              ],
              "name": "scale",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "scale"
                    },
                    {
                      "kind": "text",
                      "text": " is a scalar.  Otherwise,\n"
                    },
                    {
                      "kind": "code",
                      "text": "flops.array(scale).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Output shape.  If the given shape is, e.g., "
                },
                {
                  "kind": "code",
                  "text": "(m, n, k)"
                },
                {
                  "kind": "text",
                  "text": ", then\n"
                },
                {
                  "kind": "code",
                  "text": "m * n * k"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn.  If size is "
                },
                {
                  "kind": "code",
                  "text": "None"
                },
                {
                  "kind": "text",
                  "text": " (default),\na single value is returned if "
                },
                {
                  "kind": "code",
                  "text": "scale"
                },
                {
                  "kind": "text",
                  "text": " is a scalar.  Otherwise,\n"
                },
                {
                  "kind": "code",
                  "text": "flops.array(scale).size"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn."
                }
