          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope.numpy as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "orig_settings = flops.seterr(all='ignore')  # seterr to known value"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.int16(32000) * flops.int16(3)"
            },
            {
              "kind": "output",
              "text": "flops.int16(30464)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.seterr(over='raise')"
            },
            {
              "kind": "output",
              "text": "{'divide': 'ignore', 'over': 'ignore', 'under': 'ignore', 'invalid': 'ignore'}"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "old_settings = flops.seterr(all='warn', over='raise')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.int16(32000) * flops.int16(3)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "output",
              "text": "  File \"<stdin>\", line 1, in <module>"
            },
            {
              "kind": "output",
              "text": "FloatingPointError: overflow encountered in scalar multiply"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "old_settings = flops.seterr(all='print')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.geterr()"
            },
            {
              "kind": "output",
              "text": "{'divide': 'print', 'over': 'print', 'under': 'print', 'invalid': 'print'}"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.int16(32000) * flops.int16(3)"
            },
            {
              "kind": "output",
              "text": "flops.int16(30464)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.seterr(**orig_settings)  # restore original"
            },
            {
              "kind": "output",
              "text": "{'divide': 'print', 'over': 'print', 'under': 'print', 'invalid': 'print'}"
            }
          ],
          "type": "doctest_block"
        }
