  "area": "random",
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return random floats in the half-open interval [0.0, 1.0)."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Results are from the \"continuous uniform\" distribution over the\nstated interval.  To sample "
            },
            {
              "kind": "math",
              "latex": "Unif[a, b), b > a"
            },
            {
              "kind": "text",
              "text": " use "
            },
            {
              "kind": "code",
              "text": "uniform"
            },
            {
              "kind": "text",
              "text": "\nor multiply the output of "
            },
            {
              "kind": "code",
              "text": "random"
            },
            {
              "kind": "text",
              "text": " by "
            },
            {
              "kind": "code",
              "text": "(b - a)"
            },
            {
              "kind": "text",
              "text": " and add "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "language": null,
          "text": "(b - a) * random() + a",
          "type": "literal_block"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Output shape.  If the given shape is, e.g., "
                },
                {
                  "kind": "code",
                  "text": "(m, n, k)"
                },
                {
                  "kind": "text",
                  "text": ", then\n"
                },
                {
                  "kind": "code",
                  "text": "m * n * k"
                },
                {
                  "kind": "text",
                  "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                }
              ],
              "name": "size",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Desired dtype of the result, only "
                    },
                    {
                      "kind": "code",
                      "text": "float64"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "float32"
                    },
                    {
                      "kind": "text",
                      "text": " are supported.\nByteorder must be native. The default value is flops.float64."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "dtype, optional",
              "inline": [
                {
