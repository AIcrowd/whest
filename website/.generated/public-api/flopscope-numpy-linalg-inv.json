              "kind": "text",
              "text": "Compute the inverse of a matrix."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Given a square matrix "
            },
            {
              "kind": "code",
              "text": "a"
            },
            {
              "kind": "text",
              "text": ", return the matrix "
            },
            {
              "kind": "code",
              "text": "ainv"
            },
            {
              "kind": "text",
              "text": " satisfying\n"
            },
            {
              "kind": "code",
              "text": "a @ ainv = ainv @ a = eye(a.shape[0])"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
