    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "symmetrize"
            },
            {
              "kind": "text",
              "text": " performs exact Reynolds averaging internally and then delegates\nto "
            },
            {
              "display_text": "as_symmetric",
              "explicit_title": false,
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.as_symmetric.html",
              "href": "",
              "kind": "role_reference",
              "original_target": "as_symmetric",
              "role": "func",
              "suppress_link": false,
              "target": "as_symmetric",
              "unresolved": false
            },
            {
              "kind": "text",
              "text": " so the result participates in downstream symmetry\ntracking and validation in the usual way."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Estimated FLOP cost is approximately:"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "|G| * n_elem + n_elem"
            },
            {
              "kind": "text",
              "text": " for projection, plus validation from\n"
            },
            {
              "kind": "code",
              "text": "as_symmetric"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "|G|"
                    },
                    {
                      "kind": "text",
                      "text": " transposed add passes over "
                    },
                    {
                      "kind": "code",
                      "text": "n_elem"
                    },
                    {
                      "kind": "text",
                      "text": " elements"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "one final scaling pass"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "symmetry checks inside validation"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "code",
              "text": "|G|"
            },
            {
              "kind": "text",
              "text": " is the group order and "
            },
            {
              "kind": "code",
              "text": "n_elem = data.size"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The canonical pattern for generating random data with symmetry is:"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "fnp.random.symmetric(shape, symmetry_group, distribution=...)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
