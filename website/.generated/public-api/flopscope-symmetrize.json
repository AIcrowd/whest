              "kind": "text",
              "text": "Project an array onto the invariant subspace of a permutation group."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "This applies Reynolds symmetrization:"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "R_G(T) = (1 / |G|) * sum_{g in G} g \u00b7 T"
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
