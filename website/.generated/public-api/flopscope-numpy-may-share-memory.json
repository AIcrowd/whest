              "text": "Determine if two arrays might share memory"
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "A return of True does not necessarily mean that the two arrays\nshare any element.  It just means that they "
            },
            {
              "kind": "emphasis",
              "text": "might"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Only the memory bounds of a and b are checked by default."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
