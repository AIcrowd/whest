              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope.numpy as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "from io import StringIO"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "text = StringIO(\"1312 foo\\n1534  bar\\n444   qux\")"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "regexp = r\"(\\d+)\\s+(...)\"  # match [digits, whitespace, anything]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "output = flops.fromregex(text, regexp,"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[('num', flops.int64), ('key', 'S3')])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "output"
            },
            {
              "kind": "output",
              "text": "array([(1312, b'foo'), (1534, b'bar'), ( 444, b'qux')],"
            },
            {
              "kind": "output",
              "text": "      dtype=[('num', '<i8'), ('key', 'S3')])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "output['num']"
            },
            {
              "kind": "output",
              "text": "array([1312, 1534,  444])"
            }
          ],
          "type": "doctest_block"
        }
