  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Return a sample of uniformly distributed random integers in the interval [0, "
            },
            {
              "kind": "code",
              "text": "flops.iinfo(\"long\").max"
            },
            {
              "kind": "text",
              "text": "]."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "argument_inline": [],
          "content_blocks": [
            {
              "inline": [
                {
                  "kind": "text",
                  "text": "This function uses the C-long dtype, which is 32bit on windows\nand otherwise 64bit on 64bit platforms (and 32bit on 32bit ones).\nSince NumPy 2.0, NumPy's default integer is 32bit on 32bit platforms\nand 64bit on 64bit platforms."
                }
              ],
              "type": "paragraph"
            }
          ],
          "directive": "warning",
          "options": [],
          "raw_source": ".. warning::\n   This function uses the C-long dtype, which is 32bit on windows\n   and otherwise 64bit on 64bit platforms (and 32bit on 32bit ones).\n   Since NumPy 2.0, NumPy's default integer is 32bit on 32bit platforms\n   and 64bit on 64bit platforms.",
          "supported": true,
          "type": "directive_block"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
