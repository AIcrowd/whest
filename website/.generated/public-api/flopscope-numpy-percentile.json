  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compute the q-th percentile of the data along the specified axis."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Returns the q-th percentile(s) of the array elements."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Input array or object that can be converted to an array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like of real numbers",
              "inline": [
                {
                  "kind": "text",
                  "text": "Input array or object that can be converted to an array."
                }
              ],
              "name": "a",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Percentage or sequence of percentages for the percentiles to compute.\nValues must be between 0 and 100 inclusive."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "array_like of float",
              "inline": [
                {
                  "kind": "text",
                  "text": "Percentage or sequence of percentages for the percentiles to compute.\nValues must be between 0 and 100 inclusive."
                }
              ],
              "name": "q",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Axis or axes along which the percentiles are computed. The\ndefault is to compute the percentile(s) along a flattened\nversion of the array."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{int, tuple of int, None}, optional",
              "inline": [
                {
                  "kind": "text",
