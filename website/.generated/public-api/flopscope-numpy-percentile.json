          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope.numpy as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a = flops.array([[10, 7, 4], [3, 2, 1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "a"
            },
            {
              "kind": "output",
              "text": "array([[10,  7,  4],"
            },
            {
              "kind": "output",
              "text": "       [ 3,  2,  1]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.percentile(a, 50)"
            },
            {
              "kind": "output",
              "text": "3.5"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.percentile(a, 50, axis=0)"
            },
            {
              "kind": "output",
              "text": "array([6.5, 4.5, 2.5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.percentile(a, 50, axis=1)"
            },
            {
              "kind": "output",
              "text": "array([7.,  2.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.percentile(a, 50, axis=1, keepdims=True)"
            },
            {
              "kind": "output",
              "text": "array([[7.],"
            },
            {
              "kind": "output",
              "text": "       [2.]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "m = flops.percentile(a, 50, axis=0)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out = flops.zeros_like(m)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.percentile(a, 50, axis=0, out=out)"
            },
            {
              "kind": "output",
              "text": "array([6.5, 4.5, 2.5])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "m"
            },
            {
              "kind": "output",
              "text": "array([6.5, 4.5, 2.5])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = a.copy()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.percentile(b, 50, axis=1, overwrite_input=True)"
            },
            {
              "kind": "output",
              "text": "array([7.,  2.])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "assert not flops.all(a == b)"
            }
          ],
          "type": "doctest_block"
        },
