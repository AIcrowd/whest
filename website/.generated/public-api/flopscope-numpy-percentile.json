            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "This parameter specifies the method to use for estimating the\npercentile.  There are many different methods, some unique to NumPy.\nSee the notes for explanation.  The options sorted by their R type\nas summarized in the H&F paper "
                    },
                    {
                      "kind": "text",
                      "text": "[1]_"
                    },
                    {
                      "kind": "text",
                      "text": " are:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'inverted_cdf'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'averaged_inverted_cdf'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'closest_observation'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'interpolated_inverted_cdf'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'hazen'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'weibull'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'linear'  (default)"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
