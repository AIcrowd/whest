          "inline": [
            {
              "kind": "text",
              "text": "Create a data type object."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "A numpy array is homogeneous, and contains elements described by a\ndtype object. A dtype object can be constructed from different\ncombinations of fundamental numeric types."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
