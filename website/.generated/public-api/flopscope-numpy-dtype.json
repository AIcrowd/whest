    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Using array-scalar type:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import flopscope.numpy as fnp"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype(flops.int16)"
            },
            {
              "kind": "output",
              "text": "dtype('int16')"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Structured type, one field name 'f1', containing int16:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype([('f1', flops.int16)])"
            },
            {
              "kind": "output",
              "text": "dtype([('f1', '<i2')])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Structured type, one field named 'f1', in itself containing a structured\ntype with one field:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype([('f1', [('f1', flops.int16)])])"
            },
            {
              "kind": "output",
              "text": "dtype([('f1', [('f1', '<i2')])])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Structured type, two fields: the first field contains an unsigned int, the\nsecond an int32:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype([('f1', flops.uint64), ('f2', flops.int32)])"
            },
            {
              "kind": "output",
              "text": "dtype([('f1', '<u8'), ('f2', '<i4')])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Using array-protocol type strings:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype([('a','f8'),('b','S10')])"
            },
            {
              "kind": "output",
              "text": "dtype([('a', '<f8'), ('b', 'S10')])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Using comma-separated field formats.  The shape is (2,3):"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype(\"i4, (2,3)f8\")"
            },
            {
              "kind": "output",
              "text": "dtype([('f0', '<i4'), ('f1', '<f8', (2, 3))])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Using tuples.  "
            },
            {
              "kind": "code",
              "text": "int"
            },
            {
              "kind": "text",
              "text": " is a fixed type, 3 the field's shape.  "
            },
            {
              "kind": "code",
              "text": "void"
            },
            {
              "kind": "text",
              "text": "\nis a flexible type, here of size 10:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype([('hello',(flops.int64,3)),('world',flops.void,10)])"
            },
            {
              "kind": "output",
              "text": "dtype([('hello', '<i8', (3,)), ('world', 'V10')])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Subdivide "
            },
            {
              "kind": "code",
              "text": "int16"
            },
            {
              "kind": "text",
              "text": " into 2 "
            },
            {
              "kind": "code",
              "text": "int8"
            },
            {
              "kind": "text",
              "text": "'s, called x and y.  0 and 1 are\nthe offsets in bytes:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype((flops.int16, {'x':(flops.int8,0), 'y':(flops.int8,1)}))"
            },
            {
              "kind": "output",
              "text": "dtype((flops.int16, [('x', 'i1'), ('y', 'i1')]))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Using dictionaries.  Two fields named 'gender' and 'age':"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype({'names':['gender','age'], 'formats':['S1',flops.uint8]})"
            },
            {
              "kind": "output",
              "text": "dtype([('gender', 'S1'), ('age', 'u1')])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Offsets in bytes, here 0 and 25:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.dtype({'surname':('S25',0),'age':(flops.uint8,25)})"
            },
            {
              "kind": "output",
              "text": "dtype([('surname', 'S25'), ('age', 'u1')])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
  ],
