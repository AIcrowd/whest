                  "inline": [
                    {
                      "kind": "text",
                      "text": "Object to be converted to a data type object."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "",
              "inline": [
                {
                  "kind": "text",
                  "text": "Object to be converted to a data type object."
                }
              ],
              "name": "dtype",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Add padding to the fields to match what a C compiler would output\nfor a similar C-struct. Can be "
                    },
                    {
                      "kind": "code",
                      "text": "True"
                    },
                    {
                      "kind": "text",
                      "text": " only if "
                    },
                    {
                      "kind": "code",
                      "text": "obj"
                    },
                    {
                      "kind": "text",
                      "text": " is a dictionary\nor a comma-separated string. If a struct dtype is being created,\nthis also sets a sticky alignment flag "
                    },
                    {
                      "kind": "code",
                      "text": "isalignedstruct"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Add padding to the fields to match what a C compiler would output\nfor a similar C-struct. Can be "
                },
                {
                  "kind": "code",
                  "text": "True"
                },
                {
                  "kind": "text",
                  "text": " only if "
                },
                {
                  "kind": "code",
                  "text": "obj"
                },
                {
                  "kind": "text",
                  "text": " is a dictionary\nor a comma-separated string. If a struct dtype is being created,\nthis also sets a sticky alignment flag "
                },
                {
                  "kind": "code",
                  "text": "isalignedstruct"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "align",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Make a new copy of the data-type object. If "
                    },
                    {
                      "kind": "code",
                      "text": "False"
                    },
                    {
                      "kind": "text",
                      "text": ", the result\nmay just be a reference to a built-in data-type object."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
