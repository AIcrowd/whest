                  "inline": [
                    {
                      "kind": "text",
                      "text": "Degrees of freedom in denominator, must be > 0."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of float",
              "inline": [
                {
                  "kind": "text",
                  "text": "Degrees of freedom in denominator, must be > 0."
                }
              ],
              "name": "dfden",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Output shape.  If the given shape is, e.g., "
                    },
                    {
                      "kind": "code",
                      "text": "(m, n, k)"
                    },
                    {
                      "kind": "text",
                      "text": ", then\n"
                    },
                    {
                      "kind": "code",
                      "text": "m * n * k"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn.  If size is "
                    },
                    {
                      "kind": "code",
                      "text": "None"
                    },
                    {
                      "kind": "text",
                      "text": " (default),\na single value is returned if "
                    },
                    {
                      "kind": "code",
                      "text": "dfnum"
                    },
                    {
                      "kind": "text",
                      "text": " and "
                    },
                    {
                      "kind": "code",
                      "text": "dfden"
                    },
                    {
                      "kind": "text",
                      "text": " are both scalars.\nOtherwise, "
                    },
                    {
                      "kind": "code",
                      "text": "flops.broadcast(dfnum, dfden).size"
                    },
                    {
                      "kind": "text",
                      "text": " samples are drawn."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or tuple of ints, optional",
