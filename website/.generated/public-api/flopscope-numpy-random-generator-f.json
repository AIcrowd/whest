  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from an F distribution."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Samples are drawn from an F distribution with specified parameters,\n"
            },
            {
              "kind": "code",
              "text": "dfnum"
            },
            {
              "kind": "text",
              "text": " (degrees of freedom in numerator) and "
            },
            {
              "kind": "code",
              "text": "dfden"
            },
            {
              "kind": "text",
              "text": " (degrees of\nfreedom in denominator), where both parameters must be greater than\nzero."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The random variate of the F distribution (also known as the\nFisher distribution) is a continuous probability distribution\nthat arises in ANOVA tests, and is the ratio of two chi-square\nvariates."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Degrees of freedom in numerator, must be > 0."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "float or array_like of floats",
              "inline": [
