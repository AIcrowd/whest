              "text": "axis"
            },
            {
              "kind": "text",
              "text": " parameter which can be found at\n"
            },
            {
              "display_text": "generator-handling-axis-parameter",
              "explicit_title": false,
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.generator-handling-axis-parameter.html",
              "href": "",
