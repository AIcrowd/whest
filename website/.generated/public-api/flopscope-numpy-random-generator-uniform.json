      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The probability density function of the uniform distribution is"
            }
          ],
          "type": "paragraph"
        },
        {
          "formulas": [
            "p(x) = \\frac{1}{b - a}"
          ],
          "type": "math_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "anywhere within the interval "
            },
            {
              "kind": "code",
              "text": "[a, b)"
            },
            {
              "kind": "text",
              "text": ", and zero elsewhere."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "When "
            },
            {
              "kind": "code",
              "text": "high"
            },
            {
              "kind": "text",
              "text": " == "
            },
            {
              "kind": "code",
              "text": "low"
            },
            {
              "kind": "text",
              "text": ", values of "
            },
            {
              "kind": "code",
              "text": "low"
            },
            {
              "kind": "text",
              "text": " will be returned."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Draw samples from the distribution:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "rng = flops.random.default_rng()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "s = rng.uniform(-1,0,1000)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "All values are within the given interval:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.all(s >= -1)"
            },
            {
              "kind": "output",
              "text": "True"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "flops.all(s < 0)"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Display the histogram of the samples, along with the\nprobability density function:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import matplotlib.pyplot as plt"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "count, bins, _ = plt.hist(s, 15, density=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.plot(bins, flops.ones_like(bins), linewidth=2, color='r')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "plt.show()"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
