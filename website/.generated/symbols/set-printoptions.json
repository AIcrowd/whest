                  "raw_source": ".. versionchanged:: 2.2",
                  "supported": true,
                  "type": "directive_block",
                  "version": "2.2"
                }
              ],
              "data_type": "string or `False`, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If set to the string "
                },
                {
                  "kind": "code",
                  "text": "'1.13'"
                },
                {
                  "kind": "text",
                  "text": " enables 1.13 legacy printing mode. This\napproximates numpy 1.13 print output by including a space in the sign\nposition of floats and different behavior for 0d arrays. This also\nenables 1.21 legacy printing mode (described below)."
                }
              ],
              "name": "legacy",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If set a passed function will be used for generating arrays' repr.\nOther options will be ignored."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "",
              "inline": [
