  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Set printing options."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "These options determine the way floating point numbers, arrays and\nother NumPy objects are displayed."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Number of digits of precision for floating point output (default 8).\nMay be None if "
                    },
                    {
                      "kind": "code",
                      "text": "floatmode"
                    },
                    {
                      "kind": "text",
                      "text": " is not "
                    },
                    {
                      "kind": "code",
                      "text": "fixed"
                    },
                    {
                      "kind": "text",
                      "text": ", to print as many digits as\nnecessary to uniquely specify the value."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int or None, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Number of digits of precision for floating point output (default 8).\nMay be None if "
                },
                {
                  "kind": "code",
                  "text": "floatmode"
                },
                {
                  "kind": "text",
                  "text": " is not "
                },
                {
                  "kind": "code",
                  "text": "fixed"
                },
                {
                  "kind": "text",
                  "text": ", to print as many digits as\nnecessary to uniquely specify the value."
                }
              ],
              "name": "precision",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Total number of array elements which trigger summarization\nrather than full repr (default 1000).\nTo always use the full repr without summarization, pass "
                    },
                    {
                      "kind": "code",
                      "text": "sys.maxsize"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Total number of array elements which trigger summarization\nrather than full repr (default 1000).\nTo always use the full repr without summarization, pass "
                },
                {
                  "kind": "code",
                  "text": "sys.maxsize"
                },
                {
                  "kind": "text",
                  "text": "."
                }
              ],
              "name": "threshold",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Number of array items in summary at beginning and end of\neach dimension (default 3)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Number of array items in summary at beginning and end of\neach dimension (default 3)."
                }
              ],
              "name": "edgeitems",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The number of characters per line for the purpose of inserting\nline breaks (default 75)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "int, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The number of characters per line for the purpose of inserting\nline breaks (default 75)."
                }
              ],
              "name": "linewidth",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If True, always print floating point numbers using fixed point\nnotation, in which case numbers equal to zero in the current precision\nwill print as zero.  If False, then scientific notation is used when\nabsolute value of the smallest number is < 1e-4 or the ratio of the\nmaximum absolute value to the minimum is > 1e3. The default is False."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "bool, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If True, always print floating point numbers using fixed point\nnotation, in which case numbers equal to zero in the current precision\nwill print as zero.  If False, then scientific notation is used when\nabsolute value of the smallest number is < 1e-4 or the ratio of the\nmaximum absolute value to the minimum is > 1e3. The default is False."
                }
              ],
              "name": "suppress",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "String representation of floating point not-a-number (default nan)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "str, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "String representation of floating point not-a-number (default nan)."
                }
              ],
              "name": "nanstr",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "String representation of floating point infinity (default inf)."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "str, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "String representation of floating point infinity (default inf)."
                }
              ],
              "name": "infstr",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Controls printing of the sign of floating-point types. If '+', always\nprint the sign of positive values. If ' ', always prints a space\n(whitespace character) in the sign position of positive values.  If\n'-', omit the sign character of positive values. (default '-')"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "versionchanged",
                  "options": [],
                  "raw_source": ".. versionchanged:: 2.0\n     The sign parameter can now be an integer type, previously\n     types were floating-point types.",
                  "supported": true,
                  "type": "directive_block",
                  "version": "2.0"
                }
              ],
              "data_type": "string, either '-', '+', or ' ', optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Controls printing of the sign of floating-point types. If '+', always\nprint the sign of positive values. If ' ', always prints a space\n(whitespace character) in the sign position of positive values.  If\n'-', omit the sign character of positive values. (default '-')"
                }
              ],
              "name": "sign",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If not None, the keys should indicate the type(s) that the respective\nformatting function applies to.  Callables should return a string.\nTypes that are not specified (by their corresponding keys) are handled\nby the default formatters.  Individual types for which a formatter\ncan be set are:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'bool'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'int'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'timedelta' : a "
                            },
                            {
                              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.timedelta64.html",
                              "href": "",
                              "kind": "link",
                              "target": "timedelta64",
                              "text": "we.timedelta64"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'datetime' : a "
                            },
                            {
                              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.datetime64.html",
                              "href": "",
                              "kind": "link",
                              "target": "datetime64",
                              "text": "we.datetime64"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'float'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'longfloat' : 128-bit floats"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'complexfloat'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'longcomplexfloat' : composed of two 128-bit floats"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'numpystr' : types "
                            },
                            {
                              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.bytes_.html",
                              "href": "",
                              "kind": "link",
                              "target": "bytes_",
                              "text": "we.bytes_"
                            },
                            {
                              "kind": "text",
                              "text": " and "
                            },
                            {
                              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.str_.html",
                              "href": "",
                              "kind": "link",
                              "target": "str_",
                              "text": "we.str_"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'object' : "
                            },
                            {
                              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.object_.html",
                              "href": "",
                              "kind": "link",
                              "target": "object_",
                              "text": "we.object_"
                            },
                            {
                              "kind": "text",
                              "text": " arrays"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    }
                  ],
                  "ordered": false,
                  "type": "list"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Other keys that can be used to set a group of types at once are:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'all' : sets all types"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'int_kind' : sets 'int'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'float_kind' : sets 'float' and 'longfloat'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'complex_kind' : sets 'complexfloat' and 'longcomplexfloat'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "'str_kind' : sets 'numpystr'"
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    }
                  ],
                  "ordered": false,
                  "type": "list"
                }
              ],
              "data_type": "dict of callables, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "If not None, the keys should indicate the type(s) that the respective\nformatting function applies to.  Callables should return a string.\nTypes that are not specified (by their corresponding keys) are handled\nby the default formatters.  Individual types for which a formatter\ncan be set are:"
                }
              ],
              "name": "formatter",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Controls the interpretation of the "
                    },
                    {
                      "kind": "code",
                      "text": "precision"
                    },
                    {
                      "kind": "text",
                      "text": " option for\nfloating-point types. Can take the following values\n(default maxprec_equal):"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "items": [
                            {
                              "blocks": [
                                {
                                  "inline": [
                                    {
                                      "kind": "text",
                                      "text": "even if this would print more or fewer digits than\nnecessary to specify the value uniquely."
                                    }
                                  ],
                                  "type": "paragraph"
                                }
                              ],
                              "term_inline": [
                                {
                                  "kind": "text",
                                  "text": "'fixed': Always print exactly "
                                },
                                {
                                  "kind": "code",
                                  "text": "precision"
                                },
                                {
                                  "kind": "text",
                                  "text": " fractional digits,"
                                }
                              ]
                            }
                          ],
                          "type": "definition_list"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "items": [
                            {
                              "blocks": [
                                {
                                  "inline": [
                                    {
                                      "kind": "text",
                                      "text": "to represent each value uniquely. Different elements may\nhave a different number of digits. The value of the\n"
                                    },
                                    {
                                      "kind": "code",
                                      "text": "precision"
                                    },
                                    {
                                      "kind": "text",
                                      "text": " option is ignored."
                                    }
                                  ],
                                  "type": "paragraph"
                                }
                              ],
                              "term_inline": [
                                {
                                  "kind": "text",
                                  "text": "'unique': Print the minimum number of fractional digits necessary"
                                }
                              ]
                            }
                          ],
                          "type": "definition_list"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "items": [
                            {
                              "blocks": [
                                {
                                  "inline": [
                                    {
                                      "kind": "text",
                                      "text": "an element can be uniquely represented with fewer digits\nonly print it with that many."
                                    }
                                  ],
                                  "type": "paragraph"
                                }
                              ],
                              "term_inline": [
                                {
                                  "kind": "text",
                                  "text": "'maxprec': Print at most "
                                },
                                {
                                  "kind": "code",
                                  "text": "precision"
                                },
                                {
                                  "kind": "text",
                                  "text": " fractional digits, but if"
                                }
                              ]
                            }
                          ],
                          "type": "definition_list"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "items": [
                            {
                              "blocks": [
                                {
                                  "inline": [
                                    {
                                      "kind": "text",
                                      "text": "but if every element in the array can be uniquely\nrepresented with an equal number of fewer digits, use that\nmany digits for all elements."
                                    }
                                  ],
                                  "type": "paragraph"
                                }
                              ],
                              "term_inline": [
                                {
                                  "kind": "text",
                                  "text": "'maxprec_equal': Print at most "
                                },
                                {
                                  "kind": "code",
                                  "text": "precision"
                                },
                                {
                                  "kind": "text",
                                  "text": " fractional digits,"
                                }
                              ]
                            }
                          ],
                          "type": "definition_list"
                        }
                      ]
                    }
                  ],
                  "ordered": false,
                  "type": "list"
                }
              ],
              "data_type": "str, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Controls the interpretation of the "
                },
                {
                  "kind": "code",
                  "text": "precision"
                },
                {
                  "kind": "text",
                  "text": " option for\nfloating-point types. Can take the following values\n(default maxprec_equal):"
                }
              ],
              "name": "floatmode",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If set to the string "
                    },
                    {
                      "kind": "code",
                      "text": "'1.13'"
                    },
                    {
                      "kind": "text",
                      "text": " enables 1.13 legacy printing mode. This\napproximates numpy 1.13 print output by including a space in the sign\nposition of floats and different behavior for 0d arrays. This also\nenables 1.21 legacy printing mode (described below)."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If set to the string "
                    },
                    {
                      "kind": "code",
                      "text": "'1.21'"
                    },
                    {
                      "kind": "text",
                      "text": " enables 1.21 legacy printing mode. This\napproximates numpy 1.21 print output of complex structured dtypes\nby not inserting spaces after commas that separate fields and after\ncolons."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If set to "
                    },
                    {
                      "kind": "code",
                      "text": "'1.25'"
                    },
                    {
                      "kind": "text",
                      "text": " approximates printing of 1.25 which mainly means\nthat numeric scalars are printed without their type information, e.g.\nas "
                    },
                    {
                      "kind": "code",
                      "text": "3.0"
                    },
                    {
                      "kind": "text",
                      "text": " rather than "
                    },
                    {
                      "kind": "code",
                      "text": "we.float64(3.0)"
                    },
                    {
                      "kind": "text",
                      "text": "."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If set to "
                    },
                    {
                      "kind": "code",
                      "text": "'2.1'"
                    },
                    {
                      "kind": "text",
                      "text": ", shape information is not given when arrays are\nsummarized (i.e., multiple elements replaced with "
                    },
                    {
                      "kind": "code",
                      "text": "..."
                    },
                    {
                      "kind": "text",
                      "text": ")."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "If set to "
                    },
                    {
                      "kind": "code",
                      "text": "False"
                    },
                    {
                      "kind": "text",
                      "text": ", disables legacy mode."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Unrecognized strings will be ignored with a warning for forward\ncompatibility."
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "argument_inline": [],
                  "content_blocks": [],
                  "directive": "versionchanged",
                  "options": [],
                  "raw_source": ".. versionchanged:: 1.22.0",
                  "supported": true,
