          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Floating point precision can be set:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.set_printoptions(precision=4)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.array([1.123456789])"
            },
            {
              "kind": "output",
              "text": "[1.1235]"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Long arrays can be summarised:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.set_printoptions(threshold=5)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.arange(10)"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 2, ..., 7, 8, 9], shape=(10,))"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Small results can be suppressed:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "eps = we.finfo(float).eps"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(4.)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x**2 - (x + eps)**2"
            },
            {
              "kind": "output",
              "text": "array([-4.9304e-32, -4.4409e-16,  0.0000e+00,  0.0000e+00])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.set_printoptions(suppress=True)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x**2 - (x + eps)**2"
            },
            {
              "kind": "output",
              "text": "array([-0., -0.,  0.,  0.])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "A custom formatter can be used to display array elements as desired:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.set_printoptions(formatter={'all':lambda x: 'int: '+str(-x)})"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([int: 0, int: -1, int: -2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.set_printoptions()  # formatter gets reset"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([0, 1, 2])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "To put back the default options, you can use:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.set_printoptions(edgeitems=3, infstr='inf',"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "linewidth=75, nanstr='nan', precision=8,"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "suppress=False, threshold=1000, formatter=None)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Also to temporarily override options, use "
            },
            {
              "kind": "code",
              "text": "printoptions"
            },
            {
              "kind": "text",
              "text": "\nas a context manager:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "with we.printoptions(precision=2, suppress=True, threshold=5):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "we.linspace(0, 10, 10)"
            },
            {
              "kind": "output",
              "text": "array([ 0.  ,  1.11,  2.22, ...,  7.78,  8.89, 10.  ], shape=(10,))"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
