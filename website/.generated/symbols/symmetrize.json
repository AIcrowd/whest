    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "code",
              "text": "symmetrize"
            },
            {
              "kind": "text",
              "text": " performs exact Reynolds averaging internally and then delegates\nto "
            },
            {
              "display_text": "as_symmetric",
              "explicit_title": false,
              "external_url": "",
              "href": "/docs/api/as-symmetric/",
              "kind": "role_reference",
              "original_target": "as_symmetric",
              "role": "func",
              "suppress_link": false,
              "target": "as_symmetric",
              "unresolved": false
            },
            {
              "kind": "text",
              "text": " so the result participates in downstream symmetry\ntracking and validation in the usual way."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Estimated FLOP cost is approximately:"
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "code",
              "text": "|G| * n_elem + n_elem"
            },
            {
              "kind": "text",
              "text": " for projection, plus validation from\n"
            },
            {
              "kind": "code",
              "text": "as_symmetric"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "code",
                      "text": "|G|"
                    },
                    {
                      "kind": "text",
                      "text": " transposed add passes over "
                    },
                    {
                      "kind": "code",
                      "text": "n_elem"
                    },
                    {
                      "kind": "text",
                      "text": " elements"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "one final scaling pass"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "symmetry checks inside validation"
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "where "
            },
            {
              "kind": "code",
              "text": "|G|"
            },
            {
              "kind": "text",
              "text": " is the group order and "
            },
            {
              "kind": "code",
              "text": "n_elem = data.size"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        },
