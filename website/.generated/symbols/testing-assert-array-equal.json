      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "When one of "
            },
            {
              "kind": "code",
              "text": "actual"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "desired"
            },
            {
              "kind": "text",
              "text": " is a scalar and the other is array_like,\nthe function checks that each element of the array_like object is equal to\nthe scalar. This behaviour can be disabled with the "
            },
            {
              "kind": "code",
              "text": "strict"
            },
            {
              "kind": "text",
              "text": " parameter."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The first assert does not raise an exception:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_array_equal([1.0,2.33333,we.nan],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[we.exp(0),2.33333, we.nan])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Assert fails with numerical imprecision with floats:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_array_equal([1.0,we.pi,we.nan],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[1, we.sqrt(we.pi)**2, we.nan])"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "AssertionError:"
            },
            {
              "kind": "output",
              "text": "Arrays are not equal"
            },
            {
              "kind": "output",
              "text": "<BLANKLINE>"
            },
            {
              "kind": "output",
              "text": "Mismatched elements: 1 / 3 (33.3%)"
            },
            {
              "kind": "output",
              "text": "Max absolute difference among violations: 4.4408921e-16"
            },
            {
              "kind": "output",
              "text": "Max relative difference among violations: 1.41357986e-16"
            },
            {
              "kind": "output",
              "text": " ACTUAL: array([1.      , 3.141593,      nan])"
            },
            {
              "kind": "output",
              "text": " DESIRED: array([1.      , 3.141593,      nan])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Use "
            },
            {
              "kind": "code",
              "text": "assert_allclose"
            },
            {
              "kind": "text",
              "text": " or one of the nulp (number of floating point values)\nfunctions for these cases instead:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_allclose([1.0,we.pi,we.nan],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "[1, we.sqrt(we.pi)**2, we.nan],"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "rtol=1e-10, atol=0)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "As mentioned in the Notes section, "
            },
            {
              "kind": "code",
              "text": "assert_array_equal"
            },
            {
              "kind": "text",
              "text": " has special\nhandling for scalars. Here the test checks that each value in "
            },
            {
              "kind": "code",
              "text": "x"
            },
            {
              "kind": "text",
              "text": " is 3:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.full((2, 5), fill_value=3)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_array_equal(x, 3)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Use "
            },
            {
              "kind": "code",
              "text": "strict"
            },
            {
              "kind": "text",
              "text": " to raise an AssertionError when comparing a scalar with an\narray:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_array_equal(x, 3, strict=True)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "AssertionError:"
            },
            {
              "kind": "output",
              "text": "Arrays are not equal"
            },
            {
              "kind": "output",
              "text": "<BLANKLINE>"
            },
            {
              "kind": "output",
              "text": "(shapes (2, 5), () mismatch)"
            },
            {
              "kind": "output",
              "text": " ACTUAL: array([[3, 3, 3, 3, 3],"
            },
            {
              "kind": "output",
              "text": "       [3, 3, 3, 3, 3]])"
            },
            {
              "kind": "output",
              "text": " DESIRED: array(3)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "strict"
            },
            {
              "kind": "text",
              "text": " parameter also ensures that the array data types match:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([2, 2, 2])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([2., 2., 2.], dtype=we.float32)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_array_equal(x, y, strict=True)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "AssertionError:"
            },
            {
              "kind": "output",
              "text": "Arrays are not equal"
            },
            {
              "kind": "output",
              "text": "<BLANKLINE>"
            },
            {
              "kind": "output",
              "text": "(dtypes int64, float32 mismatch)"
            },
            {
              "kind": "output",
              "text": " ACTUAL: array([2, 2, 2])"
            },
            {
              "kind": "output",
              "text": " DESIRED: array([2., 2., 2.], dtype=float32)"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
