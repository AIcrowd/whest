    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Manually adding two vectors, using broadcasting:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.array([[1], [2], [3]])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.array([4, 5, 6])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "b = we.broadcast(x, y)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out = we.empty(b.shape)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out.flat = [u+v for (u,v) in b]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "out"
            },
            {
              "kind": "output",
              "text": "array([[5.,  6.,  7.],"
            },
            {
              "kind": "output",
              "text": "       [6.,  7.,  8.],"
            },
            {
              "kind": "output",
              "text": "       [7.,  8.,  9.]])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Compare against built-in broadcasting:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x + y"
            },
            {
              "kind": "output",
              "text": "array([[5, 6, 7],"
            },
            {
              "kind": "output",
              "text": "       [6, 7, 8],"
            },
            {
              "kind": "output",
              "text": "       [7, 8, 9]])"
            }
          ],
          "type": "doctest_block"
        }
      ],
