      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Do not rely on the combination of "
            },
            {
              "kind": "code",
              "text": "tofile"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "fromfile"
            },
            {
              "kind": "text",
              "text": " for\ndata storage, as the binary files generated are not platform\nindependent.  In particular, no byte-order or data-type information is\nsaved.  Data can be stored in the platform independent "
            },
            {
              "kind": "code",
              "text": ".npy"
            },
            {
              "kind": "text",
              "text": " format\nusing "
            },
            {
              "kind": "code",
              "text": "save"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "load"
            },
            {
              "kind": "text",
              "text": " instead."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Construct an ndarray:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "dt = we.dtype([('time', [('min', we.int64), ('sec', we.int64)]),"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "('temp', float)])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.zeros((1,), dtype=dt)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x['time']['min'] = 10; x['temp'] = 98.25"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x"
            },
            {
              "kind": "output",
              "text": "array([((10, 0), 98.25)],"
            },
            {
              "kind": "output",
              "text": "      dtype=[('time', [('min', '<i8'), ('sec', '<i8')]), ('temp', '<f8')])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Save the raw data to disk:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import tempfile"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "fname = tempfile.mkstemp()[1]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x.tofile(fname)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Read the raw data from disk:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.fromfile(fname, dtype=dt)"
            },
            {
              "kind": "output",
              "text": "array([((10, 0), 98.25)],"
            },
            {
              "kind": "output",
              "text": "      dtype=[('time', [('min', '<i8'), ('sec', '<i8')]), ('temp', '<f8')])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The recommended way to store and load data:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.save(fname, x)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.load(fname + '.npy')"
            },
            {
              "kind": "output",
              "text": "array([((10, 0), 98.25)],"
            },
            {
              "kind": "output",
              "text": "      dtype=[('time', [('min', '<i8'), ('sec', '<i8')]), ('temp', '<f8')])"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Examples"
    }
