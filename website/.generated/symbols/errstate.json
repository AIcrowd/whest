  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Context manager for floating-point error handling."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Using an instance of "
            },
            {
              "kind": "code",
              "text": "errstate"
            },
            {
              "kind": "text",
              "text": " as a context manager allows statements in\nthat context to execute with a known error handling behavior. Upon entering\nthe context the error handling is set with "
            },
            {
              "kind": "code",
              "text": "seterr"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "seterrcall"
            },
            {
              "kind": "text",
              "text": ", and\nupon exiting it is reset to what it was before."
            }
          ],
          "type": "paragraph"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionchanged",
          "options": [],
          "raw_source": ".. versionchanged:: 1.17.0\n    `errstate` is also usable as a function decorator, saving\n    a level of indentation if an entire function is wrapped.",
          "supported": true,
          "type": "directive_block",
          "version": "1.17.0"
        },
        {
          "argument_inline": [],
          "content_blocks": [],
          "directive": "versionchanged",
          "options": [],
          "raw_source": ".. versionchanged:: 2.0\n    `errstate` is now fully thread and asyncio safe, but may not be\n    entered more than once.\n    It is not safe to decorate async functions using ``errstate``.",
          "supported": true,
          "type": "directive_block",
          "version": "2.0"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Keyword arguments. The valid keywords are the possible floating-point\nexceptions. Each keyword should have a string value that defines the\ntreatment for the particular error. Possible values are\n{'ignore', 'warn', 'raise', 'call', 'print', 'log'}."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{divide, over, under, invalid}",
              "inline": [
                {
                  "kind": "text",
                  "text": "Keyword arguments. The valid keywords are the possible floating-point\nexceptions. Each keyword should have a string value that defines the\ntreatment for the particular error. Possible values are\n{'ignore', 'warn', 'raise', 'call', 'print', 'log'}."
                }
              ],
              "name": "kwargs",
              "type": "field_list"
            }
