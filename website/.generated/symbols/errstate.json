    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "olderr = we.seterr(all='ignore')  # Set error handling to known state."
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.arange(3) / 0."
            },
            {
              "kind": "output",
              "text": "array([nan, inf, inf])"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "with we.errstate(divide='ignore'):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "we.arange(3) / 0."
            },
            {
              "kind": "output",
              "text": "array([nan, inf, inf])"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.sqrt(-1)"
            },
            {
              "kind": "output",
              "text": "we.float64(nan)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "with we.errstate(invalid='raise'):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "we.sqrt(-1)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "output",
              "text": "  File \"<stdin>\", line 2, in <module>"
            },
            {
              "kind": "output",
              "text": "FloatingPointError: invalid value encountered in sqrt"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Outside the context the error handling behavior has not changed:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geterr()"
            },
            {
              "kind": "output",
              "text": "{'divide': 'ignore', 'over': 'ignore', 'under': 'ignore', 'invalid': 'ignore'}"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "olderr = we.seterr(**olderr)  # restore original state"
            }
          ],
          "type": "doctest_block"
        }
      ],
