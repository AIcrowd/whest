{
  "aliases": [
    "random.SeedSequence",
    "we.random.SeedSequence",
    "whest.random.SeedSequence"
  ],
  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "SeedSequence mixes sources of entropy in a reproducible way to set the initial state for independent and very probably non-overlapping BitGenerators."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Once the SeedSequence is instantiated, you can call the "
            },
            {
              "kind": "code",
              "text": "generate_state"
            },
            {
              "kind": "text",
              "text": "\nmethod to get an appropriately sized seed. Calling "
            },
            {
              "kind": "code",
              "text": "spawn(n) <spawn>"
            },
            {
              "kind": "text",
              "text": " will\ncreate "
            },
            {
              "kind": "code",
              "text": "n"
            },
            {
              "kind": "text",
              "text": " SeedSequences that can be used to seed independent\nBitGenerators, i.e. for different threads."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The entropy for creating a "
                    },
                    {
                      "kind": "code",
                      "text": "SeedSequence"
                    },
                    {
                      "kind": "text",
                      "text": ".\nAll integer values must be non-negative."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{None, int, sequence[int]}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The entropy for creating a "
                },
                {
                  "kind": "code",
                  "text": "SeedSequence"
                },
                {
                  "kind": "text",
                  "text": ".\nAll integer values must be non-negative."
                }
              ],
              "name": "entropy",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "An additional source of entropy based on the position of this\n"
                    },
                    {
                      "kind": "code",
                      "text": "SeedSequence"
                    },
                    {
                      "kind": "text",
                      "text": " in the tree of such objects created with the\n"
                    },
                    {
                      "kind": "code",
                      "text": "SeedSequence.spawn"
                    },
                    {
                      "kind": "text",
                      "text": " method. Typically, only "
                    },
                    {
                      "kind": "code",
                      "text": "SeedSequence.spawn"
                    },
                    {
                      "kind": "text",
                      "text": " will\nset this, and users will not."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{(), sequence[int]}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "An additional source of entropy based on the position of this\n"
                },
                {
                  "kind": "code",
                  "text": "SeedSequence"
                },
                {
                  "kind": "text",
                  "text": " in the tree of such objects created with the\n"
                },
                {
                  "kind": "code",
                  "text": "SeedSequence.spawn"
                },
                {
                  "kind": "text",
                  "text": " method. Typically, only "
                },
                {
                  "kind": "code",
                  "text": "SeedSequence.spawn"
                },
                {
                  "kind": "text",
                  "text": " will\nset this, and users will not."
                }
              ],
              "name": "spawn_key",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Size of the pooled entropy to store. Default is 4 to give a 128-bit\nentropy pool. 8 (for 256 bits) is another reasonable choice if working\nwith larger PRNGs, but there is very little to be gained by selecting\nanother value."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{int}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "Size of the pooled entropy to store. Default is 4 to give a 128-bit\nentropy pool. 8 (for 256 bits) is another reasonable choice if working\nwith larger PRNGs, but there is very little to be gained by selecting\nanother value."
                }
              ],
              "name": "pool_size",
              "type": "field_list"
            },
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The number of children already spawned. Only pass this if\nreconstructing a "
                    },
                    {
                      "kind": "code",
                      "text": "SeedSequence"
                    },
                    {
                      "kind": "text",
                      "text": " from a serialized form."
                    }
                  ],
                  "type": "paragraph"
                }
              ],
              "data_type": "{int}, optional",
              "inline": [
                {
                  "kind": "text",
                  "text": "The number of children already spawned. Only pass this if\nreconstructing a "
                },
                {
                  "kind": "code",
                  "text": "SeedSequence"
                },
                {
                  "kind": "text",
                  "text": " from a serialized form."
                }
              ],
              "name": "n_children_spawned",
              "type": "field_list"
            }
          ],
          "title": "Parameters",
          "type": "field_list"
        }
      ],
      "title": "Parameters"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Best practice for achieving reproducible bit streams is to use\nthe default "
            },
            {
              "kind": "code",
              "text": "None"
            },
            {
              "kind": "text",
              "text": " for the initial entropy, and then use\n"
            },
            {
              "kind": "code",
              "text": "SeedSequence.entropy"
            },
            {
              "kind": "text",
              "text": " to log/pickle the "
            },
            {
              "kind": "code",
              "text": "entropy"
            },
            {
              "kind": "text",
              "text": " for reproducibility:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sq1 = we.random.SeedSequence()"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sq1.entropy"
            },
            {
              "kind": "output",
              "text": "243799254704924441050048792905230269161  # random"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "sq2 = we.random.SeedSequence(sq1.entropy)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.all(sq1.generate_state(10) == sq2.generate_state(10))"
            },
            {
              "kind": "output",
              "text": "True"
            }
          ],
          "type": "doctest_block"
        }
      ],
      "title": "Notes"
    }
