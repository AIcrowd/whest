      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "The floating-point exceptions are defined in the IEEE 754 standard "
            },
            {
              "kind": "text",
              "text": "1"
            },
            {
              "kind": "text",
              "text": ":"
            }
          ],
          "type": "paragraph"
        },
        {
          "items": [
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Division by zero: infinite result obtained from finite numbers."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Overflow: result too large to be expressed."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Underflow: result so close to zero that some precision\nwas lost."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            },
            {
              "blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Invalid operation: result is not an expressible number, typically\nindicates that a NaN was produced."
                    }
                  ],
                  "type": "paragraph"
                }
              ]
            }
          ],
          "ordered": false,
          "type": "list"
        },
        {
          "raw_kind": "footnote",
          "raw_text": "1\n\nhttps://en.wikipedia.org/wiki/IEEE_754",
          "type": "raw_block"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "import whest as we"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "orig_settings = we.seterr(all='ignore')  # seterr to known value"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.int16(32000) * we.int16(3)"
            },
            {
              "kind": "output",
              "text": "we.int16(30464)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.seterr(over='raise')"
            },
            {
              "kind": "output",
              "text": "{'divide': 'ignore', 'over': 'ignore', 'under': 'ignore', 'invalid': 'ignore'}"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "old_settings = we.seterr(all='warn', over='raise')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.int16(32000) * we.int16(3)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "output",
              "text": "  File \"<stdin>\", line 1, in <module>"
            },
            {
              "kind": "output",
              "text": "FloatingPointError: overflow encountered in scalar multiply"
            }
          ],
          "type": "doctest_block"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "old_settings = we.seterr(all='print')"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.geterr()"
            },
            {
              "kind": "output",
              "text": "{'divide': 'print', 'over': 'print', 'under': 'print', 'invalid': 'print'}"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.int16(32000) * we.int16(3)"
            },
            {
              "kind": "output",
              "text": "we.int16(30464)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.seterr(**orig_settings)  # restore original"
            },
            {
              "kind": "output",
              "text": "{'divide': 'print', 'over': 'print', 'under': 'print', 'invalid': 'print'}"
            }
          ],
          "type": "doctest_block"
        }
      ],
