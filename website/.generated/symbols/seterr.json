  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Set how floating-point errors are handled."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Note that operations on integer scalar types (such as "
            },
            {
              "kind": "code",
              "text": "int16"
            },
            {
              "kind": "text",
              "text": ") are\nhandled like floating point, and are affected by these settings."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
    {
      "blocks": [
        {
          "items": [
            {
              "body_blocks": [
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "Set treatment for all types of floating-point errors at once:"
                    }
                  ],
                  "type": "paragraph"
                },
                {
                  "items": [
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "ignore: Take no action when the exception occurs."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "warn: Print a "
                            },
                            {
                              "display_text": "RuntimeWarning",
                              "explicit_title": false,
                              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.RuntimeWarning.html",
                              "href": "",
                              "kind": "role_reference",
                              "original_target": "RuntimeWarning",
                              "role": "exc",
                              "suppress_link": false,
                              "target": "RuntimeWarning",
                              "unresolved": false
                            },
                            {
                              "kind": "text",
                              "text": " (via the Python "
                            },
                            {
                              "kind": "code",
                              "text": "warnings"
                            },
                            {
                              "kind": "text",
                              "text": "\nmodule)."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "raise: Raise a "
                            },
                            {
                              "display_text": "FloatingPointError",
                              "explicit_title": false,
                              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.FloatingPointError.html",
                              "href": "",
                              "kind": "role_reference",
                              "original_target": "FloatingPointError",
                              "role": "exc",
                              "suppress_link": false,
                              "target": "FloatingPointError",
                              "unresolved": false
                            },
                            {
                              "kind": "text",
                              "text": "."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "call: Call a function specified using the "
                            },
                            {
                              "kind": "code",
                              "text": "seterrcall"
                            },
                            {
                              "kind": "text",
                              "text": " function."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "print: Print a warning directly to "
                            },
                            {
                              "kind": "code",
                              "text": "stdout"
                            },
                            {
                              "kind": "text",
                              "text": "."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    },
                    {
                      "blocks": [
                        {
                          "inline": [
                            {
                              "kind": "text",
                              "text": "log: Record error in a Log object specified by "
                            },
                            {
                              "kind": "code",
                              "text": "seterrcall"
                            },
                            {
                              "kind": "text",
                              "text": "."
                            }
                          ],
                          "type": "paragraph"
                        }
                      ]
                    }
                  ],
                  "ordered": false,
                  "type": "list"
                },
                {
                  "inline": [
                    {
                      "kind": "text",
                      "text": "The default is not to change the current behavior."
