            {
              "kind": "input",
              "prompt": ">>>",
              "text": "def shifted_uniform(shape, **kwargs):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": "return we.random.uniform(*shape, **kwargs)"
            },
            {
              "kind": "input",
