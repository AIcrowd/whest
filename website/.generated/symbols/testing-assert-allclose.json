      "title": "See also"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "When one of "
            },
            {
              "kind": "code",
              "text": "actual"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "desired"
            },
            {
              "kind": "text",
              "text": " is a scalar and the other is\narray_like, the function performs the comparison as if the scalar were\nbroadcasted to the shape of the array.\nThis behaviour can be disabled with the "
            },
            {
              "kind": "code",
              "text": "strict"
            },
            {
              "kind": "text",
              "text": " parameter."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Notes"
    },
    {
      "blocks": [
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = [1e-5, 1e-3, 1e-1]"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.arccos(we.cos(x))"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_allclose(x, y, rtol=1e-5, atol=0)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "As mentioned in the Notes section, "
            },
            {
              "kind": "code",
              "text": "assert_allclose"
            },
            {
              "kind": "text",
              "text": " has special\nhandling for scalars. Here, the test checks that the value of "
            },
            {
              "external_url": "",
              "href": "/docs/api/sin/",
              "kind": "link",
              "target": "sin",
              "text": "we.sin"
            },
            {
              "kind": "text",
              "text": "\nis nearly zero at integer multiples of \u03c0."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "x = we.arange(3) * we.pi"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_allclose(we.sin(x), 0, atol=1e-15)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Use "
            },
            {
              "kind": "code",
              "text": "strict"
            },
            {
              "kind": "text",
              "text": " to raise an "
            },
            {
              "kind": "code",
              "text": "AssertionError"
            },
            {
              "kind": "text",
              "text": " when comparing an array\nwith one or more dimensions against a scalar."
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_allclose(we.sin(x), 0, atol=1e-15, strict=True)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "AssertionError:"
            },
            {
              "kind": "output",
              "text": "Not equal to tolerance rtol=1e-07, atol=1e-15"
            },
            {
              "kind": "output",
              "text": "<BLANKLINE>"
            },
            {
              "kind": "output",
              "text": "(shapes (3,), () mismatch)"
            },
            {
              "kind": "output",
              "text": " ACTUAL: array([ 0.000000e+00,  1.224647e-16, -2.449294e-16])"
            },
            {
              "kind": "output",
              "text": " DESIRED: array(0)"
            }
          ],
          "type": "doctest_block"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The "
            },
            {
              "kind": "code",
              "text": "strict"
            },
            {
              "kind": "text",
              "text": " parameter also ensures that the array data types match:"
            }
          ],
          "type": "paragraph"
        },
        {
          "lines": [
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "y = we.zeros(3, dtype=we.float32)"
            },
            {
              "kind": "input",
              "prompt": ">>>",
              "text": "we.testing.assert_allclose(we.sin(x), y, atol=1e-15, strict=True)"
            },
            {
              "kind": "output",
              "text": "Traceback (most recent call last):"
            },
            {
              "kind": "input",
              "prompt": "...",
              "text": ""
            },
            {
              "kind": "output",
              "text": "AssertionError:"
            },
            {
              "kind": "output",
              "text": "Not equal to tolerance rtol=1e-07, atol=1e-15"
            },
            {
              "kind": "output",
              "text": "<BLANKLINE>"
            },
            {
              "kind": "output",
              "text": "(dtypes float64, float32 mismatch)"
            },
            {
              "kind": "output",
              "text": " ACTUAL: array([ 0.000000e+00,  1.224647e-16, -2.449294e-16])"
            },
            {
              "kind": "output",
              "text": " DESIRED: array([0., 0., 0.], dtype=float32)"
            }
          ],
          "type": "doctest_block"
        }
      ],
