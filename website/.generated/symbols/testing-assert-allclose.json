  "body_sections": [
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Raises an AssertionError if two objects are not equal up to desired tolerance."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Summary"
    },
    {
      "blocks": [
        {
          "inline": [
            {
              "kind": "text",
              "text": "Given two array_like objects, check that their shapes and all elements\nare equal (but see the Notes for the special handling of a scalar). An\nexception is raised if the shapes mismatch or any values conflict. In\ncontrast to the standard usage in numpy, NaNs are compared like numbers,\nno assertion is raised if both objects have NaNs in the same positions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "The test is equivalent to "
            },
            {
              "kind": "code",
              "text": "allclose(actual, desired, rtol, atol)"
            },
            {
              "kind": "text",
              "text": " (note\nthat "
            },
            {
              "external_url": "",
              "href": "/docs/api/allclose/",
              "kind": "link",
              "target": "allclose",
              "text": "allclose"
            },
            {
              "kind": "text",
              "text": " has different default values). It compares the difference\nbetween "
            },
            {
              "kind": "code",
              "text": "actual"
            },
            {
              "kind": "text",
              "text": " and "
            },
            {
              "kind": "code",
              "text": "desired"
            },
            {
              "kind": "text",
              "text": " to "
            },
            {
              "kind": "code",
              "text": "atol + rtol * abs(desired)"
            },
            {
              "kind": "text",
              "text": "."
            }
          ],
          "type": "paragraph"
        }
      ],
      "title": "Extended Summary"
    },
