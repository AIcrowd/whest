          "inline": [
            {
              "kind": "text",
              "text": "This helper multiplies the analytical FLOP count by the active weight from "
            },
            {
              "external_url": "https://numpy.org/doc/stable/reference/generated/numpy._weights.html",
              "href": "",
              "kind": "link",
              "target": "_weights",
              "text": "flopscope._weights"
            },
            {
              "kind": "text",
              "text": " and then applies "
            },
            {
              "kind": "code",
              "text": "int(...)"
            },
            {
              "kind": "text",
              "text": " so public estimates match budget deductions."
            }
          ],
          "type": "paragraph"
        },
        {
          "inline": [
            {
              "kind": "text",
              "text": "Uses $n^3/3 + n^3$ for symmetric input (Cholesky factorization + n\ntriangular solves against identity), or $n^3$ for general input (LU-based)."
            }
          ],
          "type": "paragraph"
        }
