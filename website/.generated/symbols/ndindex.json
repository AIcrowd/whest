          "inline": [
            {
              "kind": "text",
              "text": "Given the shape of an array, an "
            },
            {
              "kind": "code",
              "text": "ndindex"
            },
            {
              "kind": "text",
              "text": " instance iterates over\nthe N-dimensional index of the array. At each iteration a tuple\nof indices is returned, the last dimension is iterated over first."
            }
          ],
          "type": "paragraph"
        }
      ],
