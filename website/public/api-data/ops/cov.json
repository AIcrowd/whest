                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": " has the same form\nas that of "
                      },
                      {
                        "kind": "code",
                        "text": "m"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An additional set of variables and observations. "
                  },
                  {
                    "kind": "code",
                    "text": "y"
                  },
                  {
                    "kind": "text",
                    "text": " has the same form\nas that of "
                  },
                  {
                    "kind": "code",
                    "text": "m"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "y",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "rowvar"
                      },
                      {
                        "kind": "text",
                        "text": " is True (default), then each row represents a\nvariable, with observations in the columns. Otherwise, the relationship\nis transposed: each column represents a variable, while the rows\ncontain observations."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If "
                  },
                  {
                    "kind": "code",
                    "text": "rowvar"
                  },
                  {
                    "kind": "text",
                    "text": " is True (default), then each row represents a\nvariable, with observations in the columns. Otherwise, the relationship\nis transposed: each column represents a variable, while the rows\ncontain observations."
                  }
                ],
                "name": "rowvar",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Default normalization (False) is by "
                      },
                      {
                        "kind": "code",
                        "text": "(N - 1)"
                      },
                      {
                        "kind": "text",
                        "text": ", where "
                      },
                      {
                        "kind": "code",
                        "text": "N"
                      },
                      {
                        "kind": "text",
                        "text": " is the\nnumber of observations given (unbiased estimate). If "
                      },
                      {
                        "kind": "code",
                        "text": "bias"
                      },
                      {
                        "kind": "text",
                        "text": " is True,\nthen normalization is by "
                      },
                      {
                        "kind": "code",
                        "text": "N"
                      },
                      {
                        "kind": "text",
                        "text": ". These values can be overridden by using\nthe keyword "
                      },
                      {
                        "kind": "code",
                        "text": "ddof"
                      },
                      {
                        "kind": "text",
                        "text": " in numpy versions >= 1.5."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Default normalization (False) is by "
                  },
                  {
                    "kind": "code",
                    "text": "(N - 1)"
                  },
                  {
                    "kind": "text",
                    "text": ", where "
                  },
                  {
                    "kind": "code",
                    "text": "N"
                  },
                  {
                    "kind": "text",
                    "text": " is the\nnumber of observations given (unbiased estimate). If "
                  },
                  {
                    "kind": "code",
                    "text": "bias"
                  },
                  {
                    "kind": "text",
                    "text": " is True,\nthen normalization is by "
                  },
                  {
                    "kind": "code",
                    "text": "N"
                  },
                  {
                    "kind": "text",
                    "text": ". These values can be overridden by using\nthe keyword "
                  },
                  {
                    "kind": "code",
                    "text": "ddof"
                  },
                  {
                    "kind": "text",
                    "text": " in numpy versions >= 1.5."
                  }
                ],
                "name": "bias",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If not "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " the default value implied by "
                      },
                      {
                        "kind": "code",
                        "text": "bias"
                      },
                      {
                        "kind": "text",
                        "text": " is overridden.\nNote that "
                      },
                      {
                        "kind": "code",
                        "text": "ddof=1"
                      },
                      {
                        "kind": "text",
                        "text": " will return the unbiased estimate, even if both\n"
                      },
                      {
                        "kind": "code",
                        "text": "fweights"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "aweights"
                      },
                      {
                        "kind": "text",
                        "text": " are specified, and "
                      },
                      {
                        "kind": "code",
                        "text": "ddof=0"
                      },
                      {
                        "kind": "text",
                        "text": " will return\nthe simple average. See the notes for the details. The default value\nis "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If not "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " the default value implied by "
                  },
                  {
                    "kind": "code",
                    "text": "bias"
                  },
                  {
                    "kind": "text",
                    "text": " is overridden.\nNote that "
                  },
                  {
                    "kind": "code",
                    "text": "ddof=1"
                  },
                  {
                    "kind": "text",
                    "text": " will return the unbiased estimate, even if both\n"
                  },
                  {
                    "kind": "code",
                    "text": "fweights"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "aweights"
                  },
                  {
                    "kind": "text",
                    "text": " are specified, and "
                  },
                  {
                    "kind": "code",
                    "text": "ddof=0"
                  },
                  {
                    "kind": "text",
                    "text": " will return\nthe simple average. See the notes for the details. The default value\nis "
                  },
                  {
                    "kind": "code",
