  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Estimate a covariance matrix, given data and weights."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Covariance indicates the level to which two variables vary together.\nIf we examine N-dimensional samples, "
              },
              {
                "kind": "math",
                "latex": "X = [x_1, x_2, ..., x_N]^T"
              },
              {
                "kind": "text",
                "text": ",\nthen the covariance matrix element "
              },
              {
                "kind": "math",
                "latex": "C_{ij}"
              },
              {
                "kind": "text",
                "text": " is the covariance of\n"
              },
              {
                "kind": "math",
                "latex": "x_i"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "math",
                "latex": "x_j"
              },
              {
                "kind": "text",
                "text": ". The element "
              },
              {
                "kind": "math",
                "latex": "C_{ii}"
              },
              {
                "kind": "text",
                "text": " is the variance\nof "
              },
              {
                "kind": "math",
                "latex": "x_i"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "See the notes for an outline of the algorithm."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A 1-D or 2-D array containing multiple variables and observations.\nEach row of "
                      },
                      {
                        "kind": "code",
                        "text": "m"
                      },
                      {
                        "kind": "text",
                        "text": " represents a variable, and each column a single\nobservation of all those variables. Also see "
                      },
                      {
                        "kind": "code",
                        "text": "rowvar"
                      },
                      {
                        "kind": "text",
                        "text": " below."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A 1-D or 2-D array containing multiple variables and observations.\nEach row of "
                  },
                  {
                    "kind": "code",
                    "text": "m"
                  },
                  {
                    "kind": "text",
                    "text": " represents a variable, and each column a single\nobservation of all those variables. Also see "
                  },
                  {
                    "kind": "code",
                    "text": "rowvar"
                  },
                  {
                    "kind": "text",
                    "text": " below."
                  }
                ],
                "name": "m",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
