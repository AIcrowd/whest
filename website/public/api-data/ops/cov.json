                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "ddof",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "1-D array of integer frequency weights; the number of times each\nobservation vector should be repeated."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "1-D array of integer frequency weights; the number of times each\nobservation vector should be repeated."
                  }
                ],
                "name": "fweights",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "1-D array of observation vector weights. These relative weights are\ntypically large for observations considered \"important\" and smaller for\nobservations considered less \"important\". If "
                      },
                      {
                        "kind": "code",
                        "text": "ddof=0"
                      },
                      {
                        "kind": "text",
                        "text": " the array of\nweights can be used to assign probabilities to observation vectors."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "1-D array of observation vector weights. These relative weights are\ntypically large for observations considered \"important\" and smaller for\nobservations considered less \"important\". If "
                  },
                  {
                    "kind": "code",
                    "text": "ddof=0"
                  },
                  {
                    "kind": "text",
                    "text": " the array of\nweights can be used to assign probabilities to observation vectors."
                  }
                ],
                "name": "aweights",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Data-type of the result. By default, the return data-type will have\nat least "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.float64.html",
                        "href": "",
