    "weight": 1.0,
    "cost_formula": "numel(output)",
    "cost_formula_latex": "$\\text{numel}(\\text{output})$",
    "notes": "Element-wise addition.",
    "summary": "Add arguments element-wise.",
    "signature": "we.add(x1, x2, /, out=None, *, where=True, casting='same_kind', order='K', dtype=None, subok=True[, signature])"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Add arguments element-wise."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x1, x2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The arrays to be added.\nIf ``x1.shape != x2.shape``, they must be broadcastable to a common\nshape (which becomes the shape of the output)."
              }
            ]
          },
          {
            "name": "out",
            "type": "ndarray, None, or tuple of ndarray and None, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
              }
            ]
          },
          {
            "name": "where",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the `out` array will be set to the ufunc result.\nElsewhere, the `out` array will retain its original value.\nNote that if an uninitialized `out` array is created via the default\n``out=None``, locations within it where the condition is False will\nremain uninitialized."
              }
            ]
          },
          {
            "name": "**kwargs",
            "type": "",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "For other keyword-only arguments, see the\n:ref:`ufunc docs <ufuncs.kwargs>`."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "add",
            "type": "ndarray or scalar",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The sum of `x1` and `x2`, element-wise.\nThis is a scalar if both `x1` and `x2` are scalars."
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Equivalent to `x1` + `x2` in terms of array broadcasting."
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.add(1.0, 4.0)\n5.0\n>>> x1 = np.arange(9.0).reshape((3, 3))\n>>> x2 = np.arange(3.0)\n>>> np.add(x1, x2)\narray([[  0.,   2.,   4.],\n       [  3.,   5.,   7.],\n       [  6.,   8.,  10.]])"
          },
          {
            "type": "paragraph",
            "text": "The ``+`` operator can be used as a shorthand for ``np.add`` on ndarrays."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x1 = np.arange(9.0).reshape((3, 3))\n>>> x2 = np.arange(3.0)\n>>> x1 + x2\narray([[ 0.,  2.,  4.],\n       [ 3.,  5.,  7.],\n       [ 6.,  8., 10.]])"
          }
        ]
      }
    ]
  }
}