        "blocks": [
          {
            "type": "paragraph",
            "text": "Find the set exclusive-or of two arrays."
          },
          {
            "type": "paragraph",
            "text": "Return the sorted, unique values that are in only one (not both) of the\ninput arrays."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "ar1, ar2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input arrays."
              }
            ]
          },
          {
            "name": "assume_unique",
            "type": "bool",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If True, the input arrays are both assumed to be unique, which\ncan speed up the calculation. Default is False."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "setxor1d",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Sorted 1D array of unique values that are in only one of the input\narrays."
              }
            ]
          }
        ]
      },
