                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.kaiser(12, 14)"
              },
              {
                "kind": "output",
                "text": " array([7.72686684e-06, 3.46009194e-03, 4.65200189e-02, # may vary"
              },
              {
                "kind": "output",
                "text": "        2.29737120e-01, 5.99885316e-01, 9.45674898e-01,"
              },
              {
                "kind": "output",
                "text": "        9.45674898e-01, 5.99885316e-01, 2.29737120e-01,"
              },
              {
                "kind": "output",
                "text": "        4.65200189e-02, 3.46009194e-03, 7.72686684e-06])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Plot the window and the frequency response."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "language": "python",
                "text": "import matplotlib.pyplot as plt\nfrom fnp.fft import fft, fftshift\nwindow = fnp.kaiser(51, 14)\nplt.plot(window)\nplt.title(\"Kaiser window\")\nplt.ylabel(\"Amplitude\")\nplt.xlabel(\"Sample\")\nplt.show()\n\nplt.figure()\nA = fft(window, 2048) / 25.5\nmag = fnp.abs(fftshift(A))\nfreq = fnp.linspace(-0.5, 0.5, len(A))\nresponse = 20 * fnp.log10(mag)\nresponse = fnp.clip(response, -100, 100)\nplt.plot(freq, response)\nplt.title(\"Frequency response of Kaiser window\")\nplt.ylabel(\"Magnitude [dB]\")\nplt.xlabel(\"Normalized frequency [cycles per sample]\")\nplt.axis('tight')\nplt.show()",
                "type": "literal_block"
              }
            ],
            "directive": "plot",
            "options": [
              {
                "name": "include-source",
                "value": ""
              }
            ],
            "raw_source": ".. plot::\n    :include-source:\n\n    import matplotlib.pyplot as plt\n    from numpy.fft import fft, fftshift\n    window = np.kaiser(51, 14)\n    plt.plot(window)\n    plt.title(\"Kaiser window\")\n    plt.ylabel(\"Amplitude\")\n    plt.xlabel(\"Sample\")\n    plt.show()\n\n    plt.figure()\n    A = fft(window, 2048) / 25.5\n    mag = np.abs(fftshift(A))\n    freq = np.linspace(-0.5, 0.5, len(A))\n    response = 20 * np.log10(mag)\n    response = np.clip(response, -100, 100)\n    plt.plot(freq, response)\n    plt.title(\"Frequency response of Kaiser window\")\n    plt.ylabel(\"Magnitude [dB]\")\n    plt.xlabel(\"Normalized frequency [cycles per sample]\")\n    plt.axis('tight')\n    plt.show()",
            "supported": true,
            "type": "directive_block"
          }
        ],
        "title": "Examples"
      }
