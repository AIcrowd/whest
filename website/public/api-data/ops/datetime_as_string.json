    "weight": 1.0,
    "cost_formula": "N/A",
    "cost_formula_latex": "N/A",
    "notes": "Convert datetime array to string representation. Not supported.",
    "summary": "Convert an array of datetimes into an array of strings.",
    "signature": "we.datetime_as_string(arr, unit=None, timezone='naive', casting='same_kind')"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Convert an array of datetimes into an array of strings."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "arr",
            "type": "array_like of datetime64",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The array of UTC timestamps to format."
              }
            ]
          },
          {
            "name": "unit",
            "type": "str",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "One of None, 'auto', or\na :ref:`datetime unit <arrays.dtypes.dateunits>`."
              }
            ]
          },
          {
            "name": "timezone",
            "type": "{'naive', 'UTC', 'local'} or tzinfo",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Timezone information to use when displaying the datetime. If 'UTC',\nend with a Z to indicate UTC time. If 'local', convert to the local\ntimezone first, and suffix with a +-#### timezone offset. If a tzinfo\nobject, then do as with 'local', but use the specified timezone."
              }
            ]
          },
          {
            "name": "casting",
            "type": "{'no', 'equiv', 'safe', 'same_kind', 'unsafe'}",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Casting to allow when changing between datetime units."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "str_arr",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array of strings the same shape as `arr`."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> import pytz\n>>> d = np.arange('2002-10-27T04:30', 4*60, 60, dtype='M8[m]')\n>>> d\narray(['2002-10-27T04:30', '2002-10-27T05:30', '2002-10-27T06:30',\n       '2002-10-27T07:30'], dtype='datetime64[m]')"
          },
          {
            "type": "paragraph",
            "text": "Setting the timezone to UTC shows the same information, but with a Z suffix"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.datetime_as_string(d, timezone='UTC')\narray(['2002-10-27T04:30Z', '2002-10-27T05:30Z', '2002-10-27T06:30Z',\n       '2002-10-27T07:30Z'], dtype='<U35')"
          },
          {
            "type": "paragraph",
            "text": "Note that we picked datetimes that cross a DST boundary. Passing in a\n``pytz`` timezone object will print the appropriate offset"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.datetime_as_string(d, timezone=pytz.timezone('US/Eastern'))\narray(['2002-10-27T00:30-0400', '2002-10-27T01:30-0400',\n       '2002-10-27T01:30-0500', '2002-10-27T02:30-0500'], dtype='<U39')"
          },
          {
            "type": "paragraph",
            "text": "Passing in a unit will change the precision"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.datetime_as_string(d, unit='h')\narray(['2002-10-27T04', '2002-10-27T05', '2002-10-27T06', '2002-10-27T07'],\n      dtype='<U32')\n>>> np.datetime_as_string(d, unit='s')\narray(['2002-10-27T04:30:00', '2002-10-27T05:30:00', '2002-10-27T06:30:00',\n       '2002-10-27T07:30:00'], dtype='<U38')"
          },
          {
            "type": "paragraph",
            "text": "'casting' can be used to specify whether precision can be changed"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.datetime_as_string(d, unit='h', casting='safe')\nTraceback (most recent call last):\n    ...\nTypeError: Cannot create a datetime string as units 'h' from a NumPy\ndatetime with units 'm' according to the rule 'safe'"
          }
        ]
      }
    ]
  }
}