        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Returns the lowest common multiple of ``|x1|`` and ``|x2|``"
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x1, x2",
            "type": "array_like, int",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Arrays of values.\nIf ``x1.shape != x2.shape``, they must be broadcastable to a common\nshape (which becomes the shape of the output)."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "y",
            "type": "ndarray or scalar",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The lowest common multiple of the absolute value of the inputs\nThis is a scalar if both `x1` and `x2` are scalars."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.lcm(12, 20)\n60\n>>> np.lcm.reduce([3, 12, 20])\n60\n>>> np.lcm.reduce([40, 12, 20])\n120\n>>> np.lcm(np.arange(6), 20)\narray([ 0, 20, 20, 60, 20, 20])"
          }
        ]
