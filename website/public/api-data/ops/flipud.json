            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = we.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "A = rng.normal(size=(2,3,5))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.all(we.flipud(A) == A[::-1,...])"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
