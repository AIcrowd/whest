            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.angle([1.0, 1.0j, 1+1j])               # in radians"
              },
              {
                "kind": "output",
                "text": "array([ 0.        ,  1.57079633,  0.78539816]) # may vary"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.angle(1+1j, deg=True)                  # in degrees"
              },
              {
                "kind": "output",
                "text": "45.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.angle([0., -0., complex(0., -0.), complex(-0., -0.)])  # convention"
              },
              {
                "kind": "output",
                "text": "array([ 0.        ,  3.14159265, -0.        , -3.14159265])"
              }
