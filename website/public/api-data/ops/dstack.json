  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Stack arrays in sequence depth wise (along third axis)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This is equivalent to concatenation along the third axis after 2-D arrays\nof shape "
              },
              {
                "kind": "code",
                "text": "(M,N)"
              },
              {
                "kind": "text",
                "text": " have been reshaped to "
              },
              {
                "kind": "code",
                "text": "(M,N,1)"
              },
              {
                "kind": "text",
                "text": " and 1-D arrays of shape\n"
              },
              {
                "kind": "code",
                "text": "(N,)"
              },
              {
                "kind": "text",
                "text": " have been reshaped to "
              },
              {
                "kind": "code",
                "text": "(1,N,1)"
              },
              {
                "kind": "text",
                "text": ". Rebuilds arrays divided by\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/dsplit",
                "kind": "link",
                "target": "dsplit",
                "text": "dsplit"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function makes most sense for arrays with up to 3 dimensions. For\ninstance, for pixel-data with a height (first axis), width (second axis),\nand r/g/b channels (third axis). The functions "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/concatenate",
                "kind": "link",
                "target": "concatenate",
                "text": "concatenate"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/stack",
                "kind": "link",
                "target": "stack",
                "text": "stack"
              },
              {
                "kind": "text",
                "text": " and\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/block",
                "kind": "link",
                "target": "block",
                "text": "block"
              },
              {
                "kind": "text",
                "text": " provide more general stacking and concatenation operations."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The arrays must have the same shape along all but the third axis.\n1-D or 2-D arrays must have the same shape."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "sequence of arrays",
                "inline": [
