  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Find the unique elements of `x` and indices to reconstruct `x`."
          },
          {
            "type": "paragraph",
            "text": "This function is an Array API compatible alternative to::"
          },
          {
            "type": "paragraph",
            "text": "    np.unique(x, return_inverse=True, equal_nan=False)"
          },
          {
            "type": "paragraph",
            "text": "but returns a namedtuple for easier access to each output."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array. It will be flattened if it is not already 1-D."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "namedtuple",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The result containing:"
              },
              {
                "type": "paragraph",
                "text": "* values - The unique elements of an input array.\n* inverse_indices - The indices from the set of unique elements\n  that reconstruct `x`."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> x = [1, 1, 2]\n>>> uniq = np.unique_inverse(x)\n>>> uniq.values\narray([1, 2])\n>>> uniq.inverse_indices\narray([0, 0, 1])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "unique \u2014 Find the unique elements of an array."
          }
        ]
      }
    ]
  }
