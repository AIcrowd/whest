      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The number 13 has the binary representation "
              },
              {
                "kind": "code",
                "text": "00001101"
              },
              {
                "kind": "text",
                "text": ". Likewise,\n16 is represented by "
              },
              {
                "kind": "code",
                "text": "00010000"
              },
              {
                "kind": "text",
                "text": ".  The bit-wise OR of 13 and 16 is\nthen "
              },
              {
                "kind": "code",
                "text": "00011101"
              },
              {
                "kind": "text",
                "text": ", or 29:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bitwise_or(13, 16)"
              },
              {
                "kind": "output",
                "text": "29"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.binary_repr(29)"
              },
              {
                "kind": "output",
                "text": "'11101'"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bitwise_or(32, 2)"
              },
              {
                "kind": "output",
                "text": "34"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bitwise_or([33, 4], 1)"
              },
              {
                "kind": "output",
                "text": "array([33,  5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bitwise_or([33, 4], [1, 2])"
              },
              {
                "kind": "output",
                "text": "array([33,  6])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bitwise_or(we.array([2, 5, 255]), we.array([4, 4, 4]))"
              },
              {
                "kind": "output",
                "text": "array([  6,   5, 255])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.array([2, 5, 255]) | we.array([4, 4, 4])"
              },
              {
                "kind": "output",
                "text": "array([  6,   5, 255])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bitwise_or(we.array([2, 5, 255, 2147483647], dtype=we.int32),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "we.array([4, 4, 4, 2147483647], dtype=we.int32))"
              },
              {
                "kind": "output",
                "text": "array([         6,          5,        255, 2147483647], dtype=int32)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.bitwise_or([True, True], [False, True])"
              },
              {
                "kind": "output",
                "text": "array([ True,  True])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "code",
                "text": "|"
              },
              {
                "kind": "text",
                "text": " operator can be used as a shorthand for "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/bitwise_or",
                "kind": "link",
                "target": "bitwise_or",
                "text": "we.bitwise_or"
              },
              {
                "kind": "text",
                "text": " on\nndarrays."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x1 = we.array([2, 5, 255])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x2 = we.array([4, 4, 4])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x1 | x2"
              },
              {
                "kind": "output",
                "text": "array([  6,   5, 255])"
              }
            ],
            "type": "doctest_block"
          }
        ],
