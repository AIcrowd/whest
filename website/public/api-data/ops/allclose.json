{
  "detail_href": "/docs/api/ops/allclose/",
  "detail_json_href": "/api-data/ops/allclose.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns True if two arrays are element-wise equal within a tolerance."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The tolerance values are positive, typically very small numbers.  The\nrelative difference ("
              },
              {
                "kind": "code",
                "text": "rtol"
              },
              {
                "kind": "text",
                "text": " * abs("
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": ")) and the absolute difference\n"
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " are added together to compare against the absolute difference\nbetween "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [
              {
                "kind": "text",
                "text": "The default "
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " is not appropriate for comparing numbers"
              }
            ],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "with magnitudes much smaller than one (see Notes)."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "warning",
            "options": [],
            "raw_source": ".. warning:: The default `atol` is not appropriate for comparing numbers\n             with magnitudes much smaller than one (see Notes).",
            "supported": true,
            "type": "directive_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "NaNs are treated as equal if they are in the same place and if\n"
              },
              {
                "kind": "code",
                "text": "equal_nan=True"
              },
              {
                "kind": "text",
                "text": ".  Infs are treated as equal if they are in the same\nplace and of the same sign in both arrays."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input arrays to compare."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input arrays to compare."
                  }
                ],
                "name": "a, b",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The relative tolerance parameter (see Notes)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The relative tolerance parameter (see Notes)."
                  }
                ],
                "name": "rtol",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The absolute tolerance parameter (see Notes)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The absolute tolerance parameter (see Notes)."
                  }
                ],
                "name": "atol",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Whether to compare NaN's as equal.  If True, NaN's in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " will be\nconsidered equal to NaN's in "
                      },
                      {
                        "kind": "code",
                        "text": "b"
                      },
                      {
                        "kind": "text",
                        "text": " in the output array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Whether to compare NaN's as equal.  If True, NaN's in "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " will be\nconsidered equal to NaN's in "
                  },
                  {
                    "kind": "code",
                    "text": "b"
                  },
                  {
                    "kind": "text",
                    "text": " in the output array."
                  }
                ],
                "name": "equal_nan",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Returns True if the two arrays are equal within the given\ntolerance; False otherwise."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Returns True if the two arrays are equal within the given\ntolerance; False otherwise."
                  }
                ],
                "name": "allclose",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
