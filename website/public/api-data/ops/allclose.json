        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "If the following equation is element-wise True, then allclose returns\nTrue.:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "absolute(a - b) <= (atol + rtol * absolute(b))",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The above equation is not symmetric in "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": ", so that\n"
              },
              {
                "kind": "code",
                "text": "allclose(a, b)"
              },
              {
                "kind": "text",
                "text": " might be different from "
              },
              {
                "kind": "code",
                "text": "allclose(b, a)"
              },
              {
                "kind": "text",
                "text": " in\nsome rare cases."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The default value of "
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " is not appropriate when the reference value\n"
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " has magnitude smaller than one. For example, it is unlikely that\n"
              },
              {
                "kind": "code",
                "text": "a = 1e-9"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b = 2e-9"
              },
              {
                "kind": "text",
                "text": " should be considered \"close\", yet\n"
              },
              {
                "kind": "code",
                "text": "allclose(1e-9, 2e-9)"
              },
              {
                "kind": "text",
                "text": " is "
              },
              {
                "kind": "code",
                "text": "True"
              },
              {
                "kind": "text",
                "text": " with default settings. Be sure\nto select "
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " for the use case at hand, especially for defining the\nthreshold below which a non-zero value in "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " will be considered \"close\"\nto a very small or zero value in "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The comparison of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " uses standard broadcasting, which\nmeans that "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " need not have the same shape in order for\n"
              },
              {
                "kind": "code",
                "text": "allclose(a, b)"
              },
              {
                "kind": "text",
                "text": " to evaluate to True.  The same is true for\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/equal",
                "kind": "link",
                "target": "equal",
                "text": "equal"
              },
              {
                "kind": "text",
                "text": " but not "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/array_equal",
                "kind": "link",
                "target": "array_equal",
                "text": "array_equal"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/allclose",
                "kind": "link",
                "target": "allclose",
                "text": "allclose"
              },
              {
                "kind": "text",
                "text": " is not defined for non-numeric data types.\n"
              },
              {
                "kind": "code",
                "text": "bool"
              },
              {
                "kind": "text",
                "text": " is considered a numeric data-type for this purpose."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
