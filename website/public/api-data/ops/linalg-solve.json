      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Solve the system of equations:\n"
              },
              {
                "kind": "code",
                "text": "x0 + 2 * x1 = 1"
              },
              {
                "kind": "text",
                "text": " and\n"
              },
              {
                "kind": "code",
                "text": "3 * x0 + 5 * x1 = 2"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[1, 2], [3, 5]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.array([1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.linalg.solve(a, b)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([-1.,  1.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Check that the solution is correct:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.allclose(we.dot(a, x), b)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
