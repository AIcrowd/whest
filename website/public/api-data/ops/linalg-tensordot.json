{
  "detail_href": "/docs/api/linalg/tensordot/",
  "detail_json_href": "/api-data/ops/linalg-tensordot.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute tensor dot product along specified axes."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given two tensors, "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": ", and an array_like object containing\ntwo array_like objects, "
              },
              {
                "kind": "code",
                "text": "(a_axes, b_axes)"
              },
              {
                "kind": "text",
                "text": ", sum the products of\n"
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": "'s and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": "'s elements (components) over the axes specified by\n"
              },
              {
                "kind": "code",
                "text": "a_axes"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b_axes"
              },
              {
                "kind": "text",
                "text": ". The third argument can be a single non-negative\ninteger_like scalar, "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": "; if it is such, then the last "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": " dimensions\nof "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and the first "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": " dimensions of "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " are summed over."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Tensors to \"dot\"."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Tensors to \"dot\"."
                  }
                ],
                "name": "a, b",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "integer_like\nIf an int N, sum over the last N axes of "
                              },
                              {
                                "kind": "code",
                                "text": "a"
                              },
                              {
                                "kind": "text",
                                "text": " and the first N axes\nof "
                              },
                              {
                                "kind": "code",
                                "text": "b"
                              },
                              {
                                "kind": "text",
                                "text": " in order. The sizes of the corresponding axes must match."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "(2,) array_like\nOr, a list of axes to be summed over, first sequence applying to "
                              },
                              {
                                "kind": "code",
                                "text": "a"
                              },
                              {
                                "kind": "text",
                                "text": ",\nsecond to "
                              },
                              {
                                "kind": "code",
                                "text": "b"
                              },
                              {
                                "kind": "text",
                                "text": ". Both elements array_like must be of the same length."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  }
                ],
                "data_type": "int or (2,) array_like",
                "inline": [],
                "name": "axes",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The tensor dot product of the input."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The tensor dot product of the input."
                  }
                ],
                "name": "output",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "",
                "description_inline": [],
                "external_url": "",
                "href": "/docs/api/ops/dot",
                "label": "we.dot",
                "original_target": "dot",
                "role": "",
                "target": "dot",
                "unresolved": false
              },
              {
                "description": "",
                "description_inline": [],
                "external_url": "",
                "href": "/docs/api/ops/einsum",
                "label": "we.einsum",
                "original_target": "einsum",
                "role": "",
                "target": "einsum",
                "unresolved": false
              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "blocks": [
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "code",
                                "text": "axes = 0"
                              },
                              {
                                "kind": "text",
                                "text": " : tensor product "
                              },
                              {
                                "kind": "math",
                                "latex": "a\\otimes b"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "code",
                                "text": "axes = 1"
                              },
                              {
                                "kind": "text",
                                "text": " : tensor dot product "
                              },
                              {
                                "kind": "math",
                                "latex": "a\\cdot b"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "code",
                                "text": "axes = 2"
                              },
                              {
                                "kind": "text",
                                "text": " : (default) tensor double contraction "
                              },
                              {
                                "kind": "math",
                                "latex": "a:b"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  }
                ],
                "term_inline": [
                  {
                    "kind": "text",
                    "text": "Three common use cases are:"
                  }
                ]
              }
            ],
            "type": "definition_list"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When "
              },
              {
                "kind": "code",
                "text": "axes"
              },
              {
                "kind": "text",
                "text": " is integer_like, the sequence of axes for evaluation\nwill be: from the -Nth axis to the -1th axis in "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": ",\nand from the 0th axis to (N-1)th axis in "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": ".\nFor example, "
              },
              {
                "kind": "code",
                "text": "axes = 2"
              },
              {
                "kind": "text",
                "text": " is the equal to\n"
              },
              {
                "kind": "code",
                "text": "axes = [[-2, -1], [0, 1]]"
              },
              {
                "kind": "text",
                "text": ".\nWhen N-1 is smaller than 0, or when -N is larger than -1,\nthe element of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " are defined as the "
              },
              {
                "kind": "code",
                "text": "axes"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When there is more than one axis to sum over - and they are not the last\n(first) axes of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " ("
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": ") - the argument "
              },
              {
                "kind": "code",
                "text": "axes"
              },
              {
                "kind": "text",
                "text": " should consist of\ntwo sequences of the same length, with the first axis to sum over given\nfirst in both sequences, the second axis second, and so forth.\nThe calculation can be referred to "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/einsum",
                "kind": "link",
                "target": "einsum",
                "text": "we.einsum"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The shape of the result consists of the non-contracted axes of the\nfirst tensor, followed by the non-contracted axes of the second."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "An example on integer_like:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a_0 = we.array([[1, 2], [3, 4]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b_0 = we.array([[5, 6], [7, 8]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c_0 = we.tensordot(a_0, b_0, axes=0)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c_0.shape"
              },
              {
                "kind": "output",
                "text": "(2, 2, 2, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c_0"
              },
              {
                "kind": "output",
                "text": "array([[[[ 5,  6],"
              },
              {
                "kind": "output",
                "text": "         [ 7,  8]],"
              },
              {
                "kind": "output",
                "text": "        [[10, 12],"
              },
              {
                "kind": "output",
                "text": "         [14, 16]]],"
              },
              {
                "kind": "output",
                "text": "       [[[15, 18],"
              },
              {
                "kind": "output",
                "text": "         [21, 24]],"
              },
              {
                "kind": "output",
                "text": "        [[20, 24],"
              },
              {
                "kind": "output",
                "text": "         [28, 32]]]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "An example on array_like:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.arange(60.).reshape(3,4,5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.arange(24.).reshape(4,3,2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c = we.tensordot(a,b, axes=([1,0],[0,1]))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c.shape"
              },
              {
                "kind": "output",
                "text": "(5, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c"
              },
              {
                "kind": "output",
                "text": "array([[4400., 4730.],"
              },
              {
                "kind": "output",
                "text": "       [4532., 4874.],"
              },
              {
                "kind": "output",
                "text": "       [4664., 5018.],"
              },
              {
                "kind": "output",
                "text": "       [4796., 5162.],"
              },
              {
                "kind": "output",
                "text": "       [4928., 5306.]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "A slower but equivalent way of computing the same..."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "d = we.zeros((5,2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "for i in range(5):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "for j in range(2):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "for k in range(3):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "for n in range(4):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "d[i,j] += a[k,n,i] * b[n,k,j]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c == d"
              },
              {
                "kind": "output",
                "text": "array([[ True,  True],"
              },
              {
                "kind": "output",
                "text": "       [ True,  True],"
              },
              {
                "kind": "output",
                "text": "       [ True,  True],"
              },
              {
                "kind": "output",
                "text": "       [ True,  True],"
              },
              {
                "kind": "output",
                "text": "       [ True,  True]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "An extended example taking advantage of the overloading of + and \u0000*:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array(range(1, 9))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a.shape = (2, 2, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "A = we.array(('a', 'b', 'c', 'd'), dtype=object)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "A.shape = (2, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a; A"
              },
              {
                "kind": "output",
                "text": "array([[[1, 2],"
              },
              {
                "kind": "output",
                "text": "        [3, 4]],"
              },
              {
                "kind": "output",
                "text": "       [[5, 6],"
              },
              {
                "kind": "output",
                "text": "        [7, 8]]])"
              },
              {
                "kind": "output",
                "text": "array([['a', 'b'],"
              },
              {
                "kind": "output",
                "text": "       ['c', 'd']], dtype=object)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.tensordot(a, A) # third argument default is 2 for double-contraction"
              },
              {
                "kind": "output",
                "text": "array(['abbcccdddd', 'aaaaabbbbbbcccccccdddddddd'], dtype=object)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.tensordot(a, A, 1)"
              },
              {
                "kind": "output",
                "text": "array([[['acc', 'bdd'],"
              },
              {
                "kind": "output",
                "text": "        ['aaacccc', 'bbbdddd']],"
              },
              {
                "kind": "output",
                "text": "       [['aaaaacccccc', 'bbbbbdddddd'],"
              },
              {
                "kind": "output",
                "text": "        ['aaaaaaacccccccc', 'bbbbbbbdddddddd']]], dtype=object)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.tensordot(a, A, 0) # tensor product (result too long to incl.)"
              },
              {
                "kind": "output",
                "text": "array([[[[['a', 'b'],"
              },
              {
                "kind": "output",
                "text": "          ['c', 'd']],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": ""
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.tensordot(a, A, (0, 1))"
              },
              {
                "kind": "output",
                "text": "array([[['abbbbb', 'cddddd'],"
              },
              {
                "kind": "output",
                "text": "        ['aabbbbbb', 'ccdddddd']],"
              },
              {
                "kind": "output",
                "text": "       [['aaabbbbbbb', 'cccddddddd'],"
              },
              {
                "kind": "output",
                "text": "        ['aaaabbbbbbbb', 'ccccdddddddd']]], dtype=object)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.tensordot(a, A, (2, 1))"
              },
              {
                "kind": "output",
                "text": "array([[['abb', 'cdd'],"
              },
              {
                "kind": "output",
                "text": "        ['aaabbbb', 'cccdddd']],"
              },
              {
                "kind": "output",
                "text": "       [['aaaaabbbbbb', 'cccccdddddd'],"
              },
              {
                "kind": "output",
                "text": "        ['aaaaaaabbbbbbbb', 'cccccccdddddddd']]], dtype=object)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.tensordot(a, A, ((0, 1), (0, 1)))"
              },
              {
                "kind": "output",
                "text": "array(['abbbcccccddddddd', 'aabbbbccccccdddddddd'], dtype=object)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.tensordot(a, A, ((2, 1), (1, 0)))"
              },
              {
                "kind": "output",
                "text": "array(['acccbbdddd', 'aaaaacccccccbbbbbbdddddddd'], dtype=object)"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
