            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The natural logarithm "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/log",
                "kind": "link",
                "target": "log",
                "text": "log"
              },
              {
                "kind": "text",
                "text": " is the inverse of the exponential function,\nso that "
              },
              {
                "kind": "code",
                "text": "log(exp(x)) = x"
              },
              {
                "kind": "text",
                "text": ". The natural logarithm is logarithm in base\n"
              },
              {
                "kind": "code",
                "text": "e"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
