      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Create a 4 by 4 array."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.arange(16).reshape(4, 4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[ 0,  1,  2,  3],"
              },
              {
                "kind": "output",
                "text": "       [ 4,  5,  6,  7],"
              },
              {
                "kind": "output",
                "text": "       [ 8,  9, 10, 11],"
              },
              {
                "kind": "output",
                "text": "       [12, 13, 14, 15]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Get the indices of the diagonal elements."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "di = fnp.diag_indices_from(a)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "di"
              },
              {
                "kind": "output",
                "text": "(array([0, 1, 2, 3]), array([0, 1, 2, 3]))"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[di]"
              },
              {
                "kind": "output",
                "text": "array([ 0,  5, 10, 15])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "This is simply syntactic sugar for diag_indices."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.diag_indices(a.shape[0])"
              },
              {
                "kind": "output",
                "text": "(array([0, 1, 2, 3]), array([0, 1, 2, 3]))"
              }
            ],
            "type": "doctest_block"
          }
        ],
