      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Raises a TypeError if the "
              },
              {
                "kind": "code",
                "text": "casting"
              },
              {
                "kind": "text",
                "text": " rule is violated, and if\n"
              },
