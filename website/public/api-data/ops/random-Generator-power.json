  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draws samples in [0, 1] from a power distribution with positive exponent a - 1."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Also known as the power function distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Parameter of the distribution. Must be non-negative."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Parameter of the distribution. Must be non-negative."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is a scalar.  Otherwise,\n"
                      },
                      {
                        "kind": "code",
                        "text": "flops.array(a).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  If size is "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " (default),\na single value is returned if "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is a scalar.  Otherwise,\n"
                  },
                  {
                    "kind": "code",
                    "text": "flops.array(a).size"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn."
                  }
                ],
                "name": "size",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Drawn samples from the parameterized power distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Drawn samples from the parameterized power distribution."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If a <= 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ValueError",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If a <= 0."
                  }
                ],
                "name": "",
                "type": "field_list"
              }
            ],
            "title": "Raises",
            "type": "field_list"
          }
        ],
        "title": "Raises"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density function is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "P(x; a) = ax^{a-1}, 0 \\le x \\le 1, a>0."
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The power function distribution is just the inverse of the Pareto\ndistribution. It may also be seen as a special case of the Beta\ndistribution."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "It is used, for example, in modeling the over-reporting of insurance\nclaims."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nChristian Kleiber, Samuel Kotz, \"Statistical size distributions\nin economics and actuarial sciences\", Wiley, 2003.",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nHeckert, N. A. and Filliben, James J. \"NIST Handbook 148:\nDataplot Reference Manual, Volume 2: Let Subcommands and Library\nFunctions\", National Institute of Standards and Technology\nHandbook Series, June 2003.\nhttps://www.itl.nist.gov/div898/software/dataplot/refman2/auxillar/powpdf.pdf",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the distribution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = 5. # shape"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "samples = 1000"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = rng.power(a, samples)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Display the histogram of the samples, along with\nthe probability density function:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "count, bins, _ = plt.hist(s, bins=30)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = flops.linspace(0, 1, 100)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = a*x**(a-1.)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "normed_y = samples*flops.diff(bins)[0]*y"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(x, normed_y)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compare the power function distribution to the inverse of the Pareto."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from scipy import stats  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rvs = rng.power(5, 1000000)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rvsp = rng.pareto(5, 1000000)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "xx = flops.linspace(0,1,100)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "powpdf = stats.powerlaw.pdf(xx,5)  # doctest: +SKIP"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.figure()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.hist(rvs, bins=50, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(xx,powpdf,'r-')  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.title('power(5)')"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.figure()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.hist(1./(1.+rvsp), bins=50, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(xx,powpdf,'r-')  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.title('inverse of 1 + Generator.pareto(5)')"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.figure()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.hist(1./(1.+rvsp), bins=50, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(xx,powpdf,'r-')  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.title('inverse of stats.pareto(5)')"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
