  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from an exponential distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Its probability density function is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "f(x; \\frac{1}{\\beta}) = \\frac{1}{\\beta} \\exp(-\\frac{x}{\\beta}),"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "for "
              },
              {
                "kind": "code",
                "text": "x > 0"
              },
              {
                "kind": "text",
                "text": " and 0 elsewhere. "
              },
              {
                "kind": "math",
                "latex": "\\beta"
              },
              {
                "kind": "text",
                "text": " is the scale parameter,\nwhich is the inverse of the rate parameter "
              },
              {
                "kind": "math",
                "latex": "\\lambda = 1/\\beta"
              },
              {
                "kind": "text",
                "text": ".\nThe rate parameter is an alternative, widely used parameterization\nof the exponential distribution "
              },
              {
                "kind": "text",
                "text": "[3]_"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The exponential distribution is a continuous analogue of the\ngeometric distribution.  It describes many common situations, such as\nthe size of raindrops measured over many rainstorms "
              },
              {
                "kind": "text",
                "text": "[1]_"
              },
              {
                "kind": "text",
                "text": ", or the time\nbetween page requests to Wikipedia "
              },
              {
                "kind": "text",
                "text": "[2]_"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "New code should use the "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.exponential.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator.exponential",
                    "text": "exponential"
                  },
                  {
                    "kind": "text",
                    "text": "\nmethod of a "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator",
                    "text": "Generator"
                  },
                  {
                    "kind": "text",
                    "text": " instance instead;\nplease see the "
                  },
                  {
                    "display_text": "random-quick-start",
                    "explicit_title": false,
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "random-quick-start",
                    "role": "ref",
                    "suppress_link": false,
                    "target": "random-quick-start",
                    "unresolved": false
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "note",
            "options": [],
            "raw_source": ".. note::\n    New code should use the `~fnp.random.Generator.exponential`\n    method of a `~fnp.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
            "supported": true,
            "type": "directive_block"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The scale parameter, "
                      },
                      {
                        "kind": "math",
                        "latex": "\\beta = 1/\\lambda"
                      },
                      {
                        "kind": "text",
                        "text": ". Must be\nnon-negative."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The scale parameter, "
                  },
                  {
                    "kind": "math",
                    "latex": "\\beta = 1/\\lambda"
                  },
                  {
                    "kind": "text",
                    "text": ". Must be\nnon-negative."
                  }
                ],
                "name": "scale",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "scale"
                      },
                      {
                        "kind": "text",
                        "text": " is a scalar.  Otherwise,\n"
                      },
                      {
                        "kind": "code",
                        "text": "fnp.array(scale).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
