            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "When only "
                  },
                  {
                    "kind": "code",
                    "text": "condition"
                  },
                  {
                    "kind": "text",
                    "text": " is provided, this function is a shorthand for\n"
                  },
                  {
                    "kind": "code",
                    "text": "fnp.asarray(condition).nonzero()"
                  },
                  {
                    "kind": "text",
                    "text": ". Using "
