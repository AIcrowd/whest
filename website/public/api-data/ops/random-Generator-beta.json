  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from a Beta distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The Beta distribution is a special case of the Dirichlet distribution,\nand is related to the Gamma distribution. It has the probability\ndistribution function"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "f(x; a,b) = \\frac{1}{B(\\alpha, \\beta)} x^{\\alpha - 1} (1 - x)^{\\beta - 1},"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where the normalization, B, is the beta function,"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "B(\\alpha, \\beta) = \\int_0^1 t^{\\alpha - 1} (1 - t)^{\\beta - 1} dt."
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "It is often seen in Bayesian inference and order statistics."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Alpha, positive (>0)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Alpha, positive (>0)."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Beta, positive (>0)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Beta, positive (>0)."
                  }
                ],
                "name": "b",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "b"
                      },
                      {
                        "kind": "text",
                        "text": " are both scalars.\nOtherwise, "
                      },
                      {
                        "kind": "code",
                        "text": "flops.broadcast(a, b).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  If size is "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " (default),\na single value is returned if "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "b"
                  },
                  {
                    "kind": "text",
                    "text": " are both scalars.\nOtherwise, "
                  },
                  {
                    "kind": "code",
                    "text": "flops.broadcast(a, b).size"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn."
                  }
                ],
                "name": "size",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Drawn samples from the parameterized beta distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Drawn samples from the parameterized beta distribution."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nWikipedia, \"Beta distribution\",\nhttps://en.wikipedia.org/wiki/Beta_distribution",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The beta distribution has mean a/(a+b). If "
              },
              {
                "kind": "code",
                "text": "a == b"
              },
              {
                "kind": "text",
                "text": " and both\nare > 1, the distribution is symmetric with mean 0.5."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a, b, size = 2.0, 2.0, 10000"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "sample = rng.beta(a=a, b=b, size=size)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.mean(sample)"
              },
              {
                "kind": "output",
                "text": "0.5047328775385895  # may vary"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Otherwise the distribution is skewed left or right according to\nwhether "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " or "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " is greater. The distribution is mirror\nsymmetric. See for example:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a, b, size = 2, 7, 10000"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "sample_left = rng.beta(a=a, b=b, size=size)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "sample_right = rng.beta(a=b, b=a, size=size)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "m_left, m_right = flops.mean(sample_left), flops.mean(sample_right)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(m_left, m_right)"
              },
              {
                "kind": "output",
                "text": "0.2238596793678923 0.7774613834041182  # may vary"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(m_left - a/(a+b))"
              },
              {
                "kind": "output",
                "text": "0.001637457145670096  # may vary"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(m_right - b/(a+b))"
              },
              {
                "kind": "output",
                "text": "-0.0003163943736596009  # may vary"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Display the histogram of the two samples:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.hist([sample_left, sample_right],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "50, density=True, histtype='bar')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
