            "inline": [
              {
                "kind": "text",
                "text": "Find the unique elements of an array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the sorted unique elements of an array. There are three optional\noutputs in addition to the unique elements:"
              }
            ],
            "type": "paragraph"
          },
          {
            "items": [
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "the indices of the input array that give the unique values"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "the indices of the unique array that reconstruct the input array"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "the number of times each unique value comes up in the input array"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              }
            ],
            "ordered": false,
            "type": "list"
          }
        ],
        "title": "Extended Summary"
