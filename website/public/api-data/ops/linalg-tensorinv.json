  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the 'inverse' of an N-dimensional array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The result is an inverse for "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " relative to the tensordot operation\n"
              },
              {
                "kind": "code",
                "text": "tensordot(a, b, ind)"
              },
              {
                "kind": "text",
                "text": ", i. e., up to floating-point accuracy,\n"
              },
              {
                "kind": "code",
                "text": "tensordot(tensorinv(a), a, ind)"
              },
              {
                "kind": "text",
                "text": " is the \"identity\" tensor for the\ntensordot operation."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Tensor to 'invert'. Its shape must be 'square', i. e.,\n"
                      },
                      {
                        "kind": "code",
                        "text": "prod(a.shape[:ind]) == prod(a.shape[ind:])"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Tensor to 'invert'. Its shape must be 'square', i. e.,\n"
                  },
                  {
                    "kind": "code",
                    "text": "prod(a.shape[:ind]) == prod(a.shape[ind:])"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Number of first indices that are involved in the inverse sum.\nMust be a positive integer, default is 2."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Number of first indices that are involved in the inverse sum.\nMust be a positive integer, default is 2."
                  }
