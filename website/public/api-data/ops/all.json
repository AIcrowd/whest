              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the input array."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If the default value is passed, then "
                      },
                      {
                        "kind": "code",
                        "text": "keepdims"
                      },
                      {
                        "kind": "text",
                        "text": " will not be\npassed through to the "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/all",
                        "kind": "link",
                        "target": "all",
                        "text": "all"
                      },
                      {
                        "kind": "text",
                        "text": " method of sub-classes of\n"
                      },
                      {
                        "kind": "code",
                        "text": "ndarray"
                      },
                      {
                        "kind": "text",
                        "text": ", however any non-default value will be.  If the\nsub-class' method does not implement "
                      },
                      {
                        "kind": "code",
                        "text": "keepdims"
                      },
                      {
                        "kind": "text",
                        "text": " any\nexceptions will be raised."
                      }
