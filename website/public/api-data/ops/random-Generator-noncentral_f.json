                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Drawn samples from the parameterized noncentral Fisher distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Drawn samples from the parameterized noncentral Fisher distribution."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
