  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the noncentral F distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from an F distribution with specified parameters,\n"
              },
              {
                "kind": "code",
                "text": "dfnum"
              },
              {
                "kind": "text",
                "text": " (degrees of freedom in numerator) and "
              },
              {
                "kind": "code",
                "text": "dfden"
              },
              {
                "kind": "text",
                "text": " (degrees of\nfreedom in denominator), where both parameters > 1.\n"
              },
              {
                "kind": "code",
                "text": "nonc"
              },
              {
                "kind": "text",
                "text": " is the non-centrality parameter."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Numerator degrees of freedom, must be > 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Numerator degrees of freedom, must be > 0."
                  }
                ],
                "name": "dfnum",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Denominator degrees of freedom, must be > 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Denominator degrees of freedom, must be > 0."
                  }
                ],
                "name": "dfden",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Non-centrality parameter, the sum of the squares of the numerator\nmeans, must be >= 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Non-centrality parameter, the sum of the squares of the numerator\nmeans, must be >= 0."
                  }
                ],
                "name": "nonc",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "dfnum"
                      },
                      {
                        "kind": "text",
                        "text": ", "
                      },
                      {
                        "kind": "code",
                        "text": "dfden"
                      },
                      {
                        "kind": "text",
                        "text": ", and "
                      },
                      {
                        "kind": "code",
                        "text": "nonc"
                      },
                      {
                        "kind": "text",
                        "text": "\nare all scalars.  Otherwise, "
                      },
                      {
                        "kind": "code",
                        "text": "flops.broadcast(dfnum, dfden, nonc).size"
                      },
                      {
                        "kind": "text",
                        "text": "\nsamples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  If size is "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " (default),\na single value is returned if "
                  },
                  {
                    "kind": "code",
                    "text": "dfnum"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "dfden"
                  },
                  {
                    "kind": "text",
                    "text": ", and "
                  },
                  {
                    "kind": "code",
