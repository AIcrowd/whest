                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "prob1 = we.log(1e-50)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "prob2 = we.log(2.5e-50)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "prob12 = we.logaddexp(prob1, prob2)"
              },
