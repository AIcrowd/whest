            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.eye(4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fft.ifftn(fnp.fft.fftn(a, axes=(0,)), axes=(1,))"
              },
              {
                "kind": "output",
                "text": "array([[1.+0.j,  0.+0.j,  0.+0.j,  0.+0.j], # may vary"
              },
              {
                "kind": "output",
                "text": "       [0.+0.j,  1.+0.j,  0.+0.j,  0.+0.j],"
              },
              {
                "kind": "output",
                "text": "       [0.+0.j,  0.+0.j,  1.+0.j,  0.+0.j],"
              },
              {
                "kind": "output",
                "text": "       [0.+0.j,  0.+0.j,  0.+0.j,  1.+0.j]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Create and plot an image with band-limited frequency content:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "n = fnp.zeros((200,200), dtype=complex)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "n[60:80, 20:40] = fnp.exp(1j*fnp.random.uniform(0, 2*fnp.pi, (20, 20)))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "im = fnp.fft.ifftn(n).real"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.imshow(im)"
              },
              {
                "kind": "output",
                "text": "<matplotlib.image.AxesImage object at 0x...>"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
