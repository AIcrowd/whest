      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "Discrete, linear convolution of two one-dimensional sequences.",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "Discrete, linear convolution of two one-dimensional sequences."
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/convolve",
                "label": "we.convolve",
                "original_target": "convolve",
                "role": "",
                "target": "convolve",
                "unresolved": false
              },
              {
                "description": "uses FFT which has superior performance on large arrays.",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "uses FFT which has superior performance on large arrays."
                  }
                ],
                "external_url": "https://docs.scipy.org/doc/scipy/reference/generated/scipy.signal.correlate.html",
                "href": "",
                "label": "scipy.signal.correlate",
                "original_target": "scipy.signal.correlate",
                "role": "",
                "target": "scipy.signal.correlate",
                "unresolved": false
              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The definition of correlation above is not unique and sometimes\ncorrelation may be defined differently. Another common definition is "
              },
              {
                "kind": "text",
                "text": "[1]_"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "c'_k = \\sum_n a_{n} \\cdot \\overline{v_{n+k}}"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "which is related to "
              },
              {
                "kind": "math",
                "latex": "c_k"
              },
              {
                "kind": "text",
                "text": " by "
              },
              {
                "kind": "math",
                "latex": "c'_k = c_{-k}"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/correlate",
                "kind": "link",
                "target": "correlate",
                "text": "we.correlate"
              },
              {
                "kind": "text",
                "text": " may perform slowly in large arrays (i.e. n = 1e5)\nbecause it does not use the FFT to compute the convolution; in that case,\n"
              },
              {
                "external_url": "https://docs.scipy.org/doc/scipy/reference/generated/scipy.signal.correlate.html",
                "href": "",
                "kind": "link",
                "target": "scipy.signal.correlate",
                "text": "scipy.signal.correlate"
              },
              {
                "kind": "text",
                "text": " might be preferable."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nWikipedia, \"Cross-correlation\",\nhttps://en.wikipedia.org/wiki/Cross-correlation",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.correlate([1, 2, 3], [0, 1, 0.5])"
              },
              {
                "kind": "output",
                "text": "array([3.5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.correlate([1, 2, 3], [0, 1, 0.5], \"same\")"
              },
              {
                "kind": "output",
                "text": "array([2. ,  3.5,  3. ])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.correlate([1, 2, 3], [0, 1, 0.5], \"full\")"
              },
              {
                "kind": "output",
                "text": "array([0.5,  2. ,  3.5,  3. ,  0. ])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Using complex sequences:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.correlate([1+1j, 2, 3-1j], [0, 1, 0.5j], 'full')"
              },
              {
                "kind": "output",
                "text": "array([ 0.5-0.5j,  1.0+0.j ,  1.5-1.5j,  3.0-1.j ,  0.0+0.j ])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that you get the time reversed, complex conjugated result\n("
              },
              {
                "kind": "math",
                "latex": "\\overline{c_{-k}}"
              },
              {
                "kind": "text",
                "text": ") when the two input sequences a and v change\nplaces:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.correlate([0, 1, 0.5j], [1+1j, 2, 3-1j], 'full')"
              },
              {
                "kind": "output",
                "text": "array([ 0.0+0.j ,  3.0+1.j ,  1.5+1.5j,  1.0+0.j ,  0.5+0.5j])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
