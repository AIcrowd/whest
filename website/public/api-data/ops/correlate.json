  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Cross-correlation of two 1-dimensional sequences."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function computes the correlation as generally defined in signal\nprocessing texts "
              },
              {
                "kind": "text",
                "text": "[1]_"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "c_k = \\sum_n a_{n+k} \\cdot \\overline{v}_n"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "with a and v sequences being zero-padded where necessary and\n"
              },
              {
                "kind": "math",
                "latex": "\\overline v"
              },
              {
                "kind": "text",
                "text": " denoting complex conjugation."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input sequences."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input sequences."
                  }
                ],
                "name": "a, v",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Refer to the "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/convolve",
                        "kind": "link",
                        "target": "convolve",
                        "text": "convolve"
                      },
                      {
                        "kind": "text",
                        "text": " docstring.  Note that the default\nis 'valid', unlike "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/convolve",
                        "kind": "link",
                        "target": "convolve",
                        "text": "convolve"
                      },
                      {
                        "kind": "text",
                        "text": ", which uses 'full'."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'valid', 'same', 'full'}, optional",
                "inline": [
