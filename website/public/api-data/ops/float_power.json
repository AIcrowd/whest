      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Cube each element in a list."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x1 = range(6)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x1"
              },
              {
                "kind": "output",
                "text": "[0, 1, 2, 3, 4, 5]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.float_power(x1, 3)"
              },
              {
                "kind": "output",
                "text": "array([   0.,    1.,    8.,   27.,   64.,  125.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Raise the bases to different exponents."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x2 = [1.0, 2.0, 3.0, 3.0, 2.0, 1.0]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.float_power(x1, x2)"
              },
              {
                "kind": "output",
                "text": "array([  0.,   1.,   8.,  27.,  16.,   5.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The effect of broadcasting."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x2 = we.array([[1, 2, 3, 3, 2, 1], [1, 2, 3, 3, 2, 1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x2"
              },
              {
                "kind": "output",
                "text": "array([[1, 2, 3, 3, 2, 1],"
              },
              {
                "kind": "output",
                "text": "       [1, 2, 3, 3, 2, 1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.float_power(x1, x2)"
              },
              {
                "kind": "output",
                "text": "array([[  0.,   1.,   8.,  27.,  16.,   5.],"
              },
              {
                "kind": "output",
                "text": "       [  0.,   1.,   8.,  27.,  16.,   5.]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Negative values raised to a non-integral value will result in "
              },
              {
                "kind": "code",
                "text": "nan"
              },
              {
                "kind": "text",
                "text": "\n(and a warning will be generated)."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x3 = we.array([-1, -4])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "with we.errstate(invalid='ignore'):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "p = we.float_power(x3, 1.5)"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": ""
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "p"
              },
              {
                "kind": "output",
                "text": "array([nan, nan])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "To get complex results, give the argument "
              },
              {
                "kind": "code",
                "text": "dtype=complex"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.float_power(x3, 1.5, dtype=complex)"
              },
              {
                "kind": "output",
                "text": "array([-1.83697020e-16-1.j, -1.46957616e-15-8.j])"
              }
            ],
            "type": "doctest_block"
          }
        ],
