  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "First array elements raised to powers from second array, element-wise."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Raise each base in "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " to the positionally-corresponding power in "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": ".\n"
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " must be broadcastable to the same shape. This differs from\nthe power function in that integers, float16, and float32  are promoted to\nfloats with a minimum precision of float64 so that the result is always\ninexact.  The intent is that the function will return a usable result for\nnegative powers and seldom overflow for positive powers."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Negative values raised to a non-integral value will return "
              },
              {
                "kind": "code",
                "text": "nan"
              },
              {
                "kind": "text",
                "text": ".\nTo get complex results, cast the input to complex, or specify the\n"
              },
              {
                "kind": "code",
                "text": "dtype"
              },
              {
                "kind": "text",
                "text": " to be "
              },
              {
                "kind": "code",
                "text": "complex"
              },
              {
                "kind": "text",
                "text": " (see the example below)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The bases."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The bases."
                  }
                ],
                "name": "x1",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The exponents.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "x1.shape != x2.shape"
                      },
                      {
                        "kind": "text",
                        "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The exponents.\nIf "
                  },
                  {
                    "kind": "code",
                    "text": "x1.shape != x2.shape"
                  },
                  {
                    "kind": "text",
                    "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                  }
                ],
                "name": "x2",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, None, or tuple of ndarray and None, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
                  }
                ],
                "name": "out",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " array will be set to the ufunc result.\nElsewhere, the "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " array will retain its original value.\nNote that if an uninitialized "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " array is created via the default\n"
                      },
                      {
                        "kind": "code",
                        "text": "out=None"
                      },
                      {
                        "kind": "text",
                        "text": ", locations within it where the condition is False will\nremain uninitialized."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
