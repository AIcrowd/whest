      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Convert a list into an array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = [1, 2]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.asarray(a)"
              },
              {
                "kind": "output",
                "text": "array([1, 2])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Existing arrays are not copied:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.asarray(a) is a"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "dtype"
              },
              {
                "kind": "text",
                "text": " is set, array is copied only if dtype does not match:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([1, 2], dtype=fnp.float32)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.shares_memory(fnp.asarray(a, dtype=fnp.float32), a)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.shares_memory(fnp.asarray(a, dtype=fnp.float64), a)"
              },
              {
                "kind": "output",
                "text": "False"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Contrary to "
              },
              {
                "kind": "code",
                "text": "asanyarray"
              },
              {
                "kind": "text",
                "text": ", ndarray subclasses are not passed through:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "issubclass(fnp.recarray, fnp.ndarray)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([(1., 2), (3., 4)], dtype='f4,i4').view(fnp.recarray)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.asarray(a) is a"
              },
              {
                "kind": "output",
                "text": "False"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.asanyarray(a) is a"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
