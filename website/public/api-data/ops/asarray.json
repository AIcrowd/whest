                      {
                        "kind": "text",
                        "text": "Array interpretation of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ".  No copy is performed if the input\nis already an ndarray with matching dtype and order.  If "
