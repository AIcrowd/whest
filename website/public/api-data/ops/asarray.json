                "name": "device",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "True"
                      },
                      {
                        "kind": "text",
                        "text": ", then the object is copied. If "
                      },
                      {
