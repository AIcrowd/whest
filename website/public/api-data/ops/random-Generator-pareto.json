        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density for the Pareto II distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "p(x) = \\frac{a}{{x+1}^{a+1}} , x \\ge 0"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where "
              },
              {
                "kind": "math",
                "latex": "a > 0"
              },
              {
                "kind": "text",
                "text": " is the shape."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The Pareto II distribution is a shifted and scaled version of the\nPareto I distribution, which can be found in "
              },
              {
                "external_url": "https://docs.scipy.org/doc/scipy/reference/generated/scipy.stats.pareto.html",
                "href": "",
                "kind": "link",
                "target": "stats.pareto",
                "text": "scipy.stats.pareto"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nFrancis Hunt and Paul Johnson, On the Pareto Distribution of\nSourceforge projects.",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nPareto, V. (1896). Course of Political Economy. Lausanne.",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "3\n\nReiss, R.D., Thomas, M.(2001), Statistical Analysis of Extreme\nValues, Birkhauser Verlag, Basel, pp 23-30.",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "4\n\nWikipedia, \"Pareto distribution\",\nhttps://en.wikipedia.org/wiki/Pareto_distribution",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the distribution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = 3."
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = rng.pareto(a, 10000)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Display the histogram of the samples, along with the probability\ndensity function:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = flops.linspace(0, 3, 50)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "pdf = a / (x+1)**(a+1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.hist(s, bins=x, density=True, label='histogram')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(x, pdf, linewidth=2, color='r', label='pdf')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.xlim(x.min(), x.max())"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.legend()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
