                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "str",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A printable representation of the einsum path."
                  }
                ],
                "name": "string_repr",
                "type": "field_list"
              }
            ],
