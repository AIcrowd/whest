          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The resulting path indicates which terms of the input contraction should be\ncontracted first, the result of this contraction is then appended to the\nend of the contraction list. This list can then be iterated over until all\nintermediate contractions are complete."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "We can begin with a chain dot example. In this case, it is optimal to\ncontract the "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "c"
              },
              {
                "kind": "text",
                "text": " tensors first as represented by the first\nelement of the path "
              },
              {
                "kind": "code",
                "text": "(1, 2)"
              },
              {
                "kind": "text",
                "text": ". The resulting tensor is added to the end\nof the contraction and the remaining contraction "
              },
              {
                "kind": "code",
                "text": "(0, 1)"
              },
              {
                "kind": "text",
                "text": " is then\ncompleted."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.random.seed(123)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.random.rand(2, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.random.rand(2, 5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c = we.random.rand(5, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "path_info = we.einsum_path('ij,jk,kl->il', a, b, c, optimize='greedy')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(path_info[0])"
              },
              {
                "kind": "output",
                "text": "['einsum_path', (1, 2), (0, 1)]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(path_info[1])"
              },
              {
                "kind": "output",
                "text": "  Complete contraction:  ij,jk,kl->il # may vary"
              },
              {
                "kind": "output",
                "text": "         Naive scaling:  4"
              },
              {
                "kind": "output",
                "text": "     Optimized scaling:  3"
              },
              {
                "kind": "output",
                "text": "      Naive FLOP count:  1.600e+02"
              },
              {
                "kind": "output",
                "text": "  Optimized FLOP count:  5.600e+01"
              },
              {
                "kind": "output",
                "text": "   Theoretical speedup:  2.857"
              },
              {
                "kind": "output",
                "text": "  Largest intermediate:  4.000e+00 elements"
              },
              {
                "kind": "output",
                "text": "-------------------------------------------------------------------------"
              },
              {
                "kind": "output",
                "text": "scaling                  current                                remaining"
              },
              {
                "kind": "output",
                "text": "-------------------------------------------------------------------------"
              },
              {
                "kind": "output",
                "text": "   3                   kl,jk->jl                                ij,jl->il"
              },
              {
                "kind": "output",
                "text": "   3                   jl,ij->il                                   il->il"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "A more complex index transformation example."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "I = we.random.rand(10, 10, 10, 10)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "C = we.random.rand(10, 10)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "path_info = we.einsum_path('ea,fb,abcd,gc,hd->efgh', C, C, I, C, C,"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "optimize='greedy')"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(path_info[0])"
              },
              {
                "kind": "output",
                "text": "['einsum_path', (0, 2), (0, 3), (0, 2), (0, 1)]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(path_info[1])"
              },
              {
                "kind": "output",
                "text": "  Complete contraction:  ea,fb,abcd,gc,hd->efgh # may vary"
              },
              {
                "kind": "output",
                "text": "         Naive scaling:  8"
              },
              {
                "kind": "output",
                "text": "     Optimized scaling:  5"
              },
              {
                "kind": "output",
                "text": "      Naive FLOP count:  8.000e+08"
              },
              {
                "kind": "output",
                "text": "  Optimized FLOP count:  8.000e+05"
              },
              {
                "kind": "output",
                "text": "   Theoretical speedup:  1000.000"
              },
              {
                "kind": "output",
                "text": "  Largest intermediate:  1.000e+04 elements"
              },
              {
                "kind": "output",
                "text": "--------------------------------------------------------------------------"
              },
              {
                "kind": "output",
                "text": "scaling                  current                                remaining"
              },
              {
                "kind": "output",
                "text": "--------------------------------------------------------------------------"
              },
              {
                "kind": "output",
                "text": "   5               abcd,ea->bcde                      fb,gc,hd,bcde->efgh"
              },
              {
                "kind": "output",
                "text": "   5               bcde,fb->cdef                         gc,hd,cdef->efgh"
              },
              {
                "kind": "output",
                "text": "   5               cdef,gc->defg                            hd,defg->efgh"
              },
              {
                "kind": "output",
                "text": "   5               defg,hd->efgh                               efgh->efgh"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
