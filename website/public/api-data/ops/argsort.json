        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "One dimensional array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([3, 1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argsort(x)"
              },
              {
                "kind": "output",
                "text": "array([1, 2, 0])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Two-dimensional array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([[0, 3], [2, 2]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([[0, 3],"
              },
              {
                "kind": "output",
                "text": "       [2, 2]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind = we.argsort(x, axis=0)  # sorts along first axis (down)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind"
              },
              {
                "kind": "output",
                "text": "array([[0, 1],"
              },
              {
                "kind": "output",
                "text": "       [1, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.take_along_axis(x, ind, axis=0)  # same as we.sort(x, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([[0, 2],"
              },
              {
                "kind": "output",
                "text": "       [2, 3]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind = we.argsort(x, axis=1)  # sorts along last axis (across)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind"
              },
              {
                "kind": "output",
                "text": "array([[0, 1],"
              },
              {
                "kind": "output",
                "text": "       [0, 1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.take_along_axis(x, ind, axis=1)  # same as we.sort(x, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([[0, 3],"
              },
              {
                "kind": "output",
                "text": "       [2, 2]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Indices of the sorted elements of a N-dimensional array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind = we.unravel_index(we.argsort(x, axis=None), x.shape)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind"
              },
              {
                "kind": "output",
                "text": "(array([0, 1, 1, 0]), array([0, 0, 1, 1]))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x[ind]  # same as we.sort(x, axis=None)"
              },
              {
                "kind": "output",
                "text": "array([0, 2, 2, 3])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Sorting with keys:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([(1, 0), (0, 1)], dtype=[('x', '<i4'), ('y', '<i4')])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([(1, 0), (0, 1)],"
              },
              {
                "kind": "output",
                "text": "      dtype=[('x', '<i4'), ('y', '<i4')])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argsort(x, order=('x','y'))"
              },
              {
                "kind": "output",
                "text": "array([1, 0])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argsort(x, order=('y','x'))"
              },
              {
                "kind": "output",
                "text": "array([0, 1])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
