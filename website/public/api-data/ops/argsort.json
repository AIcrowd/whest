                        "kind": "text",
                        "text": "\nalways yields the sorted "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ", irrespective of dimensionality."
                      }
                    ],
