                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " along the specified "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": ".\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is one-dimensional, "
                      },
                      {
                        "kind": "code",
                        "text": "a[index_array]"
                      },
                      {
                        "kind": "text",
                        "text": " yields a sorted "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ".\nMore generally, "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.take_along_axis(a, index_array, axis=axis).html",
                        "href": "",
                        "kind": "link",
                        "target": "take_along_axis(a, index_array, axis=axis)",
                        "text": "we.take_along_axis(a, index_array, axis=axis)"
                      },
