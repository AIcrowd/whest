    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the floor of the input, element-wise."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The floor of the scalar "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is the largest integer "
              },
              {
                "kind": "code",
                "text": "i"
              },
              {
                "kind": "text",
                "text": ", such that\n"
              },
              {
                "kind": "code",
                "text": "i <= x"
              },
              {
                "kind": "text",
                "text": ".  It is often denoted as "
              },
              {
                "kind": "math",
                "latex": "\\lfloor x \\rfloor"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
