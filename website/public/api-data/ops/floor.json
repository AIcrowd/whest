                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([-1.7, -1.5, -0.2, 0.2, 1.5, 1.7, 2.0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.floor(a)"
              },
              {
                "kind": "output",
                "text": "array([-2., -2., -1.,  0.,  1.,  1.,  2.])"
              }
