        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Some spreadsheet programs calculate the \"floor-towards-zero\", where\n"
              },
              {
                "kind": "code",
                "text": "floor(-2.5) == -2"
              },
              {
                "kind": "text",
                "text": ".  NumPy instead uses the definition of\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/floor",
                "kind": "link",
                "target": "floor",
                "text": "floor"
              },
              {
                "kind": "text",
                "text": " where "
              },
              {
                "kind": "code",
                "text": "floor(-2.5) == -3"
              },
              {
                "kind": "text",
                "text": ". The \"floor-towards-zero\"\nfunction is called "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/trunc",
                "kind": "link",
                "target": "trunc",
                "text": "fix"
              },
              {
                "kind": "text",
                "text": " in NumPy."
              }
            ],
            "type": "paragraph"
          }
        ],
