        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "For finite values, isclose uses the following equation to test whether\ntwo floating point values are equivalent.:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "absolute(a - b) <= (atol + rtol * absolute(b))",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Unlike the built-in "
              },
              {
                "kind": "code",
                "text": "math.isclose"
              },
              {
                "kind": "text",
                "text": ", the above equation is not symmetric\nin "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " -- it assumes "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " is the reference value -- so that\n"
              },
              {
                "kind": "code",
                "text": "isclose(a, b)"
              },
              {
                "kind": "text",
                "text": " might be different from "
              },
              {
                "kind": "code",
                "text": "isclose(b, a)"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The default value of "
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " is not appropriate when the reference value\n"
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " has magnitude smaller than one. For example, it is unlikely that\n"
              },
              {
                "kind": "code",
                "text": "a = 1e-9"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b = 2e-9"
              },
              {
                "kind": "text",
                "text": " should be considered \"close\", yet\n"
              },
              {
                "kind": "code",
                "text": "isclose(1e-9, 2e-9)"
              },
              {
                "kind": "text",
                "text": " is "
              },
              {
                "kind": "code",
                "text": "True"
              },
              {
                "kind": "text",
                "text": " with default settings. Be sure\nto select "
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " for the use case at hand, especially for defining the\nthreshold below which a non-zero value in "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " will be considered \"close\"\nto a very small or zero value in "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/isclose",
                "kind": "link",
                "target": "isclose",
                "text": "isclose"
              },
              {
                "kind": "text",
                "text": " is not defined for non-numeric data types.\n"
              },
              {
                "display_text": "bool",
                "explicit_title": false,
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.bool.html",
                "href": "",
                "kind": "role_reference",
                "original_target": "bool",
                "role": "class",
                "suppress_link": false,
                "target": "bool",
                "unresolved": false
              },
              {
                "kind": "text",
                "text": " is considered a numeric data-type for this purpose."
              }
            ],
            "type": "paragraph"
          }
        ],
