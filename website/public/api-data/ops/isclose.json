  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns a boolean array where two arrays are element-wise equal within a tolerance."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The tolerance values are positive, typically very small numbers.  The\nrelative difference ("
              },
              {
                "kind": "code",
                "text": "rtol"
              },
              {
                "kind": "text",
                "text": " * abs("
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": ")) and the absolute difference\n"
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " are added together to compare against the absolute difference\nbetween "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [
              {
                "kind": "text",
                "text": "The default "
              },
              {
                "kind": "code",
                "text": "atol"
              },
              {
                "kind": "text",
                "text": " is not appropriate for comparing numbers"
              }
            ],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "with magnitudes much smaller than one (see Notes)."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "warning",
            "options": [],
            "raw_source": ".. warning:: The default `atol` is not appropriate for comparing numbers\n             with magnitudes much smaller than one (see Notes).",
            "supported": true,
            "type": "directive_block"
          }
        ],
        "title": "Extended Summary"
      },
