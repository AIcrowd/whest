                        "kind": "text",
                        "text": " are equal within the\ngiven tolerance. If both "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "b"
                      },
                      {
                        "kind": "text",
                        "text": " are scalars, returns a single\nboolean value."
                      }
                    ],
