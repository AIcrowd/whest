      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.trace(fnp.eye(3))"
              },
              {
                "kind": "output",
                "text": "3.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.arange(8).reshape((2, 2, 2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.trace(a)"
              },
              {
                "kind": "output",
                "text": "array([3, 11])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Trace is computed with the last two axes as the 2-d sub-arrays.\nThis behavior differs from "
              },
              {
                "display_text": "fnp.trace",
                "explicit_title": false,
                "external_url": "",
                "href": "/docs/api/ops/trace",
                "kind": "role_reference",
                "original_target": "fnp.trace",
                "role": "py:func",
                "suppress_link": false,
                "target": "trace",
                "unresolved": false
              },
              {
                "kind": "text",
                "text": " which uses the first two\naxes by default."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.arange(24).reshape((3, 2, 2, 2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.trace(a).shape"
              },
              {
                "kind": "output",
                "text": "(3, 2)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Traces adjacent to the main diagonal can be obtained by using the\n"
              },
              {
                "kind": "code",
                "text": "offset"
              },
              {
                "kind": "text",
                "text": " argument:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.arange(9).reshape((3, 3)); a"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2],"
              },
              {
                "kind": "output",
                "text": "       [3, 4, 5],"
              },
              {
                "kind": "output",
                "text": "       [6, 7, 8]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.trace(a, offset=1)  # First superdiagonal"
              },
              {
                "kind": "output",
                "text": "6"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.trace(a, offset=2)  # Second superdiagonal"
              },
              {
                "kind": "output",
                "text": "2"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.trace(a, offset=-1)  # First subdiagonal"
              },
              {
                "kind": "output",
                "text": "10"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.trace(a, offset=-2)  # Second subdiagonal"
              },
              {
                "kind": "output",
                "text": "6"
              }
            ],
            "type": "doctest_block"
          }
        ],
