      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "A = fnp.asmatrix('1 1; 1 1')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "B = fnp.asmatrix('2 2; 2 2')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "C = fnp.asmatrix('3 4; 5 6')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "D = fnp.asmatrix('7 8; 9 0')"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "All the following expressions construct the same block matrix:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.bmat([[A, B], [C, D]])"
              },
              {
                "kind": "output",
                "text": "matrix([[1, 1, 2, 2],"
              },
              {
                "kind": "output",
                "text": "        [1, 1, 2, 2],"
              },
              {
                "kind": "output",
                "text": "        [3, 4, 7, 8],"
              },
              {
                "kind": "output",
                "text": "        [5, 6, 9, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.bmat(fnp.r_[fnp.c_[A, B], fnp.c_[C, D]])"
              },
              {
                "kind": "output",
                "text": "matrix([[1, 1, 2, 2],"
              },
              {
                "kind": "output",
                "text": "        [1, 1, 2, 2],"
              },
              {
                "kind": "output",
                "text": "        [3, 4, 7, 8],"
              },
              {
                "kind": "output",
                "text": "        [5, 6, 9, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.bmat('A,B; C,D')"
              },
              {
                "kind": "output",
                "text": "matrix([[1, 1, 2, 2],"
              },
              {
                "kind": "output",
                "text": "        [1, 1, 2, 2],"
              },
              {
                "kind": "output",
                "text": "        [3, 4, 7, 8],"
              },
              {
                "kind": "output",
                "text": "        [5, 6, 9, 0]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
