    "summary": "Subtract arguments, element-wise.",
    "signature": "we.subtract(x1, x2, /, out=None, *, where=True, casting='same_kind', order='K', dtype=None, subok=True[, signature])"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Subtract arguments, element-wise."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x1, x2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The arrays to be subtracted from each other.\nIf ``x1.shape != x2.shape``, they must be broadcastable to a common\nshape (which becomes the shape of the output)."
              }
            ]
          },
          {
            "name": "out",
            "type": "ndarray, None, or tuple of ndarray and None, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
              }
            ]
          },
          {
            "name": "where",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the `out` array will be set to the ufunc result.\nElsewhere, the `out` array will retain its original value.\nNote that if an uninitialized `out` array is created via the default\n``out=None``, locations within it where the condition is False will\nremain uninitialized."
              }
            ]
          },
          {
            "name": "**kwargs",
            "type": "",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "For other keyword-only arguments, see the\n:ref:`ufunc docs <ufuncs.kwargs>`."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "y",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The difference of `x1` and `x2`, element-wise.\nThis is a scalar if both `x1` and `x2` are scalars."
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Equivalent to ``x1 - x2`` in terms of array broadcasting."
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.subtract(1.0, 4.0)\n-3.0"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x1 = np.arange(9.0).reshape((3, 3))\n>>> x2 = np.arange(3.0)\n>>> np.subtract(x1, x2)\narray([[ 0.,  0.,  0.],\n       [ 3.,  3.,  3.],\n       [ 6.,  6.,  6.]])"
          },
          {
            "type": "paragraph",
            "text": "The ``-`` operator can be used as a shorthand for ``np.subtract`` on\nndarrays."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x1 = np.arange(9.0).reshape((3, 3))\n>>> x2 = np.arange(3.0)\n>>> x1 - x2\narray([[0., 0., 0.],\n       [3., 3., 3.],\n       [6., 6., 6.]])"
          }
        ]
      }
    ]
  }
