        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return a copy of an array with the elements below the "
              },
              {
                "kind": "code",
                "text": "k"
              },
              {
                "kind": "text",
                "text": "-th diagonal\nzeroed. For arrays with "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/ndim",
                "kind": "link",
                "target": "ndim",
                "text": "ndim"
              },
              {
                "kind": "text",
                "text": " exceeding 2, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/triu",
                "kind": "link",
                "target": "triu",
                "text": "triu"
              },
              {
                "kind": "text",
                "text": " will apply to the\nfinal two axes."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Please refer to the documentation for "
              },
