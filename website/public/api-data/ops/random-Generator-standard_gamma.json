                "kind": "text",
                "text": "Draw samples from a standard Gamma distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from a Gamma distribution with specified parameters,\nshape (sometimes designated \"k\") and scale=1."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
