                      {
                        "kind": "text",
                        "text": "Parameter, must be non-negative."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Parameter, must be non-negative."
                  }
                ],
                "name": "shape",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
