            "text": "View inputs as arrays with at least two dimensions."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "arys1, arys2, ...",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "One or more array-like sequences.  Non-array inputs are converted\nto arrays.  Arrays that already have two or more dimensions are\npreserved."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "res, res2, ...",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array, or tuple of arrays, each with ``a.ndim >= 2``.\nCopies are avoided where possible, and views with two or more\ndimensions are returned."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.atleast_2d(3.0)\narray([[3.]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x = np.arange(3.0)\n>>> np.atleast_2d(x)\narray([[0., 1., 2.]])\n>>> np.atleast_2d(x).base is x\nTrue"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.atleast_2d(1, [1, 2], [[1, 2]])\n(array([[1]]), array([[1, 2]]), array([[1, 2]]))"
          }
