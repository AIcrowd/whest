            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([0, 1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.tile(a, 2)"
              },
              {
                "kind": "output",
                "text": "array([0, 1, 2, 0, 1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.tile(a, (2, 2))"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2, 0, 1, 2],"
              },
              {
                "kind": "output",
                "text": "       [0, 1, 2, 0, 1, 2]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.tile(a, (2, 1, 2))"
              },
              {
                "kind": "output",
                "text": "array([[[0, 1, 2, 0, 1, 2]],"
              },
              {
                "kind": "output",
                "text": "       [[0, 1, 2, 0, 1, 2]]])"
              }
            ],
