      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([1,2,3])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.cumprod(a) # intermediate results 1, 1*2"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "# total product 1*2*3 = 6"
              },
              {
                "kind": "output",
                "text": "array([1, 2, 6])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[1, 2, 3], [4, 5, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.cumprod(a, dtype=float) # specify type of output"
              },
              {
                "kind": "output",
                "text": "array([   1.,    2.,    6.,   24.,  120.,  720.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The cumulative product for each column (i.e., over the rows) of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.cumprod(a, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([[ 1,  2,  3],"
              },
              {
                "kind": "output",
                "text": "       [ 4, 10, 18]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The cumulative product for each row (i.e. over the columns) of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
