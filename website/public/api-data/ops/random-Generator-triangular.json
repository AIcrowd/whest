                        "kind": "text",
                        "text": "Drawn samples from the parameterized triangular distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
