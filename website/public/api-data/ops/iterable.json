        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "y",
            "type": "object",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input object."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "b",
            "type": "bool",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Return ``True`` if the object has an iterator method or is a\nsequence and ``False`` otherwise."
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "In most cases, the results of ``np.iterable(obj)`` are consistent with\n``isinstance(obj, collections.abc.Iterable)``. One notable exception is\nthe treatment of 0-dimensional arrays::"
          },
          {
            "type": "code",
            "language": "text",
            "code": "    >>> from collections.abc import Iterable\n    >>> a = np.array(1.0)  # 0-dimensional numpy array\n    >>> isinstance(a, Iterable)\n    True\n    >>> np.iterable(a)\n    False"
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.iterable([1, 2, 3])\nTrue\n>>> np.iterable(2)\nFalse"
          }
        ]
      }
    ]
  }
