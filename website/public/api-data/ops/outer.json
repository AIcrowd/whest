  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the outer product of two vectors."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given two vectors "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " of length "
              },
              {
                "kind": "code",
                "text": "M"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": ", respectively,\nthe outer product "
              },
              {
                "kind": "text",
                "text": "[1]_"
              },
              {
                "kind": "text",
                "text": " is:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "[[a_0*b_0  a_0*b_1 ... a_0*b_{N-1} ]\n [a_1*b_0    .\n [ ...          .\n [a_{M-1}*b_0            a_{M-1}*b_{N-1} ]]",
            "type": "literal_block"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "First input vector.  Input is flattened if\nnot already 1-dimensional."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(M,) array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "First input vector.  Input is flattened if\nnot already 1-dimensional."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Second input vector.  Input is flattened if\nnot already 1-dimensional."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(N,) array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Second input vector.  Input is flattened if\nnot already 1-dimensional."
                  }
                ],
                "name": "b",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A location where the result is stored"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(M, N) ndarray, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A location where the result is stored"
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "out[i, j] = a[i] * b[j]"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(M, N) ndarray",
                "inline": [
                  {
                    "kind": "code",
                    "text": "out[i, j] = a[i] * b[j]"
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
