      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The result of the modulo operation for negative dividend and divisors\nis bound by conventions. For "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/fmod",
                "kind": "link",
                "target": "fmod",
                "text": "fmod"
              },
              {
                "kind": "text",
                "text": ", the sign of result is the sign of\nthe dividend, while for "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/remainder",
                "kind": "link",
                "target": "remainder",
                "text": "remainder"
              },
              {
                "kind": "text",
                "text": " the sign of the result is the sign\nof the divisor. The "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/fmod",
                "kind": "link",
                "target": "fmod",
                "text": "fmod"
              },
              {
                "kind": "text",
                "text": " function is equivalent to the Matlab(TM)\n"
              },
              {
                "kind": "code",
                "text": "rem"
              },
              {
                "kind": "text",
                "text": " function."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fmod([-3, -2, -1, 1, 2, 3], 2)"
              },
              {
                "kind": "output",
                "text": "array([-1,  0, -1,  1,  0,  1])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.remainder([-3, -2, -1, 1, 2, 3], 2)"
              },
              {
                "kind": "output",
                "text": "array([1, 0, 1, 1, 0, 1])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fmod([5, 3], [2, 2.])"
              },
              {
                "kind": "output",
                "text": "array([ 1.,  1.])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.arange(-3, 3).reshape(3, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[-3, -2],"
              },
              {
                "kind": "output",
                "text": "       [-1,  0],"
              },
              {
                "kind": "output",
                "text": "       [ 1,  2]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fmod(a, [2,2])"
              },
              {
                "kind": "output",
                "text": "array([[-1,  0],"
              },
              {
                "kind": "output",
                "text": "       [-1,  0],"
              },
              {
                "kind": "output",
                "text": "       [ 1,  0]])"
              }
            ],
            "type": "doctest_block"
          }
