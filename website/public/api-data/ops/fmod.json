            "inline": [
              {
                "kind": "text",
                "text": "Returns the element-wise remainder of division."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This is the NumPy implementation of the C library function fmod, the\nremainder has the same sign as the dividend "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": ". It is equivalent to\nthe Matlab(TM) "
              },
              {
                "kind": "code",
                "text": "rem"
              },
              {
                "kind": "text",
                "text": " function and should not be confused with the\nPython modulus operator "
              },
              {
                "kind": "code",
                "text": "x1 % x2"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
