                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Dividend."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Dividend."
