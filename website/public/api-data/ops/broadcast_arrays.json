      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = fnp.array([[1,2,3]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = fnp.array([[4],[5]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.broadcast_arrays(x, y)"
              },
              {
                "kind": "output",
                "text": "(array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "        [1, 2, 3]]),"
              },
              {
                "kind": "output",
                "text": " array([[4, 4, 4],"
              },
              {
                "kind": "output",
                "text": "        [5, 5, 5]]))"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Here is a useful idiom for getting contiguous copies instead of\nnon-contiguous views."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "[fnp.array(a) for a in fnp.broadcast_arrays(x, y)]"
              },
              {
                "kind": "output",
                "text": "[array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "        [1, 2, 3]]),"
              },
              {
                "kind": "output",
                "text": " array([[4, 4, 4],"
              },
              {
                "kind": "output",
                "text": "        [5, 5, 5]])]"
              }
            ],
            "type": "doctest_block"
          }
        ],
