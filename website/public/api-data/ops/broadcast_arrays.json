                "kind": "text",
                "text": "Broadcast any number of arrays against each other."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The arrays to broadcast."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_likes",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The arrays to broadcast."
                  }
                ],
                "name": "*args",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, then sub-classes will be passed-through, otherwise\nthe returned arrays will be forced to be a base-class array (default)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, then sub-classes will be passed-through, otherwise\nthe returned arrays will be forced to be a base-class array (default)."
                  }
                ],
                "name": "subok",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "These arrays are views on the original arrays.  They are typically\nnot contiguous.  Furthermore, more than one element of a\nbroadcasted array may refer to a single memory location. If you need\nto write to the arrays, make copies first. While you can set the\n"
                      },
                      {
                        "kind": "code",
                        "text": "writable"
                      },
                      {
                        "kind": "text",
                        "text": " flag True, writing to a single output value may end up\nchanging more than one location in the output array."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "deprecated",
                    "options": [],
                    "raw_source": ".. deprecated:: 1.17\n    The output is currently marked so that if written to, a deprecation\n    warning will be emitted. A future version will set the\n    ``writable`` flag False so writing to it will raise an error.",
                    "supported": true,
                    "type": "directive_block",
                    "version": "1.17"
                  }
                ],
                "data_type": "tuple of arrays",
                "inline": [
                  {
                    "kind": "text",
                    "text": "These arrays are views on the original arrays.  They are typically\nnot contiguous.  Furthermore, more than one element of a\nbroadcasted array may refer to a single memory location. If you need\nto write to the arrays, make copies first. While you can set the\n"
                  },
                  {
                    "kind": "code",
                    "text": "writable"
                  },
                  {
                    "kind": "text",
                    "text": " flag True, writing to a single output value may end up\nchanging more than one location in the output array."
                  }
                ],
                "name": "broadcasted",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
