  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return the complex conjugate, element-wise."
          },
          {
            "type": "paragraph",
            "text": "The complex conjugate of a complex number is obtained by changing the\nsign of its imaginary part."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input value."
              }
            ]
          },
          {
            "name": "out",
            "type": "ndarray, None, or tuple of ndarray and None, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
              }
            ]
          },
          {
            "name": "where",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the `out` array will be set to the ufunc result.\nElsewhere, the `out` array will retain its original value.\nNote that if an uninitialized `out` array is created via the default\n``out=None``, locations within it where the condition is False will\nremain uninitialized."
              }
            ]
          },
          {
            "name": "**kwargs",
            "type": "",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "For other keyword-only arguments, see the\n:ref:`ufunc docs <ufuncs.kwargs>`."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "y",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The complex conjugate of `x`, with same dtype as `y`.\nThis is a scalar if `x` is a scalar."
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "`conj` is an alias for `conjugate`:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.conj is np.conjugate\nTrue"
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.conjugate(1+2j)\n(1-2j)"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x = np.eye(2) + 1j * np.eye(2)\n>>> np.conjugate(x)\narray([[ 1.-1.j,  0.-0.j],\n       [ 0.-0.j,  1.-1.j]])"
          }
        ]
      }
