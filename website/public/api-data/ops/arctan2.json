  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Element-wise arc tangent of "
              },
              {
                "kind": "code",
                "text": "x1/x2"
              },
              {
                "kind": "text",
                "text": " choosing the quadrant correctly."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The quadrant (i.e., branch) is chosen so that "
              },
              {
                "kind": "code",
                "text": "arctan2(x1, x2)"
              },
              {
                "kind": "text",
                "text": " is\nthe signed angle in radians between the ray ending at the origin and\npassing through the point (1,0), and the ray ending at the origin and\npassing through the point ("
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": ").  (Note the role reversal: the\n\""
              },
              {
                "kind": "code",
                "text": "y"
              },
              {
                "kind": "text",
                "text": "-coordinate\" is the first function parameter, the \""
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": "-coordinate\"\nis the second.)  By IEEE convention, this function is defined for\n"
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " = +/-0 and for either or both of "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " = +/-inf (see\nNotes for specific values)."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function is not defined for complex-valued arguments; for the\nso-called argument of complex values, use "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/angle",
                "kind": "link",
                "target": "angle",
                "text": "angle"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
