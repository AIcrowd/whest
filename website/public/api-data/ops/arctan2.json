        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "emphasis",
                "text": "arctan2"
              },
              {
                "kind": "text",
                "text": " is identical to the "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arctan2",
                "kind": "link",
                "target": "arctan2",
                "text": "atan2"
              },
              {
                "kind": "text",
                "text": " function of the underlying\nC library.  The following special values are defined in the C\nstandard: "
              },
              {
                "kind": "text",
                "text": "[1]_"
              }
            ],
            "type": "paragraph"
          },
          {
            "raw_kind": "table",
            "raw_text": "\n\n\n\n\n\nx1\n\nx2\n\narctan2(x1,x2)\n\n+/- 0\n\n+0\n\n+/- 0\n\n+/- 0\n\n-0\n\n+/- pi\n\n> 0\n\n+/-inf\n\n+0 / +pi\n\n< 0\n\n+/-inf\n\n-0 / -pi\n\n+/-inf\n\n+inf\n\n+/- (pi/4)\n\n+/-inf\n\n-inf\n\n+/- (3*pi/4)",
            "type": "raw_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that +0 and -0 are distinct floating point numbers, as are +inf\nand -inf."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nISO/IEC standard 9899:1999, \"Programming language C.\"",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Consider four points in different quadrants:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([-1, +1, +1, -1])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = we.array([-1, -1, +1, +1])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.arctan2(y, x) * 180 / we.pi"
              },
              {
                "kind": "output",
                "text": "array([-135.,  -45.,   45.,  135.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note the order of the parameters. "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arctan2",
                "kind": "link",
                "target": "arctan2",
                "text": "arctan2"
              },
              {
                "kind": "text",
                "text": " is defined also when "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " = 0\nand at several other special points, obtaining values in\nthe range "
              },
              {
                "kind": "code",
                "text": "[-pi, pi]"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.arctan2([1., -1.], [0., 0.])"
              },
              {
                "kind": "output",
                "text": "array([ 1.57079633, -1.57079633])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.arctan2([0., 0., we.inf], [+0., -0., we.inf])"
              },
              {
                "kind": "output",
                "text": "array([0.        , 3.14159265, 0.78539816])"
              }
            ],
            "type": "doctest_block"
          }
        ],
