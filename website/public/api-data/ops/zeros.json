  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return a new array of given shape and type, filled with zeros."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "shape",
            "type": "int or tuple of ints",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Shape of the new array, e.g., ``(2, 3)`` or ``2``."
              }
            ]
          },
          {
            "name": "dtype",
            "type": "data-type, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The desired data-type for the array, e.g., `numpy.int8`.  Default is\n`numpy.float64`."
              }
            ]
          },
          {
            "name": "order",
            "type": "{'C', 'F'}, optional, default: 'C'",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Whether to store multi-dimensional data in row-major\n(C-style) or column-major (Fortran-style) order in\nmemory."
              }
            ]
          },
          {
            "name": "like",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as ``like`` supports\nthe ``__array_function__`` protocol, the result will be defined\nby it. In this case, it ensures the creation of an array object\ncompatible with that passed in via this argument."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.20.0",
                "body": "",
                "raw": ".. versionadded:: 1.20.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Array of zeros with the given shape, dtype, and order."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": "    >>> import numpy as np\n    >>> np.zeros(5)\n    array([ 0.,  0.,  0.,  0.,  0.])"
          },
          {
            "type": "code",
            "language": "text",
            "code": "    >>> np.zeros((5,), dtype=int)\n    array([0, 0, 0, 0, 0])"
          },
          {
            "type": "code",
            "language": "text",
            "code": "    >>> np.zeros((2, 1))\n    array([[ 0.],\n           [ 0.]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": "    >>> s = (2,2)\n    >>> np.zeros(s)\n    array([[ 0.,  0.],\n           [ 0.,  0.]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": "    >>> np.zeros((2,), dtype=[('x', 'i4'), ('y', 'i4')]) # custom dtype\n    array([(0, 0), (0, 0)],\n          dtype=[('x', '<i4'), ('y', '<i4')])"
          }
        ]
      },
