    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return an array of zeros with the same shape and type as a given array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The shape and data-type of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " define these same attributes of\nthe returned array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The shape and data-type of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " define these same attributes of\nthe returned array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Overrides the data type of the result."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "data-type, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Overrides the data type of the result."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Overrides the memory layout of the result. 'C' means C-order,\n'F' means F-order, 'A' means 'F' if "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is Fortran contiguous,\n'C' otherwise. 'K' means match the layout of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " as closely\nas possible."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'C', 'F', 'A', or 'K'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Overrides the memory layout of the result. 'C' means C-order,\n'F' means F-order, 'A' means 'F' if "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is Fortran contiguous,\n'C' otherwise. 'K' means match the layout of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " as closely\nas possible."
                  }
                ],
                "name": "order",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, then the newly created array will use the sub-class\ntype of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ", otherwise it will be a base-class array. Defaults\nto True."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional.",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, then the newly created array will use the sub-class\ntype of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": ", otherwise it will be a base-class array. Defaults\nto True."
                  }
                ],
                "name": "subok",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Overrides the shape of the result. If order='K' and the number of\ndimensions is unchanged, will try to keep order, otherwise,\norder='C' is implied."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or sequence of ints, optional.",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Overrides the shape of the result. If order='K' and the number of\ndimensions is unchanged, will try to keep order, otherwise,\norder='C' is implied."
                  }
                ],
                "name": "shape",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The device on which to place the created array. Default: None.\nFor Array-API interoperability only, so must be "
