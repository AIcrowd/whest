    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Determine if two arrays share memory."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "This function can be exponentially slow for some inputs, unless\n"
                  },
                  {
                    "kind": "code",
                    "text": "max_work"
                  },
                  {
                    "kind": "text",
                    "text": " is set to zero or a positive integer.\nIf in doubt, use "
                  },
                  {
                    "external_url": "",
                    "href": "/docs/api/ops/may_share_memory",
                    "kind": "link",
                    "target": "may_share_memory",
                    "text": "fnp.may_share_memory"
                  },
                  {
                    "kind": "text",
                    "text": " instead."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "warning",
            "options": [],
            "raw_source": ".. warning::\n\n   This function can be exponentially slow for some inputs, unless\n   `max_work` is set to zero or a positive integer.\n   If in doubt, use `fnp.may_share_memory` instead.",
            "supported": true,
            "type": "directive_block"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input arrays"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input arrays"
                  }
                ],
                "name": "a, b",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Effort to spend on solving the overlap problem (maximum number\nof candidate solutions to consider). The following special\nvalues are recognized:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "The problem is solved exactly. In this case, the function returns\nTrue only if there is an element shared between the arrays. Finding\nthe exact solution may take extremely long in some cases."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "max_work=-1 (default)"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Only the memory bounds of a and b are checked.\nThis is equivalent to using "
                              },
                              {
                                "kind": "code",
                                "text": "may_share_memory()"
                              },
                              {
                                "kind": "text",
                                "text": "."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "max_work=0"
                          }
                        ]
                      }
                    ],
                    "type": "definition_list"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Effort to spend on solving the overlap problem (maximum number\nof candidate solutions to consider). The following special\nvalues are recognized:"
                  }
                ],
                "name": "max_work",
                "type": "field_list"
              }
            ],
