                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Alternate output array in which to place the result.  The default\nis "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": ". If provided, it must have the same shape as the\nexpected output, but the type will be cast if necessary.  See\n"
                      },
                      {
                        "display_text": "ufuncs-output-type",
                        "explicit_title": false,
