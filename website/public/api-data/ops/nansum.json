              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[1, 1], [1, we.nan]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.nansum(a)"
              },
              {
                "kind": "output",
                "text": "3.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.nansum(a, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([2.,  1.])"
              },
