                      {
                        "kind": "text",
                        "text": " for what values are\nsupported for matrices and vectors respectively). inf means numpy's\n"
                      },
                      {
                        "kind": "code",
                        "text": "inf"
                      },
                      {
                        "kind": "text",
                        "text": " object. The default is None."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{int, float, inf, -inf, 'fro', 'nuc'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Order of the norm (see table under "
                  },
                  {
                    "kind": "code",
                    "text": "Notes"
                  },
                  {
                    "kind": "text",
                    "text": " for what values are\nsupported for matrices and vectors respectively). inf means numpy's\n"
                  },
                  {
                    "kind": "code",
                    "text": "inf"
                  },
                  {
                    "kind": "text",
                    "text": " object. The default is None."
                  }
                ],
                "name": "ord",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " is an integer, it specifies the axis of "
                      },
                      {
                        "kind": "code",
