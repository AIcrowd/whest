        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function is able to return one of eight different matrix norms,\nor one of an infinite number of vector norms (described below), depending\non the value of the "
              },
              {
                "kind": "code",
                "text": "ord"
              },
              {
                "kind": "text",
                "text": " parameter."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
