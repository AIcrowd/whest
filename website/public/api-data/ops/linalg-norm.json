                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " is None, "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " must be 1-D or 2-D, unless "
                      },
                      {
                        "kind": "code",
                        "text": "ord"
                      },
