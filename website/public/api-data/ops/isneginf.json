            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isneginf(-we.inf)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isneginf(we.inf)"
              },
              {
                "kind": "output",
                "text": "False"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isneginf([-we.inf, 0., we.inf])"
              },
              {
                "kind": "output",
                "text": "array([ True, False, False])"
              }
            ],
            "type": "doctest_block"
          },
          {
