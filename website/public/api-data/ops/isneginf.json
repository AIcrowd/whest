              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([-we.inf, 0., we.inf])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = we.array([2, 2, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isneginf(x, y)"
              },
              {
                "kind": "output",
                "text": "array([1, 0, 0])"
              },
