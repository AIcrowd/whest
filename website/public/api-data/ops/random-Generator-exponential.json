      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nPeyton Z. Peebles Jr., \"Probability, Random Variables and\nRandom Signal Principles\", 4th ed, 2001, p. 57.",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nWikipedia, \"Poisson process\",\nhttps://en.wikipedia.org/wiki/Poisson_process",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "3\n\nWikipedia, \"Exponential distribution\",\nhttps://en.wikipedia.org/wiki/Exponential_distribution",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Assume a company has 10000 customer support agents and the time\nbetween customer calls is exponentially distributed and that the\naverage time between customer calls is 4 minutes."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "scale, size = 4, 10000"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "time_between_calls = rng.exponential(scale=scale, size=size)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "What is the probability that a customer will call in the next\n4 to 5 minutes?"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = ((time_between_calls < 5).sum())/size"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = ((time_between_calls < 4).sum())/size"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x - y"
              },
              {
                "kind": "output",
                "text": "0.08  # may vary"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The corresponding distribution can be visualized as follows:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "scale, size = 4, 10000"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "sample = rng.exponential(scale=scale, size=size)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "count, bins, _ = plt.hist(sample, 30, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(bins, scale**(-1)*flops.exp(-scale**-1*bins), linewidth=2, color='r')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
