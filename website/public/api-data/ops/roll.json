            "inline": [
              {
                "kind": "text",
                "text": "Roll array elements along a given axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Elements that roll beyond the last position are re-introduced at\nthe first."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The number of places by which elements are shifted.  If a tuple,\nthen "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " must be a tuple of the same size, and each of the\ngiven axes is shifted by the corresponding number.  If an int\nwhile "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " is a tuple of ints, then the same value is used for\nall given axes."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The number of places by which elements are shifted.  If a tuple,\nthen "
                  },
                  {
                    "kind": "code",
                    "text": "axis"
                  },
                  {
                    "kind": "text",
                    "text": " must be a tuple of the same size, and each of the\ngiven axes is shifted by the corresponding number.  If an int\nwhile "
                  },
                  {
                    "kind": "code",
                    "text": "axis"
                  },
                  {
                    "kind": "text",
                    "text": " is a tuple of ints, then the same value is used for\nall given axes."
                  }
                ],
                "name": "shift",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which elements are shifted.  By default, the\narray is flattened before shifting, after which the original\nshape is restored."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which elements are shifted.  By default, the\narray is flattened before shifting, after which the original\nshape is restored."
