      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "In case of multiple occurrences of the minimum values, the indices\ncorresponding to the first occurrence are returned."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.arange(6).reshape(2,3) + 10"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[10, 11, 12],"
              },
              {
                "kind": "output",
                "text": "       [13, 14, 15]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argmin(a)"
              },
              {
                "kind": "output",
                "text": "0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argmin(a, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([0, 0, 0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argmin(a, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([0, 0])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Indices of the minimum elements of a N-dimensional array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind = we.unravel_index(we.argmin(a, axis=None), a.shape)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind"
              },
              {
                "kind": "output",
                "text": "(0, 0)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[ind]"
              },
              {
                "kind": "output",
                "text": "10"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.arange(6) + 10"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b[4] = 10"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b"
              },
              {
                "kind": "output",
                "text": "array([10, 11, 12, 13, 10, 15])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argmin(b)  # Only the first occurrence is returned."
              },
              {
                "kind": "output",
                "text": "0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([[4,2,3], [1,0,3]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "index_array = we.argmin(x, axis=-1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# Same as we.amin(x, axis=-1, keepdims=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.take_along_axis(x, we.expand_dims(index_array, axis=-1), axis=-1)"
              },
              {
                "kind": "output",
                "text": "array([[2],"
              },
              {
                "kind": "output",
                "text": "       [0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# Same as we.amax(x, axis=-1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.take_along_axis(x, we.expand_dims(index_array, axis=-1),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "axis=-1).squeeze(axis=-1)"
              },
              {
                "kind": "output",
                "text": "array([2, 0])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Setting "
              },
              {
                "kind": "code",
                "text": "keepdims"
              },
              {
                "kind": "text",
                "text": " to "
              },
              {
                "kind": "code",
                "text": "True"
              },
              {
                "kind": "text",
                "text": ","
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.arange(24).reshape((2, 3, 4))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "res = we.argmin(x, axis=1, keepdims=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "res.shape"
              },
              {
                "kind": "output",
                "text": "(2, 1, 4)"
              }
            ],
            "type": "doctest_block"
          }
        ],
