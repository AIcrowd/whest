          {
            "type": "paragraph",
            "text": "Interpret the input as a matrix."
          },
          {
            "type": "paragraph",
            "text": "Unlike `matrix`, `asmatrix` does not make a copy if the input is already\na matrix or an ndarray.  Equivalent to ``matrix(data, copy=False)``."
          }
        ]
