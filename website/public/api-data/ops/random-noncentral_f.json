        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from an F distribution with specified parameters,\n"
              },
              {
                "kind": "code",
                "text": "dfnum"
              },
              {
                "kind": "text",
                "text": " (degrees of freedom in numerator) and "
              },
              {
                "kind": "code",
                "text": "dfden"
              },
              {
                "kind": "text",
                "text": " (degrees of\nfreedom in denominator), where both parameters > 1.\n"
              },
              {
                "kind": "code",
                "text": "nonc"
              },
              {
                "kind": "text",
                "text": " is the non-centrality parameter."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "New code should use the\n"
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.noncentral_f.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator.noncentral_f",
                    "text": "noncentral_f"
                  },
                  {
                    "kind": "text",
                    "text": "\nmethod of a "
