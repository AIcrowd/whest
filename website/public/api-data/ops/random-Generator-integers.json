{
  "detail_href": "/docs/api/numpy/random/generator/integers/",
  "detail_json_href": "/api-data/ops/random-Generator-integers.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return random integers from "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": " (inclusive) to "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " (exclusive), or if endpoint=True, "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": " (inclusive) to "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " (inclusive). Replaces "
              },
              {
                "kind": "code",
                "text": "RandomState.randint"
              },
              {
                "kind": "text",
                "text": " (with endpoint=False) and "
              },
              {
                "kind": "code",
                "text": "RandomState.random_integers"
              },
              {
                "kind": "text",
                "text": " (with endpoint=True)"
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return random integers from the \"discrete uniform\" distribution of\nthe specified dtype. If "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " is None (the default), then results are\nfrom 0 to "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Lowest (signed) integers to be drawn from the distribution (unless\n"
                      },
                      {
                        "kind": "code",
                        "text": "high=None"
                      },
                      {
                        "kind": "text",
                        "text": ", in which case this parameter is 0 and this value is\nused for "
                      },
                      {
                        "kind": "code",
                        "text": "high"
                      },
                      {
                        "kind": "text",
                        "text": ")."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or array-like of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Lowest (signed) integers to be drawn from the distribution (unless\n"
                  },
                  {
                    "kind": "code",
                    "text": "high=None"
                  },
                  {
                    "kind": "text",
                    "text": ", in which case this parameter is 0 and this value is\nused for "
                  },
                  {
                    "kind": "code",
                    "text": "high"
                  },
                  {
                    "kind": "text",
                    "text": ")."
                  }
                ],
                "name": "low",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If provided, one above the largest (signed) integer to be drawn\nfrom the distribution (see above for behavior if "
                      },
                      {
                        "kind": "code",
                        "text": "high=None"
                      },
                      {
                        "kind": "text",
                        "text": ").\nIf array-like, must contain integer values"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or array-like of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If provided, one above the largest (signed) integer to be drawn\nfrom the distribution (see above for behavior if "
                  },
                  {
                    "kind": "code",
                    "text": "high=None"
                  },
                  {
                    "kind": "text",
                    "text": ").\nIf array-like, must contain integer values"
                  }
                ],
                "name": "high",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                  }
                ],
                "name": "size",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Desired dtype of the result. Byteorder must be native.\nThe default value is flops.int64."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Desired dtype of the result. Byteorder must be native.\nThe default value is flops.int64."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If true, sample from the interval [low, high] instead of the\ndefault [low, high)\nDefaults to False"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If true, sample from the interval [low, high] instead of the\ndefault [low, high)\nDefaults to False"
                  }
                ],
                "name": "endpoint",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
