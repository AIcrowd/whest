{
  "detail_href": "/docs/api/ops/flip/",
  "detail_json_href": "/api-data/ops/flip.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Reverse the order of elements in an array along the given axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The shape of the array is preserved, but the elements are reordered."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array."
                  }
                ],
                "name": "m",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which to flip over. The default,\naxis=None, will flip over all of the axes of the input array.\nIf axis is negative it counts from the last to the first axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If axis is a tuple of ints, flipping is performed on all of the axes\nspecified in the tuple."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "None or int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which to flip over. The default,\naxis=None, will flip over all of the axes of the input array.\nIf axis is negative it counts from the last to the first axis."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A view of "
                      },
                      {
                        "kind": "code",
                        "text": "m"
                      },
                      {
                        "kind": "text",
                        "text": " with the entries of axis reversed.  Since a view is\nreturned, this operation is done in constant time."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A view of "
                  },
                  {
                    "kind": "code",
                    "text": "m"
                  },
                  {
                    "kind": "text",
                    "text": " with the entries of axis reversed.  Since a view is\nreturned, this operation is done in constant time."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "Flip an array vertically (axis=0).",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "Flip an array vertically (axis=0)."
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/flipud",
                "label": "fnp.flipud",
                "original_target": "flipud",
                "role": "",
                "target": "flipud",
                "unresolved": false
              },
              {
                "description": "Flip an array horizontally (axis=1).",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "Flip an array horizontally (axis=1)."
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/fliplr",
                "label": "fnp.fliplr",
                "original_target": "fliplr",
                "role": "",
