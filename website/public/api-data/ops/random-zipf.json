                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is a scalar. Otherwise,\n"
                      },
                      {
                        "kind": "code",
                        "text": "we.array(a).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
