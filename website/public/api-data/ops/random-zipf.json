        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability mass function (PMF) for the Zipf distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "p(k) = \\frac{k^{-a}}{\\zeta(a)},"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "for integers "
              },
              {
                "kind": "math",
                "latex": "k \\geq 1"
              },
              {
                "kind": "text",
                "text": ", where "
              },
              {
                "kind": "math",
                "latex": "\\zeta"
              },
              {
                "kind": "text",
                "text": " is the Riemann Zeta\nfunction."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "It is named for the American linguist George Kingsley Zipf, who noted\nthat the frequency of any word in a sample of a language is inversely\nproportional to its rank in the frequency table."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nZipf, G. K., \"Selected Studies of the Principle of Relative\nFrequency in Language,\" Cambridge, MA: Harvard Univ. Press,\n1932.",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the distribution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = 4.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "n = 20000"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = we.random.zipf(a, n)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Display the histogram of the samples, along with\nthe expected histogram based on the probability\ndensity function:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from scipy.special import zeta  # doctest: +SKIP"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/bincount",
                "kind": "link",
                "target": "bincount",
                "text": "bincount"
              },
              {
                "kind": "text",
                "text": " provides a fast histogram for small integers."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "count = we.bincount(s)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "k = we.arange(1, s.max() + 1)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.bar(k, count[1:], alpha=0.5, label='sample count')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(k, n*(k**-a)/zeta(a), 'k.-', alpha=0.5,"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "label='expected count')   # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.semilogy()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.grid(alpha=0.4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.legend()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.title(f'Zipf sample, a={a}, size={n}')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
