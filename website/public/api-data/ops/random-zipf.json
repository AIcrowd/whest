        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from a Zipf distribution with specified parameter\n"
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " > 1."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The Zipf distribution (also known as the zeta distribution) is a\ndiscrete probability distribution that satisfies Zipf's law: the\nfrequency of an item is inversely proportional to its rank in a\nfrequency table."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "New code should use the "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.zipf.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator.zipf",
                    "text": "zipf"
                  },
                  {
                    "kind": "text",
                    "text": "\nmethod of a "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator",
                    "text": "Generator"
                  },
                  {
                    "kind": "text",
                    "text": " instance instead;\nplease see the "
                  },
                  {
                    "display_text": "random-quick-start",
                    "explicit_title": false,
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                    "href": "",
