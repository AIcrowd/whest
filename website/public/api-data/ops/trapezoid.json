        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Image "
              },
              {
                "kind": "text",
                "text": "[2]_"
              },
              {
                "kind": "text",
                "text": " illustrates trapezoidal rule -- y-axis locations of points\nwill be taken from "
              },
              {
                "kind": "code",
                "text": "y"
              },
              {
                "kind": "text",
                "text": " array, by default x-axis distances between\npoints will be 1.0, alternatively they can be provided with "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " array\nor with "
              },
              {
                "kind": "code",
                "text": "dx"
              },
              {
                "kind": "text",
                "text": " scalar.  Return value will be equal to combined area under\nthe red lines."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nWikipedia page: https://en.wikipedia.org/wiki/Trapezoidal_rule",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nIllustration image:\nhttps://en.wikipedia.org/wiki/File:Composite_trapezoidal_rule_illustration.png",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Use the trapezoidal rule on evenly spaced points:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid([1, 2, 3])"
              },
              {
                "kind": "output",
                "text": "4.0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The spacing between sample points can be selected by either the\n"
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " or "
              },
              {
                "kind": "code",
                "text": "dx"
              },
              {
                "kind": "text",
                "text": " arguments:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid([1, 2, 3], x=[4, 6, 8])"
              },
              {
                "kind": "output",
                "text": "8.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid([1, 2, 3], dx=2)"
              },
              {
                "kind": "output",
                "text": "8.0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Using a decreasing "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " corresponds to integrating in reverse:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid([1, 2, 3], x=[8, 6, 4])"
              },
              {
                "kind": "output",
                "text": "-8.0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "More generally "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is used to integrate along a parametric curve. We can\nestimate the integral "
              },
              {
                "kind": "math",
                "latex": "\\int_0^1 x^2 = 1/3"
              },
              {
                "kind": "text",
                "text": " using:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = fnp.linspace(0, 1, num=50)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = x**2"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid(y, x)"
              },
              {
                "kind": "output",
                "text": "0.33340274885464394"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Or estimate the area of a circle, noting we repeat the sample which closes\nthe curve:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "theta = fnp.linspace(0, 2 * fnp.pi, num=1000, endpoint=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid(fnp.cos(theta), x=fnp.sin(theta))"
              },
              {
                "kind": "output",
                "text": "3.141571941375841"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/trapezoid",
                "kind": "link",
                "target": "trapezoid",
                "text": "fnp.trapezoid"
              },
              {
                "kind": "text",
                "text": " can be applied along a specified axis to do multiple\ncomputations in one call:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.arange(6).reshape(2, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2],"
              },
              {
                "kind": "output",
                "text": "       [3, 4, 5]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid(a, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([1.5, 2.5, 3.5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.trapezoid(a, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([2.,  8.])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
  "op": {
