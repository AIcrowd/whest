{
  "detail_href": "/docs/api/ops/trapezoid/",
  "detail_json_href": "/api-data/ops/trapezoid.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Integrate along the given axis using the composite trapezoidal rule."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is provided, the integration happens in sequence along its\nelements - they are not sorted."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Integrate "
              },
              {
                "kind": "code",
                "text": "y"
              },
              {
                "kind": "text",
                "text": " ("
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": ") along each 1d slice on the given axis, compute\n"
              },
              {
                "kind": "math",
                "latex": "\\int y(x) dx"
              },
              {
                "kind": "text",
                "text": ".\nWhen "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is specified, this integrates along the parametric curve,\ncomputing "
              },
              {
                "kind": "math",
                "latex": "\\int_t y(t) dt =\n\\int_t y(t) \\left.\\frac{dx}{dt}\\right|_{x=x(t)} dt"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [],
            "directive": "versionadded",
            "options": [],
            "raw_source": ".. versionadded:: 2.0.0",
            "supported": true,
            "type": "directive_block",
            "version": "2.0.0"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array to integrate."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array to integrate."
                  }
                ],
                "name": "y",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The sample points corresponding to the "
                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": " values. If "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " is None,\nthe sample points are assumed to be evenly spaced "
                      },
                      {
                        "kind": "code",
                        "text": "dx"
                      },
                      {
                        "kind": "text",
                        "text": " apart. The\ndefault is None."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The sample points corresponding to the "
                  },
                  {
                    "kind": "code",
                    "text": "y"
                  },
                  {
                    "kind": "text",
                    "text": " values. If "
                  },
                  {
                    "kind": "code",
                    "text": "x"
                  },
                  {
                    "kind": "text",
                    "text": " is None,\nthe sample points are assumed to be evenly spaced "
                  },
                  {
                    "kind": "code",
                    "text": "dx"
                  },
                  {
                    "kind": "text",
                    "text": " apart. The\ndefault is None."
                  }
                ],
                "name": "x",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The spacing between sample points when "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " is None. The default is 1."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "scalar, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The spacing between sample points when "
                  },
                  {
                    "kind": "code",
                    "text": "x"
                  },
                  {
                    "kind": "text",
                    "text": " is None. The default is 1."
                  }
                ],
                "name": "dx",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The axis along which to integrate."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The axis along which to integrate."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Definite integral of "
                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": " = n-dimensional array as approximated along\na single axis by the trapezoidal rule. If "
                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": " is a 1-dimensional array,\nthen the result is a float. If "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " is greater than 1, then the result\nis an "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": "-1 dimensional array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Definite integral of "
                  },
                  {
                    "kind": "code",
                    "text": "y"
                  },
                  {
                    "kind": "text",
                    "text": " = n-dimensional array as approximated along\na single axis by the trapezoidal rule. If "
                  },
                  {
                    "kind": "code",
                    "text": "y"
                  },
                  {
                    "kind": "text",
                    "text": " is a 1-dimensional array,\nthen the result is a float. If "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " is greater than 1, then the result\nis an "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": "-1 dimensional array."
                  }
                ],
                "name": "trapezoid",
                "type": "field_list"
              }
            ],
