            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "iterable = (x*x for x in range(5))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.fromiter(iterable, float)"
              },
              {
                "kind": "output",
                "text": "array([  0.,   1.,   4.,   9.,  16.])"
