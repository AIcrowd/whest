            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "A carefully constructed subarray dtype will lead to higher dimensional\nresults:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "iterable = ((x+1, x+2) for x in range(5))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.fromiter(iterable, dtype=we.dtype((int, 2)))"
              },
              {
                "kind": "output",
                "text": "array([[1, 2],"
              },
              {
                "kind": "output",
                "text": "       [2, 3],"
              },
              {
                "kind": "output",
                "text": "       [3, 4],"
              },
              {
                "kind": "output",
                "text": "       [4, 5],"
              },
              {
                "kind": "output",
                "text": "       [5, 6]])"
              }
            ],
