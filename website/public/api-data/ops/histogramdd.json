      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = we.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "r = rng.normal(size=(100,3))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "H, edges = we.histogramdd(r, bins = (5, 8, 4))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "H.shape, edges[0].size, edges[1].size, edges[2].size"
              },
              {
                "kind": "output",
                "text": "((5, 8, 4), 6, 9, 5)"
              }
            ],
            "type": "doctest_block"
          }
        ],
