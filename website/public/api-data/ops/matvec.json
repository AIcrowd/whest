  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Matrix-vector dot product of two arrays."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given a matrix (or stack of matrices) "
              },
              {
                "kind": "math",
                "latex": "\\mathbf{A}"
              },
              {
                "kind": "text",
                "text": " in "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and\na vector (or stack of vectors) "
              },
              {
                "kind": "math",
                "latex": "\\mathbf{v}"
              },
              {
                "kind": "text",
                "text": " in "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": ", the\nmatrix-vector product is defined as:"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "\\mathbf{A} \\cdot \\mathbf{b} = \\sum_{j=0}^{n-1} A_{ij} v_j"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where the sum is over the last dimensions in "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": "\n(unless "
              },
              {
                "kind": "code",
                "text": "axes"
              },
              {
                "kind": "text",
                "text": " is specified).  (For a matrix-vector product with the\nvector conjugated, use "
              },
              {
                "kind": "code",
                "text": "we.vecmat(x2, x1.mT)"
              },
              {
                "kind": "text",
                "text": ".)"
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [],
            "directive": "versionadded",
            "options": [],
            "raw_source": ".. versionadded:: 2.2.0",
            "supported": true,
            "type": "directive_block",
            "version": "2.2.0"
          }
        ],
