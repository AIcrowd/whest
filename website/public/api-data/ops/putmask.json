    "notes": "Change elements of array based on condition and input values. Cost: numel(input).",
    "summary": "Changes elements of an array based on conditional and input values.",
    "signature": "we.putmask(a, mask, values)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Changes elements of an array based on conditional and input values."
          },
          {
            "type": "paragraph",
            "text": "Sets ``a.flat[n] = values[n]`` for each n where ``mask.flat[n]==True``."
          },
          {
            "type": "paragraph",
            "text": "If `values` is not the same size as `a` and `mask` then it will repeat.\nThis gives behavior different from ``a[mask] = values``."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Target array."
              }
            ]
          },
          {
            "name": "mask",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Boolean mask array. It has to be the same shape as `a`."
              }
            ]
          },
          {
            "name": "values",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Values to put into `a` where `mask` is True. If `values` is smaller\nthan `a` it will be repeated."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> x = np.arange(6).reshape(2, 3)\n>>> np.putmask(x, x>2, x**2)\n>>> x\narray([[ 0,  1,  2],\n       [ 9, 16, 25]])"
          },
          {
            "type": "paragraph",
            "text": "If `values` is smaller than `a` it is repeated:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x = np.arange(5)\n>>> np.putmask(x, x>1, [-33, -44])\n>>> x\narray([  0,   1, -33, -44, -33])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "place, put, take, copyto"
          }
        ]
      }
    ]
  }
