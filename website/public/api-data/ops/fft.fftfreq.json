  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return the Discrete Fourier Transform sample frequencies."
          },
          {
            "type": "paragraph",
            "text": "The returned float array `f` contains the frequency bin centers in cycles\nper unit of the sample spacing (with zero at the start).  For instance, if\nthe sample spacing is in seconds, then the frequency unit is cycles/second."
          },
          {
            "type": "paragraph",
            "text": "Given a window length `n` and a sample spacing `d`::"
          },
          {
            "type": "paragraph",
            "text": "  f = [0, 1, ...,   n/2-1,     -n/2, ..., -1] / (d*n)   if n is even\n  f = [0, 1, ..., (n-1)/2, -(n-1)/2, ..., -1] / (d*n)   if n is odd"
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "n",
            "type": "int",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Window length."
              }
            ]
          },
          {
            "name": "d",
            "type": "scalar, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Sample spacing (inverse of the sampling rate). Defaults to 1."
              }
            ]
          },
          {
            "name": "device",
            "type": "str, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The device on which to place the created array. Default: ``None``.\nFor Array-API interoperability only, so must be ``\"cpu\"`` if passed."
              },
              {
                "type": "directive",
                "name": "versionadded:: 2.0.0",
                "body": "",
                "raw": ".. versionadded:: 2.0.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "f",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Array of length `n` containing the sample frequencies."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> signal = np.array([-2, 8, 6, 4, 1, 0, 3, 5], dtype=float)\n>>> fourier = np.fft.fft(signal)\n>>> n = signal.size\n>>> timestep = 0.1\n>>> freq = np.fft.fftfreq(n, d=timestep)\n>>> freq\narray([ 0.  ,  1.25,  2.5 , ..., -3.75, -2.5 , -1.25])"
          }
        ]
      }
    ]
  }
