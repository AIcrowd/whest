{
  "detail_href": "/docs/api/ops/argpartition/",
  "detail_json_href": "/api-data/ops/argpartition.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Perform an indirect partition along the given axis using the algorithm specified by the "
              },
              {
                "kind": "code",
                "text": "kind"
              },
              {
                "kind": "text",
                "text": " keyword. It returns an array of indices of the same shape as "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " that index data along the given axis in partitioned order."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array to sort."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array to sort."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Element index to partition by. The k-th element will be in its\nfinal sorted position and all smaller elements will be moved\nbefore it and all larger elements behind it. The order of all\nelements in the partitions is undefined. If provided with a\nsequence of k-th it will partition all of them into their sorted\nposition at once."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or sequence of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Element index to partition by. The k-th element will be in its\nfinal sorted position and all smaller elements will be moved\nbefore it and all larger elements behind it. The order of all\nelements in the partitions is undefined. If provided with a\nsequence of k-th it will partition all of them into their sorted\nposition at once."
                  }
                ],
                "name": "kth",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis along which to sort. The default is -1 (the last axis). If\nNone, the flattened array is used."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or None, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis along which to sort. The default is -1 (the last axis). If\nNone, the flattened array is used."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Selection algorithm. Default is 'introselect'"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'introselect'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Selection algorithm. Default is 'introselect'"
                  }
                ],
                "name": "kind",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "When "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is an array with fields defined, this argument\nspecifies which fields to compare first, second, etc. A single\nfield can be specified as a string, and not all fields need be\nspecified, but unspecified fields will still be used, in the\norder in which they come up in the dtype, to break ties."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "str or list of str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "When "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is an array with fields defined, this argument\nspecifies which fields to compare first, second, etc. A single\nfield can be specified as a string, and not all fields need be\nspecified, but unspecified fields will still be used, in the\norder in which they come up in the dtype, to break ties."
                  }
                ],
                "name": "order",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array of indices that partition "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " along the specified axis.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is one-dimensional, "
                      },
                      {
                        "kind": "code",
                        "text": "a[index_array]"
                      },
                      {
                        "kind": "text",
                        "text": " yields a partitioned "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ".\nMore generally, "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.take_along_axis(a, index_array, axis=axis).html",
                        "href": "",
                        "kind": "link",
                        "target": "take_along_axis(a, index_array, axis=axis)",
                        "text": "fnp.take_along_axis(a, index_array, axis=axis)"
                      },
                      {
                        "kind": "text",
                        "text": "\nalways yields the partitioned "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ", irrespective of dimensionality."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, int",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array of indices that partition "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " along the specified axis.\nIf "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is one-dimensional, "
                  },
                  {
                    "kind": "code",
                    "text": "a[index_array]"
                  },
                  {
                    "kind": "text",
                    "text": " yields a partitioned "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": ".\nMore generally, "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.take_along_axis(a, index_array, axis=axis).html",
                    "href": "",
                    "kind": "link",
                    "target": "take_along_axis(a, index_array, axis=axis)",
                    "text": "fnp.take_along_axis(a, index_array, axis=axis)"
                  },
                  {
                    "kind": "text",
                    "text": "\nalways yields the partitioned "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": ", irrespective of dimensionality."
                  }
                ],
                "name": "index_array",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
