        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "This forms part of the old polynomial API. Since version 1.4, the\nnew polynomial API defined in "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.polynomial.html",
                    "href": "",
                    "kind": "link",
                    "target": "polynomial",
                    "text": "we.polynomial"
                  },
                  {
                    "kind": "text",
                    "text": " is preferred.\nA summary of the differences can be found in the\n"
                  },
                  {
                    "display_text": "transition guide",
                    "explicit_title": true,
                    "external_url": "",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "/reference/routines.polynomials",
                    "role": "doc",
                    "suppress_link": false,
                    "target": "/reference/routines.polynomials",
                    "unresolved": true
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "note",
            "options": [],
            "raw_source": ".. note::\n   This forms part of the old polynomial API. Since version 1.4, the\n   new polynomial API defined in `we.polynomial` is preferred.\n   A summary of the differences can be found in the\n   :doc:`transition guide </reference/routines.polynomials>`.",
            "supported": true,
            "type": "directive_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given two polynomials "
              },
              {
                "kind": "code",
                "text": "a1"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "a2"
              },
              {
                "kind": "text",
                "text": ", returns "
              },
              {
                "kind": "code",
                "text": "a1 - a2"
              },
              {
                "kind": "text",
                "text": ".\n"
              },
              {
                "kind": "code",
                "text": "a1"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "a2"
              },
              {
                "kind": "text",
                "text": " can be either array_like sequences of the polynomials'\ncoefficients (including coefficients equal to zero), or "
              },
              {
                "kind": "code",
                "text": "poly1d"
              },
              {
                "kind": "text",
                "text": " objects."
              }
            ],
            "type": "paragraph"
          }
        ],
