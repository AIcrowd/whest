                    "kind": "code",
                    "text": "stop"
                  },
                  {
                    "kind": "text",
                    "text": " is the last sample. Otherwise, it is not included.\nDefault is True."
                  }
                ],
                "name": "endpoint",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The type of the output array.  If "
                      },
                      {
                        "kind": "code",
                        "text": "dtype"
                      },
                      {
                        "kind": "text",
                        "text": " is not given, the data type\nis inferred from "
                      },
                      {
                        "kind": "code",
                        "text": "start"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "stop"
                      },
                      {
                        "kind": "text",
                        "text": ". The inferred dtype will never be\nan integer; "
                      },
                      {
                        "kind": "code",
                        "text": "float"
                      },
                      {
                        "kind": "text",
                        "text": " is chosen even if the arguments would produce an\narray of integers."
                      }
                    ],
