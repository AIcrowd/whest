  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return numbers spaced evenly on a log scale (a geometric progression)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This is similar to "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/logspace",
                "kind": "link",
                "target": "logspace",
                "text": "logspace"
              },
              {
                "kind": "text",
                "text": ", but with endpoints specified directly.\nEach output sample is a constant multiple of the previous."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The starting value of the sequence."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The starting value of the sequence."
                  }
                ],
                "name": "start",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The final value of the sequence, unless "
                      },
                      {
                        "kind": "code",
                        "text": "endpoint"
                      },
                      {
                        "kind": "text",
                        "text": " is False.\nIn that case, "
                      },
                      {
                        "kind": "code",
                        "text": "num + 1"
                      },
                      {
                        "kind": "text",
                        "text": " values are spaced over the\ninterval in log-space, of which all but the last (a sequence of\nlength "
                      },
                      {
                        "kind": "code",
                        "text": "num"
                      },
                      {
                        "kind": "text",
                        "text": ") are returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The final value of the sequence, unless "
                  },
                  {
                    "kind": "code",
                    "text": "endpoint"
                  },
                  {
                    "kind": "text",
                    "text": " is False.\nIn that case, "
                  },
                  {
                    "kind": "code",
                    "text": "num + 1"
                  },
                  {
                    "kind": "text",
                    "text": " values are spaced over the\ninterval in log-space, of which all but the last (a sequence of\nlength "
                  },
                  {
                    "kind": "code",
                    "text": "num"
                  },
                  {
                    "kind": "text",
                    "text": ") are returned."
                  }
                ],
                "name": "stop",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Number of samples to generate.  Default is 50."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "integer, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Number of samples to generate.  Default is 50."
                  }
                ],
                "name": "num",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If true, "
                      },
                      {
                        "kind": "code",
                        "text": "stop"
                      },
                      {
                        "kind": "text",
                        "text": " is the last sample. Otherwise, it is not included.\nDefault is True."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "boolean, optional",
                "inline": [
                  {
                    "kind": "text",
