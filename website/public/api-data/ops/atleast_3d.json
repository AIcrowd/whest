              {
                "kind": "text",
                "text": "View inputs as arrays with at least three dimensions."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "One or more array-like sequences.  Non-array inputs are converted to\narrays.  Arrays that already have three or more dimensions are\npreserved."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "One or more array-like sequences.  Non-array inputs are converted to\narrays.  Arrays that already have three or more dimensions are\npreserved."
                  }
                ],
                "name": "arys1, arys2, ...",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array, or tuple of arrays, each with "
                      },
                      {
                        "kind": "code",
                        "text": "a.ndim >= 3"
                      },
                      {
                        "kind": "text",
                        "text": ".  Copies are\navoided where possible, and views with three or more dimensions are\nreturned.  For example, a 1-D array of shape "
                      },
                      {
                        "kind": "code",
                        "text": "(N,)"
                      },
                      {
                        "kind": "text",
                        "text": " becomes a view\nof shape "
                      },
                      {
                        "kind": "code",
                        "text": "(1, N, 1)"
                      },
                      {
                        "kind": "text",
                        "text": ", and a 2-D array of shape "
                      },
                      {
                        "kind": "code",
                        "text": "(M, N)"
                      },
                      {
                        "kind": "text",
                        "text": " becomes a\nview of shape "
                      },
                      {
                        "kind": "code",
                        "text": "(M, N, 1)"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
