  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Cholesky decomposition."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the lower or upper Cholesky decomposition, "
              },
              {
                "kind": "code",
                "text": "L * L.H"
              },
              {
                "kind": "text",
                "text": " or\n"
              },
              {
                "kind": "code",
                "text": "U.H * U"
              },
              {
                "kind": "text",
                "text": ", of the square matrix "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": ", where "
              },
              {
                "kind": "code",
                "text": "L"
              },
              {
                "kind": "text",
                "text": " is lower-triangular,\n"
              },
              {
                "kind": "code",
                "text": "U"
              },
              {
                "kind": "text",
                "text": " is upper-triangular, and "
              },
              {
                "kind": "code",
                "text": ".H"
              },
              {
                "kind": "text",
                "text": " is the conjugate transpose operator\n(which is the ordinary transpose if "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " is real-valued). "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " must be\nHermitian (symmetric if real-valued) and positive-definite. No checking is\nperformed to verify whether "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " is Hermitian or not. In addition, only\nthe lower or upper-triangular and diagonal elements of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " are used.\nOnly "
              },
              {
                "kind": "code",
                "text": "L"
              },
              {
                "kind": "text",
                "text": " or "
              },
              {
                "kind": "code",
                "text": "U"
              },
              {
                "kind": "text",
                "text": " is actually returned."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
