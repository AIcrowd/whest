{
  "detail_href": "/docs/api/ops/block/",
  "detail_json_href": "/api-data/ops/block.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Assemble an nd-array from nested lists of blocks."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Blocks in the innermost lists are concatenated (see "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/concatenate",
                "kind": "link",
                "target": "concatenate",
                "text": "concatenate"
              },
              {
                "kind": "text",
                "text": ") along\nthe last dimension (-1), then these are concatenated along the\nsecond-last dimension (-2), and so on until the outermost list is reached."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Blocks can be of any dimension, but will not be broadcasted using\nthe normal rules. Instead, leading axes of size 1 are inserted,\nto make "
              },
              {
                "kind": "code",
                "text": "block.ndim"
              },
              {
                "kind": "text",
                "text": " the same for all blocks. This is primarily useful\nfor working with scalars, and means that code like "
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.block([v, 1]).html",
                "href": "",
                "kind": "link",
                "target": "block([v, 1])",
                "text": "fnp.block([v, 1])"
              },
              {
                "kind": "text",
                "text": "\nis valid, where "
              },
              {
                "kind": "code",
                "text": "v.ndim == 1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When the nested list is two levels deep, this allows block matrices to be\nconstructed from their components."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If passed a single ndarray or scalar (a nested list of depth 0), this\nis returned unmodified (and not copied)."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Elements shapes must match along the appropriate axes (without\nbroadcasting), but leading 1s will be prepended to the shape as\nnecessary to make the dimensions match."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "nested list of array_like or scalars (but not tuples)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If passed a single ndarray or scalar (a nested list of depth 0), this\nis returned unmodified (and not copied)."
                  }
                ],
                "name": "arrays",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The array assembled from the given blocks."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The dimensionality of the output is equal to the greatest of:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "the dimensionality of all the inputs"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "the depth to which the input list is nested"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The array assembled from the given blocks."
                  }
                ],
                "name": "block_array",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If list depths are mismatched - for instance, "
                              },
                              {
                                "kind": "code",
                                "text": "[[a, b], c]"
                              },
                              {
                                "kind": "text",
                                "text": " is\nillegal, and should be spelt "
                              },
                              {
                                "kind": "code",
                                "text": "[[a, b], [c]]"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If lists are empty - for instance, "
                              },
                              {
                                "kind": "code",
                                "text": "[[a, b], []]"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  }
                ],
                "data_type": "ValueError",
                "inline": [],
                "name": "",
                "type": "field_list"
              }
            ],
            "title": "Raises",
            "type": "field_list"
          }
        ],
        "title": "Raises"
      },
