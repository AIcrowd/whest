            "type": "paragraph",
            "text": "concatenate \u2014 Join a sequence of arrays along an existing axis."
          },
          {
            "type": "paragraph",
            "text": "delete \u2014 Delete elements from an array."
          }
        ]
      }
    ]
  }
}