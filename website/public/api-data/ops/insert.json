      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that for higher dimensional inserts "
              },
              {
                "kind": "code",
                "text": "obj=0"
              },
              {
                "kind": "text",
                "text": " behaves very different\nfrom "
              },
              {
                "kind": "code",
                "text": "obj=[0]"
              },
              {
                "kind": "text",
                "text": " just like "
              },
              {
                "kind": "code",
                "text": "arr[:,0,:] = values"
              },
              {
                "kind": "text",
                "text": " is different from\n"
              },
              {
                "kind": "code",
                "text": "arr[:,[0],:] = values"
              },
              {
                "kind": "text",
                "text": ". This is because of the difference between basic\nand advanced "
              },
              {
                "display_text": "indexing",
                "explicit_title": true,
                "external_url": "",
                "href": "",
                "kind": "role_reference",
                "original_target": "basics.indexing",
                "role": "ref",
                "suppress_link": false,
                "target": "basics.indexing",
                "unresolved": true
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
