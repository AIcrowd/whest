              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# Example of providing the optional output parameter illustrating"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# that what is returned is a reference to said parameter"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "out1 = we.array([0], dtype='d')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "out2 = we.cos([0.1], out1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "out2 is out1"
              },
              {
                "kind": "output",
                "text": "True"
              },
