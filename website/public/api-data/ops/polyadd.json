            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.polyadd([1, 2], [9, 5, 4])"
              },
              {
                "kind": "output",
                "text": "array([9, 6, 6])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Using poly1d objects:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "p1 = we.poly1d([1, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "p2 = we.poly1d([9, 5, 4])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(p1)"
              },
              {
                "kind": "output",
                "text": "1 x + 2"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(p2)"
              },
              {
                "kind": "output",
                "text": "   2"
              },
              {
                "kind": "output",
                "text": "9 x + 5 x + 4"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "print(we.polyadd(p1, p2))"
              },
              {
                "kind": "output",
                "text": "   2"
              },
              {
                "kind": "output",
                "text": "9 x + 6 x + 6"
              }
            ],
            "type": "doctest_block"
          }
