            "inline": [
              {
                "kind": "text",
                "text": "Reverse the order of elements along axis 1 (left/right)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "For a 2-D array, this flips the entries in each row in the left/right\ndirection. Columns are preserved, but appear in a different order than\nbefore."
              }
            ],
            "type": "paragraph"
          }
        ],
