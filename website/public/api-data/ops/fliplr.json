            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "A = fnp.diag([1.,2.,3.])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "A"
              },
              {
                "kind": "output",
                "text": "array([[1.,  0.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [0.,  2.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [0.,  0.,  3.]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fliplr(A)"
              },
              {
                "kind": "output",
                "text": "array([[0.,  0.,  1.],"
              },
              {
                "kind": "output",
                "text": "       [0.,  2.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [3.,  0.,  0.]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = fnp.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "A = rng.normal(size=(2,3,5))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.all(fnp.fliplr(A) == A[:,::-1,...])"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
