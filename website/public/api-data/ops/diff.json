                    "kind": "text",
                    "text": ", which\nresults in a "
                  },
                  {
                    "kind": "code",
                    "text": "timedelta64"
                  },
                  {
                    "kind": "text",
                    "text": " output array."
                  }
                ],
                "name": "diff",
                "type": "field_list"
              }
