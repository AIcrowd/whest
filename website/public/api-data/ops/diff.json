        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Type is preserved for boolean arrays, so the result will contain\n"
              },
              {
                "kind": "code",
                "text": "False"
              },
              {
                "kind": "text",
                "text": " when consecutive elements are the same and "
              },
              {
                "kind": "code",
                "text": "True"
              },
              {
                "kind": "text",
                "text": " when they\ndiffer."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For unsigned integer arrays, the results will also be unsigned. This\nshould not be surprising, as the result is consistent with\ncalculating the difference directly:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "u8_arr = we.array([1, 0], dtype=we.uint8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diff(u8_arr)"
              },
              {
                "kind": "output",
                "text": "array([255], dtype=uint8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "u8_arr[1,...] - u8_arr[0,...]"
              },
              {
                "kind": "output",
                "text": "we.uint8(255)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If this is not desirable, then the array should be cast to a larger\ninteger type first:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "i16_arr = u8_arr.astype(we.int16)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diff(i16_arr)"
              },
              {
                "kind": "output",
                "text": "array([-1], dtype=int16)"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([1, 2, 4, 7, 0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diff(x)"
              },
              {
                "kind": "output",
                "text": "array([ 1,  2,  3, -7])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diff(x, n=2)"
              },
              {
                "kind": "output",
                "text": "array([  1,   1, -10])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([[1, 3, 6, 10], [0, 5, 6, 8]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diff(x)"
              },
              {
                "kind": "output",
                "text": "array([[2, 3, 4],"
              },
              {
                "kind": "output",
                "text": "       [5, 1, 2]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diff(x, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([[-1,  2,  0, -2]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.arange('1066-10-13', '1066-10-16', dtype=we.datetime64)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.diff(x)"
              },
              {
                "kind": "output",
                "text": "array([1, 1], dtype='timedelta64[D]')"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
