      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([1+2j,3+4j])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = fnp.array([5+6j,7+8j])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.vdot(a, b)"
              },
              {
                "kind": "output",
                "text": "(70-8j)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.vdot(b, a)"
              },
              {
                "kind": "output",
                "text": "(70+8j)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that higher-dimensional arrays are flattened!"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[1, 4], [5, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = fnp.array([[4, 1], [2, 2]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.vdot(a, b)"
              },
              {
                "kind": "output",
                "text": "30"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.vdot(b, a)"
              },
              {
                "kind": "output",
                "text": "30"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "1*4 + 4*1 + 5*2 + 6*2"
              },
              {
                "kind": "output",
                "text": "30"
              }
            ],
            "type": "doctest_block"
          }
        ],
