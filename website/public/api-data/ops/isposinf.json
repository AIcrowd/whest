            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.isposinf(fnp.inf)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
