                "text": "fnp.isposinf(-fnp.inf)"
              },
              {
                "kind": "output",
                "text": "False"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.isposinf([-fnp.inf, 0., fnp.inf])"
              },
              {
                "kind": "output",
                "text": "array([False, False,  True])"
              }
