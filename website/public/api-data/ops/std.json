  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the standard deviation along the specified axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the standard deviation, a measure of the spread of a distribution,\nof the array elements. The standard deviation is computed for the\nflattened array by default, otherwise over the specified axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Calculate the standard deviation of these values."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Calculate the standard deviation of these values."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which the standard deviation is computed. The\ndefault is to compute the standard deviation of the flattened array.\nIf this is a tuple of ints, a standard deviation is performed over\nmultiple axes, instead of a single axis or all the axes as before."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "None or int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which the standard deviation is computed. The\ndefault is to compute the standard deviation of the flattened array.\nIf this is a tuple of ints, a standard deviation is performed over\nmultiple axes, instead of a single axis or all the axes as before."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Type to use in computing the standard deviation. For arrays of\ninteger type the default is float64, for arrays of float types it is\nthe same as the array type."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Type to use in computing the standard deviation. For arrays of\ninteger type the default is float64, for arrays of float types it is\nthe same as the array type."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Alternative output array in which to place the result. It must have\nthe same shape as the expected output but the type (of the calculated\nvalues) will be cast if necessary.\nSee "
