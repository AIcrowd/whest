            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array of the same shape as "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": ", containing the positive\nsquare-root of each element in "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": ".  If any element in "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " is\ncomplex, a complex array is returned (and the square-roots of\nnegative reals are calculated).  If all of the elements in "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": "\nare real, so is "
                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": ", with negative elements returning "
                      },
                      {
                        "kind": "code",
                        "text": "nan"
                      },
                      {
                        "kind": "text",
                        "text": ".\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " was provided, "
                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": " is a reference to it.\nThis is a scalar if "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " is a scalar."
                      }
                    ],
                    "type": "paragraph"
                  }
