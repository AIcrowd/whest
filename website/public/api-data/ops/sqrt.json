                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.sqrt([1,4,9])"
              },
              {
                "kind": "output",
                "text": "array([ 1.,  2.,  3.])"
              }
            ],
            "type": "doctest_block"
          },
