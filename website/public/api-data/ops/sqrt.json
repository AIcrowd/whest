            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.sqrt([4, -1, -3+4J])"
              },
              {
                "kind": "output",
                "text": "array([ 2.+0.j,  0.+1.j,  1.+2.j])"
              }
            ],
            "type": "doctest_block"
          },
