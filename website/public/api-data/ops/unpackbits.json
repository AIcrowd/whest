                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The elements are binary-valued (0 or 1)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, uint8 type",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The elements are binary-valued (0 or 1)."
                  }
                ],
                "name": "unpacked",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
