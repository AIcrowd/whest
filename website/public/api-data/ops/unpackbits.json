      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[2], [7], [23]], dtype=fnp.uint8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[ 2],"
              },
              {
                "kind": "output",
                "text": "       [ 7],"
              },
              {
                "kind": "output",
                "text": "       [23]], dtype=uint8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = fnp.unpackbits(a, axis=1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 0, 0, 0, 0, 1, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0, 1, 1, 1],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 1, 0, 1, 1, 1]], dtype=uint8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c = fnp.unpackbits(a, axis=1, count=-3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 1, 0]], dtype=uint8)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "p = fnp.packbits(b, axis=0)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.unpackbits(p, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 0, 0, 0, 0, 1, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0, 1, 1, 1],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 1, 0, 1, 1, 1],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0, 0, 0, 0, 0, 0]], dtype=uint8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.array_equal(b, fnp.unpackbits(p, axis=0, count=b.shape[0]))"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
