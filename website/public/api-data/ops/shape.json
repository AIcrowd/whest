        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.shape(np.eye(3))\n(3, 3)\n>>> np.shape([[1, 3]])\n(1, 2)\n>>> np.shape([0])\n(1,)\n>>> np.shape(0)\n()"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> a = np.array([(1, 2), (3, 4), (5, 6)],\n...              dtype=[('x', 'i4'), ('y', 'i4')])\n>>> np.shape(a)\n(3,)\n>>> a.shape\n(3,)"
          }
        ]
      },
