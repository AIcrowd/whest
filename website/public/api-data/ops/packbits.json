      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[[1,0,1],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[0,1,0]],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[[1,1,0],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[0,0,1]]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.packbits(a, axis=-1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b"
              },
              {
                "kind": "output",
                "text": "array([[[160],"
              },
              {
                "kind": "output",
                "text": "        [ 64]],"
              },
              {
                "kind": "output",
                "text": "       [[192],"
              },
              {
                "kind": "output",
                "text": "        [ 32]]], dtype=uint8)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that in binary 160 = 1010 0000, 64 = 0100 0000, 192 = 1100 0000,\nand 32 = 0010 0000."
              }
            ],
            "type": "paragraph"
          }
        ],
