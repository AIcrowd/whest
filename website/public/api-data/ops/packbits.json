  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Packs the elements of a binary-valued array into bits in a uint8 array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The result is padded to full bytes by inserting zero bits at the end."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array of integers or booleans whose elements should be packed to\nbits."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An array of integers or booleans whose elements should be packed to\nbits."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The dimension over which bit-packing is done.\n"
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " implies packing the flattened array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The dimension over which bit-packing is done.\n"
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " implies packing the flattened array."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The order of the input bits. 'big' will mimic bin(val),\n"
                      },
                      {
                        "kind": "code",
                        "text": "[0, 0, 0, 0, 0, 0, 1, 1] => 3 = 0b00000011"
                      },
                      {
                        "kind": "text",
                        "text": ", 'little' will\nreverse the order so "
                      },
                      {
                        "kind": "code",
                        "text": "[1, 1, 0, 0, 0, 0, 0, 0] => 3"
                      },
                      {
                        "kind": "text",
                        "text": ".\nDefaults to 'big'."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'big', 'little'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The order of the input bits. 'big' will mimic bin(val),\n"
                  },
                  {
                    "kind": "code",
                    "text": "[0, 0, 0, 0, 0, 0, 1, 1] => 3 = 0b00000011"
                  },
                  {
                    "kind": "text",
                    "text": ", 'little' will\nreverse the order so "
                  },
                  {
                    "kind": "code",
                    "text": "[1, 1, 0, 0, 0, 0, 0, 0] => 3"
                  },
                  {
                    "kind": "text",
                    "text": ".\nDefaults to 'big'."
                  }
                ],
                "name": "bitorder",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
