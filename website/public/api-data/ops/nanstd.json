  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the standard deviation along the specified axis, while ignoring NaNs."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the standard deviation, a measure of the spread of a\ndistribution, of the non-NaN array elements. The standard deviation is\ncomputed for the flattened array by default, otherwise over the\nspecified axis."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For all-NaN slices or slices with zero degrees of freedom, NaN is\nreturned and a "
              },
              {
                "kind": "code",
                "text": "RuntimeWarning"
              },
              {
                "kind": "text",
                "text": " is raised."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Calculate the standard deviation of the non-NaN values."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Calculate the standard deviation of the non-NaN values."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which the standard deviation is computed. The default is\nto compute the standard deviation of the flattened array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{int, tuple of int, None}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which the standard deviation is computed. The default is\nto compute the standard deviation of the flattened array."
