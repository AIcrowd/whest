                      {
                        "kind": "code",
                        "text": "N"
                      },
                      {
                        "kind": "text",
                        "text": " represents the number of non-NaN\nelements.  By default "
                      },
                      {
                        "kind": "code",
                        "text": "ddof"
                      },
                      {
                        "kind": "text",
                        "text": " is zero."
                      }
                    ],
                    "type": "paragraph"
