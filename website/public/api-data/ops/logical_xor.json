                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.logical_xor(True, False)"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.logical_xor([True, True, False, False], [True, False, True, False])"
              },
              {
                "kind": "output",
                "text": "array([False,  True,  True, False])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = fnp.arange(5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.logical_xor(x < 1, x > 3)"
              },
              {
                "kind": "output",
                "text": "array([ True, False, False, False,  True])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
