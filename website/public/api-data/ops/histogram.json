                "text": "we.histogram([[1, 2, 1], [1, 0, 1]], bins=[0,1,2,3])"
              },
              {
                "kind": "output",
                "text": "(array([1, 4, 1]), array([0, 1, 2, 3]))"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.arange(5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "hist, bin_edges = we.histogram(a, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "hist"
              },
              {
                "kind": "output",
                "text": "array([0.5, 0. , 0.5, 0. , 0. , 0.5, 0. , 0.5, 0. , 0.5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "hist.sum()"
              },
              {
                "kind": "output",
                "text": "2.4999999999999996"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.sum(hist * we.diff(bin_edges))"
              },
              {
                "kind": "output",
                "text": "1.0"
              }
            ],
            "type": "doctest_block"
          },
