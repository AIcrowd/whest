        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "All but the last (righthand-most) bin is half-open.  In other words,\nif "
              },
              {
                "kind": "code",
                "text": "bins"
              },
              {
                "kind": "text",
                "text": " is:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "[1, 2, 3, 4]",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "then the first bin is "
              },
              {
                "kind": "code",
                "text": "[1, 2)"
              },
              {
                "kind": "text",
                "text": " (including 1, but excluding 2) and\nthe second "
              },
              {
                "kind": "code",
                "text": "[2, 3)"
              },
              {
                "kind": "text",
                "text": ".  The last bin, however, is "
              },
              {
                "kind": "code",
                "text": "[3, 4]"
              },
              {
                "kind": "text",
                "text": ", which\n"
              },
              {
                "kind": "emphasis",
                "text": "includes"
              },
              {
                "kind": "text",
                "text": " 4."
              }
            ],
            "type": "paragraph"
          }
        ],
