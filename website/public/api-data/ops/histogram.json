                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.histogram([1, 2, 1], bins=[0, 1, 2, 3])"
              },
              {
