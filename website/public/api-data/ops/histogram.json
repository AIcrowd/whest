          {
            "argument_inline": [],
            "content_blocks": [
              {
                "language": "python",
                "text": "import matplotlib.pyplot as plt\nimport whest as we\n\nrng = we.random.RandomState(10)  # deterministic random data\na = we.hstack((rng.normal(size=1000),\n               rng.normal(loc=5, scale=2, size=1000)))\nplt.hist(a, bins='auto')  # arguments are passed to we.histogram\nplt.title(\"Histogram with 'auto' bins\")\nplt.show()",
                "type": "literal_block"
              }
            ],
