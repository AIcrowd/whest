        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input data. The histogram is computed over the flattened array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input data. The histogram is computed over the flattened array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "bins"
                      },
                      {
                        "kind": "text",
                        "text": " is an int, it defines the number of equal-width\nbins in the given range (10, by default). If "
                      },
                      {
                        "kind": "code",
                        "text": "bins"
                      },
                      {
                        "kind": "text",
                        "text": " is a\nsequence, it defines a monotonically increasing array of bin edges,\nincluding the rightmost edge, allowing for non-uniform bin widths."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "bins"
                      },
                      {
                        "kind": "text",
                        "text": " is a string, it defines the method used to calculate the\noptimal bin width, as defined by "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/histogram_bin_edges",
                        "kind": "link",
                        "target": "histogram_bin_edges",
                        "text": "histogram_bin_edges"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or sequence of scalars or str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If "
                  },
                  {
                    "kind": "code",
                    "text": "bins"
                  },
                  {
                    "kind": "text",
                    "text": " is an int, it defines the number of equal-width\nbins in the given range (10, by default). If "
                  },
                  {
                    "kind": "code",
                    "text": "bins"
                  },
                  {
                    "kind": "text",
                    "text": " is a\nsequence, it defines a monotonically increasing array of bin edges,\nincluding the rightmost edge, allowing for non-uniform bin widths."
                  }
                ],
                "name": "bins",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The lower and upper range of the bins.  If not provided, range\nis simply "
                      },
                      {
                        "kind": "code",
                        "text": "(a.min(), a.max())"
                      },
                      {
                        "kind": "text",
                        "text": ".  Values outside the range are\nignored. The first element of the range must be less than or\nequal to the second. "
                      },
                      {
                        "kind": "code",
                        "text": "range"
                      },
                      {
                        "kind": "text",
                        "text": " affects the automatic bin\ncomputation as well. While bin width is computed to be optimal\nbased on the actual data within "
                      },
                      {
                        "kind": "code",
                        "text": "range"
                      },
                      {
                        "kind": "text",
                        "text": ", the bin count will fill\nthe entire range including portions containing no data."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(float, float), optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The lower and upper range of the bins.  If not provided, range\nis simply "
                  },
                  {
                    "kind": "code",
                    "text": "(a.min(), a.max())"
                  },
                  {
                    "kind": "text",
                    "text": ".  Values outside the range are\nignored. The first element of the range must be less than or\nequal to the second. "
                  },
                  {
                    "kind": "code",
                    "text": "range"
                  },
                  {
                    "kind": "text",
                    "text": " affects the automatic bin\ncomputation as well. While bin width is computed to be optimal\nbased on the actual data within "
                  },
                  {
                    "kind": "code",
                    "text": "range"
                  },
                  {
                    "kind": "text",
                    "text": ", the bin count will fill\nthe entire range including portions containing no data."
                  }
                ],
                "name": "range",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array of weights, of the same shape as "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ".  Each value in\n"
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " only contributes its associated weight towards the bin count\n(instead of 1). If "
                      },
                      {
                        "kind": "code",
                        "text": "density"
                      },
                      {
                        "kind": "text",
                        "text": " is True, the weights are\nnormalized, so that the integral of the density over the range\nremains 1.\nPlease note that the "
                      },
                      {
                        "kind": "code",
                        "text": "dtype"
                      },
                      {
                        "kind": "text",
                        "text": " of "
                      },
                      {
                        "kind": "code",
                        "text": "weights"
                      },
                      {
                        "kind": "text",
                        "text": " will also become the\n"
                      },
                      {
                        "kind": "code",
                        "text": "dtype"
                      },
                      {
                        "kind": "text",
                        "text": " of the returned accumulator ("
                      },
                      {
                        "kind": "code",
                        "text": "hist"
                      },
                      {
                        "kind": "text",
                        "text": "), so it must be\nlarge enough to hold accumulated values as well."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An array of weights, of the same shape as "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": ".  Each value in\n"
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " only contributes its associated weight towards the bin count\n(instead of 1). If "
                  },
                  {
                    "kind": "code",
                    "text": "density"
                  },
                  {
                    "kind": "text",
                    "text": " is True, the weights are\nnormalized, so that the integral of the density over the range\nremains 1.\nPlease note that the "
                  },
                  {
                    "kind": "code",
                    "text": "dtype"
                  },
                  {
                    "kind": "text",
                    "text": " of "
                  },
                  {
                    "kind": "code",
                    "text": "weights"
                  },
                  {
                    "kind": "text",
                    "text": " will also become the\n"
                  },
                  {
                    "kind": "code",
                    "text": "dtype"
                  },
                  {
                    "kind": "text",
                    "text": " of the returned accumulator ("
                  },
                  {
                    "kind": "code",
                    "text": "hist"
                  },
                  {
                    "kind": "text",
                    "text": "), so it must be\nlarge enough to hold accumulated values as well."
                  }
                ],
                "name": "weights",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "False"
                      },
                      {
                        "kind": "text",
                        "text": ", the result will contain the number of samples in\neach bin. If "
                      },
                      {
                        "kind": "code",
                        "text": "True"
                      },
                      {
                        "kind": "text",
                        "text": ", the result is the value of the\nprobability "
                      },
                      {
                        "kind": "emphasis",
                        "text": "density"
                      },
                      {
                        "kind": "text",
                        "text": " function at the bin, normalized such that\nthe "
                      },
                      {
                        "kind": "emphasis",
                        "text": "integral"
                      },
                      {
                        "kind": "text",
                        "text": " over the range is 1. Note that the sum of the\nhistogram values will not be equal to 1 unless bins of unity\nwidth are chosen; it is not a probability "
                      },
                      {
                        "kind": "emphasis",
                        "text": "mass"
                      },
                      {
                        "kind": "text",
                        "text": " function."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
