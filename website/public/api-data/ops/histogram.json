              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.histogram(we.arange(4), bins=we.arange(5), density=True)"
              },
              {
                "kind": "output",
                "text": "(array([0.25, 0.25, 0.25, 0.25]), array([0, 1, 2, 3, 4]))"
              },
              {
                "kind": "input",
