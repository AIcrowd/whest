                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.zeros((3, 4, 5))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.moveaxis(x, 0, -1).shape"
              },
              {
                "kind": "output",
                "text": "(4, 5, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.moveaxis(x, -1, 0).shape"
