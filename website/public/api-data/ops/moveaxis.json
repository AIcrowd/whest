                "kind": "output",
                "text": "(5, 4, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.swapaxes(x, 0, -1).shape"
              },
              {
                "kind": "output",
                "text": "(5, 4, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
