              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.cumulative_sum(b,axis=0)  # sum over rows for each of the 3 columns"
              },
              {
                "kind": "output",
                "text": "array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "       [5, 7, 9]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.cumulative_sum(b,axis=1)  # sum over columns for each of the 2 rows"
              },
              {
                "kind": "output",
                "text": "array([[ 1,  3,  6],"
              },
              {
                "kind": "output",
                "text": "       [ 4,  9, 15]])"
              }
            ],
            "type": "doctest_block"
          },
