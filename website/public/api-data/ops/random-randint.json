  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return random integers from "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": " (inclusive) to "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " (exclusive)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return random integers from the \"discrete uniform\" distribution of\nthe specified dtype in the \"half-open\" interval ["
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": "). If\n"
              },
              {
                "kind": "code",
                "text": "high"
              },
              {
                "kind": "text",
                "text": " is None (the default), then results are from [0, "
              },
              {
                "kind": "code",
                "text": "low"
              },
              {
                "kind": "text",
                "text": ")."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "New code should use the "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.integers.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator.integers",
                    "text": "integers"
                  },
                  {
                    "kind": "text",
                    "text": "\nmethod of a "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random.Generator.html",
                    "href": "",
                    "kind": "link",
                    "target": "random.Generator",
                    "text": "Generator"
                  },
                  {
                    "kind": "text",
                    "text": " instance instead;\nplease see the "
                  },
                  {
                    "display_text": "random-quick-start",
                    "explicit_title": false,
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.random-quick-start.html",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "random-quick-start",
                    "role": "ref",
                    "suppress_link": false,
                    "target": "random-quick-start",
                    "unresolved": false
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "note",
            "options": [],
            "raw_source": ".. note::\n    New code should use the `~we.random.Generator.integers`\n    method of a `~we.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
            "supported": true,
            "type": "directive_block"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Lowest (signed) integers to be drawn from the distribution (unless\n"
                      },
                      {
                        "kind": "code",
                        "text": "high=None"
                      },
                      {
                        "kind": "text",
                        "text": ", in which case this parameter is one above the\n"
                      },
                      {
                        "kind": "emphasis",
                        "text": "highest"
                      },
                      {
                        "kind": "text",
                        "text": " such integer)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or array-like of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Lowest (signed) integers to be drawn from the distribution (unless\n"
                  },
                  {
                    "kind": "code",
                    "text": "high=None"
                  },
                  {
                    "kind": "text",
                    "text": ", in which case this parameter is one above the\n"
                  },
                  {
                    "kind": "emphasis",
                    "text": "highest"
                  },
                  {
                    "kind": "text",
                    "text": " such integer)."
                  }
                ],
                "name": "low",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If provided, one above the largest (signed) integer to be drawn\nfrom the distribution (see above for behavior if "
                      },
                      {
                        "kind": "code",
                        "text": "high=None"
                      },
                      {
                        "kind": "text",
                        "text": ").\nIf array-like, must contain integer values"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or array-like of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If provided, one above the largest (signed) integer to be drawn\nfrom the distribution (see above for behavior if "
                  },
                  {
                    "kind": "code",
                    "text": "high=None"
                  },
                  {
                    "kind": "text",
                    "text": ").\nIf array-like, must contain integer values"
                  }
                ],
                "name": "high",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  Default is None, in which case a\nsingle value is returned."
                  }
                ],
                "name": "size",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Desired dtype of the result. Byteorder must be native.\nThe default value is long."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [
                      {
                        "inline": [
                          {
                            "kind": "text",
                            "text": "This function defaults to the C-long dtype, which is 32bit on windows\nand otherwise 64bit on 64bit platforms (and 32bit on 32bit ones).\nSince NumPy 2.0, NumPy's default integer is 32bit on 32bit platforms\nand 64bit on 64bit platforms.  Which corresponds to "
                          },
                          {
                            "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.intp.html",
                            "href": "",
                            "kind": "link",
                            "target": "intp",
                            "text": "we.intp"
                          },
                          {
                            "kind": "text",
                            "text": ".\n("
                          },
                          {
                            "kind": "code",
                            "text": "dtype=int"
                          },
                          {
                            "kind": "text",
                            "text": " is not the same as in most NumPy functions.)"
                          }
                        ],
                        "type": "paragraph"
                      }
                    ],
                    "directive": "warning",
                    "options": [],
                    "raw_source": ".. warning::\n  This function defaults to the C-long dtype, which is 32bit on windows\n  and otherwise 64bit on 64bit platforms (and 32bit on 32bit ones).\n  Since NumPy 2.0, NumPy's default integer is 32bit on 32bit platforms\n  and 64bit on 64bit platforms.  Which corresponds to `we.intp`.\n  (`dtype=int` is not the same as in most NumPy functions.)",
                    "supported": true,
                    "type": "directive_block"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Desired dtype of the result. Byteorder must be native.\nThe default value is long."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              }
            ],
