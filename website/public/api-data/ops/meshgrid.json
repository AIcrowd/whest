                    "text": " to\n"
                  },
                  {
                    "kind": "code",
                    "text": "(1, ..., 1, Ni, 1, ..., 1)"
                  },
                  {
                    "kind": "text",
                    "text": ".  These sparse coordinate grids are\nintended to be use with "
                  },
                  {
                    "display_text": "basics.broadcasting",
                    "explicit_title": false,
                    "external_url": "",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "basics.broadcasting",
                    "role": "ref",
