                "name": "sparse",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If False, a view into the original arrays are returned in order to\nconserve memory.  Default is True.  Please note that\n"
                      },
                      {
                        "kind": "code",
                        "text": "sparse=False, copy=False"
                      },
                      {
                        "kind": "text",
                        "text": " will likely return non-contiguous\narrays.  Furthermore, more than one element of a broadcast array\nmay refer to a single memory location.  If you need to write to the\narrays, make copies first."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If False, a view into the original arrays are returned in order to\nconserve memory.  Default is True.  Please note that\n"
                  },
                  {
                    "kind": "code",
