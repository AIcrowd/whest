                        "kind": "text",
                        "text": " to\n"
                      },
                      {
                        "kind": "code",
                        "text": "(1, ..., 1, Ni, 1, ..., 1)"
                      },
                      {
                        "kind": "text",
                        "text": ".  These sparse coordinate grids are\nintended to be use with "
                      },
                      {
                        "display_text": "basics.broadcasting",
                        "explicit_title": false,
                        "external_url": "",
                        "href": "",
                        "kind": "role_reference",
                        "original_target": "basics.broadcasting",
                        "role": "ref",
                        "suppress_link": false,
                        "target": "basics.broadcasting",
                        "unresolved": true
                      },
                      {
                        "kind": "text",
                        "text": ".  When all\ncoordinates are used in an expression, broadcasting still leads to a\nfully-dimensonal result array."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Default is False."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True the shape of the returned coordinate array for dimension "
                  },
                  {
                    "kind": "emphasis",
                    "text": "i"
                  },
                  {
                    "kind": "text",
                    "text": "\nis reduced from "
