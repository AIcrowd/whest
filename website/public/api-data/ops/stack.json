    "notes": "Join arrays along new axis. Cost: numel(output).",
    "summary": "Join a sequence of arrays along a new axis.",
    "signature": "we.stack(arrays, axis=0, out=None, *, dtype=None, casting='same_kind')"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Join a sequence of arrays along a new axis."
          },
          {
            "type": "paragraph",
            "text": "The ``axis`` parameter specifies the index of the new axis in the\ndimensions of the result. For example, if ``axis=0`` it will be the first\ndimension and if ``axis=-1`` it will be the last dimension."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "arrays",
            "type": "sequence of ndarrays",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Each array must have the same shape. In the case of a single ndarray\narray_like input, it will be treated as a sequence of arrays; i.e.,\neach element along the zeroth axis is treated as a separate array."
              }
            ]
          },
          {
            "name": "axis",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The axis in the result array along which the input arrays are stacked."
              }
            ]
          },
          {
            "name": "out",
            "type": "ndarray, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If provided, the destination to place the result. The shape must be\ncorrect, matching that of what stack would have returned if no\nout argument were specified."
              }
            ]
          },
          {
            "name": "dtype",
            "type": "str or dtype",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If provided, the destination array will have this dtype. Cannot be\nprovided together with `out`."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.24",
                "body": "",
                "raw": ".. versionadded:: 1.24"
              }
            ]
          },
          {
            "name": "casting",
            "type": "{'no', 'equiv', 'safe', 'same_kind', 'unsafe'}, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Controls what kind of data casting may occur. Defaults to 'same_kind'."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.24",
                "body": "",
                "raw": ".. versionadded:: 1.24"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "stacked",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The stacked array has one more dimension than the input arrays."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> rng = np.random.default_rng()\n>>> arrays = [rng.normal(size=(3,4)) for _ in range(10)]\n>>> np.stack(arrays, axis=0).shape\n(10, 3, 4)"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.stack(arrays, axis=1).shape\n(3, 10, 4)"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.stack(arrays, axis=2).shape\n(3, 4, 10)"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> a = np.array([1, 2, 3])\n>>> b = np.array([4, 5, 6])\n>>> np.stack((a, b))\narray([[1, 2, 3],\n       [4, 5, 6]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.stack((a, b), axis=-1)\narray([[1, 4],\n       [2, 5],\n       [3, 6]])"
          }
        ]
      },
