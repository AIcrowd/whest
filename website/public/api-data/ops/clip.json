  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Clip (limit) the values in an array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given an interval, values outside the interval are clipped to\nthe interval edges.  For example, if an interval of "
              },
              {
                "kind": "code",
                "text": "[0, 1]"
              },
              {
                "kind": "text",
                "text": "\nis specified, values smaller than 0 become 0, and values larger\nthan 1 become 1."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Equivalent to but faster than "
              },
              {
                "kind": "code",
                "text": "we.minimum(a_max, we.maximum(a, a_min))"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "No check is performed to ensure "
              },
              {
                "kind": "code",
                "text": "a_min < a_max"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
