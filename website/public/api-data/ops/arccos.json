                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The angle of the ray intersecting the unit circle at the given\n"
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": "-coordinate in radians [0, pi].\nThis is a scalar if "
                      },
