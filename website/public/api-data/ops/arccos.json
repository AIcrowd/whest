        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/arccos",
                "kind": "link",
                "target": "arccos",
                "text": "arccos"
              },
              {
                "kind": "text",
                "text": " is a multivalued function: for each "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " there are infinitely\nmany numbers "
              },
              {
                "kind": "code",
                "text": "z"
              },
              {
                "kind": "text",
                "text": " such that "
              },
              {
                "kind": "code",
                "text": "cos(z) = x"
              },
              {
                "kind": "text",
                "text": ". The convention is to return\nthe angle "
              },
              {
                "kind": "code",
                "text": "z"
              },
              {
                "kind": "text",
                "text": " whose real part lies in "
              },
              {
                "kind": "code",
                "text": "[0, pi]"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For real-valued input data types, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arccos",
                "kind": "link",
                "target": "arccos",
                "text": "arccos"
              },
              {
                "kind": "text",
                "text": " always returns real output.\nFor each value that cannot be expressed as a real number or infinity,\nit yields "
              },
              {
                "kind": "code",
                "text": "nan"
              },
              {
                "kind": "text",
                "text": " and sets the "
              },
              {
                "kind": "code",
                "text": "invalid"
              },
              {
                "kind": "text",
                "text": " floating point error flag."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For complex-valued input, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arccos",
                "kind": "link",
                "target": "arccos",
                "text": "arccos"
              },
              {
                "kind": "text",
                "text": " is a complex analytic function that\nhas branch cuts "
              },
              {
                "kind": "code",
                "text": "[-inf, -1]"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "[1, inf]"
              },
              {
                "kind": "text",
                "text": " and is continuous from\nabove on the former and from below on the latter."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The inverse "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/cos",
                "kind": "link",
                "target": "cos",
                "text": "cos"
              },
              {
                "kind": "text",
                "text": " is also known as "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arccos",
                "kind": "link",
                "target": "arccos",
                "text": "acos"
              },
              {
                "kind": "text",
                "text": " or cos^-1."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "M. Abramowitz and I.A. Stegun, \"Handbook of Mathematical Functions\",\n10th printing, 1964, pp. 79.\n"
              },
              {
                "external_url": "https://personal.math.ubc.ca/~cbm/aands/page_79.htm",
