        "title": "References"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "We expect the arccos of 1 to be 0, and of -1 to be pi:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.arccos([1, -1])"
              },
              {
                "kind": "output",
                "text": "array([ 0.        ,  3.14159265])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Plot arccos:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.linspace(-1, 1, num=100)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(x, we.arccos(x))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.axis('tight')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
