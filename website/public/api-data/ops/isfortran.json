        "title": "Returns"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "fnp.array allows to specify whether the array is written in C-contiguous\norder (last index varies the fastest), or FORTRAN-contiguous order in\nmemory (first index varies the fastest)."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[1, 2, 3], [4, 5, 6]], order='C')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "       [4, 5, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.isfortran(a)"
              },
              {
                "kind": "output",
                "text": "False"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = fnp.array([[1, 2, 3], [4, 5, 6]], order='F')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b"
              },
              {
                "kind": "output",
                "text": "array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "       [4, 5, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.isfortran(b)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The transpose of a C-ordered array is a FORTRAN-ordered array."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[1, 2, 3], [4, 5, 6]], order='C')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[1, 2, 3],"
              },
              {
                "kind": "output",
                "text": "       [4, 5, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.isfortran(a)"
              },
              {
                "kind": "output",
                "text": "False"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = a.T"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b"
              },
              {
                "kind": "output",
                "text": "array([[1, 4],"
              },
              {
                "kind": "output",
                "text": "       [2, 5],"
              },
              {
                "kind": "output",
                "text": "       [3, 6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.isfortran(b)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "C-ordered arrays evaluate as False even if they are also FORTRAN-ordered."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.isfortran(fnp.array([1, 2], order='F'))"
              },
              {
                "kind": "output",
                "text": "False"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
