            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = we.random.standard_cauchy(1000000)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = s[(s>-25) & (s<25)]  # truncate distribution so it plots well"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.hist(s, bins=100)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
