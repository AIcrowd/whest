  "op": {
    "name": "linalg.solve",
    "module": "numpy.linalg",
    "whest_ref": "we.linalg.solve",
    "numpy_ref": "np.linalg.solve",
    "category": "counted_custom",
    "status": "supported",
    "weight": 4.0,
    "cost_formula": "n^3",
    "cost_formula_latex": "$n^3$",
    "notes": "Solve Ax=b. Cost: $n^3$.",
    "summary": "Solve a linear matrix equation, or system of linear scalar equations.",
    "signature": "we.linalg.solve(a, b)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Solve a linear matrix equation, or system of linear scalar equations."
          },
          {
            "type": "paragraph",
            "text": "Computes the \"exact\" solution, `x`, of the well-determined, i.e., full\nrank, linear matrix equation `ax = b`."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a",
            "type": "(..., M, M) array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Coefficient matrix."
              }
            ]
          },
          {
            "name": "b",
            "type": "{(M,), (..., M, K)}, array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Ordinate or \"dependent variable\" values."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "x",
            "type": "{(..., M,), (..., M, K)} ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Solution to the system a x = b.  Returned shape is (..., M) if b is\nshape (M,) and (..., M, K) if b is (..., M, K), where the \"...\" part is\nbroadcasted between a and b."
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Broadcasting rules apply, see the `numpy.linalg` documentation for\ndetails."
          },
          {
            "type": "paragraph",
            "text": "The solutions are computed using LAPACK routine ``_gesv``."
          },
          {
            "type": "paragraph",
            "text": "`a` must be square and of full-rank, i.e., all rows (or, equivalently,\ncolumns) must be linearly independent; if either is not true, use\n`lstsq` for the least-squares best \"solution\" of the\nsystem/equation."
          },
          {
            "type": "directive",
            "name": "versionchanged:: 2.0",
            "body": "",
            "raw": ".. versionchanged:: 2.0"
          },
          {
            "type": "paragraph",
            "text": "   The b array is only treated as a shape (M,) column vector if it is\n   exactly 1-dimensional. In all other instances it is treated as a stack\n   of (M, K) matrices. Previously b would be treated as a stack of (M,)\n   vectors if b.ndim was equal to a.ndim - 1."
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Solve the system of equations:\n``x0 + 2 * x1 = 1`` and\n``3 * x0 + 5 * x1 = 2``:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> a = np.array([[1, 2], [3, 5]])\n>>> b = np.array([1, 2])\n>>> x = np.linalg.solve(a, b)\n>>> x\narray([-1.,  1.])"
          },
          {
            "type": "paragraph",
            "text": "Check that the solution is correct:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.allclose(np.dot(a, x), b)\nTrue"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "scipy.linalg.solve \u2014 Similar function in SciPy."
          }
        ]
      }
    ]
  }
}