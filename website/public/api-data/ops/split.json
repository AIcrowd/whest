            "inline": [
              {
                "kind": "text",
                "text": "Split an array into multiple sub-arrays as views into "
              },
              {
                "kind": "code",
                "text": "ary"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array to be divided into sub-arrays."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array to be divided into sub-arrays."
                  }
                ],
                "name": "ary",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "indices_or_sections"
                      },
                      {
                        "kind": "text",
                        "text": " is an integer, N, the array will be divided\ninto N equal arrays along "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": ".  If such a split is not possible,\nan error is raised."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "indices_or_sections"
                      },
                      {
                        "kind": "text",
                        "text": " is a 1-D array of sorted integers, the entries\nindicate where along "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " the array is split.  For example,\n"
                      },
                      {
                        "kind": "code",
                        "text": "[2, 3]"
                      },
                      {
                        "kind": "text",
                        "text": " would, for "
                      },
                      {
                        "kind": "code",
                        "text": "axis=0"
                      },
                      {
                        "kind": "text",
                        "text": ", result in"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "ary[:2]"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "ary[2:3]"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "ary[3:]"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If an index exceeds the dimension of the array along "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": ",\nan empty sub-array is returned correspondingly."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or 1-D array",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If "
                  },
                  {
                    "kind": "code",
                    "text": "indices_or_sections"
                  },
                  {
                    "kind": "text",
                    "text": " is an integer, N, the array will be divided\ninto N equal arrays along "
                  },
                  {
                    "kind": "code",
                    "text": "axis"
                  },
                  {
                    "kind": "text",
                    "text": ".  If such a split is not possible,\nan error is raised."
                  }
                ],
                "name": "indices_or_sections",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The axis along which to split, default is 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The axis along which to split, default is 0."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              }
            ],
