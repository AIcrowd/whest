  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the product of array elements over a given axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input data."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input data."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which a product is performed.  The default,\naxis=None, will calculate the product of all the elements in the\ninput array. If axis is negative it counts from the last to the\nfirst axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If axis is a tuple of ints, a product is performed on all of the\naxes specified in the tuple instead of a single axis or all the\naxes as before."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "None or int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which a product is performed.  The default,\naxis=None, will calculate the product of all the elements in the\ninput array. If axis is negative it counts from the last to the\nfirst axis."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The type of the returned array, as well as of the accumulator in\nwhich the elements are multiplied.  The dtype of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is used by\ndefault unless "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " has an integer dtype of less precision than the\ndefault platform integer.  In that case, if "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is signed then the\nplatform integer is used while if "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is unsigned then an unsigned\ninteger of the same precision as the platform integer is used."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The type of the returned array, as well as of the accumulator in\nwhich the elements are multiplied.  The dtype of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is used by\ndefault unless "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " has an integer dtype of less precision than the\ndefault platform integer.  In that case, if "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is signed then the\nplatform integer is used while if "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is unsigned then an unsigned\ninteger of the same precision as the platform integer is used."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Alternative output array in which to place the result. It must have\nthe same shape as the expected output, but the type of the output\nvalues will be cast if necessary."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Alternative output array in which to place the result. It must have\nthe same shape as the expected output, but the type of the output\nvalues will be cast if necessary."
                  }
                ],
                "name": "out",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If this is set to True, the axes which are reduced are left in the\nresult as dimensions with size one. With this option, the result\nwill broadcast correctly against the input array."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If the default value is passed, then "
                      },
                      {
                        "kind": "code",
                        "text": "keepdims"
                      },
                      {
                        "kind": "text",
                        "text": " will not be\npassed through to the "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/prod",
                        "kind": "link",
                        "target": "prod",
                        "text": "prod"
                      },
                      {
                        "kind": "text",
                        "text": " method of sub-classes of\n"
                      },
                      {
                        "kind": "code",
                        "text": "ndarray"
                      },
                      {
                        "kind": "text",
                        "text": ", however any non-default value will be.  If the\nsub-class' method does not implement "
                      },
                      {
                        "kind": "code",
                        "text": "keepdims"
                      },
                      {
                        "kind": "text",
                        "text": " any\nexceptions will be raised."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If this is set to True, the axes which are reduced are left in the\nresult as dimensions with size one. With this option, the result\nwill broadcast correctly against the input array."
                  }
                ],
