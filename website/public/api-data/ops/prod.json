        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Arithmetic is modular when using integer types, and no error is\nraised on overflow.  That means that, on a 32-bit platform:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([536870910, 536870910, 536870910, 536870910])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod(x)"
              },
              {
                "kind": "output",
                "text": "16 # may vary"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The product of an empty array is the neutral element 1:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod([])"
              },
              {
                "kind": "output",
                "text": "1.0"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "By default, calculate the product of all elements:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod([1.,2.])"
              },
              {
                "kind": "output",
                "text": "2.0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Even when the input array is two-dimensional:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[1., 2.], [3., 4.]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod(a)"
              },
              {
                "kind": "output",
                "text": "24.0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "But we can also specify the axis over which to multiply:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod(a, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([  2.,  12.])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod(a, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([3., 8.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Or select specific elements to include:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod([1., we.nan, 3.], where=[True, False, True])"
              },
              {
                "kind": "output",
                "text": "3.0"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If the type of "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is unsigned, then the output type is\nthe unsigned platform integer:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([1, 2, 3], dtype=we.uint8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod(x).dtype == we.uint"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is of a signed integer type, then the output type\nis the default platform integer:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([1, 2, 3], dtype=we.int8)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod(x).dtype == int"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "You can also start the product with a value other than one:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.prod([1, 2], initial=5)"
              },
              {
                "kind": "output",
                "text": "10"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
