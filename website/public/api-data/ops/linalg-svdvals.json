            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = fnp.linalg.svdvals([[1, 2, 3],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[2, 4, 6],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[-1, 1, -1]]); s"
              },
              {
                "kind": "output",
                "text": "array([8.38434191e+00, 1.64402274e+00, 2.31534378e-16])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.count_nonzero(s > 1e-10)  # Matrix of rank 2"
              },
              {
                "kind": "output",
                "text": "2"
              }
            ],
            "type": "doctest_block"
          }
