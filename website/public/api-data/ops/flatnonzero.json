    "summary": "Return indices that are non-zero in the flattened version of a.",
    "signature": "we.flatnonzero(a)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return indices that are non-zero in the flattened version of a."
          },
          {
            "type": "paragraph",
            "text": "This is equivalent to ``np.nonzero(np.ravel(a))[0]``."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input data."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "res",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Output array, containing the indices of the elements of ``a.ravel()``\nthat are non-zero."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> x = np.arange(-2, 3)\n>>> x\narray([-2, -1,  0,  1,  2])\n>>> np.flatnonzero(x)\narray([0, 1, 3, 4])"
          },
          {
            "type": "paragraph",
            "text": "Use the indices of the non-zero elements as an index array to extract\nthese elements:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x.ravel()[np.flatnonzero(x)]\narray([-2, -1,  1,  2])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "nonzero \u2014 Return the indices of the non-zero elements of the input array."
          },
          {
            "type": "paragraph",
            "text": "ravel \u2014 Return a 1-D array containing the elements of the input array."
          }
        ]
      }
    ]
  }
