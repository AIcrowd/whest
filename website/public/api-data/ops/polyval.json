            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.polyval([3,0,1], 5)  # 3 * 5**2 + 0 * 5**1 + 1"
              },
              {
                "kind": "output",
                "text": "76"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.polyval([3,0,1], we.poly1d(5))"
              },
              {
                "kind": "output",
                "text": "poly1d([76])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.polyval(we.poly1d([3,0,1]), 5)"
              },
              {
                "kind": "output",
                "text": "76"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.polyval(we.poly1d([3,0,1]), we.poly1d(5))"
              },
              {
                "kind": "output",
                "text": "poly1d([76])"
              }
            ],
            "type": "doctest_block"
          }
