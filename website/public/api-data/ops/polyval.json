        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Horner's scheme "
              },
              {
                "kind": "text",
                "text": "[1]_"
              },
              {
                "kind": "text",
                "text": " is used to evaluate the polynomial. Even so,\nfor polynomials of high degree the values may be inaccurate due to\nrounding errors. Use carefully."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is a subtype of "
              },
              {
                "kind": "code",
                "text": "ndarray"
              },
              {
                "kind": "text",
                "text": " the return value will be of the same type."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
