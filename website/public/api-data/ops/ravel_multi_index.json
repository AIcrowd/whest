    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Converts a tuple of index arrays into an array of flat indices, applying boundary modes to the multi-index."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A tuple of integer arrays, one array for each dimension."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "tuple of array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A tuple of integer arrays, one array for each dimension."
                  }
                ],
                "name": "multi_index",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The shape of array into which the indices from "
                      },
                      {
                        "kind": "code",
                        "text": "multi_index"
                      },
                      {
                        "kind": "text",
                        "text": " apply."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "tuple of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The shape of array into which the indices from "
                  },
                  {
                    "kind": "code",
                    "text": "multi_index"
                  },
                  {
                    "kind": "text",
                    "text": " apply."
                  }
                ],
                "name": "dims",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Specifies how out-of-bounds indices are handled.  Can specify\neither one mode or a tuple of modes, one mode per index."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'raise' -- raise an error (default)"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'wrap' -- wrap around"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'clip' -- clip to the range"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "In 'clip' mode, a negative index which would normally\nwrap will clip to 0 instead."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'raise', 'wrap', 'clip'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Specifies how out-of-bounds indices are handled.  Can specify\neither one mode or a tuple of modes, one mode per index."
                  }
                ],
                "name": "mode",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Determines whether the multi-index should be viewed as\nindexing in row-major (C-style) or column-major\n(Fortran-style) order."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'C', 'F'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Determines whether the multi-index should be viewed as\nindexing in row-major (C-style) or column-major\n(Fortran-style) order."
