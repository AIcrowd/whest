              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.array_equal(a, a)"
              },
              {
                "kind": "output",
                "text": "False"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.array_equal(a, a, equal_nan=True)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When "
              },
              {
                "kind": "code",
                "text": "equal_nan"
              },
              {
                "kind": "text",
                "text": " is True, complex values with nan components are\nconsidered equal if either the real "
              },
              {
                "kind": "emphasis",
                "text": "or"
              },
              {
                "kind": "text",
                "text": " the imaginary components are nan."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([1 + 1j])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = a.copy()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a.real = fnp.nan"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b.imag = fnp.nan"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.array_equal(a, b, equal_nan=True)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
