  },
  "op": {
    "name": "array_equal",
    "module": "numpy",
    "whest_ref": "we.array_equal",
    "numpy_ref": "np.array_equal",
    "category": "counted_custom",
    "status": "supported",
    "weight": 1.0,
    "cost_formula": "per-operation",
    "cost_formula_latex": "varies",
    "notes": "Element-wise equality; cost = numel(a).",
    "summary": "True if two arrays have the same shape and elements, False otherwise.",
    "signature": "we.array_equal(a1, a2, equal_nan=False)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "True if two arrays have the same shape and elements, False otherwise."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a1, a2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input arrays."
              }
            ]
          },
          {
            "name": "equal_nan",
            "type": "bool",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Whether to compare NaN's as equal. If the dtype of a1 and a2 is\ncomplex, values will be considered equal if either the real or the\nimaginary component of a given value is ``nan``."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "b",
            "type": "bool",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Returns True if the arrays are equal."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.array_equal([1, 2], [1, 2])\nTrue"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.array_equal(np.array([1, 2]), np.array([1, 2]))\nTrue"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.array_equal([1, 2], [1, 2, 3])\nFalse"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.array_equal([1, 2], [1, 4])\nFalse"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> a = np.array([1, np.nan])\n>>> np.array_equal(a, a)\nFalse"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.array_equal(a, a, equal_nan=True)\nTrue"
          },
          {
            "type": "paragraph",
            "text": "When ``equal_nan`` is True, complex values with nan components are\nconsidered equal if either the real *or* the imaginary components are nan."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> a = np.array([1 + 1j])\n>>> b = a.copy()\n>>> a.real = np.nan\n>>> b.imag = np.nan\n>>> np.array_equal(a, b, equal_nan=True)\nTrue"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "allclose \u2014 Returns True if two arrays are element-wise equal within a tolerance."
          },
          {
            "type": "paragraph",
            "text": "array_equiv \u2014 Returns True if input arrays are shape consistent and all elements equal."
          }
        ]
      }
    ]
  }
