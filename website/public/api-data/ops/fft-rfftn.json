                    "inline": [
                      {
                        "kind": "text",
                        "text": "The truncated or zero-padded input, transformed along the axes\nindicated by "
                      },
                      {
                        "kind": "code",
                        "text": "axes"
                      },
                      {
                        "kind": "text",
                        "text": ", or by a combination of "
                      },
                      {
                        "kind": "code",
                        "text": "s"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ",\nas explained in the parameters section above.\nThe length of the last axis transformed will be "
                      },
                      {
                        "kind": "code",
                        "text": "s[-1]//2+1"
                      },
                      {
                        "kind": "text",
                        "text": ",\nwhile the remaining transformed axes will have lengths according to\n"
                      },
                      {
                        "kind": "code",
                        "text": "s"
                      },
                      {
                        "kind": "text",
                        "text": ", or unchanged from the input."
                      }
