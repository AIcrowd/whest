        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The transform for real input is performed over the last transformation\naxis, as by "
              },
              {
                "kind": "code",
                "text": "rfft"
              },
              {
                "kind": "text",
                "text": ", then the transform over the remaining axes is\nperformed as by "
              },
              {
                "kind": "code",
                "text": "fftn"
              },
              {
                "kind": "text",
                "text": ".  The order of the output is as for "
              },
              {
                "kind": "code",
                "text": "rfft"
              },
              {
                "kind": "text",
                "text": " for the\nfinal transformation axis, and as for "
              },
              {
                "kind": "code",
                "text": "fftn"
              },
              {
                "kind": "text",
                "text": " for the remaining\ntransformation axes."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "See "
              },
              {
                "kind": "code",
                "text": "fft"
              },
              {
                "kind": "text",
                "text": " for details, definitions and conventions used."
              }
            ],
            "type": "paragraph"
          }
        ],
