        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.ones((2, 2, 2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.fft.rfftn(a)"
              },
              {
                "kind": "output",
                "text": "array([[[8.+0.j,  0.+0.j], # may vary"
              },
              {
                "kind": "output",
                "text": "        [0.+0.j,  0.+0.j]],"
              },
              {
                "kind": "output",
                "text": "       [[0.+0.j,  0.+0.j],"
              },
              {
                "kind": "output",
                "text": "        [0.+0.j,  0.+0.j]]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.fft.rfftn(a, axes=(2, 0))"
              },
              {
                "kind": "output",
                "text": "array([[[4.+0.j,  0.+0.j], # may vary"
              },
              {
                "kind": "output",
