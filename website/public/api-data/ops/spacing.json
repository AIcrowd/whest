      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "It can be considered as a generalization of EPS:\n"
              },
              {
                "kind": "code",
                "text": "spacing(fnp.float64(1)) == fnp.finfo(fnp.float64).eps"
              },
              {
                "kind": "text",
                "text": ", and there\nshould not be any representable number between "
              },
              {
                "kind": "code",
                "text": "x + spacing(x)"
              },
              {
                "kind": "text",
                "text": " and\nx for any finite x."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Spacing of +- inf and NaN is NaN."
              }
            ],
            "type": "paragraph"
          }
        ],
