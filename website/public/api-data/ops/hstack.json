                "text": "a = fnp.array((1,2,3))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = fnp.array((4,5,6))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.hstack((a,b))"
              },
              {
                "kind": "output",
                "text": "array([1, 2, 3, 4, 5, 6])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[1],[2],[3]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = fnp.array([[4],[5],[6]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.hstack((a,b))"
              },
              {
                "kind": "output",
