                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and twos exponents "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " are used to construct\nfloating point numbers "
              },
