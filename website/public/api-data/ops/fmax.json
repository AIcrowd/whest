            "inline": [
              {
                "kind": "text",
                "text": "The fmax is equivalent to "
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.where(x1 >= x2, x1, x2).html",
                "href": "",
                "kind": "link",
                "target": "where(x1 >= x2, x1, x2)",
                "text": "we.where(x1 >= x2, x1, x2)"
              },
              {
                "kind": "text",
                "text": " when neither\nx1 nor x2 are NaNs, but it is faster and does proper broadcasting."
              }
            ],
            "type": "paragraph"
          }
