                "label": "we.histogram",
                "original_target": "histogram",
                "role": "",
                "target": "histogram",
                "unresolved": false
              },
              {
                "description": "Multidimensional histogram",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "Multidimensional histogram"
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/histogramdd",
                "label": "we.histogramdd",
                "original_target": "histogramdd",
                "role": "",
                "target": "histogramdd",
                "unresolved": false
              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "When "
              },
              {
                "kind": "code",
                "text": "density"
              },
              {
                "kind": "text",
                "text": " is True, then the returned histogram is the sample\ndensity, defined such that the sum over bins of the product\n"
              },
              {
                "kind": "code",
                "text": "bin_value * bin_area"
              },
              {
                "kind": "text",
                "text": " is 1."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Please note that the histogram does not follow the Cartesian convention\nwhere "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " values are on the abscissa and "
              },
              {
                "kind": "code",
                "text": "y"
              },
              {
                "kind": "text",
                "text": " values on the ordinate\naxis.  Rather, "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is histogrammed along the first dimension of the\narray (vertical), and "
              },
              {
                "kind": "code",
                "text": "y"
              },
              {
                "kind": "text",
                "text": " along the second dimension of the array\n(horizontal).  This ensures compatibility with "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/histogramdd",
                "kind": "link",
                "target": "histogramdd",
                "text": "histogramdd"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from matplotlib.image import NonUniformImage"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Construct a 2-D histogram with variable bin width. First define the bin\nedges:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "xedges = [0, 1, 3, 5]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "yedges = [0, 2, 3, 4, 6]"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Next we create a histogram H with random bin content:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.random.normal(2, 1, 100)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = we.random.normal(1, 1, 100)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "H, xedges, yedges = we.histogram2d(x, y, bins=(xedges, yedges))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# Histogram does not follow Cartesian convention (see Notes),"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# therefore transpose H for visualization purposes."
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "H = H.T"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "display_text": "imshow",
                "explicit_title": true,
                "external_url": "",
                "href": "",
                "kind": "role_reference",
                "original_target": "matplotlib.pyplot.imshow",
                "role": "func",
                "suppress_link": false,
                "target": "matplotlib.pyplot.imshow",
                "unresolved": true
              },
              {
                "kind": "text",
                "text": " can only display square bins:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fig = plt.figure(figsize=(7, 3))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax = fig.add_subplot(131, title='imshow: square bins')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.imshow(H, interpolation='nearest', origin='lower',"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "extent=[xedges[0], xedges[-1], yedges[0], yedges[-1]])"
              },
              {
                "kind": "output",
                "text": "<matplotlib.image.AxesImage object at 0x...>"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "display_text": "pcolormesh",
                "explicit_title": true,
                "external_url": "",
                "href": "",
                "kind": "role_reference",
                "original_target": "matplotlib.pyplot.pcolormesh",
                "role": "func",
                "suppress_link": false,
                "target": "matplotlib.pyplot.pcolormesh",
                "unresolved": true
              },
              {
                "kind": "text",
                "text": " can display actual edges:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax = fig.add_subplot(132, title='pcolormesh: actual edges',"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "aspect='equal')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "X, Y = we.meshgrid(xedges, yedges)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax.pcolormesh(X, Y, H)"
              },
              {
                "kind": "output",
                "text": "<matplotlib.collections.QuadMesh object at 0x...>"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "display_text": "NonUniformImage",
                "explicit_title": true,
                "external_url": "",
                "href": "",
                "kind": "role_reference",
                "original_target": "matplotlib.image.NonUniformImage",
                "role": "class",
                "suppress_link": false,
                "target": "matplotlib.image.NonUniformImage",
                "unresolved": true
              },
              {
                "kind": "text",
                "text": " can be used to\ndisplay actual bin edges with interpolation:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax = fig.add_subplot(133, title='NonUniformImage: interpolated',"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "aspect='equal', xlim=xedges[[0, -1]], ylim=yedges[[0, -1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "im = NonUniformImage(ax, interpolation='bilinear')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "xcenters = (xedges[:-1] + xedges[1:]) / 2"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ycenters = (yedges[:-1] + yedges[1:]) / 2"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "im.set_data(xcenters, ycenters, H)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax.add_image(im)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "It is also possible to construct a 2-D histogram without specifying bin\nedges:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# Generate non-symmetric test data"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "n = 10000"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.linspace(1, 100, n)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = 2*we.log(x) + we.random.rand(n) - 0.5"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# Compute 2d histogram. Note the order of x/y and xedges/yedges"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "H, yedges, xedges = we.histogram2d(y, x, bins=20)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Now we can plot the histogram using\n"
              },
              {
                "display_text": "pcolormesh",
                "explicit_title": true,
                "external_url": "",
                "href": "",
                "kind": "role_reference",
                "original_target": "matplotlib.pyplot.pcolormesh",
                "role": "func",
                "suppress_link": false,
                "target": "matplotlib.pyplot.pcolormesh",
                "unresolved": true
              },
              {
                "kind": "text",
                "text": ", and a\n"
              },
              {
                "display_text": "hexbin",
                "explicit_title": true,
                "external_url": "",
                "href": "",
                "kind": "role_reference",
                "original_target": "matplotlib.pyplot.hexbin",
                "role": "func",
                "suppress_link": false,
                "target": "matplotlib.pyplot.hexbin",
                "unresolved": true
              },
              {
                "kind": "text",
                "text": " for comparison."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# Plot histogram using pcolormesh"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fig, (ax1, ax2) = plt.subplots(ncols=2, sharey=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax1.pcolormesh(xedges, yedges, H, cmap='rainbow')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax1.plot(x, 2*we.log(x), 'k-')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax1.set_xlim(x.min(), x.max())"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ax1.set_ylim(y.min(), y.max())"
              },
