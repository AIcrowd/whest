{
  "detail_href": "/docs/api/ops/histogram2d/",
  "detail_json_href": "/api-data/ops/histogram2d.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the bi-dimensional histogram of two data samples."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array containing the x coordinates of the points to be\nhistogrammed."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape (N,)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An array containing the x coordinates of the points to be\nhistogrammed."
                  }
                ],
                "name": "x",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array containing the y coordinates of the points to be\nhistogrammed."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape (N,)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An array containing the y coordinates of the points to be\nhistogrammed."
                  }
                ],
                "name": "y",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The bin specification:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If int, the number of bins for the two dimensions (nx=ny=bins)."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If array_like, the bin edges for the two dimensions\n(x_edges=y_edges=bins)."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If [int, int], the number of bins in each dimension\n(nx, ny = bins)."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "If [array, array], the bin edges in each dimension\n(x_edges, y_edges = bins)."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "A combination [int, array] or [array, int], where int\nis the number of bins and array is the bin edges."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  }
                ],
                "data_type": "int or array_like or [int, int] or [array, array], optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The bin specification:"
                  }
                ],
                "name": "bins",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The leftmost and rightmost edges of the bins along each dimension\n(if not specified explicitly in the "
                      },
                      {
                        "kind": "code",
                        "text": "bins"
                      },
                      {
                        "kind": "text",
                        "text": " parameters):\n"
                      },
                      {
                        "kind": "code",
                        "text": "[[xmin, xmax], [ymin, ymax]]"
                      },
                      {
                        "kind": "text",
                        "text": ". All values outside of this range\nwill be considered outliers and not tallied in the histogram."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape(2,2), optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The leftmost and rightmost edges of the bins along each dimension\n(if not specified explicitly in the "
                  },
                  {
                    "kind": "code",
                    "text": "bins"
                  },
                  {
                    "kind": "text",
                    "text": " parameters):\n"
                  },
                  {
                    "kind": "code",
                    "text": "[[xmin, xmax], [ymin, ymax]]"
                  },
                  {
                    "kind": "text",
                    "text": ". All values outside of this range\nwill be considered outliers and not tallied in the histogram."
                  }
                ],
                "name": "range",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If False, the default, returns the number of samples in each bin.\nIf True, returns the probability "
                      },
                      {
                        "kind": "emphasis",
                        "text": "density"
                      },
                      {
                        "kind": "text",
                        "text": " function at the bin,\n"
                      },
                      {
                        "kind": "code",
                        "text": "bin_count / sample_count / bin_area"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If False, the default, returns the number of samples in each bin.\nIf True, returns the probability "
                  },
                  {
                    "kind": "emphasis",
                    "text": "density"
                  },
                  {
                    "kind": "text",
                    "text": " function at the bin,\n"
                  },
                  {
                    "kind": "code",
                    "text": "bin_count / sample_count / bin_area"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "density",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array of values "
                      },
                      {
                        "kind": "code",
                        "text": "w_i"
                      },
                      {
                        "kind": "text",
                        "text": " weighing each sample "
                      },
                      {
                        "kind": "code",
                        "text": "(x_i, y_i)"
                      },
                      {
                        "kind": "text",
                        "text": ".\nWeights are normalized to 1 if "
                      },
                      {
                        "kind": "code",
                        "text": "density"
                      },
                      {
                        "kind": "text",
                        "text": " is True. If "
                      },
                      {
                        "kind": "code",
                        "text": "density"
                      },
                      {
                        "kind": "text",
                        "text": " is\nFalse, the values of the returned histogram are equal to the sum of\nthe weights belonging to the samples falling into each bin."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape(N,), optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An array of values "
                  },
                  {
                    "kind": "code",
                    "text": "w_i"
                  },
                  {
                    "kind": "text",
                    "text": " weighing each sample "
                  },
                  {
                    "kind": "code",
                    "text": "(x_i, y_i)"
                  },
                  {
                    "kind": "text",
                    "text": ".\nWeights are normalized to 1 if "
                  },
                  {
                    "kind": "code",
                    "text": "density"
                  },
                  {
                    "kind": "text",
                    "text": " is True. If "
                  },
                  {
                    "kind": "code",
                    "text": "density"
                  },
                  {
                    "kind": "text",
                    "text": " is\nFalse, the values of the returned histogram are equal to the sum of\nthe weights belonging to the samples falling into each bin."
                  }
                ],
                "name": "weights",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The bi-dimensional histogram of samples "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": ". Values in "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": "\nare histogrammed along the first dimension and values in "
                      },
                      {
                        "kind": "code",
                        "text": "y"
                      },
                      {
                        "kind": "text",
                        "text": " are\nhistogrammed along the second dimension."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, shape(nx, ny)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The bi-dimensional histogram of samples "
                  },
                  {
                    "kind": "code",
                    "text": "x"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "y"
                  },
                  {
                    "kind": "text",
                    "text": ". Values in "
                  },
                  {
                    "kind": "code",
                    "text": "x"
                  },
                  {
                    "kind": "text",
                    "text": "\nare histogrammed along the first dimension and values in "
                  },
                  {
                    "kind": "code",
                    "text": "y"
                  },
                  {
                    "kind": "text",
                    "text": " are\nhistogrammed along the second dimension."
                  }
                ],
                "name": "H",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The bin edges along the first dimension."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, shape(nx+1,)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The bin edges along the first dimension."
                  }
                ],
                "name": "xedges",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The bin edges along the second dimension."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, shape(ny+1,)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The bin edges along the second dimension."
                  }
                ],
                "name": "yedges",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "1D histogram",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "1D histogram"
                  }
                ],
                "external_url": "",
