  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the indices of the bins to which each value in input array belongs."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "raw_kind": "table",
            "raw_text": "\n\n\n\n\n\nright\n\norder of bins\n\nreturned index i satisfies\n\nFalse\n\nincreasing\n\nbins[i-1] <= x < bins[i]\n\nTrue\n\nincreasing\n\nbins[i-1] < x <= bins[i]\n\nFalse\n\ndecreasing\n\nbins[i-1] > x >= bins[i]\n\nTrue\n\ndecreasing\n\nbins[i-1] >= x > bins[i]",
            "type": "raw_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If values in "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " are beyond the bounds of "
              },
              {
                "kind": "code",
                "text": "bins"
              },
              {
                "kind": "text",
                "text": ", 0 or "
              },
              {
                "kind": "code",
                "text": "len(bins)"
              },
              {
                "kind": "text",
                "text": " is\nreturned as appropriate."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array to be binned. Prior to NumPy 1.10.0, this array had to\nbe 1-dimensional, but can now have any shape."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array to be binned. Prior to NumPy 1.10.0, this array had to\nbe 1-dimensional, but can now have any shape."
                  }
                ],
                "name": "x",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array of bins. It has to be 1-dimensional and monotonic."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array of bins. It has to be 1-dimensional and monotonic."
                  }
                ],
                "name": "bins",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Indicating whether the intervals include the right or the left bin\nedge. Default behavior is (right==False) indicating that the interval\ndoes not include the right edge. The left bin end is open in this\ncase, i.e., bins[i-1] <= x < bins[i] is the default behavior for\nmonotonically increasing bins."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Indicating whether the intervals include the right or the left bin\nedge. Default behavior is (right==False) indicating that the interval\ndoes not include the right edge. The left bin end is open in this\ncase, i.e., bins[i-1] <= x < bins[i] is the default behavior for\nmonotonically increasing bins."
                  }
                ],
                "name": "right",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
