              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Create and plot a band-limited signal with random phases:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "t = we.arange(400)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "n = we.zeros((400,), dtype=complex)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "n[40:60] = we.exp(1j*we.random.uniform(0, 2*we.pi, (20,)))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = we.fft.ifft(n)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(t, s.real, label='real')"
              },
              {
                "kind": "output",
                "text": "[<matplotlib.lines.Line2D object at ...>]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(t, s.imag, '--', label='imaginary')"
              },
              {
                "kind": "output",
                "text": "[<matplotlib.lines.Line2D object at ...>]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.legend()"
              },
              {
                "kind": "output",
                "text": "<matplotlib.legend.Legend object at ...>"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
