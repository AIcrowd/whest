{
  "detail_href": "/docs/api/ops/fft-ifft/",
  "detail_json_href": "/api-data/ops/fft-ifft.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the one-dimensional inverse discrete Fourier Transform."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function computes the inverse of the one-dimensional "
              },
              {
                "kind": "emphasis",
                "text": "n"
              },
              {
                "kind": "text",
                "text": "-point\ndiscrete Fourier transform computed by "
              },
              {
                "kind": "code",
                "text": "fft"
              },
              {
                "kind": "text",
                "text": ".  In other words,\n"
              },
              {
                "kind": "code",
                "text": "ifft(fft(a)) == a"
              },
              {
                "kind": "text",
                "text": " to within numerical accuracy.\nFor a general description of the algorithm and definitions,\nsee "
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                "href": "",
                "kind": "link",
                "target": "fft",
                "text": "we.fft"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The input should be ordered in the same way as is returned by "
              },
              {
                "kind": "code",
                "text": "fft"
              },
              {
                "kind": "text",
                "text": ",\ni.e.,"
              }
            ],
            "type": "paragraph"
          },
          {
            "items": [
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "a[0]"
                      },
                      {
                        "kind": "text",
                        "text": " should contain the zero frequency term,"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "a[1:n//2]"
                      },
                      {
                        "kind": "text",
                        "text": " should contain the positive-frequency terms,"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "a[n//2 + 1:]"
                      },
                      {
                        "kind": "text",
                        "text": " should contain the negative-frequency terms, in\nincreasing order starting from the most negative frequency."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              }
            ],
            "ordered": false,
            "type": "list"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For an even number of input points, "
              },
              {
                "kind": "code",
                "text": "A[n//2]"
              },
              {
                "kind": "text",
                "text": " represents the sum of\nthe values at the positive and negative Nyquist frequencies, as the two\nare aliased together. See "
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                "href": "",
                "kind": "link",
                "target": "fft",
                "text": "we.fft"
              },
              {
                "kind": "text",
                "text": " for details."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array, can be complex."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array, can be complex."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Length of the transformed axis of the output.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " is smaller than the length of the input, the input is cropped.\nIf it is larger, the input is padded with zeros.  If "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " is not given,\nthe length of the input along the axis specified by "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " is used.\nSee notes about padding issues."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Length of the transformed axis of the output.\nIf "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " is smaller than the length of the input, the input is cropped.\nIf it is larger, the input is padded with zeros.  If "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " is not given,\nthe length of the input along the axis specified by "
                  },
                  {
                    "kind": "code",
                    "text": "axis"
                  },
                  {
                    "kind": "text",
                    "text": " is used.\nSee notes about padding issues."
                  }
                ],
                "name": "n",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis over which to compute the inverse DFT.  If not given, the last\naxis is used."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis over which to compute the inverse DFT.  If not given, the last\naxis is used."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Normalization mode (see "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                        "href": "",
                        "kind": "link",
                        "target": "fft",
                        "text": "we.fft"
                      },
                      {
                        "kind": "text",
                        "text": "). Default is \"backward\".\nIndicates which direction of the forward/backward pair of transforms\nis scaled and with what normalization factor."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "versionadded",
                    "options": [],
                    "raw_source": ".. versionadded:: 1.20.0\n\n    The \"backward\", \"forward\" values were added.",
                    "supported": true,
                    "type": "directive_block",
                    "version": "1.20.0"
                  }
                ],
                "data_type": "{\"backward\", \"ortho\", \"forward\"}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Normalization mode (see "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                    "href": "",
                    "kind": "link",
                    "target": "fft",
                    "text": "we.fft"
                  },
                  {
                    "kind": "text",
                    "text": "). Default is \"backward\".\nIndicates which direction of the forward/backward pair of transforms\nis scaled and with what normalization factor."
                  }
                ],
                "name": "norm",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If provided, the result will be placed in this array. It should be\nof the appropriate shape and dtype."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
