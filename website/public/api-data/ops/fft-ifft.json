              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.fft.ifft([0, 4, 0, 0])"
              },
              {
                "kind": "output",
