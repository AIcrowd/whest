  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Round to nearest integer towards zero."
          },
          {
            "type": "paragraph",
            "text": "Round an array of floats element-wise to nearest integer towards zero.\nThe rounded values have the same data-type as the input."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array to be rounded"
              }
            ]
          },
          {
            "name": "out",
            "type": "ndarray, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "A location into which the result is stored. If provided, it must have\na shape that the input broadcasts to. If not provided or None, a\nfreshly-allocated array is returned."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray of floats",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array with the same dimensions and data-type as the input.\nIf second argument is not supplied then a new array is returned\nwith the rounded values."
              },
              {
                "type": "paragraph",
                "text": "If a second argument is supplied the result is stored there.\nThe return value ``out`` is then a reference to that array."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.fix(3.14)\n3.0\n>>> np.fix(3)\n3\n>>> np.fix([2.1, 2.9, -2.1, -2.9])\narray([ 2.,  2., -2., -2.])"
          }
        ]
      },
      {
