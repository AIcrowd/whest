              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.common_type(np.arange(2, dtype=np.float32))\n<class 'numpy.float32'>\n>>> np.common_type(np.arange(2, dtype=np.float32), np.arange(2))\n<class 'numpy.float64'>\n>>> np.common_type(np.arange(4), np.array([45, 6.j]), np.array([45.0]))\n<class 'numpy.complex128'>"
          }
        ]
