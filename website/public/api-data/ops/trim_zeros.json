  "schema_version": 1,
  "slug": "trim_zeros",
  "detail_href": "/docs/api/ops/trim_zeros/",
  "detail_json_href": "/api-data/ops/trim_zeros.json",
  "source": {
    "whest": "https://github.com/AIcrowd/whest/blob/main/src/whest/_ndarray.py#L1458-L1467",
    "numpy": "https://numpy.org/doc/stable/reference/generated/numpy.trim_zeros.html"
  },
  "op": {
    "name": "trim_zeros",
    "module": "numpy",
    "whest_ref": "we.trim_zeros",
    "numpy_ref": "np.trim_zeros",
    "category": "counted_custom",
    "status": "supported",
    "weight": 4.0,
    "cost_formula": "per-operation",
    "cost_formula_latex": "varies",
    "notes": "Trim leading/trailing zeros from 1-D array. Cost: num trimmed.",
    "summary": "Remove values along a dimension which are zero along all other.",
    "signature": "we.trim_zeros(filt, trim='fb', axis=None)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Remove values along a dimension which are zero along all other."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "filt",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array."
              }
            ]
          },
          {
            "name": "trim",
            "type": "{\"fb\", \"f\", \"b\"}, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "A string with 'f' representing trim from front and 'b' to trim from\nback. By default, zeros are trimmed on both sides.\nFront and back refer to the edges of a dimension, with \"front\" refering\nto the side with the lowest index 0, and \"back\" refering to the highest\nindex (or index -1)."
              }
            ]
          },
          {
            "name": "axis",
            "type": "int or sequence, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If None, `filt` is cropped such, that the smallest bounding box is\nreturned that still contains all values which are not zero.\nIf an axis is specified, `filt` will be sliced in that dimension only\non the sides specified by `trim`. The remaining area will be the\nsmallest that still contains all values wich are not zero."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "trimmed",
            "type": "ndarray or sequence",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The result of trimming the input. The number of dimensions and the\ninput data type are preserved."
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "For all-zero arrays, the first axis is trimmed first."
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> a = np.array((0, 0, 0, 1, 2, 3, 0, 2, 1, 0))\n>>> np.trim_zeros(a)\narray([1, 2, 3, 0, 2, 1])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.trim_zeros(a, trim='b')\narray([0, 0, 0, ..., 0, 2, 1])"
          },
          {
            "type": "paragraph",
            "text": "Multiple dimensions are supported."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> b = np.array([[0, 0, 2, 3, 0, 0],\n...               [0, 1, 0, 3, 0, 0],\n...               [0, 0, 0, 0, 0, 0]])\n>>> np.trim_zeros(b)\narray([[0, 2, 3],\n       [1, 0, 3]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.trim_zeros(b, axis=-1)\narray([[0, 2, 3],\n       [1, 0, 3],\n       [0, 0, 0]])"
          },
          {
            "type": "paragraph",
            "text": "The input data type is preserved, list/tuple in means list/tuple out."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.trim_zeros([0, 1, 2, 0])\n[1, 2]"
          }
        ]
      }
    ]
  }
}