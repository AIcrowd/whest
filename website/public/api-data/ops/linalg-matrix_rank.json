    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return matrix rank of array using SVD method"
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Rank of the array is the number of singular values of the array that are\ngreater than "
              },
              {
                "kind": "code",
                "text": "tol"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input vector or stack of matrices."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{(M,), (..., M, N)} array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input vector or stack of matrices."
                  }
                ],
                "name": "A",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Threshold below which SVD values are considered zero. If "
                      },
                      {
                        "kind": "code",
                        "text": "tol"
                      },
                      {
                        "kind": "text",
                        "text": " is\nNone, and "
                      },
                      {
                        "kind": "code",
                        "text": "S"
                      },
                      {
                        "kind": "text",
                        "text": " is an array with singular values for "
                      },
                      {
                        "kind": "code",
                        "text": "M"
                      },
                      {
                        "kind": "text",
                        "text": ", and\n"
                      },
                      {
                        "kind": "code",
                        "text": "eps"
                      },
                      {
                        "kind": "text",
                        "text": " is the epsilon value for datatype of "
                      },
                      {
                        "kind": "code",
                        "text": "S"
                      },
                      {
                        "kind": "text",
                        "text": ", then "
                      },
                      {
                        "kind": "code",
                        "text": "tol"
                      },
                      {
                        "kind": "text",
                        "text": " is\nset to "
                      },
                      {
                        "kind": "code",
                        "text": "S.max() * max(M, N) * eps"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(...) array_like, float, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Threshold below which SVD values are considered zero. If "
                  },
                  {
                    "kind": "code",
                    "text": "tol"
                  },
                  {
                    "kind": "text",
                    "text": " is\nNone, and "
                  },
                  {
                    "kind": "code",
                    "text": "S"
                  },
                  {
                    "kind": "text",
                    "text": " is an array with singular values for "
                  },
                  {
                    "kind": "code",
