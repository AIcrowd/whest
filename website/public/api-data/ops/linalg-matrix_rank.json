                  {
                    "kind": "code",
                    "text": "S.max() * max(M, N) * eps"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "tol",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, "
                      },
                      {
                        "kind": "code",
                        "text": "A"
                      },
                      {
                        "kind": "text",
                        "text": " is assumed to be Hermitian (symmetric if real-valued),\nenabling a more efficient method for finding singular values.\nDefaults to False."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
