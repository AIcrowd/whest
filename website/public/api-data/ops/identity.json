  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return the identity array."
          },
          {
            "type": "paragraph",
            "text": "The identity array is a square array with ones on\nthe main diagonal."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "n",
            "type": "int",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Number of rows (and columns) in `n` x `n` output."
              }
            ]
          },
          {
            "name": "dtype",
            "type": "data-type, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Data-type of the output.  Defaults to ``float``."
              }
            ]
          },
          {
            "name": "like",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "    Reference object to allow the creation of arrays which are not\n    NumPy arrays. If an array-like passed in as ``like`` supports\n    the ``__array_function__`` protocol, the result will be defined\n    by it. In this case, it ensures the creation of an array object\n    compatible with that passed in via this argument."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.20.0",
                "body": "",
                "raw": ".. versionadded:: 1.20.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "`n` x `n` array with its main diagonal set to one,\nand all other elements 0."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.identity(3)\narray([[1.,  0.,  0.],\n       [0.,  1.,  0.],\n       [0.,  0.,  1.]])"
          }
        ]
      }
