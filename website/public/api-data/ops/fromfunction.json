  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Construct an array by executing a function over each coordinate."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The resulting array therefore has a value "
              },
              {
                "kind": "code",
                "text": "fn(x, y, z)"
              },
              {
                "kind": "text",
                "text": " at\ncoordinate "
              },
              {
                "kind": "code",
                "text": "(x, y, z)"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The function is called with N parameters, where N is the rank of\n"
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/shape",
                        "kind": "link",
                        "target": "shape",
                        "text": "shape"
                      },
                      {
                        "kind": "text",
                        "text": ".  Each parameter represents the coordinates of the array\nvarying along a specific axis.  For example, if "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/shape",
                        "kind": "link",
                        "target": "shape",
                        "text": "shape"
                      },
                      {
                        "kind": "text",
                        "text": "\nwere "
                      },
                      {
                        "kind": "code",
                        "text": "(2, 2)"
                      },
                      {
                        "kind": "text",
                        "text": ", then the parameters would be\n"
                      },
                      {
                        "kind": "code",
                        "text": "array([[0, 0], [1, 1]])"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "array([[0, 1], [0, 1]])"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "callable",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The function is called with N parameters, where N is the rank of\n"
                  },
                  {
                    "external_url": "",
                    "href": "/docs/api/ops/shape",
                    "kind": "link",
                    "target": "shape",
                    "text": "shape"
                  },
                  {
                    "kind": "text",
                    "text": ".  Each parameter represents the coordinates of the array\nvarying along a specific axis.  For example, if "
                  },
