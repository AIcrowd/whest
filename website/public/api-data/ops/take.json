        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "By eliminating the inner loop in the description above, and using "
              },
              {
                "kind": "code",
                "text": "s_"
              },
              {
                "kind": "text",
                "text": " to\nbuild simple slice objects, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/take",
                "kind": "link",
                "target": "take",
                "text": "take"
              },
              {
                "kind": "text",
                "text": " can be expressed  in terms of applying\nfancy indexing to each 1-d slice:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "Ni, Nk = a.shape[:axis], a.shape[axis+1:]\nfor ii in ndindex(Ni):\n    for kk in ndindex(Nj):\n        out[ii + s_[...,] + kk] = a[ii + s_[:,] + kk][indices]",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For this reason, it is equivalent to (but faster than) the following use\nof "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/apply_along_axis",
                "kind": "link",
                "target": "apply_along_axis",
                "text": "apply_along_axis"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "out = we.apply_along_axis(lambda a_1d: a_1d[indices], axis, a)",
            "type": "literal_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = [4, 3, 5, 7, 6, 8]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "indices = [0, 1, 4]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.take(a, indices)"
              },
              {
                "kind": "output",
                "text": "array([4, 3, 6])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "In this example if "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " is an ndarray, \"fancy\" indexing can be used."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array(a)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[indices]"
              },
              {
                "kind": "output",
                "text": "array([4, 3, 6])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/indices",
                "kind": "link",
                "target": "indices",
                "text": "indices"
              },
              {
                "kind": "text",
                "text": " is not one dimensional, the output also has these dimensions."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.take(a, [[0, 1], [2, 3]])"
              },
              {
                "kind": "output",
                "text": "array([[4, 3],"
              },
              {
                "kind": "output",
                "text": "       [5, 7]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
