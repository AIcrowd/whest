{
  "detail_href": "/docs/api/ops/take/",
  "detail_json_href": "/api-data/ops/take.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Take elements from an array along an axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "When axis is not None, this function does the same thing as \"fancy\"\nindexing (indexing arrays using arrays); however, it can be easier to use\nif you need elements along a given axis. A call such as\n"
              },
              {
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.take(arr, indices, axis=3).html",
                "href": "",
                "kind": "link",
                "target": "take(arr, indices, axis=3)",
                "text": "we.take(arr, indices, axis=3)"
              },
              {
                "kind": "text",
                "text": " is equivalent to\n"
              },
              {
                "kind": "code",
                "text": "arr[:,:,:,indices,...]"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Explained without fancy indexing, this is equivalent to the following use\nof "
              },
              {
                "kind": "code",
                "text": "ndindex"
              },
              {
                "kind": "text",
                "text": ", which sets each of "
              },
              {
                "kind": "code",
                "text": "ii"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "jj"
              },
              {
                "kind": "text",
                "text": ", and "
              },
              {
                "kind": "code",
                "text": "kk"
              },
              {
                "kind": "text",
                "text": " to a tuple of\nindices:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "Ni, Nk = a.shape[:axis], a.shape[axis+1:]\nNj = indices.shape\nfor ii in ndindex(Ni):\n    for jj in ndindex(Nj):\n        for kk in ndindex(Nk):\n            out[ii + jj + kk] = a[ii + (indices[jj],) + kk]",
            "type": "literal_block"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The source array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like (Ni..., M, Nk...)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The source array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The indices of the values to extract.\nAlso allow scalars for indices."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like (Nj...)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The indices of the values to extract.\nAlso allow scalars for indices."
                  }
                ],
                "name": "indices",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The axis over which to select values. By default, the flattened\ninput array is used."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The axis over which to select values. By default, the flattened\ninput array is used."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If provided, the result will be placed in this array. It should\nbe of the appropriate shape and dtype. Note that "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " is always\nbuffered if "
                      },
                      {
                        "kind": "code",
                        "text": "mode='raise'"
                      },
                      {
                        "kind": "text",
                        "text": "; use other modes for better performance."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, optional (Ni..., Nj..., Nk...)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If provided, the result will be placed in this array. It should\nbe of the appropriate shape and dtype. Note that "
                  },
                  {
                    "kind": "code",
                    "text": "out"
                  },
                  {
                    "kind": "text",
                    "text": " is always\nbuffered if "
                  },
                  {
                    "kind": "code",
                    "text": "mode='raise'"
                  },
                  {
                    "kind": "text",
                    "text": "; use other modes for better performance."
                  }
                ],
                "name": "out",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Specifies how out-of-bounds indices will behave."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'raise' -- raise an error (default)"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'wrap' -- wrap around"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'clip' -- clip to the range"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "'clip' mode means that all indices that are too large are replaced\nby the index that addresses the last element along that axis. Note\nthat this disables indexing with negative numbers."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'raise', 'wrap', 'clip'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Specifies how out-of-bounds indices will behave."
                  }
                ],
                "name": "mode",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
