  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return a string representation of the data in an array."
          },
          {
            "type": "paragraph",
            "text": "The data in the array is returned as a single string.  This function is\nsimilar to `array_repr`, the difference being that `array_repr` also\nreturns information on the kind of array and its data type."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array."
              }
            ]
          },
          {
            "name": "max_line_width",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Inserts newlines if text is longer than `max_line_width`.\nDefaults to ``numpy.get_printoptions()['linewidth']``."
              }
            ]
          },
          {
            "name": "precision",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Floating point precision.\nDefaults to ``numpy.get_printoptions()['precision']``."
              }
            ]
          },
          {
            "name": "suppress_small",
            "type": "bool, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Represent numbers \"very close\" to zero as zero; default is False.\nVery close is defined by precision: if the precision is 8, e.g.,\nnumbers smaller (in absolute value) than 5e-9 are represented as\nzero.\nDefaults to ``numpy.get_printoptions()['suppress']``."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.array_str(np.arange(3))\n'[0 1 2]'"
          }
        ]
      },
