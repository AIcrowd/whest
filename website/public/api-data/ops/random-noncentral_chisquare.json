        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density function for the noncentral Chi-square\ndistribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "P(x;df,nonc) = \\sum^{\\infty}_{i=0} \\frac{e^{-nonc/2}(nonc/2)^{i}}{i!} P_{Y_{df+2i}}(x),"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where "
              },
              {
                "kind": "math",
                "latex": "Y_{q}"
              },
              {
                "kind": "text",
                "text": " is the Chi-square with q degrees of freedom."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
