        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw values from the distribution and plot the histogram"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "values = plt.hist(fnp.random.noncentral_chisquare(3, 20, 100000),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "bins=200, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw values from a noncentral chisquare with very small noncentrality,\nand compare to a chisquare."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.figure()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "values = plt.hist(fnp.random.noncentral_chisquare(3, .0000001, 100000),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "bins=fnp.arange(0., 25, .1), density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "values2 = plt.hist(fnp.random.chisquare(3, 100000),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "bins=fnp.arange(0., 25, .1), density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(values[1][0:-1], values[0]-values2[0], 'ob')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Demonstrate how large values of non-centrality lead to a more symmetric\ndistribution."
              }
            ],
            "type": "paragraph"
          },
