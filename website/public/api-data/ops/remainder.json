  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the element-wise remainder of division."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Computes the remainder complementary to the "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/floor_divide",
                "kind": "link",
                "target": "floor_divide",
                "text": "floor_divide"
              },
              {
                "kind": "text",
                "text": " function.  It is\nequivalent to the Python modulus operator "
              },
              {
                "kind": "code",
                "text": "x1 % x2"
              },
              {
                "kind": "text",
                "text": " and has the same sign\nas the divisor "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": ". The MATLAB function equivalent to "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/remainder",
                "kind": "link",
                "target": "remainder",
                "text": "we.remainder"
              },
              {
                "kind": "text",
                "text": "\nis "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/mod",
                "kind": "link",
                "target": "mod",
                "text": "mod"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "This should not be confused with:"
                  }
                ],
                "type": "paragraph"
              },
              {
                "items": [
                  {
                    "blocks": [
                      {
                        "inline": [
                          {
                            "kind": "text",
                            "text": "Python 3.7's "
                          },
                          {
                            "kind": "code",
                            "text": "math.remainder"
                          },
                          {
                            "kind": "text",
                            "text": " and C's "
                          },
                          {
                            "external_url": "",
                            "href": "/docs/api/ops/remainder",
                            "kind": "link",
                            "target": "remainder",
                            "text": "remainder"
                          },
                          {
                            "kind": "text",
                            "text": ", which\ncomputes the IEEE remainder, which are the complement to\n"
                          },
                          {
                            "kind": "code",
                            "text": "round(x1 / x2)"
                          },
                          {
                            "kind": "text",
                            "text": "."
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
                  },
                  {
                    "blocks": [
                      {
                        "inline": [
                          {
                            "kind": "text",
                            "text": "The MATLAB "
                          },
                          {
                            "kind": "code",
                            "text": "rem"
                          },
                          {
                            "kind": "text",
                            "text": " function and or the C "
                          },
                          {
                            "kind": "code",
                            "text": "%"
                          },
                          {
                            "kind": "text",
                            "text": " operator which is the\ncomplement to "
                          },
                          {
                            "kind": "code",
                            "text": "int(x1 / x2)"
                          },
                          {
                            "kind": "text",
                            "text": "."
                          }
                        ],
                        "type": "paragraph"
                      }
                    ]
                  }
                ],
                "ordered": false,
                "type": "list"
              }
            ],
            "directive": "warning",
            "options": [],
            "raw_source": ".. warning::\n\n    This should not be confused with:\n\n    * Python 3.7's `math.remainder` and C's ``remainder``, which\n      computes the IEEE remainder, which are the complement to\n      ``round(x1 / x2)``.\n    * The MATLAB ``rem`` function and or the C ``%`` operator which is the\n      complement to ``int(x1 / x2)``.",
            "supported": true,
            "type": "directive_block"
          }
        ],
