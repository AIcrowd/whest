                  }
                ],
                "name": "overwrite_input",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the original "
                      },
                      {
                        "kind": "code",
                        "text": "arr"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the original "
                  },
                  {
                    "kind": "code",
                    "text": "arr"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "keepdims",
                "type": "field_list"
              }
            ],
