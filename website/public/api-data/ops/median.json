        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given a vector "
              },
              {
                "kind": "code",
                "text": "V"
              },
              {
                "kind": "text",
                "text": " of length "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": ", the median of "
              },
              {
                "kind": "code",
                "text": "V"
              },
              {
                "kind": "text",
                "text": " is the\nmiddle value of a sorted copy of "
              },
              {
                "kind": "code",
                "text": "V"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "V_sorted"
              },
              {
                "kind": "text",
                "text": " - i\ne., "
              },
              {
                "kind": "code",
                "text": "V_sorted[(N-1)/2]"
              },
              {
                "kind": "text",
                "text": ", when "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": " is odd, and the average of the\ntwo middle values of "
              },
              {
                "kind": "code",
                "text": "V_sorted"
              },
              {
                "kind": "text",
                "text": " when "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": " is even."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[10, 7, 4], [3, 2, 1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[10,  7,  4],"
              },
              {
                "kind": "output",
                "text": "       [ 3,  2,  1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.median(a)"
              },
              {
                "kind": "output",
                "text": "we.float64(3.5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.median(a, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([6.5, 4.5, 2.5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.median(a, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([7.,  2.])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.median(a, axis=(0, 1))"
              },
              {
                "kind": "output",
                "text": "we.float64(3.5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "m = we.median(a, axis=0)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "out = we.zeros_like(m)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.median(a, axis=0, out=m)"
              },
              {
                "kind": "output",
                "text": "array([6.5,  4.5,  2.5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "m"
              },
              {
                "kind": "output",
                "text": "array([6.5,  4.5,  2.5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = a.copy()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.median(b, axis=1, overwrite_input=True)"
              },
              {
                "kind": "output",
                "text": "array([7.,  2.])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "assert not we.all(a==b)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = a.copy()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.median(b, axis=None, overwrite_input=True)"
              },
              {
                "kind": "output",
                "text": "we.float64(3.5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "assert not we.all(a==b)"
              }
            ],
            "type": "doctest_block"
          }
        ],
