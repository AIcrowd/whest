  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the median along the specified axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the median of the array elements."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array or object that can be converted to an array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array or object that can be converted to an array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which the medians are computed. The default,\naxis=None, will compute the median along a flattened version of\nthe array. If a sequence of axes, the array is first flattened\nalong the given axes, then the median is computed along the\nresulting flattened axis."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{int, sequence of int, None}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which the medians are computed. The default,\naxis=None, will compute the median along a flattened version of\nthe array. If a sequence of axes, the array is first flattened\nalong the given axes, then the median is computed along the\nresulting flattened axis."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Alternative output array in which to place the result. It must\nhave the same shape and buffer length as the expected output,\nbut the type (of the output) will be cast if necessary."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Alternative output array in which to place the result. It must\nhave the same shape and buffer length as the expected output,\nbut the type (of the output) will be cast if necessary."
                  }
                ],
                "name": "out",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, then allow use of memory of input array "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " for\ncalculations. The input array will be modified by the call to\n"
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/median",
                        "kind": "link",
                        "target": "median",
                        "text": "median"
                      },
                      {
                        "kind": "text",
                        "text": ". This will save memory when you do not need to preserve\nthe contents of the input array. Treat the input as undefined,\nbut it will probably be fully or partially sorted. Default is\nFalse. If "
                      },
                      {
                        "kind": "code",
                        "text": "overwrite_input"
                      },
                      {
                        "kind": "text",
                        "text": " is "
                      },
                      {
                        "kind": "code",
                        "text": "True"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is not already an\n"
                      },
                      {
                        "kind": "code",
                        "text": "ndarray"
                      },
                      {
                        "kind": "text",
                        "text": ", an error will be raised."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, then allow use of memory of input array "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " for\ncalculations. The input array will be modified by the call to\n"
                  },
                  {
                    "external_url": "",
                    "href": "/docs/api/ops/median",
                    "kind": "link",
                    "target": "median",
                    "text": "median"
                  },
                  {
                    "kind": "text",
                    "text": ". This will save memory when you do not need to preserve\nthe contents of the input array. Treat the input as undefined,\nbut it will probably be fully or partially sorted. Default is\nFalse. If "
                  },
                  {
                    "kind": "code",
                    "text": "overwrite_input"
                  },
                  {
                    "kind": "text",
                    "text": " is "
                  },
                  {
                    "kind": "code",
