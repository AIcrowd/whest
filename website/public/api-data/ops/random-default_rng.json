  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Construct a new Generator with the default BitGenerator (PCG64)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A seed to initialize the "
                      },
                      {
                        "kind": "code",
                        "text": "BitGenerator"
                      },
                      {
                        "kind": "text",
                        "text": ". If None, then fresh,\nunpredictable entropy will be pulled from the OS. If an "
                      },
                      {
                        "kind": "code",
                        "text": "int"
                      },
                      {
                        "kind": "text",
                        "text": " or\n"
                      },
                      {
                        "kind": "code",
                        "text": "array_like[ints]"
                      },
                      {
                        "kind": "text",
                        "text": " is passed, then all values must be non-negative and will be\npassed to "
                      },
                      {
                        "kind": "code",
                        "text": "SeedSequence"
                      },
                      {
                        "kind": "text",
                        "text": " to derive the initial "
                      },
                      {
                        "kind": "code",
                        "text": "BitGenerator"
                      },
                      {
                        "kind": "text",
                        "text": " state. One may also\npass in a "
                      },
                      {
                        "kind": "code",
                        "text": "SeedSequence"
                      },
                      {
                        "kind": "text",
                        "text": " instance.\nAdditionally, when passed a "
                      },
                      {
                        "kind": "code",
                        "text": "BitGenerator"
                      },
                      {
                        "kind": "text",
                        "text": ", it will be wrapped by\n"
                      },
                      {
                        "kind": "code",
                        "text": "Generator"
                      },
                      {
                        "kind": "text",
                        "text": ". If passed a "
                      },
                      {
                        "kind": "code",
                        "text": "Generator"
                      },
                      {
                        "kind": "text",
                        "text": ", it will be returned unaltered.\nWhen passed a legacy "
                      },
                      {
                        "kind": "code",
                        "text": "RandomState"
                      },
                      {
                        "kind": "text",
                        "text": " instance it will be coerced to a "
                      },
                      {
                        "kind": "code",
                        "text": "Generator"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{None, int, array_like[ints], SeedSequence, BitGenerator, Generator, RandomState}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A seed to initialize the "
                  },
                  {
                    "kind": "code",
                    "text": "BitGenerator"
                  },
                  {
                    "kind": "text",
                    "text": ". If None, then fresh,\nunpredictable entropy will be pulled from the OS. If an "
                  },
                  {
                    "kind": "code",
                    "text": "int"
                  },
                  {
                    "kind": "text",
                    "text": " or\n"
                  },
                  {
                    "kind": "code",
                    "text": "array_like[ints]"
                  },
                  {
                    "kind": "text",
                    "text": " is passed, then all values must be non-negative and will be\npassed to "
                  },
                  {
                    "kind": "code",
                    "text": "SeedSequence"
                  },
                  {
                    "kind": "text",
                    "text": " to derive the initial "
                  },
                  {
                    "kind": "code",
                    "text": "BitGenerator"
                  },
                  {
                    "kind": "text",
                    "text": " state. One may also\npass in a "
                  },
                  {
                    "kind": "code",
                    "text": "SeedSequence"
                  },
                  {
                    "kind": "text",
                    "text": " instance.\nAdditionally, when passed a "
                  },
                  {
                    "kind": "code",
                    "text": "BitGenerator"
                  },
                  {
                    "kind": "text",
                    "text": ", it will be wrapped by\n"
                  },
                  {
                    "kind": "code",
                    "text": "Generator"
                  },
                  {
                    "kind": "text",
                    "text": ". If passed a "
                  },
                  {
                    "kind": "code",
                    "text": "Generator"
                  },
                  {
                    "kind": "text",
                    "text": ", it will be returned unaltered.\nWhen passed a legacy "
                  },
                  {
                    "kind": "code",
                    "text": "RandomState"
                  },
                  {
                    "kind": "text",
                    "text": " instance it will be coerced to a "
                  },
                  {
                    "kind": "code",
                    "text": "Generator"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "seed",
                "type": "field_list"
              }
            ],
