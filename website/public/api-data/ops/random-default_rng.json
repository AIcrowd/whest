      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "seed"
              },
              {
                "kind": "text",
                "text": " is not a "
              },
              {
                "kind": "code",
                "text": "BitGenerator"
              },
              {
                "kind": "text",
                "text": " or a "
              },
              {
                "kind": "code",
                "text": "Generator"
              },
              {
                "kind": "text",
                "text": ", a new "
              },
              {
                "kind": "code",
                "text": "BitGenerator"
              },
              {
                "kind": "text",
                "text": "\nis instantiated. This function does not manage a default global instance."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "See "
              },
              {
                "display_text": "seeding_and_entropy",
                "explicit_title": false,
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.seeding_and_entropy.html",
                "href": "",
                "kind": "role_reference",
                "original_target": "seeding_and_entropy",
                "role": "ref",
                "suppress_link": false,
                "target": "seeding_and_entropy",
