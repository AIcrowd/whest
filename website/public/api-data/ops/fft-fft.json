              {
                "kind": "emphasis",
                "text": "n"
              },
              {
                "kind": "text",
                "text": "-point discrete Fourier\nTransform (DFT) with the efficient Fast Fourier Transform (FFT)\nalgorithm "
              },
              {
                "kind": "text",
                "text": "[CT]_"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
