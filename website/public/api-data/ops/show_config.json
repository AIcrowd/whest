            "text": "Show libraries and system information on which NumPy was built\nand is being used"
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "mode",
            "type": "{`'stdout'`, `'dicts'`}, optional.",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Indicates how to display the config information.\n`'stdout'` prints to console, `'dicts'` returns a dictionary\nof the configuration."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "{`dict`, `None`}",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If mode is `'dicts'`, a dict is returned, else None"
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "1. The `'stdout'` mode will give more readable\n   output if ``pyyaml`` is installed"
