  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the indices to access (n, n) arrays, given a masking function."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Assume "
              },
              {
                "kind": "code",
                "text": "mask_func"
              },
              {
                "kind": "text",
                "text": " is a function that, for a square array a of size\n"
              },
              {
                "kind": "code",
                "text": "(n, n)"
              },
              {
                "kind": "text",
                "text": " with a possible offset argument "
              },
              {
                "kind": "code",
                "text": "k"
              },
              {
                "kind": "text",
                "text": ", when called as\n"
              },
              {
                "kind": "code",
                "text": "mask_func(a, k)"
              },
              {
                "kind": "text",
                "text": " returns a new array with zeros in certain locations\n(functions like "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/triu",
                "kind": "link",
                "target": "triu",
                "text": "triu"
              },
              {
                "kind": "text",
                "text": " or "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/tril",
                "kind": "link",
                "target": "tril",
                "text": "tril"
              },
              {
                "kind": "text",
                "text": " do precisely this). Then this function\nreturns the indices where the non-zero values would be located."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
