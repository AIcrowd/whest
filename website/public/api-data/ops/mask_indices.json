        "title": "See also"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "These are the indices that would allow you to access the upper triangular\npart of any 3x3 array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "iu = we.mask_indices(3, we.triu)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For example, if "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " is a 3x3 array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.arange(9).reshape(3, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2],"
              },
              {
                "kind": "output",
                "text": "       [3, 4, 5],"
              },
              {
                "kind": "output",
                "text": "       [6, 7, 8]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[iu]"
              },
              {
                "kind": "output",
                "text": "array([0, 1, 2, 4, 5, 8])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "An offset can be passed also to the masking function.  This gets us the\nindices starting on the first diagonal right of the main one:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "iu1 = we.mask_indices(3, we.triu, 1)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "with which we now extract only three elements:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[iu1]"
              },
              {
                "kind": "output",
                "text": "array([1, 2, 5])"
              }
            ],
            "type": "doctest_block"
          }
        ],
