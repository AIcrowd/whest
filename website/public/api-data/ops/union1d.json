    "notes": "Set union; cost = (n+m)*ceil(log2(n+m)).",
    "summary": "Find the union of two arrays.",
    "signature": "we.union1d(ar1, ar2)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Find the union of two arrays."
          },
          {
            "type": "paragraph",
            "text": "Return the unique, sorted array of values that are in either of the two\ninput arrays."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "ar1, ar2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input arrays. They are flattened if they are not already 1D."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "union1d",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Unique, sorted union of the input arrays."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.union1d([-1, 0, 1], [-2, 0, 2])\narray([-2, -1,  0,  1,  2])"
          },
          {
            "type": "paragraph",
            "text": "To find the union of more than two arrays, use functools.reduce:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> from functools import reduce\n>>> reduce(np.union1d, ([1, 3, 4, 3], [3, 1, 2, 1], [6, 3, 4, 2]))\narray([1, 2, 3, 4, 6])"
          }
        ]
      }
    ]
  }
