                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.argwhere(a).html",
                "href": "",
                "kind": "link",
                "target": "argwhere(a)",
                "text": "we.argwhere(a)"
              },
              {
                "kind": "text",
                "text": " is almost the same as "
              },
              {
                "kind": "code",
                "text": "we.transpose(we.nonzero(a))"
              },
              {
                "kind": "text",
                "text": ",\nbut produces a result of the correct shape for a 0D array."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The output of "
