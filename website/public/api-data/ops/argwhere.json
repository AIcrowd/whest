                "target": "argwhere",
                "text": "argwhere"
              },
              {
                "kind": "text",
                "text": " is not suitable for indexing arrays.\nFor this purpose use "
              },
              {
                "kind": "code",
                "text": "nonzero(a)"
              },
              {
                "kind": "text",
                "text": " instead."
              }
