        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The determinant of a 2-D array [[a, b], [c, d]] is ad - bc:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[1, 2], [3, 4]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.det(a)"
              },
              {
                "kind": "output",
                "text": "-2.0 # may vary"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Computing determinants for a stack of matrices:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([ [[1, 2], [3, 4]], [[1, 2], [2, 1]], [[1, 3], [3, 1]] ])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a.shape"
              },
              {
                "kind": "output",
                "text": "(3, 2, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.det(a)"
              },
              {
                "kind": "output",
                "text": "array([-2., -3., -8.])"
              }
            ],
            "type": "doctest_block"
          }
        ],
