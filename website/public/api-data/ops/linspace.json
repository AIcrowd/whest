  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return evenly spaced numbers over a specified interval."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns "
              },
              {
                "kind": "code",
                "text": "num"
              },
              {
                "kind": "text",
                "text": " evenly spaced samples, calculated over the\ninterval ["
              },
              {
                "kind": "code",
                "text": "start"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "stop"
              },
              {
                "kind": "text",
                "text": "]."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The endpoint of the interval can optionally be excluded."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [],
            "directive": "versionchanged",
            "options": [],
            "raw_source": ".. versionchanged:: 1.20.0\n    Values are rounded towards ``-inf`` instead of ``0`` when an\n    integer ``dtype`` is specified. The old behavior can\n    still be obtained with ``fnp.linspace(start, stop, num).astype(int)``",
            "supported": true,
            "type": "directive_block",
            "version": "1.20.0"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The starting value of the sequence."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The starting value of the sequence."
                  }
                ],
                "name": "start",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The end value of the sequence, unless "
                      },
                      {
                        "kind": "code",
                        "text": "endpoint"
                      },
                      {
                        "kind": "text",
                        "text": " is set to False.\nIn that case, the sequence consists of all but the last of "
                      },
                      {
                        "kind": "code",
                        "text": "num + 1"
                      },
                      {
                        "kind": "text",
                        "text": "\nevenly spaced samples, so that "
                      },
                      {
                        "kind": "code",
                        "text": "stop"
                      },
                      {
                        "kind": "text",
                        "text": " is excluded.  Note that the step\nsize changes when "
                      },
                      {
                        "kind": "code",
                        "text": "endpoint"
                      },
                      {
                        "kind": "text",
                        "text": " is False."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The end value of the sequence, unless "
                  },
                  {
                    "kind": "code",
                    "text": "endpoint"
                  },
                  {
                    "kind": "text",
                    "text": " is set to False.\nIn that case, the sequence consists of all but the last of "
                  },
                  {
                    "kind": "code",
                    "text": "num + 1"
                  },
                  {
                    "kind": "text",
                    "text": "\nevenly spaced samples, so that "
                  },
                  {
                    "kind": "code",
                    "text": "stop"
                  },
                  {
                    "kind": "text",
                    "text": " is excluded.  Note that the step\nsize changes when "
                  },
                  {
                    "kind": "code",
                    "text": "endpoint"
                  },
                  {
                    "kind": "text",
                    "text": " is False."
                  }
                ],
                "name": "stop",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Number of samples to generate. Default is 50. Must be non-negative."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Number of samples to generate. Default is 50. Must be non-negative."
                  }
                ],
                "name": "num",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, "
                      },
                      {
                        "kind": "code",
                        "text": "stop"
                      },
                      {
                        "kind": "text",
                        "text": " is the last sample. Otherwise, it is not included.\nDefault is True."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, "
                  },
                  {
                    "kind": "code",
                    "text": "stop"
                  },
                  {
                    "kind": "text",
                    "text": " is the last sample. Otherwise, it is not included.\nDefault is True."
                  }
                ],
                "name": "endpoint",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, return ("
                      },
                      {
                        "kind": "code",
                        "text": "samples"
                      },
                      {
                        "kind": "text",
                        "text": ", "
                      },
                      {
                        "kind": "code",
                        "text": "step"
                      },
                      {
                        "kind": "text",
                        "text": "), where "
                      },
                      {
                        "kind": "code",
                        "text": "step"
                      },
                      {
                        "kind": "text",
                        "text": " is the spacing\nbetween samples."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, return ("
                  },
                  {
                    "kind": "code",
                    "text": "samples"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "step"
                  },
                  {
                    "kind": "text",
                    "text": "), where "
                  },
                  {
                    "kind": "code",
                    "text": "step"
                  },
                  {
                    "kind": "text",
                    "text": " is the spacing\nbetween samples."
                  }
                ],
                "name": "retstep",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The type of the output array.  If "
                      },
                      {
                        "kind": "code",
                        "text": "dtype"
                      },
                      {
                        "kind": "text",
                        "text": " is not given, the data type\nis inferred from "
                      },
                      {
                        "kind": "code",
                        "text": "start"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "stop"
                      },
                      {
                        "kind": "text",
                        "text": ". The inferred dtype will never be\nan integer; "
                      },
                      {
                        "kind": "code",
                        "text": "float"
                      },
                      {
                        "kind": "text",
                        "text": " is chosen even if the arguments would produce an\narray of integers."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The type of the output array.  If "
                  },
                  {
                    "kind": "code",
                    "text": "dtype"
                  },
                  {
                    "kind": "text",
                    "text": " is not given, the data type\nis inferred from "
                  },
                  {
                    "kind": "code",
                    "text": "start"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "stop"
                  },
                  {
                    "kind": "text",
                    "text": ". The inferred dtype will never be\nan integer; "
                  },
                  {
                    "kind": "code",
                    "text": "float"
                  },
                  {
                    "kind": "text",
                    "text": " is chosen even if the arguments would produce an\narray of integers."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The axis in the result to store the samples.  Relevant only if start\nor stop are array-like.  By default (0), the samples will be along a\nnew axis inserted at the beginning. Use -1 to get an axis at the end."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The axis in the result to store the samples.  Relevant only if start\nor stop are array-like.  By default (0), the samples will be along a\nnew axis inserted at the beginning. Use -1 to get an axis at the end."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The device on which to place the created array. Default: None.\nFor Array-API interoperability only, so must be "
                      },
                      {
                        "kind": "code",
                        "text": "\"cpu\""
                      },
                      {
                        "kind": "text",
                        "text": " if passed."
                      }
                    ],
