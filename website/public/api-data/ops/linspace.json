            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linspace(2.0, 3.0, num=5)"
              },
              {
                "kind": "output",
                "text": "array([2.  , 2.25, 2.5 , 2.75, 3.  ])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linspace(2.0, 3.0, num=5, endpoint=False)"
              },
              {
                "kind": "output",
                "text": "array([2. ,  2.2,  2.4,  2.6,  2.8])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linspace(2.0, 3.0, num=5, retstep=True)"
              },
              {
                "kind": "output",
                "text": "(array([2.  ,  2.25,  2.5 ,  2.75,  3.  ]), 0.25)"
              }
            ],
