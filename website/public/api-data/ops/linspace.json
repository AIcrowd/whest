            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "N = 8"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = fnp.zeros(N)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x1 = fnp.linspace(0, 10, N, endpoint=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x2 = fnp.linspace(0, 10, N, endpoint=False)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(x1, y, 'o')"
              },
              {
                "kind": "output",
                "text": "[<matplotlib.lines.Line2D object at 0x...>]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(x2, y + 0.5, 'o')"
              },
              {
                "kind": "output",
                "text": "[<matplotlib.lines.Line2D object at 0x...>]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.ylim([-0.5, 1])"
              },
              {
                "kind": "output",
                "text": "(-0.5, 1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
