                        "kind": "code",
                        "text": "arr"
                      },
                      {
                        "kind": "text",
                        "text": ". This must match the\ndimension of arr, but dimensions in Ni and Nj may be 1 to broadcast\nagainst "
                      },
                      {
                        "kind": "code",
                        "text": "arr"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray (Ni..., J, Nk...)",
                "inline": [
                  {
