        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This is equivalent to (but faster than) the following use of "
              },
              {
                "kind": "code",
                "text": "ndindex"
              },
              {
                "kind": "text",
                "text": " and\n"
              },
              {
                "kind": "code",
                "text": "s_"
              },
              {
                "kind": "text",
                "text": ", which sets each of "
              },
              {
                "kind": "code",
                "text": "ii"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "kk"
              },
              {
                "kind": "text",
                "text": " to a tuple of indices:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "Ni, M, Nk = a.shape[:axis], a.shape[axis], a.shape[axis+1:]\nJ = indices.shape[axis]  # Need not equal M\n\nfor ii in ndindex(Ni):\n    for kk in ndindex(Nk):\n        a_1d       = a      [ii + s_[:,] + kk]\n        indices_1d = indices[ii + s_[:,] + kk]\n        values_1d  = values [ii + s_[:,] + kk]\n        for j in range(J):\n            a_1d[indices_1d[j]] = values_1d[j]",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Equivalently, eliminating the inner loop, the last two lines would be:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "a_1d[indices_1d] = values_1d",
            "type": "literal_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For this sample array"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[10, 30, 20], [60, 40, 50]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "We can replace the maximum values with:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai = we.argmax(a, axis=1, keepdims=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai"
              },
              {
                "kind": "output",
                "text": "array([[1],"
              },
              {
                "kind": "output",
                "text": "       [0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.put_along_axis(a, ai, 99, axis=1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[10, 99, 20],"
              },
              {
                "kind": "output",
                "text": "       [99, 40, 50]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
