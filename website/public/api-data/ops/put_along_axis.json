        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Put values into the destination array by matching 1d index and data slices."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This iterates over matching 1d slices oriented along the specified axis in\nthe index and data arrays, and uses the former to place values into the\nlatter. These slices can be different lengths."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Functions returning an index along an axis, like "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/argsort",
                "kind": "link",
                "target": "argsort",
                "text": "argsort"
              },
              {
                "kind": "text",
                "text": " and\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/argpartition",
                "kind": "link",
                "target": "argpartition",
                "text": "argpartition"
              },
              {
                "kind": "text",
                "text": ", produce suitable indices for this function."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Destination array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray (Ni..., M, Nk...)",
