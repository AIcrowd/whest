  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Vector-matrix dot product of two arrays."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given a vector (or stack of vector) "
              },
              {
                "kind": "math",
                "latex": "\\mathbf{v}"
              },
              {
                "kind": "text",
                "text": " in "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and\na matrix (or stack of matrices) "
              },
              {
                "kind": "math",
                "latex": "\\mathbf{A}"
              },
              {
                "kind": "text",
                "text": " in "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": ", the\nvector-matrix product is defined as:"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "\\mathbf{b} \\cdot \\mathbf{A} = \\sum_{i=0}^{n-1} \\overline{v_i}A_{ij}"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where the sum is over the last dimension of "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and the one-but-last\ndimensions in "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " (unless "
              },
              {
                "kind": "code",
                "text": "axes"
              },
              {
                "kind": "text",
                "text": " is specified) and where\n"
              },
              {
                "kind": "math",
                "latex": "\\overline{v_i}"
              },
              {
                "kind": "text",
                "text": " denotes the complex conjugate if "
              },
              {
                "kind": "math",
                "latex": "v"
              },
              {
                "kind": "text",
                "text": "\nis complex and the identity otherwise. (For a non-conjugated vector-matrix\nproduct, use "
              },
              {
                "kind": "code",
                "text": "we.matvec(x2.mT, x1)"
              },
              {
                "kind": "text",
                "text": ".)"
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [],
            "directive": "versionadded",
            "options": [],
            "raw_source": ".. versionadded:: 2.2.0",
            "supported": true,
            "type": "directive_block",
            "version": "2.2.0"
          }
        ],
