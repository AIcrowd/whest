      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = fnp.array([1, 2, 3, 5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "N = 3"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.vander(x, N)"
              },
              {
                "kind": "output",
                "text": "array([[ 1,  1,  1],"
              },
              {
                "kind": "output",
                "text": "       [ 4,  2,  1],"
              },
              {
                "kind": "output",
                "text": "       [ 9,  3,  1],"
              },
              {
                "kind": "output",
                "text": "       [25,  5,  1]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.column_stack([x**(N-1-i) for i in range(N)])"
              },
              {
                "kind": "output",
                "text": "array([[ 1,  1,  1],"
              },
              {
                "kind": "output",
                "text": "       [ 4,  2,  1],"
              },
              {
                "kind": "output",
                "text": "       [ 9,  3,  1],"
              },
              {
                "kind": "output",
                "text": "       [25,  5,  1]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = fnp.array([1, 2, 3, 5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.vander(x)"
              },
              {
                "kind": "output",
                "text": "array([[  1,   1,   1,   1],"
              },
              {
                "kind": "output",
                "text": "       [  8,   4,   2,   1],"
              },
              {
                "kind": "output",
                "text": "       [ 27,   9,   3,   1],"
              },
              {
                "kind": "output",
                "text": "       [125,  25,   5,   1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.vander(x, increasing=True)"
              },
              {
                "kind": "output",
                "text": "array([[  1,   1,   1,   1],"
              },
              {
                "kind": "output",
                "text": "       [  1,   2,   4,   8],"
              },
              {
                "kind": "output",
                "text": "       [  1,   3,   9,  27],"
              },
              {
                "kind": "output",
                "text": "       [  1,   5,  25, 125]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The determinant of a square Vandermonde matrix is the product\nof the differences between the values of the input vector:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.linalg.det(fnp.vander(x))"
              },
              {
                "kind": "output",
                "text": "48.000000000000043 # may vary"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "(5-3)*(5-2)*(5-1)*(3-2)*(3-1)*(2-1)"
              },
              {
                "kind": "output",
                "text": "48"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
