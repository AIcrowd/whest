  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate a Vandermonde matrix."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The columns of the output matrix are powers of the input vector. The\norder of the powers is determined by the "
              },
              {
                "kind": "code",
                "text": "increasing"
              },
              {
                "kind": "text",
                "text": " boolean argument.\nSpecifically, when "
              },
              {
                "kind": "code",
                "text": "increasing"
              },
              {
                "kind": "text",
                "text": " is False, the "
              },
              {
                "kind": "code",
                "text": "i"
              },
              {
                "kind": "text",
                "text": "-th output column is\nthe input vector raised element-wise to the power of "
              },
              {
                "kind": "code",
                "text": "N - i - 1"
              },
              {
                "kind": "text",
                "text": ". Such\na matrix with a geometric progression in each row is named for Alexandre-\nTheophile Vandermonde."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "1-D input array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "1-D input array."
                  }
                ],
                "name": "x",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Number of columns in the output.  If "
                      },
                      {
                        "kind": "code",
                        "text": "N"
                      },
                      {
                        "kind": "text",
                        "text": " is not specified, a square\narray is returned ("
                      },
                      {
                        "kind": "code",
                        "text": "N = len(x)"
                      },
                      {
                        "kind": "text",
                        "text": ")."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Number of columns in the output.  If "
                  },
                  {
                    "kind": "code",
                    "text": "N"
                  },
                  {
                    "kind": "text",
                    "text": " is not specified, a square\narray is returned ("
                  },
                  {
                    "kind": "code",
                    "text": "N = len(x)"
                  },
                  {
                    "kind": "text",
                    "text": ")."
                  }
                ],
                "name": "N",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Order of the powers of the columns.  If True, the powers increase\nfrom left to right, if False (the default) they are reversed."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Order of the powers of the columns.  If True, the powers increase\nfrom left to right, if False (the default) they are reversed."
                  }
                ],
                "name": "increasing",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Vandermonde matrix.  If "
                      },
                      {
                        "kind": "code",
                        "text": "increasing"
                      },
                      {
                        "kind": "text",
                        "text": " is False, the first column is\n"
                      },
                      {
                        "kind": "code",
                        "text": "x^(N-1)"
                      },
                      {
                        "kind": "text",
                        "text": ", the second "
                      },
                      {
                        "kind": "code",
                        "text": "x^(N-2)"
                      },
                      {
                        "kind": "text",
                        "text": " and so forth. If "
                      },
                      {
                        "kind": "code",
                        "text": "increasing"
                      },
                      {
                        "kind": "text",
                        "text": " is\nTrue, the columns are "
                      },
                      {
                        "kind": "code",
                        "text": "x^0, x^1, ..., x^(N-1)"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Vandermonde matrix.  If "
                  },
                  {
                    "kind": "code",
                    "text": "increasing"
                  },
                  {
                    "kind": "text",
                    "text": " is False, the first column is\n"
                  },
                  {
                    "kind": "code",
                    "text": "x^(N-1)"
                  },
                  {
                    "kind": "text",
                    "text": ", the second "
                  },
                  {
                    "kind": "code",
                    "text": "x^(N-2)"
                  },
                  {
                    "kind": "text",
                    "text": " and so forth. If "
                  },
                  {
                    "kind": "code",
                    "text": "increasing"
                  },
                  {
                    "kind": "text",
                    "text": " is\nTrue, the columns are "
                  },
                  {
                    "kind": "code",
                    "text": "x^0, x^1, ..., x^(N-1)"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
