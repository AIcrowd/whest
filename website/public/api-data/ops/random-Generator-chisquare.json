            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from a chi-square distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "When "
              },
              {
                "kind": "code",
                "text": "df"
              },
              {
                "kind": "text",
                "text": " independent random variables, each with standard normal\ndistributions (mean 0, variance 1), are squared and summed, the\nresulting distribution is chi-square (see Notes).  This distribution\nis often used in hypothesis testing."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
