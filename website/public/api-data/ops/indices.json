              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The output shape in the dense case is obtained by prepending the number\nof dimensions in front of the tuple of dimensions, i.e. if "
              },
              {
                "kind": "code",
                "text": "dimensions"
              },
              {
                "kind": "text",
                "text": "\nis a tuple "
              },
              {
                "kind": "code",
                "text": "(r0, ..., rN-1)"
              },
              {
                "kind": "text",
                "text": " of length "
              },
              {
                "kind": "code",
                "text": "N"
              },
              {
                "kind": "text",
                "text": ", the output shape is\n"
              },
              {
                "kind": "code",
                "text": "(N, r0, ..., rN-1)"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The subarrays "
              },
              {
                "kind": "code",
                "text": "grid[k]"
              },
              {
                "kind": "text",
                "text": " contains the N-D array of indices along the\n"
              },
              {
                "kind": "code",
                "text": "k-th"
              },
              {
                "kind": "text",
                "text": " axis. Explicitly:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "grid[k, i0, i1, ..., iN-1] = ik",
            "type": "literal_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "grid = we.indices((2, 3))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "grid.shape"
              },
              {
                "kind": "output",
                "text": "(2, 2, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "grid[0]        # row indices"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [1, 1, 1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "grid[1]        # column indices"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2],"
              },
              {
                "kind": "output",
                "text": "       [0, 1, 2]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The indices can be used as an index into an array."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.arange(20).reshape(5, 4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "row, col = we.indices((2, 3))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x[row, col]"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2],"
              },
              {
                "kind": "output",
                "text": "       [4, 5, 6]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that it would be more straightforward in the above example to\nextract the required elements directly with "
              },
              {
                "kind": "code",
                "text": "x[:2, :3]"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If sparse is set to true, the grid will be returned in a sparse\nrepresentation."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "i, j = we.indices((2, 3), sparse=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "i.shape"
              },
              {
                "kind": "output",
                "text": "(2, 1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "j.shape"
              },
              {
                "kind": "output",
                "text": "(1, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "i        # row indices"
              },
              {
                "kind": "output",
                "text": "array([[0],"
              },
              {
                "kind": "output",
                "text": "       [1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "j        # column indices"
              },
              {
                "kind": "output",
                "text": "array([[0, 1, 2]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
