{
  "detail_href": "/docs/api/ops/indices/",
  "detail_json_href": "/api-data/ops/indices.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return an array representing the indices of a grid."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute an array where the subarrays contain index values 0, 1, ...\nvarying only along the corresponding axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The shape of the grid."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "sequence of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The shape of the grid."
                  }
                ],
                "name": "dimensions",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Data type of the result."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Data type of the result."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Return a sparse representation of the grid instead of a dense\nrepresentation. Default is False."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "boolean, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Return a sparse representation of the grid instead of a dense\nrepresentation. Default is False."
                  }
                ],
                "name": "sparse",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Returns one array of grid indices,\n"
                              },
                              {
                                "kind": "code",
                                "text": "grid.shape = (len(dimensions),) + tuple(dimensions)"
                              },
                              {
                                "kind": "text",
                                "text": "."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "If sparse is False:"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Returns a tuple of arrays, with\n"
                              },
                              {
                                "kind": "code",
                                "text": "grid[i].shape = (1, ..., 1, dimensions[i], 1, ..., 1)"
                              },
                              {
                                "kind": "text",
                                "text": " with\ndimensions[i] in the ith place"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "If sparse is True:"
                          }
                        ]
                      }
                    ],
                    "type": "definition_list"
                  }
                ],
                "data_type": "one ndarray or tuple of ndarrays",
                "inline": [],
                "name": "grid",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "",
                "description_inline": [],
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.mgrid.html",
                "href": "",
                "label": "mgrid",
                "original_target": "mgrid",
