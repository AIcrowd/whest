              {
                "kind": "text",
                "text": "Split an array into a sequence of arrays along the given axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "code",
                "text": "axis"
              },
              {
                "kind": "text",
                "text": " parameter specifies the dimension along which the array will\nbe split. For example, if "
              },
              {
                "kind": "code",
                "text": "axis=0"
              },
              {
                "kind": "text",
                "text": " (the default) it will be the first\ndimension and if "
              },
              {
                "kind": "code",
                "text": "axis=-1"
              },
              {
                "kind": "text",
                "text": " it will be the last dimension."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The result is a tuple of arrays split along "
              },
              {
                "kind": "code",
                "text": "axis"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
