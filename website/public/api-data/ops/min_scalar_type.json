  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "For scalar ``a``, returns the data type with the smallest size\nand smallest scalar kind which can hold its value.  For non-scalar\narray ``a``, returns the vector's dtype unmodified."
          },
          {
            "type": "paragraph",
            "text": "Floating point values are not demoted to integers,\nand complex values are not demoted to floats."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a",
            "type": "scalar or array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The value whose minimal data type is to be found."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "dtype",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The minimal data type."
              }
            ]
          }
        ]
      },
