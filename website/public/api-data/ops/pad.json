                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'empty'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Padding function, see Notes."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "<function>"
                          }
                        ]
                      }
                    ],
                    "type": "definition_list"
                  }
                ],
                "data_type": "str or function, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "One of the following string values or a user supplied function."
                  }
                ],
                "name": "mode",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Used in 'maximum', 'mean', 'median', and 'minimum'.  Number of\nvalues at edge of each axis used to calculate the statistic value."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "((before_1, after_1), ... (before_N, after_N))"
                      },
                      {
                        "kind": "text",
                        "text": " unique statistic\nlengths for each axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "(before, after)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "((before, after),)"
                      },
                      {
                        "kind": "text",
                        "text": " yields same before\nand after statistic lengths for each axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "(stat_length,)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "int"
                      },
                      {
                        "kind": "text",
                        "text": " is a shortcut for\n"
                      },
                      {
                        "kind": "code",
                        "text": "before = after = statistic"
                      },
                      {
                        "kind": "text",
                        "text": " length for all axes."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Default is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": ", to use the entire axis."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "sequence or int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Used in 'maximum', 'mean', 'median', and 'minimum'.  Number of\nvalues at edge of each axis used to calculate the statistic value."
                  }
                ],
                "name": "stat_length",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Used in 'constant'.  The values to set the padded values for each\naxis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "((before_1, after_1), ... (before_N, after_N))"
                      },
                      {
                        "kind": "text",
                        "text": " unique pad constants\nfor each axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "(before, after)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "((before, after),)"
                      },
                      {
                        "kind": "text",
                        "text": " yields same before\nand after constants for each axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "(constant,)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "constant"
                      },
                      {
                        "kind": "text",
                        "text": " is a shortcut for\n"
                      },
                      {
                        "kind": "code",
                        "text": "before = after = constant"
                      },
                      {
                        "kind": "text",
                        "text": " for all axes."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Default is 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "sequence or scalar, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Used in 'constant'.  The values to set the padded values for each\naxis."
                  }
                ],
                "name": "constant_values",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Used in 'linear_ramp'.  The values used for the ending value of the\nlinear_ramp and that will form the edge of the padded array."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "((before_1, after_1), ... (before_N, after_N))"
                      },
                      {
                        "kind": "text",
                        "text": " unique end values\nfor each axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "(before, after)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "((before, after),)"
                      },
                      {
                        "kind": "text",
                        "text": " yields same before\nand after end values for each axis."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "(constant,)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "constant"
                      },
                      {
                        "kind": "text",
                        "text": " is a shortcut for\n"
                      },
                      {
                        "kind": "code",
                        "text": "before = after = constant"
                      },
                      {
                        "kind": "text",
                        "text": " for all axes."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Default is 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "sequence or scalar, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Used in 'linear_ramp'.  The values used for the ending value of the\nlinear_ramp and that will form the edge of the padded array."
                  }
                ],
                "name": "end_values",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Used in 'reflect', and 'symmetric'.  The 'even' style is the\ndefault with an unaltered reflection around the edge value.  For\nthe 'odd' style, the extended part of the array is created by\nsubtracting the reflected values from two times the edge value."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'even', 'odd'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Used in 'reflect', and 'symmetric'.  The 'even' style is the\ndefault with an unaltered reflection around the edge value.  For\nthe 'odd' style, the extended part of the array is created by\nsubtracting the reflected values from two times the edge value."
                  }
                ],
                "name": "reflect_type",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Padded array of rank equal to "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/array",
                        "kind": "link",
                        "target": "array",
                        "text": "array"
                      },
                      {
                        "kind": "text",
                        "text": " with shape increased\naccording to "
                      },
                      {
                        "kind": "code",
                        "text": "pad_width"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Padded array of rank equal to "
                  },
                  {
                    "external_url": "",
                    "href": "/docs/api/ops/array",
                    "kind": "link",
                    "target": "array",
                    "text": "array"
                  },
                  {
                    "kind": "text",
                    "text": " with shape increased\naccording to "
                  },
                  {
                    "kind": "code",
                    "text": "pad_width"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "pad",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "For an array with rank greater than 1, some of the padding of later\naxes is calculated from padding of previous axes.  This is easiest to\nthink about with a rank 2 array where the corners of the padded array\nare calculated by using padded values from the first axis."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The padding function, if used, should modify a rank 1 array in-place. It\nhas the following signature:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "padding_func(vector, iaxis_pad_width, iaxis, kwargs)",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where"
              }
            ],
            "type": "paragraph"
          },
          {
            "items": [
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A rank 1 array already padded with zeros.  Padded values are\nvector[:iaxis_pad_width[0]] and vector[-iaxis_pad_width[1]:]."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "term_inline": [
                  {
                    "kind": "text",
                    "text": "vector"
                  },
                  {
                    "kind": "text",
                    "text": "ndarray"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A 2-tuple of ints, iaxis_pad_width[0] represents the number of\nvalues padded at the beginning of vector where\niaxis_pad_width[1] represents the number of values padded at\nthe end of vector."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "term_inline": [
                  {
                    "kind": "text",
                    "text": "iaxis_pad_width"
                  },
                  {
                    "kind": "text",
                    "text": "tuple"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The axis currently being calculated."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "term_inline": [
                  {
                    "kind": "text",
                    "text": "iaxis"
                  },
                  {
                    "kind": "text",
                    "text": "int"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Any keyword arguments the function requires."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "term_inline": [
                  {
                    "kind": "text",
                    "text": "kwargs"
                  },
                  {
                    "kind": "text",
                    "text": "dict"
                  }
                ]
              }
            ],
            "type": "definition_list"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = [1, 2, 3, 4, 5]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.pad(a, (2, 3), 'constant', constant_values=(4, 6))"
              },
              {
                "kind": "output",
                "text": "array([4, 4, 1, ..., 6, 6, 6])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.pad(a, (2, 3), 'edge')"
              },
              {
                "kind": "output",
                "text": "array([1, 1, 1, ..., 5, 5, 5])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.pad(a, (2, 3), 'linear_ramp', end_values=(5, -4))"
              },
              {
                "kind": "output",
                "text": "array([ 5,  3,  1,  2,  3,  4,  5,  2, -1, -4])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.pad(a, (2,), 'maximum')"
              },
              {
                "kind": "output",
                "text": "array([5, 5, 1, 2, 3, 4, 5, 5, 5])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.pad(a, (2,), 'mean')"
              },
              {
                "kind": "output",
                "text": "array([3, 3, 1, 2, 3, 4, 5, 3, 3])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.pad(a, (2,), 'median')"
              },
              {
                "kind": "output",
                "text": "array([3, 3, 1, 2, 3, 4, 5, 3, 3])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = [[1, 2], [3, 4]]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.pad(a, ((3, 2), (2, 3)), 'minimum')"
              },
              {
                "kind": "output",
                "text": "array([[1, 1, 1, 2, 1, 1, 1],"
              },
              {
                "kind": "output",
                "text": "       [1, 1, 1, 2, 1, 1, 1],"
              },
              {
                "kind": "output",
                "text": "       [1, 1, 1, 2, 1, 1, 1],"
              },
