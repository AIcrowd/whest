                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with a constant value."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'constant' (default)"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the edge values of array."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'edge'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the linear ramp between end_value and the\narray edge value."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'linear_ramp'"
