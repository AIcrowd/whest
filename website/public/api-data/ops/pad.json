    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Pad an array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The array to pad."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like of rank N",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The array to pad."
                  }
                ],
                "name": "array",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Number of values padded to the edges of each axis.\n"
                      },
                      {
                        "kind": "code",
                        "text": "((before_1, after_1), ... (before_N, after_N))"
                      },
                      {
                        "kind": "text",
                        "text": " unique pad widths\nfor each axis.\n"
                      },
                      {
                        "kind": "code",
                        "text": "(before, after)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "((before, after),)"
                      },
                      {
                        "kind": "text",
                        "text": " yields same before\nand after pad for each axis.\n"
                      },
                      {
                        "kind": "code",
                        "text": "(pad,)"
                      },
                      {
                        "kind": "text",
                        "text": " or "
                      },
                      {
                        "kind": "code",
                        "text": "int"
                      },
                      {
                        "kind": "text",
                        "text": " is a shortcut for before = after = pad width\nfor all axes."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{sequence, array_like, int}",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Number of values padded to the edges of each axis.\n"
                  },
                  {
                    "kind": "code",
                    "text": "((before_1, after_1), ... (before_N, after_N))"
                  },
                  {
                    "kind": "text",
                    "text": " unique pad widths\nfor each axis.\n"
                  },
                  {
                    "kind": "code",
                    "text": "(before, after)"
                  },
                  {
                    "kind": "text",
                    "text": " or "
                  },
                  {
                    "kind": "code",
                    "text": "((before, after),)"
                  },
                  {
                    "kind": "text",
                    "text": " yields same before\nand after pad for each axis.\n"
                  },
                  {
                    "kind": "code",
                    "text": "(pad,)"
                  },
                  {
                    "kind": "text",
                    "text": " or "
                  },
                  {
                    "kind": "code",
                    "text": "int"
                  },
                  {
                    "kind": "text",
                    "text": " is a shortcut for before = after = pad width\nfor all axes."
