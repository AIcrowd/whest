                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the maximum value of all or part of the\nvector along each axis."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'maximum'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the mean value of all or part of the\nvector along each axis."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'mean'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the median value of all or part of the\nvector along each axis."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'median'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the minimum value of all or part of the\nvector along each axis."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'minimum'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the reflection of the vector mirrored on\nthe first and last values of the vector along each\naxis."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'reflect'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the reflection of the vector mirrored\nalong the edge of the array."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'symmetric'"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "Pads with the wrap of the vector along the axis.\nThe first values are used to pad the end and the\nend values are used to pad the beginning."
                              }
                            ],
                            "type": "paragraph"
                          }
                        ],
                        "term_inline": [
                          {
                            "kind": "text",
                            "text": "'wrap'"
