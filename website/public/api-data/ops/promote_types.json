    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the data type with the smallest size and smallest scalar kind to which both "
              },
              {
                "kind": "code",
                "text": "type1"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "type2"
              },
              {
                "kind": "text",
                "text": " may be safely cast. The returned data type is always considered \"canonical\", this mainly means that the promoted dtype will always be in native byte order."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function is symmetric, but rarely associative."
