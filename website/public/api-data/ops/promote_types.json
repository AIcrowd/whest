      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Please see "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/result_type",
                "kind": "link",
                "target": "result_type",
                "text": "fnp.result_type"
              },
              {
                "kind": "text",
                "text": " for additional information about promotion."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Starting in NumPy 1.9, promote_types function now returns a valid string\nlength when given an integer or float dtype as one argument and a string\ndtype as another argument. Previously it always returned the input string\ndtype, even if it wasn't long enough to store the max integer/float value\nconverted to a string."
              }
            ],
            "type": "paragraph"
          },
          {
            "argument_inline": [],
            "content_blocks": [],
            "directive": "versionchanged",
            "options": [],
            "raw_source": ".. versionchanged:: 1.23.0",
            "supported": true,
            "type": "directive_block",
            "version": "1.23.0"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "NumPy now supports promotion for more structured dtypes.  It will now\nremove unnecessary padding from a structure dtype and promote included\nfields individually."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
