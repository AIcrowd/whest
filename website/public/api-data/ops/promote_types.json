                "kind": "input",
                "prompt": ">>>",
                "text": "p = fnp.promote_types"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "p('S', p('i1', 'u1'))"
              },
              {
                "kind": "output",
                "text": "dtype('S6')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "p(p('S', 'i1'), 'u1')"
              },
              {
