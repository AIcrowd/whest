    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Rotate an array by 90 degrees in the plane specified by axes."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Rotation direction is from the first towards the second axis.\nThis means for a 2D array with the default "
              },
              {
                "kind": "code",
                "text": "k"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "axes"
              },
              {
                "kind": "text",
                "text": ", the\nrotation will be counterclockwise."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
