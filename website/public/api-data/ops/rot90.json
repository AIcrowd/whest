        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "code",
                "text": "rot90(m, k=1, axes=(1,0))"
              },
              {
                "kind": "text",
                "text": "  is the reverse of\n"
              },
              {
                "kind": "code",
                "text": "rot90(m, k=1, axes=(0,1))"
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "code",
                "text": "rot90(m, k=1, axes=(1,0))"
              },
              {
                "kind": "text",
                "text": " is equivalent to\n"
              },
              {
                "kind": "code",
                "text": "rot90(m, k=-1, axes=(0,1))"
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as flops"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "m = flops.array([[1,2],[3,4]], int)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "m"
              },
              {
                "kind": "output",
                "text": "array([[1, 2],"
              },
              {
                "kind": "output",
                "text": "       [3, 4]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.rot90(m)"
              },
              {
                "kind": "output",
                "text": "array([[2, 4],"
              },
              {
                "kind": "output",
                "text": "       [1, 3]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.rot90(m, 2)"
              },
              {
                "kind": "output",
                "text": "array([[4, 3],"
              },
              {
                "kind": "output",
                "text": "       [2, 1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "m = flops.arange(8).reshape((2,2,2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "flops.rot90(m, 1, (1,2))"
              },
              {
                "kind": "output",
                "text": "array([[[1, 3],"
              },
              {
                "kind": "output",
                "text": "        [0, 2]],"
              },
              {
                "kind": "output",
                "text": "       [[5, 7],"
              },
              {
                "kind": "output",
                "text": "        [4, 6]]])"
              }
            ],
            "type": "doctest_block"
          }
