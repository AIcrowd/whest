                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[1, fnp.nan], [3, 4]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.nanmean(a)"
              },
              {
                "kind": "output",
                "text": "2.6666666666666665"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.nanmean(a, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([2.,  4.])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.nanmean(a, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([1.,  3.5]) # may vary"
              }
