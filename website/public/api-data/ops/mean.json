              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Type to use in computing the mean.  For integer inputs, the default\nis "
                      },
                      {
                        "kind": "code",
                        "text": "float64"
                      },
                      {
                        "kind": "text",
                        "text": "; for floating point inputs, it is the same as the\ninput dtype."
