  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the arithmetic mean along the specified axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the average of the array elements.  The average is taken over\nthe flattened array by default, otherwise over the specified axis.\n"
              },
              {
                "kind": "code",
                "text": "float64"
              },
              {
                "kind": "text",
                "text": " intermediate and return values are used for integer inputs."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array containing numbers whose mean is desired. If "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is not an\narray, a conversion is attempted."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array containing numbers whose mean is desired. If "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is not an\narray, a conversion is attempted."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which the means are computed. The default is to\ncompute the mean of the flattened array."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If this is a tuple of ints, a mean is performed over multiple axes,\ninstead of a single axis or all the axes as before."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "None or int or tuple of ints, optional",
