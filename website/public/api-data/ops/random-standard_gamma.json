        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the distribution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "shape, scale = 2., 1. # mean and width"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = fnp.random.standard_gamma(shape, 1000000)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Display the histogram of the samples, along with\nthe probability density function:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import scipy.special as sps  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "count, bins, ignored = plt.hist(s, 50, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = bins**(shape-1) * ((fnp.exp(-bins/scale))/  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "(sps.gamma(shape) * scale**shape))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(bins, y, linewidth=2, color='r')  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
