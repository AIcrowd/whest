        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the cross product of 3-element vectors."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": " and/or "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " are multi-dimensional arrays, then\nthe cross-product of each pair of corresponding 3-element vectors\nis independently computed."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function is Array API compatible, contrary to\n"
              },
              {
                "display_text": "we.cross",
                "explicit_title": false,
                "external_url": "",
                "href": "/docs/api/ops/cross",
                "kind": "role_reference",
