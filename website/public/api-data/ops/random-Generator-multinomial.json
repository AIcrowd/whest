{
  "detail_href": "/docs/api/numpy/random/generator/multinomial/",
  "detail_json_href": "/api-data/ops/random-Generator-multinomial.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from a multinomial distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The multinomial distribution is a multivariate generalization of the\nbinomial distribution.  Take an experiment with one of "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": "\npossible outcomes.  An example of such an experiment is throwing a dice,\nwhere the outcome can be 1 through 6.  Each sample drawn from the\ndistribution represents "
              },
              {
                "kind": "code",
                "text": "n"
              },
              {
                "kind": "text",
                "text": " such experiments.  Its values,\n"
              },
              {
                "kind": "code",
                "text": "X_i = [X_0, X_1, ..., X_p]"
              },
              {
                "kind": "text",
                "text": ", represent the number of times the\noutcome was "
              },
              {
                "kind": "code",
                "text": "i"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Number of experiments."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or array-like of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Number of experiments."
                  }
                ],
                "name": "n",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Probabilities of each of the "
                      },
                      {
                        "kind": "code",
                        "text": "p"
                      },
                      {
                        "kind": "text",
                        "text": " different outcomes with shape\n"
                      },
                      {
                        "kind": "code",
                        "text": "(k0, k1, ..., kn, p)"
                      },
                      {
                        "kind": "text",
                        "text": ". Each element "
                      },
                      {
                        "kind": "code",
                        "text": "pvals[i,j,...,:]"
                      },
                      {
                        "kind": "text",
                        "text": " must\nsum to 1 (however, the last element is always assumed to account\nfor the remaining probability, as long as\n"
                      },
                      {
                        "kind": "code",
                        "text": "sum(pvals[..., :-1], axis=-1) <= 1.0"
                      },
                      {
                        "kind": "text",
                        "text": ". Must have at least 1\ndimension where pvals.shape[-1] > 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array-like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Probabilities of each of the "
                  },
                  {
                    "kind": "code",
                    "text": "p"
                  },
                  {
                    "kind": "text",
                    "text": " different outcomes with shape\n"
                  },
                  {
                    "kind": "code",
                    "text": "(k0, k1, ..., kn, p)"
                  },
                  {
                    "kind": "text",
                    "text": ". Each element "
                  },
                  {
                    "kind": "code",
                    "text": "pvals[i,j,...,:]"
                  },
                  {
                    "kind": "text",
                    "text": " must\nsum to 1 (however, the last element is always assumed to account\nfor the remaining probability, as long as\n"
                  },
                  {
                    "kind": "code",
                    "text": "sum(pvals[..., :-1], axis=-1) <= 1.0"
                  },
                  {
                    "kind": "text",
                    "text": ". Must have at least 1\ndimension where pvals.shape[-1] > 0."
                  }
                ],
                "name": "pvals",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn each with "
                      },
                      {
                        "kind": "code",
                        "text": "p"
                      },
                      {
                        "kind": "text",
                        "text": " elements. Default\nis None where the output size is determined by the broadcast shape\nof "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " and all by the final dimension of "
                      },
                      {
                        "kind": "code",
                        "text": "pvals"
                      },
                      {
                        "kind": "text",
                        "text": ", which is\ndenoted as "
                      },
                      {
                        "kind": "code",
                        "text": "b=(b0, b1, ..., bq)"
                      },
                      {
                        "kind": "text",
                        "text": ". If size is not None, then it\nmust be compatible with the broadcast shape "
                      },
                      {
                        "kind": "code",
                        "text": "b"
                      },
                      {
                        "kind": "text",
                        "text": ". Specifically,\nsize must have "
                      },
                      {
                        "kind": "code",
                        "text": "q"
                      },
                      {
                        "kind": "text",
                        "text": " or more elements and size[-(q-j):] must equal\n"
                      },
                      {
                        "kind": "code",
                        "text": "bj"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn each with "
                  },
                  {
                    "kind": "code",
                    "text": "p"
                  },
                  {
                    "kind": "text",
                    "text": " elements. Default\nis None where the output size is determined by the broadcast shape\nof "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " and all by the final dimension of "
                  },
                  {
                    "kind": "code",
                    "text": "pvals"
                  },
                  {
                    "kind": "text",
                    "text": ", which is\ndenoted as "
                  },
                  {
                    "kind": "code",
                    "text": "b=(b0, b1, ..., bq)"
                  },
                  {
                    "kind": "text",
                    "text": ". If size is not None, then it\nmust be compatible with the broadcast shape "
                  },
                  {
                    "kind": "code",
                    "text": "b"
                  },
                  {
                    "kind": "text",
                    "text": ". Specifically,\nsize must have "
                  },
                  {
                    "kind": "code",
                    "text": "q"
                  },
                  {
                    "kind": "text",
                    "text": " or more elements and size[-(q-j):] must equal\n"
                  },
                  {
                    "kind": "code",
                    "text": "bj"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "size",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The drawn samples, of shape size, if provided. When size is\nprovided, the output shape is size + (p,)  If not specified,\nthe shape is determined by the broadcast shape of "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " and\n"
                      },
                      {
                        "kind": "code",
                        "text": "pvals"
                      },
                      {
                        "kind": "text",
                        "text": ", "
                      },
                      {
                        "kind": "code",
                        "text": "(b0, b1, ..., bq)"
                      },
                      {
                        "kind": "text",
                        "text": " augmented with the dimension of\nthe multinomial, "
                      },
                      {
                        "kind": "code",
                        "text": "p"
                      },
                      {
                        "kind": "text",
                        "text": ", so that that output shape is\n"
                      },
                      {
                        "kind": "code",
                        "text": "(b0, b1, ..., bq, p)"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Each entry "
                      },
                      {
                        "kind": "code",
                        "text": "out[i,j,...,:]"
                      },
                      {
                        "kind": "text",
                        "text": " is a "
                      },
                      {
                        "kind": "code",
                        "text": "p"
                      },
                      {
                        "kind": "text",
                        "text": "-dimensional value drawn\nfrom the distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The drawn samples, of shape size, if provided. When size is\nprovided, the output shape is size + (p,)  If not specified,\nthe shape is determined by the broadcast shape of "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " and\n"
                  },
                  {
                    "kind": "code",
                    "text": "pvals"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "(b0, b1, ..., bq)"
                  },
                  {
                    "kind": "text",
                    "text": " augmented with the dimension of\nthe multinomial, "
                  },
                  {
                    "kind": "code",
                    "text": "p"
                  },
                  {
                    "kind": "text",
                    "text": ", so that that output shape is\n"
                  },
                  {
                    "kind": "code",
                    "text": "(b0, b1, ..., bq, p)"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Throw a dice 20 times:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial(20, [1/6.]*6, size=1)"
              },
              {
                "kind": "output",
                "text": "array([[4, 1, 7, 5, 2, 1]])  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "It landed 4 times on 1, once on 2, etc."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Now, throw the dice 20 times, and 20 times again:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial(20, [1/6.]*6, size=2)"
              },
              {
                "kind": "output",
                "text": "array([[3, 4, 3, 3, 4, 3],"
              },
              {
                "kind": "output",
                "text": "       [2, 4, 3, 4, 0, 7]])  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For the first run, we threw 3 times 1, 4 times 2, etc.  For the second,\nwe threw 2 times 1, 4 times 2, etc."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Now, do one experiment throwing the dice 10 time, and 10 times again,\nand another throwing the dice 20 times, and 20 times again:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial([[10], [20]], [1/6.]*6, size=(2, 2))"
              },
              {
                "kind": "output",
                "text": "array([[[2, 4, 0, 1, 2, 1],"
              },
              {
                "kind": "output",
                "text": "        [1, 3, 0, 3, 1, 2]],"
              },
              {
                "kind": "output",
                "text": "       [[1, 4, 4, 4, 4, 3],"
              },
              {
                "kind": "output",
                "text": "        [3, 3, 2, 5, 5, 2]]])  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The first array shows the outcomes of throwing the dice 10 times, and\nthe second shows the outcomes from throwing the dice 20 times."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "A loaded die is more likely to land on number 6:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial(100, [1/7.]*5 + [2/7.])"
              },
              {
                "kind": "output",
                "text": "array([11, 16, 14, 17, 16, 26])  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Simulate 10 throws of a 4-sided die and 20 throws of a 6-sided die"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial([10, 20],[[1/4]*4 + [0]*2, [1/6]*6])"
              },
              {
                "kind": "output",
                "text": "array([[2, 1, 4, 3, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [3, 3, 3, 6, 1, 4]], dtype=int64)  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Generate categorical random variates from two categories where the\nfirst has 3 outcomes and the second has 2."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial(1, [[.1, .5, .4 ], [.3, .7, .0]])"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 1],"
              },
              {
                "kind": "output",
                "text": "       [0, 1, 0]], dtype=int64)  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "code",
                "text": "argmax(axis=-1)"
              },
              {
                "kind": "text",
                "text": " is then used to return the categories."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "pvals = [[.1, .5, .4 ], [.3, .7, .0]]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rvs = rng.multinomial(1, pvals, size=(4,2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rvs.argmax(axis=-1)"
              },
              {
                "kind": "output",
                "text": "array([[0, 1],"
              },
              {
                "kind": "output",
                "text": "       [2, 0],"
              },
              {
                "kind": "output",
                "text": "       [2, 1],"
              },
              {
                "kind": "output",
                "text": "       [2, 0]], dtype=int64)  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The same output dimension can be produced using broadcasting."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rvs = rng.multinomial([[1]] * 4, pvals)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rvs.argmax(axis=-1)"
              },
              {
                "kind": "output",
                "text": "array([[0, 1],"
              },
              {
                "kind": "output",
                "text": "       [2, 0],"
              },
              {
                "kind": "output",
                "text": "       [2, 1],"
              },
              {
                "kind": "output",
                "text": "       [2, 0]], dtype=int64)  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability inputs should be normalized. As an implementation\ndetail, the value of the last entry is ignored and assumed to take\nup any leftover probability mass, but this should not be relied on.\nA biased coin which has twice as much weight on one side as on the\nother should be sampled like so:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial(100, [1.0 / 3, 2.0 / 3])  # RIGHT"
              },
              {
                "kind": "output",
                "text": "array([38, 62])  # random"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "not like:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng.multinomial(100, [1.0, 2.0])  # WRONG"
              },
              {
                "kind": "output",
                "text": "Traceback (most recent call last):"
              },
              {
                "kind": "output",
                "text": "ValueError: pvals < 0, pvals > 1 or pvals contains NaNs"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
  "op": {
    "category": "counted_random_method",
    "cost_formula": "numel(output)",
    "cost_formula_latex": "$\\text{numel}(\\text{output})$",
