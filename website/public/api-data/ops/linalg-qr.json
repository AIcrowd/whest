  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the qr factorization of a matrix."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Factor the matrix "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " as "
              },
              {
                "kind": "emphasis",
                "text": "qr"
              },
              {
                "kind": "text",
                "text": ", where "
              },
              {
                "kind": "code",
                "text": "q"
              },
              {
                "kind": "text",
                "text": " is orthonormal and "
              },
              {
                "kind": "code",
                "text": "r"
              },
              {
                "kind": "text",
                "text": " is\nupper-triangular."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array-like object with the dimensionality of at least 2."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape (..., M, N)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An array-like object with the dimensionality of at least 2."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If K = min(M, N), then"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'reduced'  : returns Q, R with dimensions (..., M, K), (..., K, N)"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'complete' : returns Q, R with dimensions (..., M, M), (..., M, N)"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'r'        : returns R only with dimensions (..., K, N)"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'raw'      : returns h, tau with dimensions (..., N, M), (..., K,)"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The options 'reduced', 'complete, and 'raw' are new in numpy 1.8,\nsee the notes for more information. The default is 'reduced', and to\nmaintain backward compatibility with earlier versions of numpy both\nit and the old default 'full' can be omitted. Note that array h\nreturned in 'raw' mode is transposed for calling Fortran. The\n'economic' mode is deprecated.  The modes 'full' and 'economic' may\nbe passed using only the first letter for backwards compatibility,\nbut all others must be spelled out. See the Notes for more\nexplanation."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'reduced', 'complete', 'r', 'raw'}, optional, default: 'reduced'",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If K = min(M, N), then"
                  }
                ],
                "name": "mode",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [],
                "data_type": "When mode is 'reduced' or 'complete', the result will be a namedtuple with",
                "inline": [],
                "name": "",
                "type": "field_list"
              },
              {
                "body_blocks": [],
                "data_type": "the attributes `Q` and `R`.",
                "inline": [],
                "name": "",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "A matrix with orthonormal columns. When mode = 'complete' the\nresult is an orthogonal/unitary matrix depending on whether or not\na is real/complex. The determinant may be either +/- 1 in that\ncase. In case the number of dimensions in the input array is\ngreater than 2 then a stack of the matrices with above properties\nis returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray of float or complex, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "A matrix with orthonormal columns. When mode = 'complete' the\nresult is an orthogonal/unitary matrix depending on whether or not\na is real/complex. The determinant may be either +/- 1 in that\ncase. In case the number of dimensions in the input array is\ngreater than 2 then a stack of the matrices with above properties\nis returned."
                  }
                ],
                "name": "Q",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The upper-triangular matrix or a stack of upper-triangular\nmatrices if the number of dimensions in the input array is greater\nthan 2."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray of float or complex, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The upper-triangular matrix or a stack of upper-triangular\nmatrices if the number of dimensions in the input array is greater\nthan 2."
                  }
                ],
                "name": "R",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The array h contains the Householder reflectors that generate q\nalong with r. The tau array contains scaling factors for the\nreflectors. In the deprecated  'economic' mode only h is returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarrays of we.double or we.cdouble, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The array h contains the Householder reflectors that generate q\nalong with r. The tau array contains scaling factors for the\nreflectors. In the deprecated  'economic' mode only h is returned."
                  }
                ],
                "name": "(h, tau)",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
