          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Drawn samples from the parameterized Rayleigh distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Drawn samples from the parameterized Rayleigh distribution."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density function for the Rayleigh distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "P(x;scale) = \\frac{x}{scale^2}e^{\\frac{-x^2}{2 \\cdotp scale^2}}"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The Rayleigh distribution would arise, for example, if the East\nand North components of the wind velocity had identical zero-mean\nGaussian distributions.  Then the wind speed would have a Rayleigh\ndistribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nBrighton Webs Ltd., \"Rayleigh Distribution,\"\nhttps://web.archive.org/web/20090514091424/http://brighton-webs.co.uk:80/distributions/rayleigh.asp",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nWikipedia, \"Rayleigh distribution\"\nhttps://en.wikipedia.org/wiki/Rayleigh_distribution",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw values from the distribution and plot the histogram"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from matplotlib.pyplot import hist"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "values = hist(rng.rayleigh(3, 100000), bins=200, density=True)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Wave heights tend to follow a Rayleigh distribution. If the mean wave\nheight is 1 meter, what fraction of waves are likely to be larger than 3\nmeters?"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "meanvalue = 1"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "modevalue = flops.sqrt(2 / flops.pi) * meanvalue"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = rng.rayleigh(modevalue, 1000000)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The percentage of waves larger than 3 meters is:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "100.*sum(s>3)/1000000."
              },
              {
                "kind": "output",
                "text": "0.087300000000000003 # random"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
