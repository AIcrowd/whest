    "module": "numpy.linalg",
    "whest_ref": "we.linalg.cross",
    "numpy_ref": "np.linalg.cross",
    "category": "counted_custom",
    "status": "supported",
    "weight": 1.0,
    "cost_formula": "delegates to we.cross",
    "cost_formula_latex": "delegates to `cross`",
    "notes": "Delegates to `we.cross` which charges `numel(output)` FLOPs.",
    "summary": "Returns the cross product of 3-element vectors.",
    "signature": "we.linalg.cross(x1, x2, /, *, axis=-1)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Returns the cross product of 3-element vectors."
          },
          {
            "type": "paragraph",
            "text": "If ``x1`` and/or ``x2`` are multi-dimensional arrays, then\nthe cross-product of each pair of corresponding 3-element vectors\nis independently computed."
          },
          {
            "type": "paragraph",
            "text": "This function is Array API compatible, contrary to\n:func:`numpy.cross`."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x1",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The first input array."
              }
            ]
          },
          {
            "name": "x2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The second input array. Must be compatible with ``x1`` for all\nnon-compute axes. The size of the axis over which to compute\nthe cross-product must be the same size as the respective axis\nin ``x1``."
              }
            ]
          },
          {
            "name": "axis",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The axis (dimension) of ``x1`` and ``x2`` containing the vectors for\nwhich to compute the cross-product. Default: ``-1``."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array containing the cross products."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Vector cross-product."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x = np.array([1, 2, 3])\n>>> y = np.array([4, 5, 6])\n>>> np.linalg.cross(x, y)\narray([-3,  6, -3])"
          },
          {
            "type": "paragraph",
            "text": "Multiple vector cross-products. Note that the direction of the cross\nproduct vector is defined by the *right-hand rule*."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x = np.array([[1,2,3], [4,5,6]])\n>>> y = np.array([[4,5,6], [1,2,3]])\n>>> np.linalg.cross(x, y)\narray([[-3,  6, -3],\n       [ 3, -6,  3]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x = np.array([[1, 2], [3, 4], [5, 6]])\n>>> y = np.array([[4, 5], [6, 1], [2, 3]])\n>>> np.linalg.cross(x, y, axis=0)\narray([[-24,  6],\n       [ 18, 24],\n       [-6,  -18]])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
