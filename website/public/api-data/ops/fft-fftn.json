        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.mgrid[:3, :3, :3][0]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fft.fftn(a, axes=(1, 2))"
              },
              {
                "kind": "output",
                "text": "array([[[ 0.+0.j,   0.+0.j,   0.+0.j], # may vary"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,   0.+0.j,   0.+0.j],"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,   0.+0.j,   0.+0.j]],"
              },
              {
                "kind": "output",
                "text": "       [[ 9.+0.j,   0.+0.j,   0.+0.j],"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,   0.+0.j,   0.+0.j],"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,   0.+0.j,   0.+0.j]],"
              },
              {
                "kind": "output",
                "text": "       [[18.+0.j,   0.+0.j,   0.+0.j],"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,   0.+0.j,   0.+0.j],"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,   0.+0.j,   0.+0.j]]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fft.fftn(a, (2, 2), axes=(0, 1))"
              },
              {
                "kind": "output",
                "text": "array([[[ 2.+0.j,  2.+0.j,  2.+0.j], # may vary"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,  0.+0.j,  0.+0.j]],"
              },
              {
                "kind": "output",
                "text": "       [[-2.+0.j, -2.+0.j, -2.+0.j],"
              },
              {
                "kind": "output",
                "text": "        [ 0.+0.j,  0.+0.j,  0.+0.j]]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "[X, Y] = fnp.meshgrid(2 * fnp.pi * fnp.arange(200) / 12,"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "2 * fnp.pi * fnp.arange(200) / 34)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "S = fnp.sin(X) + fnp.cos(Y) + fnp.random.uniform(0, 1, X.shape)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "FS = fnp.fft.fftn(S)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.imshow(fnp.log(fnp.abs(fnp.fft.fftshift(FS))**2))"
              },
              {
                "kind": "output",
                "text": "<matplotlib.image.AxesImage object at 0x...>"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
