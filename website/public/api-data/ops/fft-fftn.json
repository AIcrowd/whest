  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the N-dimensional discrete Fourier Transform."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function computes the "
              },
              {
                "kind": "emphasis",
                "text": "N"
              },
              {
                "kind": "text",
                "text": "-dimensional discrete Fourier Transform over\nany number of axes in an "
              },
              {
                "kind": "emphasis",
                "text": "M"
              },
              {
                "kind": "text",
                "text": "-dimensional array by means of the Fast Fourier\nTransform (FFT)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array, can be complex."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array, can be complex."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Shape (length of each transformed axis) of the output\n("
                      },
                      {
                        "kind": "code",
                        "text": "s[0]"
                      },
                      {
                        "kind": "text",
                        "text": " refers to axis 0, "
                      },
                      {
                        "kind": "code",
                        "text": "s[1]"
                      },
                      {
                        "kind": "text",
                        "text": " to axis 1, etc.).\nThis corresponds to "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " for "
                      },
                      {
                        "kind": "code",
                        "text": "fft(x, n)"
                      },
                      {
                        "kind": "text",
                        "text": ".\nAlong any axis, if the given shape is smaller than that of the input,\nthe input is cropped. If it is larger, the input is padded with zeros."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "versionchanged",
                    "options": [],
                    "raw_source": ".. versionchanged:: 2.0\n\n    If it is ``-1``, the whole input is used (no padding/trimming).",
                    "supported": true,
                    "type": "directive_block",
                    "version": "2.0"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "s"
                      },
                      {
                        "kind": "text",
                        "text": " is not given, the shape of the input along the axes specified\nby "
                      },
                      {
                        "kind": "code",
                        "text": "axes"
                      },
                      {
                        "kind": "text",
                        "text": " is used."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "deprecated",
                    "options": [],
                    "raw_source": ".. deprecated:: 2.0\n\n    If `s` is not ``None``, `axes` must not be ``None`` either.",
                    "supported": true,
                    "type": "directive_block",
                    "version": "2.0"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "deprecated",
                    "options": [],
                    "raw_source": ".. deprecated:: 2.0\n\n    `s` must contain only ``int`` s, not ``None`` values. ``None``\n    values currently mean that the default value for ``n`` is used\n    in the corresponding 1-D transform, but this behaviour is\n    deprecated.",
                    "supported": true,
                    "type": "directive_block",
                    "version": "2.0"
                  }
                ],
                "data_type": "sequence of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Shape (length of each transformed axis) of the output\n("
                  },
                  {
                    "kind": "code",
                    "text": "s[0]"
                  },
                  {
                    "kind": "text",
                    "text": " refers to axis 0, "
                  },
                  {
                    "kind": "code",
                    "text": "s[1]"
                  },
                  {
                    "kind": "text",
                    "text": " to axis 1, etc.).\nThis corresponds to "
                  },
                  {
                    "kind": "code",
                    "text": "n"
                  },
                  {
                    "kind": "text",
                    "text": " for "
                  },
                  {
                    "kind": "code",
                    "text": "fft(x, n)"
                  },
                  {
                    "kind": "text",
                    "text": ".\nAlong any axis, if the given shape is smaller than that of the input,\nthe input is cropped. If it is larger, the input is padded with zeros."
                  }
                ],
                "name": "s",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axes over which to compute the FFT.  If not given, the last "
                      },
                      {
                        "kind": "code",
                        "text": "len(s)"
                      },
                      {
                        "kind": "text",
                        "text": "\naxes are used, or all axes if "
                      },
                      {
                        "kind": "code",
                        "text": "s"
                      },
                      {
                        "kind": "text",
                        "text": " is also not specified.\nRepeated indices in "
                      },
                      {
                        "kind": "code",
                        "text": "axes"
                      },
                      {
                        "kind": "text",
                        "text": " means that the transform over that axis is\nperformed multiple times."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "deprecated",
                    "options": [],
                    "raw_source": ".. deprecated:: 2.0\n\n    If `s` is specified, the corresponding `axes` to be transformed\n    must be explicitly specified too.",
                    "supported": true,
                    "type": "directive_block",
                    "version": "2.0"
                  }
                ],
                "data_type": "sequence of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axes over which to compute the FFT.  If not given, the last "
                  },
                  {
                    "kind": "code",
                    "text": "len(s)"
                  },
                  {
                    "kind": "text",
                    "text": "\naxes are used, or all axes if "
                  },
                  {
                    "kind": "code",
                    "text": "s"
                  },
                  {
                    "kind": "text",
                    "text": " is also not specified.\nRepeated indices in "
                  },
                  {
                    "kind": "code",
                    "text": "axes"
                  },
                  {
                    "kind": "text",
                    "text": " means that the transform over that axis is\nperformed multiple times."
                  }
                ],
                "name": "axes",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Normalization mode (see "
                      },
                      {
                        "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                        "href": "",
                        "kind": "link",
                        "target": "fft",
                        "text": "fnp.fft"
                      },
                      {
                        "kind": "text",
                        "text": "). Default is \"backward\".\nIndicates which direction of the forward/backward pair of transforms\nis scaled and with what normalization factor."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "versionadded",
                    "options": [],
                    "raw_source": ".. versionadded:: 1.20.0\n\n    The \"backward\", \"forward\" values were added.",
                    "supported": true,
                    "type": "directive_block",
                    "version": "1.20.0"
                  }
                ],
                "data_type": "{\"backward\", \"ortho\", \"forward\"}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Normalization mode (see "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.fft.html",
                    "href": "",
                    "kind": "link",
                    "target": "fft",
                    "text": "fnp.fft"
                  },
                  {
                    "kind": "text",
                    "text": "). Default is \"backward\".\nIndicates which direction of the forward/backward pair of transforms\nis scaled and with what normalization factor."
                  }
                ],
                "name": "norm",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If provided, the result will be placed in this array. It should be\nof the appropriate shape and dtype for all axes (and hence is\nincompatible with passing in all but the trivial "
                      },
                      {
                        "kind": "code",
                        "text": "s"
                      },
                      {
                        "kind": "text",
                        "text": ")."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
