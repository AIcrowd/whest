      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The output, analogously to "
              },
              {
                "kind": "code",
                "text": "fft"
              },
              {
                "kind": "text",
                "text": ", contains the term for zero frequency in\nthe low-order corner of all axes, the positive frequency terms in the\nfirst half of all axes, the term for the Nyquist frequency in the middle\nof all axes and the negative frequency terms in the second half of all\naxes, in order of decreasingly negative frequency."
              }
            ],
            "type": "paragraph"
          },
