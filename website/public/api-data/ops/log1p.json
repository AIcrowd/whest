        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "For real-valued input, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/log1p",
                "kind": "link",
                "target": "log1p",
                "text": "log1p"
              },
              {
                "kind": "text",
                "text": " is accurate also for "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " so small\nthat "
              },
              {
                "kind": "code",
                "text": "1 + x == 1"
              },
              {
                "kind": "text",
                "text": " in floating-point accuracy."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Logarithm is a multivalued function: for each "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " there is an infinite\nnumber of "
              },
              {
                "kind": "code",
                "text": "z"
              },
              {
                "kind": "text",
                "text": " such that "
              },
              {
                "kind": "code",
                "text": "exp(z) = 1 + x"
              },
              {
                "kind": "text",
                "text": ". The convention is to return\nthe "
              },
              {
                "kind": "code",
                "text": "z"
              },
              {
                "kind": "text",
                "text": " whose imaginary part lies in "
              },
              {
                "kind": "code",
                "text": "[-pi, pi]"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For real-valued input data types, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/log1p",
                "kind": "link",
                "target": "log1p",
                "text": "log1p"
              },
              {
                "kind": "text",
                "text": " always returns real output.\nFor each value that cannot be expressed as a real number or infinity,\nit yields "
              },
              {
                "kind": "code",
                "text": "nan"
              },
              {
                "kind": "text",
                "text": " and sets the "
              },
              {
                "kind": "code",
                "text": "invalid"
              },
              {
                "kind": "text",
                "text": " floating point error flag."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For complex-valued input, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/log1p",
                "kind": "link",
                "target": "log1p",
                "text": "log1p"
              },
              {
                "kind": "text",
                "text": " is a complex analytical function that\nhas a branch cut "
              },
              {
                "kind": "code",
                "text": "[-inf, -1]"
              },
              {
                "kind": "text",
                "text": " and is continuous from above on it.\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/log1p",
                "kind": "link",
                "target": "log1p",
                "text": "log1p"
              },
              {
                "kind": "text",
                "text": " handles the floating-point negative zero as an infinitesimal\nnegative number, conforming to the C99 standard."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
