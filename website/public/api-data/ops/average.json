  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the weighted average along the specified axis."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array containing data to be averaged. If "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is not an array, a\nconversion is attempted."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array containing data to be averaged. If "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is not an array, a\nconversion is attempted."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which to average "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ".  The default,\n"
                      },
                      {
                        "kind": "code",
                        "text": "axis=None"
                      },
                      {
                        "kind": "text",
                        "text": ", will average over all of the elements of the input array.\nIf axis is negative it counts from the last to the first axis.\nIf axis is a tuple of ints, averaging is performed on all of the axes\nspecified in the tuple instead of a single axis or all the axes as\nbefore."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "None or int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which to average "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": ".  The default,\n"
                  },
                  {
                    "kind": "code",
                    "text": "axis=None"
                  },
                  {
                    "kind": "text",
                    "text": ", will average over all of the elements of the input array.\nIf axis is negative it counts from the last to the first axis.\nIf axis is a tuple of ints, averaging is performed on all of the axes\nspecified in the tuple instead of a single axis or all the axes as\nbefore."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array of weights associated with the values in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ". Each value in\n"
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " contributes to the average according to its associated weight.\nThe array of weights must be the same shape as "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " if no axis is\nspecified, otherwise the weights must have dimensions and shape\nconsistent with "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " along the specified axis.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "weights=None"
                      },
                      {
                        "kind": "text",
                        "text": ", then all data in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " are assumed to have a\nweight equal to one.\nThe calculation is:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "language": null,
                    "text": "avg = sum(a * weights) / sum(weights)",
                    "type": "literal_block"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "where the sum is over all included elements.\nThe only constraint on the values of "
                      },
                      {
                        "kind": "code",
                        "text": "weights"
                      },
                      {
                        "kind": "text",
                        "text": " is that "
                      },
                      {
                        "kind": "code",
                        "text": "sum(weights)"
                      },
                      {
                        "kind": "text",
                        "text": "\nmust not be 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "An array of weights associated with the values in "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": ". Each value in\n"
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " contributes to the average according to its associated weight.\nThe array of weights must be the same shape as "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " if no axis is\nspecified, otherwise the weights must have dimensions and shape\nconsistent with "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " along the specified axis.\nIf "
                  },
                  {
                    "kind": "code",
                    "text": "weights=None"
                  },
                  {
                    "kind": "text",
                    "text": ", then all data in "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " are assumed to have a\nweight equal to one.\nThe calculation is:"
                  }
                ],
                "name": "weights",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Default is "
                      },
                      {
                        "kind": "code",
                        "text": "False"
                      },
                      {
                        "kind": "text",
                        "text": ". If "
                      },
                      {
                        "kind": "code",
                        "text": "True"
                      },
                      {
                        "kind": "text",
                        "text": ", the tuple ("
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/average",
                        "kind": "link",
                        "target": "average",
                        "text": "average"
                      },
                      {
                        "kind": "text",
                        "text": ", "
                      },
                      {
                        "kind": "code",
                        "text": "sum_of_weights"
                      },
                      {
                        "kind": "text",
                        "text": ")\nis returned, otherwise only the average is returned.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "weights=None"
                      },
                      {
                        "kind": "text",
                        "text": ", "
                      },
                      {
                        "kind": "code",
                        "text": "sum_of_weights"
                      },
                      {
                        "kind": "text",
                        "text": " is equivalent to the number of\nelements over which the average is taken."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Default is "
                  },
                  {
                    "kind": "code",
                    "text": "False"
                  },
                  {
                    "kind": "text",
                    "text": ". If "
                  },
                  {
                    "kind": "code",
                    "text": "True"
                  },
                  {
                    "kind": "text",
                    "text": ", the tuple ("
                  },
                  {
                    "external_url": "",
                    "href": "/docs/api/ops/average",
                    "kind": "link",
                    "target": "average",
                    "text": "average"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "sum_of_weights"
                  },
                  {
                    "kind": "text",
                    "text": ")\nis returned, otherwise only the average is returned.\nIf "
                  },
                  {
                    "kind": "code",
                    "text": "weights=None"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "sum_of_weights"
                  },
                  {
                    "kind": "text",
                    "text": " is equivalent to the number of\nelements over which the average is taken."
                  }
                ],
                "name": "returned",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the original "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ".\n"
                      },
                      {
                        "kind": "emphasis",
