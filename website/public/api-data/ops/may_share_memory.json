    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Determine if two arrays might share memory"
          },
          {
            "type": "paragraph",
            "text": "A return of True does not necessarily mean that the two arrays\nshare any element.  It just means that they *might*."
          },
          {
            "type": "paragraph",
            "text": "Only the memory bounds of a and b are checked by default."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a, b",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input arrays"
              }
            ]
          },
          {
            "name": "max_work",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Effort to spend on solving the overlap problem.  See\n`shares_memory` for details.  Default for ``may_share_memory``\nis to do a bounds check."
              }
            ]
          }
        ]
      },
      {
