      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.array_repr(np.array([1,2]))\n'array([1, 2])'\n>>> np.array_repr(np.ma.array([0.]))\n'MaskedArray([0.])'\n>>> np.array_repr(np.array([], np.int32))\n'array([], dtype=int32)'"
