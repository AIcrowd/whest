      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Check for a complex type or an array of complex numbers."
          },
          {
            "type": "paragraph",
            "text": "The type of the input is checked, not the value. Even if the input\nhas an imaginary part equal to zero, `iscomplexobj` evaluates to True."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "any",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The input can be of any type and shape."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "iscomplexobj",
            "type": "bool",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The return value, True if `x` is of a complex type or has at least\none complex element."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.iscomplexobj(1)\nFalse\n>>> np.iscomplexobj(1+0j)\nTrue\n>>> np.iscomplexobj([3, 1+0j, True])\nTrue"
          }
        ]
      },
