              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Overrides the memory layout of the result. 'C' means C-order,\n'F' means F-order, 'A' means 'F' if "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is Fortran contiguous,\n'C' otherwise. 'K' means match the layout of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " as closely\nas possible."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{'C', 'F', 'A', or 'K'}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Overrides the memory layout of the result. 'C' means C-order,\n'F' means F-order, 'A' means 'F' if "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is Fortran contiguous,\n'C' otherwise. 'K' means match the layout of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " as closely\nas possible."
                  }
                ],
                "name": "order",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, then the newly created array will use the sub-class\ntype of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ", otherwise it will be a base-class array. Defaults\nto True."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional.",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, then the newly created array will use the sub-class\ntype of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": ", otherwise it will be a base-class array. Defaults\nto True."
                  }
                ],
                "name": "subok",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Overrides the shape of the result. If order='K' and the number of\ndimensions is unchanged, will try to keep order, otherwise,\norder='C' is implied."
