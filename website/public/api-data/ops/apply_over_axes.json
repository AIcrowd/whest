        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This function is equivalent to tuple axis arguments to reorderable ufuncs\nwith keepdims=True. Tuple axis arguments to ufuncs have been available since\nversion 1.7.0."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.arange(24).reshape(2,3,4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[[ 0,  1,  2,  3],"
              },
              {
                "kind": "output",
                "text": "        [ 4,  5,  6,  7],"
              },
              {
                "kind": "output",
                "text": "        [ 8,  9, 10, 11]],"
              },
              {
                "kind": "output",
                "text": "       [[12, 13, 14, 15],"
              },
              {
                "kind": "output",
                "text": "        [16, 17, 18, 19],"
              },
              {
                "kind": "output",
                "text": "        [20, 21, 22, 23]]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Sum over axes 0 and 2. The result has same number of dimensions\nas the original array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.apply_over_axes(we.sum, a, [0,2])"
              },
              {
                "kind": "output",
                "text": "array([[[ 60],"
              },
              {
                "kind": "output",
                "text": "        [ 92],"
              },
              {
                "kind": "output",
                "text": "        [124]]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Tuple axis arguments to ufuncs are equivalent:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.sum(a, axis=(0,2), keepdims=True)"
              },
              {
                "kind": "output",
                "text": "array([[[ 60],"
              },
              {
                "kind": "output",
                "text": "        [ 92],"
              },
              {
                "kind": "output",
                "text": "        [124]]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
