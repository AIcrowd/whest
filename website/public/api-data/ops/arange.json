{
  "detail_href": "/docs/api/arange/",
  "detail_json_href": "/api-data/ops/arange.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return evenly spaced values within a given interval."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/arange",
                "kind": "link",
                "target": "arange",
                "text": "arange"
              },
              {
                "kind": "text",
                "text": " can be called with a varying number of positional arguments:"
              }
            ],
            "type": "paragraph"
          },
          {
            "items": [
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "arange(stop)"
                      },
                      {
                        "kind": "text",
                        "text": ": Values are generated within the half-open interval\n"
                      },
                      {
                        "kind": "code",
                        "text": "[0, stop)"
                      },
                      {
                        "kind": "text",
                        "text": " (in other words, the interval including "
                      },
                      {
                        "kind": "code",
                        "text": "start"
                      },
                      {
                        "kind": "text",
                        "text": " but\nexcluding "
                      },
                      {
                        "kind": "code",
                        "text": "stop"
                      },
                      {
                        "kind": "text",
                        "text": ")."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "arange(start, stop)"
                      },
                      {
                        "kind": "text",
                        "text": ": Values are generated within the half-open\ninterval "
                      },
                      {
                        "kind": "code",
                        "text": "[start, stop)"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "code",
                        "text": "arange(start, stop, step)"
                      },
                      {
                        "kind": "text",
                        "text": " Values are generated within the half-open\ninterval "
                      },
                      {
                        "kind": "code",
                        "text": "[start, stop)"
                      },
                      {
                        "kind": "text",
                        "text": ", with spacing between values given by\n"
                      },
                      {
                        "kind": "code",
                        "text": "step"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              }
            ],
            "ordered": false,
            "type": "list"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For integer arguments the function is roughly equivalent to the Python\nbuilt-in "
              },
              {
                "display_text": "range",
                "explicit_title": false,
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.range.html",
                "href": "",
                "kind": "role_reference",
                "original_target": "range",
                "role": "py:class",
                "suppress_link": false,
                "target": "range",
                "unresolved": false
              },
              {
                "kind": "text",
                "text": ", but returns an ndarray rather than a "
              },
              {
                "kind": "code",
                "text": "range"
              },
              {
                "kind": "text",
                "text": "\ninstance."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "When using a non-integer step, such as 0.1, it is often better to use\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/linspace",
                "kind": "link",
                "target": "linspace",
                "text": "we.linspace"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "See the Warning sections below for more information."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Start of interval.  The interval includes this value.  The default\nstart value is 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "integer or real, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Start of interval.  The interval includes this value.  The default\nstart value is 0."
                  }
                ],
                "name": "start",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "End of interval.  The interval does not include this value, except\nin some cases where "
                      },
                      {
                        "kind": "code",
                        "text": "step"
                      },
                      {
                        "kind": "text",
                        "text": " is not an integer and floating point\nround-off affects the length of "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "integer or real",
                "inline": [
                  {
                    "kind": "text",
                    "text": "End of interval.  The interval does not include this value, except\nin some cases where "
                  },
                  {
                    "kind": "code",
                    "text": "step"
                  },
                  {
                    "kind": "text",
                    "text": " is not an integer and floating point\nround-off affects the length of "
                  },
                  {
                    "kind": "code",
                    "text": "out"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "stop",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Spacing between values.  For any output "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": ", this is the distance\nbetween two adjacent values, "
                      },
                      {
                        "kind": "code",
                        "text": "out[i+1] - out[i]"
                      },
                      {
                        "kind": "text",
                        "text": ".  The default\nstep size is 1.  If "
                      },
                      {
                        "kind": "code",
                        "text": "step"
                      },
                      {
                        "kind": "text",
                        "text": " is specified as a position argument,\n"
                      },
                      {
                        "kind": "code",
                        "text": "start"
                      },
                      {
                        "kind": "text",
                        "text": " must also be given."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "integer or real, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Spacing between values.  For any output "
                  },
                  {
                    "kind": "code",
                    "text": "out"
                  },
                  {
                    "kind": "text",
                    "text": ", this is the distance\nbetween two adjacent values, "
                  },
                  {
                    "kind": "code",
                    "text": "out[i+1] - out[i]"
                  },
                  {
                    "kind": "text",
                    "text": ".  The default\nstep size is 1.  If "
                  },
                  {
                    "kind": "code",
                    "text": "step"
                  },
                  {
                    "kind": "text",
                    "text": " is specified as a position argument,\n"
                  },
                  {
                    "kind": "code",
                    "text": "start"
                  },
                  {
                    "kind": "text",
                    "text": " must also be given."
                  }
                ],
                "name": "step",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The type of the output array.  If "
                      },
                      {
                        "kind": "code",
                        "text": "dtype"
                      },
                      {
                        "kind": "text",
                        "text": " is not given, infer the data\ntype from the other input arguments."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The type of the output array.  If "
                  },
                  {
                    "kind": "code",
                    "text": "dtype"
                  },
                  {
                    "kind": "text",
                    "text": " is not given, infer the data\ntype from the other input arguments."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The device on which to place the created array. Default: "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": ".\nFor Array-API interoperability only, so must be "
                      },
                      {
                        "kind": "code",
                        "text": "\"cpu\""
                      },
                      {
                        "kind": "text",
                        "text": " if passed."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "versionadded",
                    "options": [],
                    "raw_source": ".. versionadded:: 2.0.0",
                    "supported": true,
                    "type": "directive_block",
                    "version": "2.0.0"
                  }
                ],
                "data_type": "str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The device on which to place the created array. Default: "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": ".\nFor Array-API interoperability only, so must be "
                  },
                  {
                    "kind": "code",
                    "text": "\"cpu\""
                  },
                  {
                    "kind": "text",
                    "text": " if passed."
                  }
                ],
                "name": "device",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as "
                      },
                      {
                        "kind": "code",
                        "text": "like"
                      },
                      {
                        "kind": "text",
                        "text": " supports\nthe "
                      },
                      {
                        "kind": "code",
                        "text": "__array_function__"
                      },
                      {
                        "kind": "text",
                        "text": " protocol, the result will be defined\nby it. In this case, it ensures the creation of an array object\ncompatible with that passed in via this argument."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "versionadded",
                    "options": [],
                    "raw_source": ".. versionadded:: 1.20.0",
                    "supported": true,
                    "type": "directive_block",
                    "version": "1.20.0"
                  }
                ],
                "data_type": "array_like, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Reference object to allow the creation of arrays which are not\nNumPy arrays. If an array-like passed in as "
                  },
                  {
                    "kind": "code",
                    "text": "like"
                  },
                  {
                    "kind": "text",
                    "text": " supports\nthe "
                  },
                  {
                    "kind": "code",
                    "text": "__array_function__"
                  },
                  {
                    "kind": "text",
                    "text": " protocol, the result will be defined\nby it. In this case, it ensures the creation of an array object\ncompatible with that passed in via this argument."
                  }
                ],
                "name": "like",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array of evenly spaced values."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "For floating point arguments, the length of the result is\n"
                      },
                      {
                        "kind": "code",
                        "text": "ceil((stop - start)/step)"
                      },
                      {
                        "kind": "text",
                        "text": ".  Because of floating point overflow,\nthis rule may result in the last element of "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " being greater\nthan "
                      },
                      {
                        "kind": "code",
                        "text": "stop"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array of evenly spaced values."
                  }
                ],
                "name": "arange",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
