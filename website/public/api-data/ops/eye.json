  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return a 2-D array with ones on the diagonal and zeros elsewhere."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "N",
            "type": "int",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Number of rows in the output."
              }
            ]
          },
          {
            "name": "M",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Number of columns in the output. If None, defaults to `N`."
              }
            ]
          },
          {
            "name": "k",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Index of the diagonal: 0 (the default) refers to the main diagonal,\na positive value refers to an upper diagonal, and a negative value\nto a lower diagonal."
              }
            ]
          },
          {
            "name": "dtype",
            "type": "data-type, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Data-type of the returned array."
              }
            ]
          },
          {
            "name": "order",
            "type": "{'C', 'F'}, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Whether the output should be stored in row-major (C-style) or\ncolumn-major (Fortran-style) order in memory."
              }
            ]
          },
          {
            "name": "device",
            "type": "str, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The device on which to place the created array. Default: None.\nFor Array-API interoperability only, so must be ``\"cpu\"`` if passed."
              },
              {
                "type": "directive",
                "name": "versionadded:: 2.0.0",
                "body": "",
                "raw": ".. versionadded:: 2.0.0"
              }
            ]
          },
          {
            "name": "like",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "    Reference object to allow the creation of arrays which are not\n    NumPy arrays. If an array-like passed in as ``like`` supports\n    the ``__array_function__`` protocol, the result will be defined\n    by it. In this case, it ensures the creation of an array object\n    compatible with that passed in via this argument."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.20.0",
                "body": "",
                "raw": ".. versionadded:: 1.20.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "I",
            "type": "ndarray of shape (N,M)",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array where all elements are equal to zero, except for the `k`-th\ndiagonal, whose values are equal to one."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.eye(2, dtype=int)\narray([[1, 0],\n       [0, 1]])\n>>> np.eye(3, k=1)\narray([[0.,  1.,  0.],\n       [0.,  0.,  1.],\n       [0.,  0.,  0.]])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
