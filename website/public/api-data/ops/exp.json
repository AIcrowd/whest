          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nM. Abramovitz and I. A. Stegun, \"Handbook of Mathematical Functions\nwith Formulas, Graphs, and Mathematical Tables,\" Dover, 1964, p. 69,\nhttps://personal.math.ubc.ca/~cbm/aands/page_69.htm",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Plot the magnitude and phase of "
              },
              {
                "kind": "code",
                "text": "exp(x)"
              },
              {
                "kind": "text",
                "text": " in the complex plane:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.linspace(-2*we.pi, 2*we.pi, 100)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "xx = x + 1j * x[:, we.newaxis] # a + ib over complex plane"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "out = we.exp(xx)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.subplot(121)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.imshow(we.abs(out),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "extent=[-2*we.pi, 2*we.pi, -2*we.pi, 2*we.pi], cmap='gray')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.title('Magnitude of exp(x)')"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.subplot(122)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.imshow(we.angle(out),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "extent=[-2*we.pi, 2*we.pi, -2*we.pi, 2*we.pi], cmap='hsv')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.title('Phase (angle) of exp(x)')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
