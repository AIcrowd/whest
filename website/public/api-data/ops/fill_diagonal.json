{
  "detail_href": "/docs/api/ops/fill_diagonal/",
  "detail_json_href": "/api-data/ops/fill_diagonal.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Fill the main diagonal of the given array of any dimensionality."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "For an array "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " with "
              },
              {
                "kind": "code",
                "text": "a.ndim >= 2"
              },
              {
                "kind": "text",
                "text": ", the diagonal is the list of\nvalues "
              },
              {
                "kind": "code",
                "text": "a[i, ..., i]"
              },
              {
                "kind": "text",
                "text": " with indices "
              },
              {
                "kind": "code",
                "text": "i"
              },
              {
                "kind": "text",
                "text": " all identical.  This function\nmodifies the input array in-place without returning a value."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array whose diagonal is to be filled in-place."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array, at least 2-D.",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array whose diagonal is to be filled in-place."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Value(s) to write on the diagonal. If "
                      },
                      {
                        "kind": "code",
                        "text": "val"
                      },
                      {
                        "kind": "text",
                        "text": " is scalar, the value is\nwritten along the diagonal. If array-like, the flattened "
                      },
                      {
                        "kind": "code",
                        "text": "val"
                      },
                      {
                        "kind": "text",
                        "text": " is\nwritten along the diagonal, repeating if necessary to fill all\ndiagonal entries."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "scalar or array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Value(s) to write on the diagonal. If "
                  },
                  {
                    "kind": "code",
                    "text": "val"
                  },
                  {
                    "kind": "text",
                    "text": " is scalar, the value is\nwritten along the diagonal. If array-like, the flattened "
                  },
                  {
                    "kind": "code",
                    "text": "val"
                  },
                  {
                    "kind": "text",
                    "text": " is\nwritten along the diagonal, repeating if necessary to fill all\ndiagonal entries."
                  }
                ],
                "name": "val",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "For tall matrices in NumPy version up to 1.6.2, the\ndiagonal \"wrapped\" after N columns. You can have this behavior\nwith this option. This affects only tall matrices."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool",
                "inline": [
                  {
                    "kind": "text",
                    "text": "For tall matrices in NumPy version up to 1.6.2, the\ndiagonal \"wrapped\" after N columns. You can have this behavior\nwith this option. This affects only tall matrices."
                  }
                ],
                "name": "wrap",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "",
                "description_inline": [],
                "external_url": "",
                "href": "/docs/api/ops/diag_indices",
                "label": "fnp.diag_indices",
                "original_target": "diag_indices",
                "role": "",
                "target": "diag_indices",
                "unresolved": false
              },
              {
                "description": "",
                "description_inline": [],
                "external_url": "",
                "href": "/docs/api/ops/diag_indices_from",
                "label": "fnp.diag_indices_from",
                "original_target": "diag_indices_from",
                "role": "",
                "target": "diag_indices_from",
                "unresolved": false
              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This functionality can be obtained via "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/diag_indices",
                "kind": "link",
                "target": "diag_indices",
                "text": "diag_indices"
              },
              {
                "kind": "text",
                "text": ", but internally\nthis version uses a much faster implementation that never constructs the\nindices and uses simple slicing."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.zeros((3, 3), int)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fill_diagonal(a, 5)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[5, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 5, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 5]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The same function can operate on a 4-D array:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.zeros((3, 3, 3, 3), int)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fill_diagonal(a, 4)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "We only show a few blocks for clarity:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[0, 0]"
              },
              {
                "kind": "output",
                "text": "array([[4, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[1, 1]"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 4, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[2, 2]"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 4]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The wrap option affects only tall matrices:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# tall matrices no wrap"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.zeros((5, 3), int)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fill_diagonal(a, 4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[4, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 4, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 4],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# tall matrices wrap"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.zeros((5, 3), int)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fill_diagonal(a, 4, wrap=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[4, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 4, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 4],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [4, 0, 0]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "# wide matrices"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.zeros((3, 5), int)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fill_diagonal(a, 4, wrap=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[4, 0, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 4, 0, 0, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 0, 4, 0, 0]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The anti-diagonal can be filled by reversing the order of elements\nusing either "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/flipud",
                "kind": "link",
                "target": "flipud",
                "text": "fnp.flipud"
              },
              {
                "kind": "text",
                "text": " or "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/fliplr",
                "kind": "link",
                "target": "fliplr",
                "text": "fnp.fliplr"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.zeros((3, 3), int);"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fill_diagonal(fnp.fliplr(a), [1,2,3])  # Horizontal flip"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 1],"
              },
              {
                "kind": "output",
                "text": "       [0, 2, 0],"
              },
              {
                "kind": "output",
                "text": "       [3, 0, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fill_diagonal(fnp.flipud(a), [1,2,3])  # Vertical flip"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[0, 0, 3],"
              },
              {
                "kind": "output",
                "text": "       [0, 2, 0],"
              },
              {
                "kind": "output",
                "text": "       [1, 0, 0]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that the order in which the diagonal is filled varies depending\non the flip function."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Examples"
      }
    ]
  },
