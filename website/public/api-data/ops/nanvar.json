                      },
                      {
                        "kind": "text",
                        "text": " is None, return a new array containing the variance,\notherwise return a reference to the output array. If ddof is >= the\nnumber of non-NaN elements in a slice or the slice contains only\nNaNs, then the result for that slice is NaN."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, see dtype parameter above",
