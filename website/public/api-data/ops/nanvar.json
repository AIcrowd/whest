  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the variance along the specified axis, while ignoring NaNs."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Returns the variance of the array elements, a measure of the spread of\na distribution.  The variance is computed for the flattened array by\ndefault, otherwise over the specified axis."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For all-NaN slices or slices with zero degrees of freedom, NaN is\nreturned and a "
              },
              {
                "kind": "code",
                "text": "RuntimeWarning"
              },
              {
                "kind": "text",
                "text": " is raised."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array containing numbers whose variance is desired.  If "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is not an\narray, a conversion is attempted."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array containing numbers whose variance is desired.  If "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is not an\narray, a conversion is attempted."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which the variance is computed.  The default is to compute\nthe variance of the flattened array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{int, tuple of int, None}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which the variance is computed.  The default is to compute\nthe variance of the flattened array."
