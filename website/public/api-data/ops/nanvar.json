              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "\"Delta Degrees of Freedom\": the divisor used in the calculation is\n"
                      },
                      {
                        "kind": "code",
                        "text": "N - ddof"
                      },
                      {
                        "kind": "text",
                        "text": ", where "
                      },
                      {
                        "kind": "code",
                        "text": "N"
                      },
                      {
                        "kind": "text",
                        "text": " represents the number of non-NaN\nelements. By default "
                      },
                      {
                        "kind": "code",
                        "text": "ddof"
                      },
                      {
                        "kind": "text",
                        "text": " is zero."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{int, float}, optional",
                "inline": [
                  {
                    "kind": "text",
