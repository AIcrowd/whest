      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.arange(16.0).reshape(4, 4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([[ 0.,   1.,   2.,   3.],"
              },
              {
                "kind": "output",
                "text": "       [ 4.,   5.,   6.,   7.],"
              },
              {
                "kind": "output",
                "text": "       [ 8.,   9.,  10.,  11.],"
              },
              {
                "kind": "output",
                "text": "       [12.,  13.,  14.,  15.]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.vsplit(x, 2)"
              },
              {
                "kind": "output",
                "text": "[array([[0., 1., 2., 3.],"
              },
              {
                "kind": "output",
                "text": "        [4., 5., 6., 7.]]),"
              },
              {
                "kind": "output",
                "text": " array([[ 8.,  9., 10., 11.],"
              },
              {
                "kind": "output",
                "text": "        [12., 13., 14., 15.]])]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.vsplit(x, we.array([3, 6]))"
              },
              {
                "kind": "output",
                "text": "[array([[ 0.,  1.,  2.,  3.],"
              },
              {
                "kind": "output",
                "text": "        [ 4.,  5.,  6.,  7.],"
              },
              {
                "kind": "output",
                "text": "        [ 8.,  9., 10., 11.]]),"
              },
              {
                "kind": "output",
                "text": " array([[12., 13., 14., 15.]]),"
              },
              {
                "kind": "output",
                "text": " array([], shape=(0, 4), dtype=float64)]"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "With a higher dimensional array the split is still along the first axis."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.arange(8.0).reshape(2, 2, 2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x"
              },
              {
                "kind": "output",
                "text": "array([[[0.,  1.],"
              },
              {
                "kind": "output",
                "text": "        [2.,  3.]],"
              },
              {
                "kind": "output",
                "text": "       [[4.,  5.],"
              },
              {
                "kind": "output",
                "text": "        [6.,  7.]]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.vsplit(x, 2)"
              },
              {
                "kind": "output",
                "text": "[array([[[0., 1.],"
              },
              {
                "kind": "output",
                "text": "         [2., 3.]]]),"
              },
              {
                "kind": "output",
                "text": " array([[[4., 5.],"
              },
              {
                "kind": "output",
                "text": "         [6., 7.]]])]"
              }
            ],
            "type": "doctest_block"
          }
        ],
