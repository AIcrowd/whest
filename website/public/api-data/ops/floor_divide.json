    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the largest integer smaller or equal to the division of the inputs. It is equivalent to the Python "
              },
              {
                "kind": "code",
                "text": "//"
              },
              {
                "kind": "text",
                "text": " operator and pairs with the Python "
              },
              {
                "kind": "code",
                "text": "%"
              },
              {
                "kind": "text",
                "text": " ("
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/remainder",
                "kind": "link",
                "target": "remainder",
                "text": "remainder"
              },
              {
                "kind": "text",
                "text": "), function so that "
              },
              {
                "kind": "code",
                "text": "a = a % b + b * (a // b)"
              },
              {
                "kind": "text",
                "text": " up to roundoff."
              }
            ],
            "type": "paragraph"
          }
        ],
