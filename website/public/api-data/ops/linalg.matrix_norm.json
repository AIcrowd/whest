  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Computes the matrix norm of a matrix (or a stack of matrices) ``x``."
          },
          {
            "type": "paragraph",
            "text": "This function is Array API compatible."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array having shape (..., M, N) and whose two innermost\ndimensions form ``MxN`` matrices."
              }
            ]
          },
          {
            "name": "keepdims",
            "type": "bool, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If this is set to True, the axes which are normed over are left in\nthe result as dimensions with size one. Default: False."
              }
            ]
          },
          {
            "name": "ord",
            "type": "{1, -1, 2, -2, inf, -inf, 'fro', 'nuc'}, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The order of the norm. For details see the table under ``Notes``\nin `numpy.linalg.norm`."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> from numpy import linalg as LA\n>>> a = np.arange(9) - 4\n>>> a\narray([-4, -3, -2, ...,  2,  3,  4])\n>>> b = a.reshape((3, 3))\n>>> b\narray([[-4, -3, -2],\n       [-1,  0,  1],\n       [ 2,  3,  4]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> LA.matrix_norm(b)\n7.745966692414834\n>>> LA.matrix_norm(b, ord='fro')\n7.745966692414834\n>>> LA.matrix_norm(b, ord=np.inf)\n9.0\n>>> LA.matrix_norm(b, ord=-np.inf)\n2.0"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> LA.matrix_norm(b, ord=1)\n7.0\n>>> LA.matrix_norm(b, ord=-1)\n6.0\n>>> LA.matrix_norm(b, ord=2)\n7.3484692283495345\n>>> LA.matrix_norm(b, ord=-2)\n1.8570331885190563e-016 # may vary"
          }
        ]
      },
