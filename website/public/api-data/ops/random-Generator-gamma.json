            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density for the Gamma distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "p(x) = x^{k-1}\\frac{e^{-x/\\theta}}{\\theta^k\\Gamma(k)},"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where "
              },
              {
                "kind": "math",
                "latex": "k"
              },
              {
                "kind": "text",
                "text": " is the shape and "
              },
              {
                "kind": "math",
                "latex": "\\theta"
              },
              {
                "kind": "text",
                "text": " the scale,\nand "
              },
              {
                "kind": "math",
                "latex": "\\Gamma"
              },
              {
                "kind": "text",
                "text": " is the Gamma function."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The Gamma distribution is often used to model the times to failure of\nelectronic components, and arises naturally in processes for which the\nwaiting times between Poisson distributed events are relevant."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nWeisstein, Eric W. \"Gamma Distribution.\" From MathWorld--A\nWolfram Web Resource.\nhttps://mathworld.wolfram.com/GammaDistribution.html",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nWikipedia, \"Gamma distribution\",\nhttps://en.wikipedia.org/wiki/Gamma_distribution",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the distribution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "shape, scale = 2., 2.  # mean=4, std=2*sqrt(2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = rng.gamma(shape, scale, 1000)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Display the histogram of the samples, along with\nthe probability density function:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import scipy.special as sps  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "count, bins, _ = plt.hist(s, 50, density=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = bins**(shape-1)*(flops.exp(-bins/scale) /  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "(sps.gamma(shape)*scale**shape))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(bins, y, linewidth=2, color='r')  # doctest: +SKIP"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
