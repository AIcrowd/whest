                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Drawn samples from the parameterized gamma distribution."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray or scalar",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Drawn samples from the parameterized gamma distribution."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
            ],
            "title": "Returns",
            "type": "field_list"
          }
        ],
        "title": "Returns"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "probability density function, distribution or cumulative density function, etc.",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "probability density function, distribution or cumulative density function, etc."
                  }
                ],
                "external_url": "https://docs.scipy.org/doc/scipy/reference/generated/scipy.stats.gamma.html",
                "href": "",
                "label": "scipy.stats.gamma",
                "original_target": "scipy.stats.gamma",
