  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from a Gamma distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from a Gamma distribution with specified parameters,\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/numpy/shape/",
                "kind": "link",
                "target": "shape",
                "text": "shape"
              },
              {
                "kind": "text",
                "text": " (sometimes designated \"k\") and "
              },
              {
                "kind": "code",
                "text": "scale"
              },
              {
                "kind": "text",
                "text": " (sometimes designated\n\"theta\"), where both parameters are > 0."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The shape of the gamma distribution. Must be non-negative."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The shape of the gamma distribution. Must be non-negative."
                  }
                ],
                "name": "shape",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The scale of the gamma distribution. Must be non-negative.\nDefault is equal to 1."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The scale of the gamma distribution. Must be non-negative.\nDefault is equal to 1."
                  }
                ],
                "name": "scale",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/numpy/shape/",
                        "kind": "link",
                        "target": "shape",
                        "text": "shape"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "scale"
                      },
                      {
                        "kind": "text",
                        "text": " are both scalars.\nOtherwise, "
                      },
                      {
                        "kind": "code",
                        "text": "flops.broadcast(shape, scale).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  If size is "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " (default),\na single value is returned if "
                  },
                  {
                    "external_url": "",
                    "href": "/docs/api/numpy/shape/",
                    "kind": "link",
                    "target": "shape",
                    "text": "shape"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "scale"
                  },
                  {
                    "kind": "text",
                    "text": " are both scalars.\nOtherwise, "
                  },
                  {
                    "kind": "code",
                    "text": "flops.broadcast(shape, scale).size"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn."
                  }
                ],
                "name": "size",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
