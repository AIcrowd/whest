  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Least squares polynomial fit."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "This forms part of the old polynomial API. Since version 1.4, the\nnew polynomial API defined in "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.polynomial.html",
                    "href": "",
                    "kind": "link",
                    "target": "polynomial",
                    "text": "fnp.polynomial"
                  },
                  {
                    "kind": "text",
                    "text": " is preferred.\nA summary of the differences can be found in the\n"
                  },
                  {
                    "display_text": "transition guide",
                    "explicit_title": true,
                    "external_url": "",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "/reference/routines.polynomials",
                    "role": "doc",
                    "suppress_link": false,
                    "target": "/reference/routines.polynomials",
                    "unresolved": true
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "note",
            "options": [],
            "raw_source": ".. note::\n   This forms part of the old polynomial API. Since version 1.4, the\n   new polynomial API defined in `fnp.polynomial` is preferred.\n   A summary of the differences can be found in the\n   :doc:`transition guide </reference/routines.polynomials>`.",
            "supported": true,
            "type": "directive_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Fit a polynomial "
              },
              {
                "kind": "code",
                "text": "p[0] * x**deg + ... + p[deg]"
              },
              {
                "kind": "text",
                "text": " of degree "
              },
              {
                "kind": "code",
                "text": "deg"
              },
              {
                "kind": "text",
                "text": "\nto points "
              },
              {
                "kind": "code",
                "text": "(x, y)"
              },
              {
                "kind": "text",
                "text": ". Returns a vector of coefficients "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " that minimises\nthe squared error in the order "
              },
              {
                "kind": "code",
                "text": "deg"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "deg-1"
              },
              {
                "kind": "text",
                "text": ", ... "
              },
              {
                "kind": "code",
                "text": "0"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "code",
                "text": "Polynomial.fit <fnp.polynomial.polynomial.Polynomial.fit>"
              },
              {
                "kind": "text",
                "text": " class\nmethod is recommended for new code as it is more stable numerically. See\nthe documentation of the method for more information."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "x-coordinates of the M sample points "
                      },
                      {
                        "kind": "code",
                        "text": "(x[i], y[i])"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape (M,)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "x-coordinates of the M sample points "
                  },
                  {
                    "kind": "code",
                    "text": "(x[i], y[i])"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "x",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "y-coordinates of the sample points. Several data sets of sample\npoints sharing the same x-coordinates can be fitted at once by\npassing in a 2D-array that contains one dataset per column."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape (M,) or (M, K)",
                "inline": [
                  {
                    "kind": "text",
                    "text": "y-coordinates of the sample points. Several data sets of sample\npoints sharing the same x-coordinates can be fitted at once by\npassing in a 2D-array that contains one dataset per column."
                  }
                ],
                "name": "y",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Degree of the fitting polynomial"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Degree of the fitting polynomial"
                  }
                ],
                "name": "deg",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Relative condition number of the fit. Singular values smaller than\nthis relative to the largest singular value will be ignored. The\ndefault value is len(x)*eps, where eps is the relative precision of\nthe float type, about 2e-16 in most cases."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Relative condition number of the fit. Singular values smaller than\nthis relative to the largest singular value will be ignored. The\ndefault value is len(x)*eps, where eps is the relative precision of\nthe float type, about 2e-16 in most cases."
                  }
                ],
                "name": "rcond",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Switch determining nature of return value. When it is False (the\ndefault) just the coefficients are returned, when True diagnostic\ninformation from the singular value decomposition is also returned."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Switch determining nature of return value. When it is False (the\ndefault) just the coefficients are returned, when True diagnostic\ninformation from the singular value decomposition is also returned."
                  }
                ],
                "name": "full",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Weights. If not None, the weight "
                      },
                      {
                        "kind": "code",
                        "text": "w[i]"
                      },
                      {
                        "kind": "text",
                        "text": " applies to the unsquared\nresidual "
                      },
                      {
                        "kind": "code",
                        "text": "y[i] - y_hat[i]"
                      },
                      {
                        "kind": "text",
                        "text": " at "
                      },
                      {
                        "kind": "code",
                        "text": "x[i]"
                      },
                      {
                        "kind": "text",
                        "text": ". Ideally the weights are\nchosen so that the errors of the products "
                      },
                      {
                        "kind": "code",
                        "text": "w[i]*y[i]"
                      },
                      {
                        "kind": "text",
                        "text": " all have the\nsame variance.  When using inverse-variance weighting, use\n"
                      },
                      {
                        "kind": "code",
                        "text": "w[i] = 1/sigma(y[i])"
                      },
                      {
                        "kind": "text",
                        "text": ".  The default value is None."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like, shape (M,), optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Weights. If not None, the weight "
                  },
                  {
                    "kind": "code",
                    "text": "w[i]"
                  },
                  {
                    "kind": "text",
                    "text": " applies to the unsquared\nresidual "
                  },
                  {
                    "kind": "code",
                    "text": "y[i] - y_hat[i]"
                  },
                  {
                    "kind": "text",
                    "text": " at "
                  },
                  {
                    "kind": "code",
                    "text": "x[i]"
                  },
                  {
                    "kind": "text",
                    "text": ". Ideally the weights are\nchosen so that the errors of the products "
                  },
                  {
                    "kind": "code",
                    "text": "w[i]*y[i]"
                  },
                  {
                    "kind": "text",
                    "text": " all have the\nsame variance.  When using inverse-variance weighting, use\n"
                  },
                  {
                    "kind": "code",
                    "text": "w[i] = 1/sigma(y[i])"
                  },
                  {
                    "kind": "text",
                    "text": ".  The default value is None."
                  }
                ],
                "name": "w",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If given and not "
                      },
                      {
                        "kind": "code",
                        "text": "False"
                      },
                      {
                        "kind": "text",
                        "text": ", return not just the estimate but also its\ncovariance matrix. By default, the covariance are scaled by\nchi2/dof, where dof = M - (deg + 1), i.e., the weights are presumed\nto be unreliable except in a relative sense and everything is scaled\nsuch that the reduced chi2 is unity. This scaling is omitted if\n"
                      },
                      {
                        "kind": "code",
                        "text": "cov='unscaled'"
                      },
                      {
                        "kind": "text",
                        "text": ", as is relevant for the case that the weights are\nw = 1/sigma, with sigma known to be a reliable estimate of the\nuncertainty."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool or str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If given and not "
                  },
                  {
                    "kind": "code",
                    "text": "False"
                  },
                  {
                    "kind": "text",
                    "text": ", return not just the estimate but also its\ncovariance matrix. By default, the covariance are scaled by\nchi2/dof, where dof = M - (deg + 1), i.e., the weights are presumed\nto be unreliable except in a relative sense and everything is scaled\nsuch that the reduced chi2 is unity. This scaling is omitted if\n"
                  },
                  {
                    "kind": "code",
                    "text": "cov='unscaled'"
                  },
                  {
                    "kind": "text",
                    "text": ", as is relevant for the case that the weights are\nw = 1/sigma, with sigma known to be a reliable estimate of the\nuncertainty."
                  }
                ],
                "name": "cov",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
