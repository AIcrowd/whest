        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Sort names: first by surname, then by name."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "surnames =    ('Hertz',    'Galilei', 'Hertz')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "first_names = ('Heinrich', 'Galileo', 'Gustav')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind = we.lexsort((first_names, surnames))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind"
              },
              {
                "kind": "output",
                "text": "array([1, 2, 0])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "[surnames[i] + \", \" + first_names[i] for i in ind]"
              },
              {
                "kind": "output",
                "text": "['Galilei, Galileo', 'Hertz, Gustav', 'Hertz, Heinrich']"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Sort according to two numerical keys, first by elements\nof "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": ", then breaking ties according to elements of "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = [1, 5, 1, 4, 3, 4, 4]  # First sequence"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = [9, 4, 0, 4, 0, 2, 1]  # Second sequence"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind = we.lexsort((b, a))  # Sort by `a`, then by `b`"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind"
              },
              {
                "kind": "output",
                "text": "array([2, 0, 4, 6, 5, 3, 1])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "[(a[i], b[i]) for i in ind]"
              },
              {
                "kind": "output",
                "text": "[(1, 0), (1, 9), (3, 0), (4, 1), (4, 2), (4, 4), (5, 4)]"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compare against "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/argsort",
                "kind": "link",
                "target": "argsort",
                "text": "argsort"
              },
              {
                "kind": "text",
                "text": ", which would sort each key independently."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argsort((b, a), kind='stable')"
              },
              {
                "kind": "output",
                "text": "array([[2, 4, 6, 5, 1, 3, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 2, 4, 3, 5, 6, 1]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "To sort lexicographically with "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/argsort",
                "kind": "link",
                "target": "argsort",
                "text": "argsort"
              },
              {
                "kind": "text",
                "text": ", we would need to provide a\nstructured array."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([(ai, bi) for ai, bi in zip(a, b)],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "dtype = we.dtype([('x', int), ('y', int)]))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.argsort(x)  # or we.argsort(x, order=('x', 'y'))"
              },
              {
                "kind": "output",
                "text": "array([2, 0, 4, 6, 5, 3, 1])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The zeroth axis of "
              },
              {
                "kind": "code",
                "text": "keys"
              },
              {
                "kind": "text",
                "text": " always corresponds with the sequence of keys,\nso 2D arrays are treated just like other sequences of keys."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "arr = we.asarray([b, a])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ind2 = we.lexsort(arr)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.testing.assert_equal(ind2, ind)"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Accordingly, the "
              },
              {
                "kind": "code",
                "text": "axis"
              },
              {
                "kind": "text",
                "text": " parameter refers to an axis of "
              },
              {
                "kind": "emphasis",
                "text": "each"
              },
              {
                "kind": "text",
                "text": " key, not of\nthe "
              },
              {
                "kind": "code",
                "text": "keys"
              },
              {
                "kind": "text",
                "text": " argument itself. For instance, the array "
              },
              {
                "kind": "code",
                "text": "arr"
              },
              {
                "kind": "text",
                "text": " is treated as\na sequence of two 1-D keys, so specifying "
              },
              {
                "kind": "code",
                "text": "axis=0"
              },
              {
                "kind": "text",
                "text": " is equivalent to\nusing the default axis, "
              },
              {
                "kind": "code",
                "text": "axis=-1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.testing.assert_equal(we.lexsort(arr, axis=0),"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "we.lexsort(arr, axis=-1))"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For higher-dimensional arrays, the axis parameter begins to matter. The\nresulting array has the same shape as each key, and the values are what\nwe would expect if "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/lexsort",
                "kind": "link",
                "target": "lexsort",
                "text": "lexsort"
              },
              {
                "kind": "text",
                "text": " were performed on corresponding slices\nof the keys independently. For instance,"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = [[1, 2, 3, 4],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[4, 3, 2, 1],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[2, 1, 4, 3]]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = [[2, 2, 1, 1],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[1, 2, 1, 2],"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "[1, 1, 2, 1]]"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.lexsort((x, y), axis=1)"
              },
              {
                "kind": "output",
                "text": "array([[2, 3, 0, 1],"
              },
              {
                "kind": "output",
                "text": "       [2, 0, 3, 1],"
              },
              {
                "kind": "output",
                "text": "       [1, 0, 3, 2]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Each row of the result is what we would expect if we were to perform\n"
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/lexsort",
                "kind": "link",
                "target": "lexsort",
                "text": "lexsort"
              },
              {
                "kind": "text",
                "text": " on the corresponding row of the keys:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "for i in range(3):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "print(we.lexsort((x[i], y[i])))"
              },
              {
                "kind": "output",
                "text": "[2 3 0 1]"
              },
              {
                "kind": "output",
                "text": "[2 0 3 1]"
              },
              {
                "kind": "output",
                "text": "[1 0 3 2]"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
