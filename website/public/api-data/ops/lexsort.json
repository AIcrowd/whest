  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Perform an indirect stable sort using a sequence of keys."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given multiple sorting keys, lexsort returns an array of integer indices\nthat describes the sort order by multiple keys. The last key in the\nsequence is used for the primary sort order, ties are broken by the\nsecond-to-last key, and so on."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The "
                      },
                      {
                        "kind": "code",
                        "text": "k"
                      },
                      {
                        "kind": "text",
                        "text": " keys to be sorted. The "
                      },
                      {
                        "kind": "emphasis",
                        "text": "last"
                      },
                      {
                        "kind": "text",
                        "text": " key (e.g, the last\nrow if "
                      },
                      {
                        "kind": "code",
                        "text": "keys"
                      },
                      {
                        "kind": "text",
                        "text": " is a 2D array) is the primary sort key.\nEach element of "
                      },
                      {
                        "kind": "code",
                        "text": "keys"
                      },
                      {
                        "kind": "text",
                        "text": " along the zeroth axis must be\nan array-like object of the same shape."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "(k, m, n, ...) array-like",
                "inline": [
