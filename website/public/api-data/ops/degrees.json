  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Convert angles from radians to degrees."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array in radians."
              }
            ]
          },
          {
            "name": "out",
            "type": "ndarray, None, or tuple of ndarray and None, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "A location into which the result is stored. If provided, it must have\na shape that the inputs broadcast to. If not provided or None,\na freshly-allocated array is returned. A tuple (possible only as a\nkeyword argument) must have length equal to the number of outputs."
              }
            ]
          },
          {
            "name": "where",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "This condition is broadcast over the input. At locations where the\ncondition is True, the `out` array will be set to the ufunc result.\nElsewhere, the `out` array will retain its original value.\nNote that if an uninitialized `out` array is created via the default\n``out=None``, locations within it where the condition is False will\nremain uninitialized."
              }
            ]
          },
          {
            "name": "**kwargs",
            "type": "",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "For other keyword-only arguments, see the\n:ref:`ufunc docs <ufuncs.kwargs>`."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "y",
            "type": "ndarray of floats",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The corresponding degree values; if `out` was supplied this is a\nreference to it.\nThis is a scalar if `x` is a scalar."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Convert a radian array to degrees"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> rad = np.arange(12.)*np.pi/6\n>>> np.degrees(rad)\narray([   0.,   30.,   60.,   90.,  120.,  150.,  180.,  210.,  240.,\n        270.,  300.,  330.])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> out = np.zeros((rad.shape))\n>>> r = np.degrees(rad, out)\n>>> np.all(r == out)\nTrue"
          }
        ]
      },
