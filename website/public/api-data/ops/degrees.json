      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Convert a radian array to degrees"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rad = we.arange(12.)*we.pi/6"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.degrees(rad)"
              },
              {
                "kind": "output",
                "text": "array([   0.,   30.,   60.,   90.,  120.,  150.,  180.,  210.,  240.,"
              },
              {
                "kind": "output",
                "text": "        270.,  300.,  330.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "out = we.zeros((rad.shape))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "r = we.degrees(rad, out)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.all(r == out)"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
