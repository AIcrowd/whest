  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the Discrete Fourier Transform sample frequencies (for usage with rfft, irfft)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The returned float array "
              },
              {
                "kind": "code",
                "text": "f"
              },
              {
                "kind": "text",
                "text": " contains the frequency bin centers in cycles\nper unit of the sample spacing (with zero at the start).  For instance, if\nthe sample spacing is in seconds, then the frequency unit is cycles/second."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Given a window length "
              },
              {
                "kind": "code",
                "text": "n"
              },
              {
                "kind": "text",
                "text": " and a sample spacing "
              },
              {
                "kind": "code",
                "text": "d"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "f = [0, 1, ...,     n/2-1,     n/2] / (d*n)   if n is even\nf = [0, 1, ..., (n-1)/2-1, (n-1)/2] / (d*n)   if n is odd",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Unlike "
              },
              {
                "kind": "code",
                "text": "fftfreq"
              },
              {
                "kind": "text",
                "text": " (but like "
              },
              {
                "external_url": "https://docs.scipy.org/doc/scipy/reference/generated/scipy.fftpack.rfftfreq.html",
                "href": "",
                "kind": "link",
                "target": "scipy.fftpack.rfftfreq",
                "text": "scipy.fftpack.rfftfreq"
              },
              {
                "kind": "text",
                "text": ")\nthe Nyquist frequency component is considered to be positive."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
