    "whest_ref": "we.full",
    "numpy_ref": "np.full",
    "category": "counted_custom",
    "status": "supported",
    "weight": 1.0,
    "cost_formula": "per-operation",
    "cost_formula_latex": "varies",
    "notes": "Create array filled with scalar value. Cost: num copied.",
    "summary": "Return a new array of given shape and type, filled with `fill_value`.",
    "signature": "we.full(shape, fill_value, dtype=None, order='C', *, device=None, like=None)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return a new array of given shape and type, filled with `fill_value`."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "shape",
            "type": "int or sequence of ints",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Shape of the new array, e.g., ``(2, 3)`` or ``2``."
              }
            ]
          },
          {
            "name": "fill_value",
            "type": "scalar or array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Fill value."
              }
            ]
          },
          {
            "name": "dtype",
            "type": "data-type, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The desired data-type for the array  The default, None, means\n ``np.array(fill_value).dtype``."
              }
            ]
          },
          {
            "name": "order",
            "type": "{'C', 'F'}, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Whether to store multidimensional data in C- or Fortran-contiguous\n(row- or column-wise) order in memory."
              }
            ]
          },
          {
            "name": "device",
            "type": "str, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The device on which to place the created array. Default: None.\nFor Array-API interoperability only, so must be ``\"cpu\"`` if passed."
              },
              {
                "type": "directive",
                "name": "versionadded:: 2.0.0",
                "body": "",
                "raw": ".. versionadded:: 2.0.0"
              }
            ]
          },
          {
            "name": "like",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "    Reference object to allow the creation of arrays which are not\n    NumPy arrays. If an array-like passed in as ``like`` supports\n    the ``__array_function__`` protocol, the result will be defined\n    by it. In this case, it ensures the creation of an array object\n    compatible with that passed in via this argument."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.20.0",
                "body": "",
                "raw": ".. versionadded:: 1.20.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Array of `fill_value` with the given shape, dtype, and order."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.full((2, 2), np.inf)\narray([[inf, inf],\n       [inf, inf]])\n>>> np.full((2, 2), 10)\narray([[10, 10],\n       [10, 10]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.full((2, 2), [1, 2])\narray([[1, 2],\n       [1, 2]])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "full_like \u2014 Return a new array with shape of input filled with value."
          },
          {
            "type": "paragraph",
            "text": "empty \u2014 Return a new uninitialized array."
          },
          {
            "type": "paragraph",
            "text": "ones \u2014 Return a new array setting values to one."
          },
          {
            "type": "paragraph",
            "text": "zeros \u2014 Return a new array setting values to zero."
          }
        ]
      }
    ]
  }
}