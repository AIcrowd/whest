    "cost_formula_latex": "$0$",
    "notes": "Create one-filled array.",
    "summary": "Return a new array of given shape and type, filled with ones.",
    "signature": "we.ones(shape, dtype=None, order='C', *, device=None, like=None)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return a new array of given shape and type, filled with ones."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "shape",
            "type": "int or sequence of ints",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Shape of the new array, e.g., ``(2, 3)`` or ``2``."
              }
            ]
          },
          {
            "name": "dtype",
            "type": "data-type, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The desired data-type for the array, e.g., `numpy.int8`.  Default is\n`numpy.float64`."
              }
            ]
          },
          {
            "name": "order",
            "type": "{'C', 'F'}, optional, default: C",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Whether to store multi-dimensional data in row-major\n(C-style) or column-major (Fortran-style) order in\nmemory."
              }
            ]
          },
          {
            "name": "device",
            "type": "str, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The device on which to place the created array. Default: None.\nFor Array-API interoperability only, so must be ``\"cpu\"`` if passed."
              },
              {
                "type": "directive",
                "name": "versionadded:: 2.0.0",
                "body": "",
                "raw": ".. versionadded:: 2.0.0"
              }
            ]
          },
          {
            "name": "like",
            "type": "array_like, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "    Reference object to allow the creation of arrays which are not\n    NumPy arrays. If an array-like passed in as ``like`` supports\n    the ``__array_function__`` protocol, the result will be defined\n    by it. In this case, it ensures the creation of an array object\n    compatible with that passed in via this argument."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.20.0",
                "body": "",
                "raw": ".. versionadded:: 1.20.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Array of ones with the given shape, dtype, and order."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> np.ones(5)\narray([1., 1., 1., 1., 1.])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.ones((5,), dtype=int)\narray([1, 1, 1, 1, 1])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.ones((2, 1))\narray([[1.],\n       [1.]])"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> s = (2,2)\n>>> np.ones(s)\narray([[1.,  1.],\n       [1.,  1.]])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "ones_like \u2014 Return an array of ones with shape and type of input."
          },
          {
            "type": "paragraph",
            "text": "empty \u2014 Return a new uninitialized array."
          },
          {
            "type": "paragraph",
            "text": "zeros \u2014 Return a new array setting values to zero."
          },
          {
            "type": "paragraph",
            "text": "full \u2014 Return a new array of given shape filled with value."
          }
        ]
      }
    ]
  }
