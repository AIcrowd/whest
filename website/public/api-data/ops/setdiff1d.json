      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Find the set difference of two arrays."
          },
          {
            "type": "paragraph",
            "text": "Return the unique values in `ar1` that are not in `ar2`."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "ar1",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array."
              }
            ]
          },
          {
            "name": "ar2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input comparison array."
              }
            ]
          },
          {
            "name": "assume_unique",
            "type": "bool",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If True, the input arrays are both assumed to be unique, which\ncan speed up the calculation.  Default is False."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "setdiff1d",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "1D array of values in `ar1` that are not in `ar2`. The result\nis sorted when `assume_unique=False`, but otherwise only sorted\nif the input is sorted."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> a = np.array([1, 2, 3, 2, 4, 1])\n>>> b = np.array([3, 4, 5, 6])\n>>> np.setdiff1d(a, b)\narray([1, 2])"
          }
        ]
