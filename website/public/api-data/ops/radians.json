        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Convert a degree array to radians"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "deg = we.arange(12.) * 30."
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.radians(deg)"
              },
              {
                "kind": "output",
                "text": "array([ 0.        ,  0.52359878,  1.04719755,  1.57079633,  2.0943951 ,"
              },
              {
                "kind": "output",
                "text": "        2.61799388,  3.14159265,  3.66519143,  4.1887902 ,  4.71238898,"
              },
              {
                "kind": "output",
                "text": "        5.23598776,  5.75958653])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "out = we.zeros((deg.shape))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ret = we.radians(deg, out)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ret is out"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          }
        ],
