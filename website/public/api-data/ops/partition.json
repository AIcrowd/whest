                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis along which to sort. If None, the array is flattened before\nsorting. The default is -1, which sorts along the last axis."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or None, optional",
