  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return a partitioned copy of an array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Creates a copy of the array and partially sorts it in such a way that\nthe value of the element in k-th position is in the position it would be\nin a sorted array. In the output array, all elements smaller than the k-th\nelement are located to the left of this element and all equal or greater\nare located to its right. The ordering of the elements in the two\npartitions on the either side of the k-th element in the output array is\nundefined."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array to be sorted."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array to be sorted."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Element index to partition by. The k-th value of the element\nwill be in its final sorted position and all smaller elements\nwill be moved before it and all equal or greater elements behind\nit. The order of all elements in the partitions is undefined. If\nprovided with a sequence of k-th it will partition all elements\nindexed by k-th  of them into their sorted position at once."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "deprecated",
                    "options": [],
                    "raw_source": ".. deprecated:: 1.22.0\n    Passing booleans as index is deprecated.",
