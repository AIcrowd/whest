                  }
                ],
                "data_type": "int or sequence of ints",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Element index to partition by. The k-th value of the element\nwill be in its final sorted position and all smaller elements\nwill be moved before it and all equal or greater elements behind\nit. The order of all elements in the partitions is undefined. If\nprovided with a sequence of k-th it will partition all elements\nindexed by k-th  of them into their sorted position at once."
                  }
                ],
                "name": "kth",
