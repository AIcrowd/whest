              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "This is equivalent to (but faster than) the following use of "
              },
              {
                "kind": "code",
                "text": "ndindex"
              },
              {
                "kind": "text",
                "text": " and\n"
              },
              {
                "kind": "code",
                "text": "s_"
              },
              {
                "kind": "text",
                "text": ", which sets each of "
              },
              {
                "kind": "code",
                "text": "ii"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "kk"
              },
              {
                "kind": "text",
                "text": " to a tuple of indices:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "Ni, M, Nk = a.shape[:axis], a.shape[axis], a.shape[axis+1:]\nJ = indices.shape[axis]  # Need not equal M\nout = fnp.empty(Ni + (J,) + Nk)\n\nfor ii in ndindex(Ni):\n    for kk in ndindex(Nk):\n        a_1d       = a      [ii + s_[:,] + kk]\n        indices_1d = indices[ii + s_[:,] + kk]\n        out_1d     = out    [ii + s_[:,] + kk]\n        for j in range(J):\n            out_1d[j] = a_1d[indices_1d[j]]",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Equivalently, eliminating the inner loop, the last two lines would be:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "out_1d[:] = a_1d[indices_1d]",
            "type": "literal_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For this sample array"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([[10, 30, 20], [60, 40, 50]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "We can sort either by using sort directly, or argsort and this function"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.sort(a, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([[10, 20, 30],"
              },
              {
                "kind": "output",
                "text": "       [40, 50, 60]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai = fnp.argsort(a, axis=1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai"
              },
              {
                "kind": "output",
                "text": "array([[0, 2, 1],"
              },
              {
                "kind": "output",
                "text": "       [1, 2, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.take_along_axis(a, ai, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([[10, 20, 30],"
              },
              {
                "kind": "output",
                "text": "       [40, 50, 60]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The same works for max and min, if you maintain the trivial dimension\nwith "
              },
              {
                "kind": "code",
                "text": "keepdims"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.max(a, axis=1, keepdims=True)"
              },
              {
                "kind": "output",
                "text": "array([[30],"
              },
              {
                "kind": "output",
                "text": "       [60]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai = fnp.argmax(a, axis=1, keepdims=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai"
              },
              {
                "kind": "output",
                "text": "array([[1],"
              },
              {
                "kind": "output",
                "text": "       [0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.take_along_axis(a, ai, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([[30],"
              },
              {
                "kind": "output",
                "text": "       [60]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If we want to get the max and min at the same time, we can stack the\nindices first"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai_min = fnp.argmin(a, axis=1, keepdims=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai_max = fnp.argmax(a, axis=1, keepdims=True)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai = fnp.concatenate([ai_min, ai_max], axis=1)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "ai"
              },
              {
                "kind": "output",
                "text": "array([[0, 1],"
              },
              {
                "kind": "output",
                "text": "       [1, 0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.take_along_axis(a, ai, axis=1)"
              },
              {
                "kind": "output",
                "text": "array([[10, 30],"
              },
              {
                "kind": "output",
                "text": "       [40, 60]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
