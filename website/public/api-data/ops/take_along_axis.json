              {
                "description": "Put values into the destination array by matching 1d index and data slices",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "Put values into the destination array by matching 1d index and data slices"
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/put_along_axis",
                "label": "fnp.put_along_axis",
                "original_target": "put_along_axis",
