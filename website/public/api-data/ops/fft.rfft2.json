  "source": {
    "whest": "https://github.com/AIcrowd/whest/blob/main/src/whest/_ndarray.py#L283-L296",
    "numpy": "https://numpy.org/doc/stable/reference/generated/numpy.fft.rfft2.html"
  },
  "op": {
    "name": "fft.rfft2",
    "module": "numpy.fft",
    "whest_ref": "we.fft.rfft2",
    "numpy_ref": "np.fft.rfft2",
    "category": "counted_custom",
    "status": "supported",
    "weight": 1.0,
    "cost_formula": "5(N/2) * ceil(log2(N))",
    "cost_formula_latex": "$5(N/2) \\cdot \\lceil\\log_2 N\\rceil$",
    "notes": "2-D real FFT. Cost: 5*(N//2)*ceil(log2(N)), N=prod(s) (Cooley-Tukey radix-2; Van Loan 1992 \u00a71.4).",
    "summary": "Compute the 2-dimensional FFT of a real array.",
    "signature": "we.fft.rfft2(a, s=None, axes=(-2, -1), norm=None, out=None)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Compute the 2-dimensional FFT of a real array."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a",
            "type": "array",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array, taken to be real."
              }
            ]
          },
          {
            "name": "s",
            "type": "sequence of ints, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Shape of the FFT."
              },
              {
                "type": "directive",
                "name": "versionchanged:: 2.0",
                "body": "",
                "raw": ".. versionchanged:: 2.0"
              },
              {
                "type": "paragraph",
                "text": "    If it is ``-1``, the whole input is used (no padding/trimming)."
              },
              {
                "type": "directive",
                "name": "deprecated:: 2.0",
                "body": "",
                "raw": ".. deprecated:: 2.0"
              },
              {
                "type": "paragraph",
                "text": "    If `s` is not ``None``, `axes` must not be ``None`` either."
              },
              {
                "type": "directive",
                "name": "deprecated:: 2.0",
                "body": "",
                "raw": ".. deprecated:: 2.0"
              },
              {
                "type": "paragraph",
                "text": "    `s` must contain only ``int`` s, not ``None`` values. ``None``\n    values currently mean that the default value for ``n`` is used\n    in the corresponding 1-D transform, but this behaviour is\n    deprecated."
              }
            ]
          },
          {
            "name": "axes",
            "type": "sequence of ints, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Axes over which to compute the FFT. Default: ``(-2, -1)``."
              },
              {
                "type": "directive",
                "name": "deprecated:: 2.0",
                "body": "",
                "raw": ".. deprecated:: 2.0"
              },
              {
                "type": "paragraph",
                "text": "    If `s` is specified, the corresponding `axes` to be transformed\n    must not be ``None``."
              }
            ]
          },
          {
            "name": "norm",
            "type": "{\"backward\", \"ortho\", \"forward\"}, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Normalization mode (see `numpy.fft`). Default is \"backward\".\nIndicates which direction of the forward/backward pair of transforms\nis scaled and with what normalization factor."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.20.0",
                "body": "",
                "raw": ".. versionadded:: 1.20.0"
              },
              {
                "type": "paragraph",
                "text": "    The \"backward\", \"forward\" values were added."
              }
            ]
          },
          {
            "name": "out",
            "type": "complex ndarray, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If provided, the result will be placed in this array. It should be\nof the appropriate shape and dtype for the last inverse transform.\nincompatible with passing in all but the trivial ``s``)."
              },
              {
                "type": "directive",
                "name": "versionadded:: 2.0.0",
                "body": "",
                "raw": ".. versionadded:: 2.0.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The result of the real 2-D FFT."
              }
            ]
          }
        ]
      },
      {
        "kind": "notes",
        "title": "Notes",
        "blocks": [
          {
            "type": "paragraph",
            "text": "This is really just `rfftn` with different default behavior.\nFor more details see `rfftn`."
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> a = np.mgrid[:5, :5][0]\n>>> np.fft.rfft2(a)\narray([[ 50.  +0.j        ,   0.  +0.j        ,   0.  +0.j        ],\n       [-12.5+17.20477401j,   0.  +0.j        ,   0.  +0.j        ],\n       [-12.5 +4.0614962j ,   0.  +0.j        ,   0.  +0.j        ],\n       [-12.5 -4.0614962j ,   0.  +0.j        ,   0.  +0.j        ],\n       [-12.5-17.20477401j,   0.  +0.j        ,   0.  +0.j        ]])"
          }
        ]
      },
      {
        "kind": "see-also",
        "title": "See Also",
        "blocks": [
          {
            "type": "paragraph",
            "text": "rfftn \u2014 Compute the N-dimensional discrete Fourier Transform for real input."
          }
        ]
      }
    ]
  }
}