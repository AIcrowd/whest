    "notes": "Get information about the step size of datetime dtype. Not supported.",
    "summary": "Get information about the step size of a date or time type.",
    "signature": "we.datetime_data(dtype, /)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Get information about the step size of a date or time type."
          },
          {
            "type": "paragraph",
            "text": "The returned tuple can be passed as the second argument of `numpy.datetime64` and\n`numpy.timedelta64`."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "dtype",
            "type": "dtype",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The dtype object, which must be a `datetime64` or `timedelta64` type."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "unit",
            "type": "str",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The :ref:`datetime unit <arrays.dtypes.dateunits>` on which this dtype\nis based."
              }
            ]
          },
          {
            "name": "count",
            "type": "int",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The number of base units in a step."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> dt_25s = np.dtype('timedelta64[25s]')\n>>> np.datetime_data(dt_25s)\n('s', 25)\n>>> np.array(10, dt_25s).astype('timedelta64[s]')\narray(250, dtype='timedelta64[s]')"
          },
          {
            "type": "paragraph",
            "text": "The result can be used to construct a datetime that uses the same units\nas a timedelta"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.datetime64('2010', np.datetime_data(dt_25s))\nnp.datetime64('2010-01-01T00:00:00','25s')"
          }
        ]
      }
    ]
  }
}