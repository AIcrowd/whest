  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the character for the minimum-size type to which given types can be safely cast."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The returned type character must represent the smallest size dtype such\nthat an array of the returned type can handle the data from an array of\nall types in "
              },
              {
                "kind": "code",
                "text": "typechars"
              },
              {
                "kind": "text",
                "text": " (or if "
              },
              {
                "kind": "code",
                "text": "typechars"
              },
              {
                "kind": "text",
                "text": " is an array, then its\ndtype.char)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If a list of strings, each string should represent a dtype.\nIf array_like, the character representation of the array dtype is used."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "list of str or array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If a list of strings, each string should represent a dtype.\nIf array_like, the character representation of the array dtype is used."
                  }
                ],
                "name": "typechars",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The set of characters that the returned character is chosen from.\nThe default set is 'GDFgdf'."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "str or list of str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The set of characters that the returned character is chosen from.\nThe default set is 'GDFgdf'."
                  }
                ],
                "name": "typeset",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The default character, this is returned if none of the characters in\n"
                      },
                      {
                        "kind": "code",
                        "text": "typechars"
                      },
                      {
                        "kind": "text",
                        "text": " matches a character in "
                      },
                      {
                        "kind": "code",
                        "text": "typeset"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The default character, this is returned if none of the characters in\n"
                  },
                  {
                    "kind": "code",
                    "text": "typechars"
                  },
                  {
                    "kind": "text",
                    "text": " matches a character in "
                  },
                  {
                    "kind": "code",
                    "text": "typeset"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "default",
                "type": "field_list"
              }
