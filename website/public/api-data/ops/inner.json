            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Ordinary inner product of vectors for 1-D arrays (without complex\nconjugation), in higher dimensions a sum product over the last axes."
              }
            ],
            "type": "paragraph"
          }
        ],
