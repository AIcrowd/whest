        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "For vectors (1-D arrays) it computes the ordinary inner-product:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "we.inner(a, b) = sum(a[:]*b[:])",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "More generally, if "
              },
              {
                "kind": "code",
                "text": "ndim(a) = r > 0"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "ndim(b) = s > 0"
              },
              {
                "kind": "text",
                "text": ":"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "we.inner(a, b) = we.tensordot(a, b, axes=(-1,-1))",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "or explicitly:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "we.inner(a, b)[i0,...,ir-2,j0,...,js-2]\n     = sum(a[i0,...,ir-2,:]*b[j0,...,js-2,:])",
            "type": "literal_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "In addition "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " or "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " may be scalars, in which case:"
              }
            ],
            "type": "paragraph"
          },
          {
            "language": null,
            "text": "we.inner(a,b) = a*b",
            "type": "literal_block"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Ordinary inner product for vectors:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([1,2,3])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.array([0,1,0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.inner(a, b)"
              },
              {
                "kind": "output",
                "text": "2"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Some multidimensional examples:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.arange(24).reshape((2,3,4))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.arange(4)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c = we.inner(a, b)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c.shape"
              },
              {
                "kind": "output",
                "text": "(2, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c"
              },
              {
                "kind": "output",
                "text": "array([[ 14,  38,  62],"
              },
              {
                "kind": "output",
                "text": "       [ 86, 110, 134]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.arange(2).reshape((1,1,2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = we.arange(6).reshape((3,2))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c = we.inner(a, b)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c.shape"
              },
              {
                "kind": "output",
                "text": "(1, 1, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "c"
              },
              {
                "kind": "output",
                "text": "array([[[1, 3, 5]]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "An example where "
              },
              {
                "kind": "code",
                "text": "b"
              },
              {
                "kind": "text",
                "text": " is a scalar:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.inner(we.eye(2), 7)"
              },
              {
                "kind": "output",
                "text": "array([[7., 0.],"
              },
              {
                "kind": "output",
                "text": "       [0., 7.]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
