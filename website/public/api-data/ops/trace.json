  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the sum along diagonals of the array."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " is 2-D, the sum along its diagonal with the given offset\nis returned, i.e., the sum of elements "
              },
              {
                "kind": "code",
                "text": "a[i,i+offset]"
              },
              {
                "kind": "text",
                "text": " for all i."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " has more than two dimensions, then the axes specified by axis1 and\naxis2 are used to determine the 2-D sub-arrays whose traces are returned.\nThe shape of the resulting array is the same as that of "
              },
              {
                "kind": "code",
                "text": "a"
              },
              {
                "kind": "text",
                "text": " with "
              },
              {
                "kind": "code",
                "text": "axis1"
              },
              {
                "kind": "text",
                "text": "\nand "
              },
              {
                "kind": "code",
                "text": "axis2"
              },
              {
                "kind": "text",
                "text": " removed."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array, from which the diagonals are taken."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array, from which the diagonals are taken."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Offset of the diagonal from the main diagonal. Can be both positive\nand negative. Defaults to 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Offset of the diagonal from the main diagonal. Can be both positive\nand negative. Defaults to 0."
                  }
                ],
                "name": "offset",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axes to be used as the first and second axis of the 2-D sub-arrays\nfrom which the diagonals should be taken. Defaults are the first two\naxes of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axes to be used as the first and second axis of the 2-D sub-arrays\nfrom which the diagonals should be taken. Defaults are the first two\naxes of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "axis1, axis2",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Determines the data-type of the returned array and of the accumulator\nwhere the elements are summed. If dtype has the value None and "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " is\nof integer type of precision less than the default integer\nprecision, then the default integer precision is used. Otherwise,\nthe precision is the same as that of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "dtype, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Determines the data-type of the returned array and of the accumulator\nwhere the elements are summed. If dtype has the value None and "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " is\nof integer type of precision less than the default integer\nprecision, then the default integer precision is used. Otherwise,\nthe precision is the same as that of "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "dtype",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Array into which the output is placed. Its type is preserved and\nit must be of the right shape to hold the output."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Array into which the output is placed. Its type is preserved and\nit must be of the right shape to hold the output."
                  }
                ],
                "name": "out",
                "type": "field_list"
              }
