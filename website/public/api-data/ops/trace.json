                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.trace(we.eye(3))"
              },
              {
                "kind": "output",
                "text": "3.0"
              },
              {
