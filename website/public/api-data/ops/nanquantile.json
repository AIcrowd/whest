            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = we.array([[10., 7., 4.], [3., 2., 1.]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a[0][1] = we.nan"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a"
              },
              {
                "kind": "output",
                "text": "array([[10.,  nan,   4.],"
              },
              {
                "kind": "output",
                "text": "      [ 3.,   2.,   1.]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.quantile(a, 0.5)"
              },
              {
                "kind": "output",
                "text": "we.float64(nan)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.nanquantile(a, 0.5)"
              },
              {
                "kind": "output",
                "text": "3.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.nanquantile(a, 0.5, axis=0)"
              },
              {
                "kind": "output",
                "text": "array([6.5, 2. , 2.5])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.nanquantile(a, 0.5, axis=1, keepdims=True)"
              },
              {
                "kind": "output",
                "text": "array([[7.],"
              },
              {
                "kind": "output",
                "text": "       [2.]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "m = we.nanquantile(a, 0.5, axis=0)"
              },
              {
