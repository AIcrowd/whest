      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "q"
                      },
                      {
                        "kind": "text",
                        "text": " is a single probability and "
                      },
                      {
                        "kind": "code",
                        "text": "axis=None"
                      },
                      {
                        "kind": "text",
                        "text": ", then the result\nis a scalar. If multiple probability levels are given, first axis of\nthe result corresponds to the quantiles. The other axes are\nthe axes that remain after the reduction of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ". If the input\ncontains integers or floats smaller than "
                      },
                      {
                        "kind": "code",
                        "text": "float64"
                      },
                      {
                        "kind": "text",
                        "text": ", the output\ndata-type is "
                      },
                      {
                        "kind": "code",
                        "text": "float64"
                      },
                      {
                        "kind": "text",
                        "text": ". Otherwise, the output data-type is the\nsame as that of the input. If "
                      },
                      {
                        "kind": "code",
                        "text": "out"
                      },
                      {
                        "kind": "text",
                        "text": " is specified, that array is\nreturned instead."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
