{
  "detail_href": "/docs/api/ops/nanquantile/",
  "detail_json_href": "/api-data/ops/nanquantile.json",
  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Compute the qth quantile of the data along the specified axis, while ignoring nan values. Returns the qth quantile(s) of the array elements."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input array or object that can be converted to an array, containing\nnan values to be ignored"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input array or object that can be converted to an array, containing\nnan values to be ignored"
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Probability or sequence of probabilities for the quantiles to compute.\nValues must be between 0 and 1 inclusive."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like of float",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Probability or sequence of probabilities for the quantiles to compute.\nValues must be between 0 and 1 inclusive."
                  }
                ],
                "name": "q",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Axis or axes along which the quantiles are computed. The\ndefault is to compute the quantile(s) along a flattened\nversion of the array."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "{int, tuple of int, None}, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Axis or axes along which the quantiles are computed. The\ndefault is to compute the quantile(s) along a flattened\nversion of the array."
                  }
                ],
                "name": "axis",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Alternative output array in which to place the result. It must\nhave the same shape and buffer length as the expected output,\nbut the type (of the output) will be cast if necessary."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Alternative output array in which to place the result. It must\nhave the same shape and buffer length as the expected output,\nbut the type (of the output) will be cast if necessary."
                  }
                ],
                "name": "out",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If True, then allow the input array "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " to be modified by intermediate\ncalculations, to save memory. In this case, the contents of the input\n"
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " after this function completes is undefined."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If True, then allow the input array "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " to be modified by intermediate\ncalculations, to save memory. In this case, the contents of the input\n"
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": " after this function completes is undefined."
                  }
                ],
                "name": "overwrite_input",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "This parameter specifies the method to use for estimating the\nquantile.  There are many different methods, some unique to NumPy.\nSee the notes for explanation.  The options sorted by their R type\nas summarized in the H&F paper "
                      },
                      {
                        "kind": "text",
                        "text": "[1]_"
                      },
                      {
                        "kind": "text",
                        "text": " are:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'inverted_cdf'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'averaged_inverted_cdf'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'closest_observation'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'interpolated_inverted_cdf'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'hazen'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'weibull'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'linear'  (default)"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'median_unbiased'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'normal_unbiased'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": true,
                    "type": "list"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The first three methods are discontinuous.  NumPy further defines the\nfollowing discontinuous variations of the default 'linear' (7.) option:"
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "items": [
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'lower'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'higher',"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'midpoint'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      },
                      {
                        "blocks": [
                          {
                            "inline": [
                              {
                                "kind": "text",
                                "text": "'nearest'"
                              }
                            ],
                            "type": "paragraph"
                          }
                        ]
                      }
                    ],
                    "ordered": false,
                    "type": "list"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
                    "directive": "versionchanged",
                    "options": [],
                    "raw_source": ".. versionchanged:: 1.22.0\n    This argument was previously called \"interpolation\" and only\n    offered the \"linear\" default and last four options.",
                    "supported": true,
                    "type": "directive_block",
                    "version": "1.22.0"
                  }
                ],
                "data_type": "str, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "This parameter specifies the method to use for estimating the\nquantile.  There are many different methods, some unique to NumPy.\nSee the notes for explanation.  The options sorted by their R type\nas summarized in the H&F paper "
                  },
                  {
                    "kind": "text",
                    "text": "[1]_"
                  },
                  {
                    "kind": "text",
                    "text": " are:"
                  }
                ],
                "name": "method",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If this is set to True, the axes which are reduced are left in\nthe result as dimensions with size one. With this option, the\nresult will broadcast correctly against the original array "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If this is anything but the default value it will be passed\nthrough (in the special case of an empty array) to the\n"
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/mean",
                        "kind": "link",
                        "target": "mean",
                        "text": "mean"
                      },
                      {
                        "kind": "text",
                        "text": " function of the underlying array.  If the array is\na sub-class and "
                      },
                      {
                        "external_url": "",
                        "href": "/docs/api/ops/mean",
                        "kind": "link",
                        "target": "mean",
                        "text": "mean"
                      },
                      {
                        "kind": "text",
                        "text": " does not have the kwarg "
                      },
                      {
                        "kind": "code",
                        "text": "keepdims"
                      },
                      {
                        "kind": "text",
                        "text": " this\nwill raise a RuntimeError."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "bool, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "If this is set to True, the axes which are reduced are left in\nthe result as dimensions with size one. With this option, the\nresult will broadcast correctly against the original array "
                  },
                  {
                    "kind": "code",
                    "text": "a"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "keepdims",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "An array of weights associated with the values in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ". Each value in\n"
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " contributes to the quantile according to its associated weight.\nThe weights array can either be 1-D (in which case its length must be\nthe size of "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " along the given axis) or of the same shape as "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": ".\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "weights=None"
                      },
                      {
                        "kind": "text",
                        "text": ", then all data in "
                      },
                      {
                        "kind": "code",
                        "text": "a"
                      },
                      {
                        "kind": "text",
                        "text": " are assumed to have a\nweight equal to one.\nOnly "
                      },
                      {
                        "kind": "code",
                        "text": "method=\"inverted_cdf\""
                      },
                      {
                        "kind": "text",
                        "text": " supports weights."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "argument_inline": [],
                    "content_blocks": [],
