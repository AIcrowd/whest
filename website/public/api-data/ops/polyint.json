              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The defining property of the antiderivative:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "p = fnp.poly1d([1,1,1])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "P = fnp.polyint(p)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "P"
              },
              {
                "kind": "output",
                "text": " poly1d([ 0.33333333,  0.5       ,  1.        ,  0.        ]) # may vary"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.polyder(P) == p"
              },
              {
                "kind": "output",
                "text": "True"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The integration constants default to zero, but can be specified:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "P = fnp.polyint(p, 3)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "P(0)"
              },
              {
                "kind": "output",
                "text": "0.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.polyder(P)(0)"
              },
              {
                "kind": "output",
                "text": "0.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.polyder(P, 2)(0)"
              },
              {
                "kind": "output",
                "text": "0.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "P = fnp.polyint(p, 3, k=[6,5,3])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "P"
              },
              {
                "kind": "output",
                "text": "poly1d([ 0.01666667,  0.04166667,  0.16666667,  3. ,  5. ,  3. ]) # may vary"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Note that 3 = 6 / 2!, and that the constants are given in the order of\nintegrations. Constant of the highest-order polynomial term comes first:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.polyder(P, 2)(0)"
              },
              {
                "kind": "output",
                "text": "6.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.polyder(P, 1)(0)"
              },
              {
                "kind": "output",
                "text": "5.0"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "P(0)"
              },
              {
                "kind": "output",
                "text": "3.0"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
