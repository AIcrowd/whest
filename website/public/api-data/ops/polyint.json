  "docs": {
    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return an antiderivative (indefinite integral) of a polynomial."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "argument_inline": [],
            "content_blocks": [
              {
                "inline": [
                  {
                    "kind": "text",
                    "text": "This forms part of the old polynomial API. Since version 1.4, the\nnew polynomial API defined in "
                  },
                  {
                    "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.polynomial.html",
                    "href": "",
                    "kind": "link",
                    "target": "polynomial",
                    "text": "fnp.polynomial"
                  },
                  {
                    "kind": "text",
                    "text": " is preferred.\nA summary of the differences can be found in the\n"
                  },
                  {
                    "display_text": "transition guide",
                    "explicit_title": true,
                    "external_url": "",
                    "href": "",
                    "kind": "role_reference",
                    "original_target": "/reference/routines.polynomials",
                    "role": "doc",
                    "suppress_link": false,
                    "target": "/reference/routines.polynomials",
                    "unresolved": true
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "note",
            "options": [],
            "raw_source": ".. note::\n   This forms part of the old polynomial API. Since version 1.4, the\n   new polynomial API defined in `fnp.polynomial` is preferred.\n   A summary of the differences can be found in the\n   :doc:`transition guide </reference/routines.polynomials>`.",
            "supported": true,
            "type": "directive_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The returned order "
              },
              {
                "kind": "code",
                "text": "m"
              },
              {
                "kind": "text",
                "text": " antiderivative "
              },
              {
                "kind": "code",
                "text": "P"
              },
              {
                "kind": "text",
                "text": " of polynomial "
              },
              {
                "kind": "code",
                "text": "p"
              },
              {
                "kind": "text",
                "text": " satisfies\n"
              },
              {
                "kind": "math",
                "latex": "\\frac{d^m}{dx^m}P(x) = p(x)"
              },
              {
                "kind": "text",
                "text": " and is defined up to "
              },
              {
                "kind": "code",
                "text": "m - 1"
              },
              {
                "kind": "text",
                "text": "\nintegration constants "
              },
              {
                "kind": "code",
                "text": "k"
              },
              {
                "kind": "text",
                "text": ". The constants determine the low-order\npolynomial part"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "\\frac{k_{m-1}}{0!} x^0 + \\ldots + \\frac{k_0}{(m-1)!}x^{m-1}"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "of "
              },
              {
                "kind": "code",
                "text": "P"
              },
              {
                "kind": "text",
                "text": " so that "
              },
              {
                "kind": "math",
                "latex": "P^{(j)}(0) = k_{m-j-1}"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Polynomial to integrate.\nA sequence is interpreted as polynomial coefficients, see "
                      },
                      {
                        "kind": "code",
                        "text": "poly1d"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like or poly1d",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Polynomial to integrate.\nA sequence is interpreted as polynomial coefficients, see "
                  },
                  {
                    "kind": "code",
                    "text": "poly1d"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "name": "p",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Order of the antiderivative. (Default: 1)"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Order of the antiderivative. (Default: 1)"
                  }
                ],
                "name": "m",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Integration constants. They are given in the order of integration:\nthose corresponding to highest-order terms come first."
                      }
                    ],
                    "type": "paragraph"
                  },
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "If "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default), all constants are assumed to be zero.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "m = 1"
                      },
                      {
                        "kind": "text",
                        "text": ", a single scalar can be given instead of a list."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "list of `m` scalars or scalar, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Integration constants. They are given in the order of integration:\nthose corresponding to highest-order terms come first."
                  }
                ],
                "name": "k",
                "type": "field_list"
              }
            ],
            "title": "Parameters",
            "type": "field_list"
          }
        ],
        "title": "Parameters"
      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "derivative of a polynomial",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "derivative of a polynomial"
                  }
                ],
