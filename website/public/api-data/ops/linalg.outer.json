  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Compute the outer product of two vectors."
          },
          {
            "type": "paragraph",
            "text": "This function is Array API compatible. Compared to ``np.outer``\nit accepts 1-dimensional inputs only."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x1",
            "type": "(M,) array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "One-dimensional input array of size ``N``.\nMust have a numeric data type."
              }
            ]
          },
          {
            "name": "x2",
            "type": "(N,) array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "One-dimensional input array of size ``M``.\nMust have a numeric data type."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "(M, N) ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "``out[i, j] = a[i] * b[j]``"
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Make a (*very* coarse) grid for computing a Mandelbrot set:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> rl = np.linalg.outer(np.ones((5,)), np.linspace(-2, 2, 5))\n>>> rl\narray([[-2., -1.,  0.,  1.,  2.],\n       [-2., -1.,  0.,  1.,  2.],\n       [-2., -1.,  0.,  1.,  2.],\n       [-2., -1.,  0.,  1.,  2.],\n       [-2., -1.,  0.,  1.,  2.]])\n>>> im = np.linalg.outer(1j*np.linspace(2, -2, 5), np.ones((5,)))\n>>> im\narray([[0.+2.j, 0.+2.j, 0.+2.j, 0.+2.j, 0.+2.j],\n       [0.+1.j, 0.+1.j, 0.+1.j, 0.+1.j, 0.+1.j],\n       [0.+0.j, 0.+0.j, 0.+0.j, 0.+0.j, 0.+0.j],\n       [0.-1.j, 0.-1.j, 0.-1.j, 0.-1.j, 0.-1.j],\n       [0.-2.j, 0.-2.j, 0.-2.j, 0.-2.j, 0.-2.j]])\n>>> grid = rl + im\n>>> grid\narray([[-2.+2.j, -1.+2.j,  0.+2.j,  1.+2.j,  2.+2.j],\n       [-2.+1.j, -1.+1.j,  0.+1.j,  1.+1.j,  2.+1.j],\n       [-2.+0.j, -1.+0.j,  0.+0.j,  1.+0.j,  2.+0.j],\n       [-2.-1.j, -1.-1.j,  0.-1.j,  1.-1.j,  2.-1.j],\n       [-2.-2.j, -1.-2.j,  0.-2.j,  1.-2.j,  2.-2.j]])"
          },
          {
            "type": "paragraph",
            "text": "An example using a \"vector\" of letters:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> x = np.array(['a', 'b', 'c'], dtype=object)\n>>> np.linalg.outer(x, [1, 2, 3])\narray([['a', 'aa', 'aaa'],\n       ['b', 'bb', 'bbb'],\n       ['c', 'cc', 'ccc']], dtype=object)"
          }
        ]
      },
