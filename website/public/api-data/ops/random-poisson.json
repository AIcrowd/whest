        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability mass function (PMF) of Poisson distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "f(k; \\lambda)=\\frac{\\lambda^k e^{-\\lambda}}{k!}"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For events with an expected separation "
              },
              {
                "kind": "math",
                "latex": "\\lambda"
              },
              {
                "kind": "text",
                "text": " the Poisson\ndistribution "
              },
              {
                "kind": "math",
                "latex": "f(k; \\lambda)"
              },
              {
                "kind": "text",
                "text": " describes the probability of\n"
              },
              {
                "kind": "math",
                "latex": "k"
              },
              {
                "kind": "text",
                "text": " events occurring within the observed\ninterval "
              },
              {
                "kind": "math",
                "latex": "\\lambda"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Because the output is limited to the range of the C int64 type, a\nValueError is raised when "
              },
              {
                "kind": "code",
                "text": "lam"
              },
              {
                "kind": "text",
                "text": " is within 10 sigma of the maximum\nrepresentable value."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
