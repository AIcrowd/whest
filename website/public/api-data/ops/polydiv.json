        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Both "
              },
              {
                "kind": "code",
                "text": "u"
              },
              {
                "kind": "text",
                "text": " and "
              },
              {
                "kind": "code",
                "text": "v"
              },
              {
                "kind": "text",
                "text": " must be 0-d or 1-d (ndim = 0 or 1), but "
              },
              {
                "kind": "code",
                "text": "u.ndim"
              },
              {
                "kind": "text",
                "text": " need\nnot equal "
              },
              {
                "kind": "code",
                "text": "v.ndim"
              },
              {
                "kind": "text",
                "text": ". In other words, all four possible combinations -\n"
              },
              {
                "kind": "code",
                "text": "u.ndim = v.ndim = 0"
              },
              {
                "kind": "text",
                "text": ", "
              },
              {
                "kind": "code",
                "text": "u.ndim = v.ndim = 1"
              },
              {
                "kind": "text",
                "text": ",\n"
              },
              {
                "kind": "code",
                "text": "u.ndim = 1, v.ndim = 0"
              },
              {
                "kind": "text",
                "text": ", and "
              },
              {
                "kind": "code",
                "text": "u.ndim = 0, v.ndim = 1"
              },
              {
                "kind": "text",
                "text": " - work."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "formulas": [
              "\\frac{3x^2 + 5x + 2}{2x + 1} = 1.5x + 1.75, remainder 0.25"
            ],
            "type": "math_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "x = we.array([3.0, 5.0, 2.0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "y = we.array([2.0, 1.0])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.polydiv(x, y)"
              },
              {
                "kind": "output",
                "text": "(array([1.5 , 1.75]), array([0.25]))"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
