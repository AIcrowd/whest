                    "inline": [
                      {
                        "kind": "text",
                        "text": "Specifies whether to copy an array when the specified dtype matches\nthe data type of the input array "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": ". If "
                      },
                      {
                        "kind": "code",
                        "text": "True"
                      },
                      {
                        "kind": "text",
                        "text": ", a newly allocated\narray must always be returned. If "
                      },
                      {
                        "kind": "code",
                        "text": "False"
                      },
                      {
                        "kind": "text",
                        "text": " and the specified dtype\nmatches the data type of the input array, the input array must be\nreturned; otherwise, a newly allocated array must be returned.\nDefaults to "
                      },
                      {
                        "kind": "code",
                        "text": "True"
                      },
