                    "suppress_link": false,
                    "target": "random-quick-start",
                    "unresolved": false
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "type": "paragraph"
              }
            ],
            "directive": "note",
            "options": [],
            "raw_source": ".. note::\n    New code should use the `~we.random.Generator.pareto`\n    method of a `~we.random.Generator` instance instead;\n    please see the :ref:`random-quick-start`.",
            "supported": true,
            "type": "directive_block"
          }
        ],
