      },
      {
        "blocks": [
          {
            "links": [
              {
                "description": "The outer product",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "The outer product"
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/outer",
