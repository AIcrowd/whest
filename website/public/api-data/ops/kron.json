            "inline": [
              {
                "kind": "text",
                "text": "Kronecker product of two arrays."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Computes the Kronecker product, a composite array made of blocks of the\nsecond array scaled by the first."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
