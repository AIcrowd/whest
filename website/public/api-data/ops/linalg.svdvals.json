    "weight": 4.0,
    "cost_formula": "m * n * min(m,n)",
    "cost_formula_latex": "$m \\cdot n \\cdot \\min(m,n)$",
    "notes": "Singular values only. Cost: m*n*min(m,n) (Golub-Reinsch).",
    "summary": "Returns the singular values of a matrix (or a stack of matrices) ``x``. When x is a stack of matrices, the function will compute the singular values for each matrix in the stack.",
    "signature": "we.linalg.svdvals(x, /, *, k: 'int | None' = None)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Returns the singular values of a matrix (or a stack of matrices) ``x``.\nWhen x is a stack of matrices, the function will compute the singular\nvalues for each matrix in the stack."
          },
          {
            "type": "paragraph",
            "text": "This function is Array API compatible."
          },
          {
            "type": "paragraph",
            "text": "Calling ``np.svdvals(x)`` to get singular values is the same as\n``np.svd(x, compute_uv=False, hermitian=False)``."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "(..., M, N) array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array having shape (..., M, N) and whose last two\ndimensions form matrices on which to perform singular value\ndecomposition. Should have a floating-point data type."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "out",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array with shape (..., K) that contains the vector(s)\nof singular values of length K, where K = min(M, N)."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> np.linalg.svdvals([[1, 2, 3, 4, 5],\n...                    [1, 4, 9, 16, 25],\n...                    [1, 8, 27, 64, 125]])\narray([146.68862757,   5.57510612,   0.60393245])"
          },
          {
            "type": "paragraph",
            "text": "Determine the rank of a matrix using singular values:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> s = np.linalg.svdvals([[1, 2, 3],\n...                        [2, 4, 6],\n...                        [-1, 1, -1]]); s\narray([8.38434191e+00, 1.64402274e+00, 2.31534378e-16])\n>>> np.count_nonzero(s > 1e-10)  # Matrix of rank 2\n2"
          }
        ]
      },
      {
        "kind": "see-also",
