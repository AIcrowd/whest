  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Computes the vector dot product."
          },
          {
            "type": "paragraph",
            "text": "This function is restricted to arguments compatible with the Array API,\ncontrary to :func:`numpy.vecdot`."
          },
          {
            "type": "paragraph",
            "text": "Let :math:`\\mathbf{a}` be a vector in ``x1`` and :math:`\\mathbf{b}` be\na corresponding vector in ``x2``. The dot product is defined as:"
          },
          {
            "type": "directive",
            "name": "math",
            "body": "   \\mathbf{a} \\cdot \\mathbf{b} = \\sum_{i=0}^{n-1} \\overline{a_i}b_i",
            "raw": ".. math::\n   \\mathbf{a} \\cdot \\mathbf{b} = \\sum_{i=0}^{n-1} \\overline{a_i}b_i"
          },
          {
            "type": "paragraph",
            "text": "over the dimension specified by ``axis`` and where :math:`\\overline{a_i}`\ndenotes the complex conjugate if :math:`a_i` is complex and the identity\notherwise."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x1",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "First input array."
              }
            ]
          },
          {
            "name": "x2",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Second input array."
              }
            ]
          },
          {
            "name": "axis",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Axis over which to compute the dot product. Default: ``-1``."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "output",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The vector dot product of the input."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Get the projected size along a given normal for an array of vectors."
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> v = np.array([[0., 5., 0.], [0., 0., 10.], [0., 6., 8.]])\n>>> n = np.array([0., 0.6, 0.8])\n>>> np.linalg.vecdot(v, n)\narray([ 3.,  8., 10.])"
          }
        ]
      },
      {
