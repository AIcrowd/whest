    "cost_formula_latex": "$0$",
    "notes": "Shift zero-frequency component to center. No arithmetic; index reordering only.",
    "summary": "Shift the zero-frequency component to the center of the spectrum.",
    "signature": "we.fft.fftshift(x, axes=None)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Shift the zero-frequency component to the center of the spectrum."
          },
          {
            "type": "paragraph",
            "text": "This function swaps half-spaces for all axes listed (defaults to all).\nNote that ``y[0]`` is the Nyquist component only if ``len(x)`` is even."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "x",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input array."
              }
            ]
          },
          {
            "name": "axes",
            "type": "int or shape tuple, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Axes over which to shift.  Default is None, which shifts all axes."
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
        "items": [
          {
            "name": "y",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "The shifted array."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> freqs = np.fft.fftfreq(10, 0.1)\n>>> freqs\narray([ 0.,  1.,  2., ..., -3., -2., -1.])\n>>> np.fft.fftshift(freqs)\narray([-5., -4., -3., -2., -1.,  0.,  1.,  2.,  3.,  4.])"
          },
          {
            "type": "paragraph",
            "text": "Shift the zero-frequency component only along the second axis:"
          },
          {
            "type": "code",
            "language": "text",
            "code": ">>> freqs = np.fft.fftfreq(9, d=1./9).reshape(3, 3)\n>>> freqs\narray([[ 0.,  1.,  2.],\n       [ 3.,  4., -4.],\n       [-3., -2., -1.]])\n>>> np.fft.fftshift(freqs, axes=(1,))\narray([[ 2.,  0.,  1.],\n       [-4.,  3.,  4.],\n       [-1., -3., -2.]])"
          }
        ]
      },
      {
