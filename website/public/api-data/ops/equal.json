      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.equal([0, 1, 3], fnp.arange(3))"
              },
              {
                "kind": "output",
                "text": "array([ True,  True, False])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "What is compared are values, not types. So an int (1) and an array of\nlength one can evaluate as True:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.equal(1, fnp.ones(1))"
              },
              {
                "kind": "output",
                "text": "array([ True])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The "
              },
              {
                "kind": "code",
                "text": "=="
              },
              {
                "kind": "text",
                "text": " operator can be used as a shorthand for "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/equal",
                "kind": "link",
                "target": "equal",
                "text": "fnp.equal"
              },
              {
                "kind": "text",
                "text": " on\nndarrays."
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a = fnp.array([2, 4, 6])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "b = fnp.array([2, 4, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "a == b"
              },
              {
                "kind": "output",
                "text": "array([ True,  True, False])"
              }
            ],
            "type": "doctest_block"
          }
        ],
