            "inline": [
              {
                "kind": "text",
                "text": "Return (x1 == x2) element-wise."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input arrays.\nIf "
                      },
                      {
                        "kind": "code",
                        "text": "x1.shape != x2.shape"
                      },
                      {
                        "kind": "text",
                        "text": ", they must be broadcastable to a common\nshape (which becomes the shape of the output)."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Input arrays.\nIf "
                  },
