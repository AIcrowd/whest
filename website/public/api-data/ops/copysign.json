            "inline": [
              {
                "kind": "text",
                "text": "Change the sign of x1 to that of x2, element-wise."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "If "
              },
              {
                "kind": "code",
                "text": "x2"
              },
              {
                "kind": "text",
                "text": " is a scalar, its sign will be copied to all elements of "
              },
              {
                "kind": "code",
                "text": "x1"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
