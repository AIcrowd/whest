        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The probability density for the Logistic distribution is"
              }
            ],
            "type": "paragraph"
          },
          {
            "formulas": [
              "P(x) = \\frac{e^{-(x-\\mu)/s}}{s(1+e^{-(x-\\mu)/s})^2},"
            ],
            "type": "math_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "where "
              },
              {
                "kind": "math",
                "latex": "\\mu"
              },
              {
                "kind": "text",
                "text": " = location and "
              },
              {
                "kind": "math",
                "latex": "s"
              },
              {
                "kind": "text",
                "text": " = scale."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The Logistic distribution is used in Extreme Value problems where it\ncan act as a mixture of Gumbel distributions, in Epidemiology, and by\nthe World Chess Federation (FIDE) where it is used in the Elo ranking\nsystem, assuming the performance of each player is a logistically\ndistributed random variable."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "raw_kind": "footnote",
            "raw_text": "1\n\nReiss, R.-D. and Thomas M. (2001), \"Statistical Analysis of\nExtreme Values, from Insurance, Finance, Hydrology and Other\nFields,\" Birkhauser Verlag, Basel, pp 132-133.",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "2\n\nWeisstein, Eric W. \"Logistic Distribution.\" From\nMathWorld--A Wolfram Web Resource.\nhttps://mathworld.wolfram.com/LogisticDistribution.html",
            "type": "raw_block"
          },
          {
            "raw_kind": "footnote",
            "raw_text": "3\n\nWikipedia, \"Logistic-distribution\",\nhttps://en.wikipedia.org/wiki/Logistic_distribution",
            "type": "raw_block"
          }
        ],
        "title": "References"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Draw samples from the distribution:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "loc, scale = 10, 1"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "rng = flops.random.default_rng()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "s = rng.logistic(loc, scale, 10000)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import matplotlib.pyplot as plt"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "count, bins, _ = plt.hist(s, bins=50, label='Sampled data')"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "#   plot sampled data against the exact distribution"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "def logistic(x, loc, scale):"
              },
              {
                "kind": "input",
                "prompt": "...",
                "text": "return flops.exp((loc-x)/scale)/(scale*(1+flops.exp((loc-x)/scale))**2)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "logistic_values  = logistic(bins, loc, scale)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "bin_spacing = flops.mean(flops.diff(bins))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.plot(bins, logistic_values  * bin_spacing * s.size, label='Logistic PDF')"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.legend()"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "plt.show()"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
