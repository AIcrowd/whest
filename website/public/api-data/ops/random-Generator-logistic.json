                "kind": "text",
                "text": "Draw samples from a logistic distribution."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Samples are drawn from a logistic distribution with specified\nparameters, loc (location or mean, also median), and scale (>0)."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Parameter of the distribution. Default is 0."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Parameter of the distribution. Default is 0."
                  }
                ],
                "name": "loc",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Parameter of the distribution. Must be non-negative.\nDefault is 1."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "float or array_like of floats, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Parameter of the distribution. Must be non-negative.\nDefault is 1."
                  }
                ],
                "name": "scale",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Output shape.  If the given shape is, e.g., "
                      },
                      {
                        "kind": "code",
                        "text": "(m, n, k)"
                      },
                      {
                        "kind": "text",
                        "text": ", then\n"
                      },
                      {
                        "kind": "code",
                        "text": "m * n * k"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn.  If size is "
                      },
                      {
                        "kind": "code",
                        "text": "None"
                      },
                      {
                        "kind": "text",
                        "text": " (default),\na single value is returned if "
                      },
                      {
                        "kind": "code",
                        "text": "loc"
                      },
                      {
                        "kind": "text",
                        "text": " and "
                      },
                      {
                        "kind": "code",
                        "text": "scale"
                      },
                      {
                        "kind": "text",
                        "text": " are both scalars.\nOtherwise, "
                      },
                      {
                        "kind": "code",
                        "text": "flops.broadcast(loc, scale).size"
                      },
                      {
                        "kind": "text",
                        "text": " samples are drawn."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int or tuple of ints, optional",
                "inline": [
                  {
                    "kind": "text",
                    "text": "Output shape.  If the given shape is, e.g., "
                  },
                  {
                    "kind": "code",
                    "text": "(m, n, k)"
                  },
                  {
                    "kind": "text",
                    "text": ", then\n"
                  },
                  {
                    "kind": "code",
                    "text": "m * n * k"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn.  If size is "
                  },
                  {
                    "kind": "code",
                    "text": "None"
                  },
                  {
                    "kind": "text",
                    "text": " (default),\na single value is returned if "
                  },
                  {
                    "kind": "code",
                    "text": "loc"
                  },
                  {
                    "kind": "text",
                    "text": " and "
                  },
                  {
                    "kind": "code",
                    "text": "scale"
                  },
                  {
                    "kind": "text",
                    "text": " are both scalars.\nOtherwise, "
                  },
                  {
                    "kind": "code",
                    "text": "flops.broadcast(loc, scale).size"
                  },
                  {
                    "kind": "text",
                    "text": " samples are drawn."
