                        "text": "[-pi/2, pi/2]"
                      },
                      {
                        "kind": "text",
                        "text": " ("
                      },
                      {
                        "kind": "code",
                        "text": "arctan(+/-inf)"
                      },
                      {
                        "kind": "text",
                        "text": " returns "
                      },
                      {
                        "kind": "code",
                        "text": "+/-pi/2"
                      },
                      {
                        "kind": "text",
                        "text": ").\nThis is a scalar if "
                      },
                      {
                        "kind": "code",
                        "text": "x"
                      },
                      {
                        "kind": "text",
                        "text": " is a scalar."
                      }
                    ],
