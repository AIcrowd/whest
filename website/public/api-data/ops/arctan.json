      {
        "blocks": [
          {
            "links": [
              {
                "description": "The \"four quadrant\" arctan of the angle formed by (`x`, `y`) and the positive `x`-axis.",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "The \"four quadrant\" arctan of the angle formed by ("
                  },
                  {
                    "kind": "code",
                    "text": "x"
                  },
                  {
                    "kind": "text",
                    "text": ", "
                  },
                  {
                    "kind": "code",
                    "text": "y"
                  },
                  {
                    "kind": "text",
                    "text": ") and the positive "
                  },
                  {
                    "kind": "code",
                    "text": "x"
                  },
                  {
                    "kind": "text",
                    "text": "-axis."
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/arctan2",
                "label": "we.arctan2",
                "original_target": "arctan2",
                "role": "",
                "target": "arctan2",
                "unresolved": false
              },
              {
                "description": "Argument of complex values.",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "Argument of complex values."
                  }
                ],
                "external_url": "",
                "href": "/docs/api/ops/angle",
                "label": "we.angle",
                "original_target": "angle",
                "role": "",
                "target": "angle",
                "unresolved": false
              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "external_url": "",
                "href": "/docs/api/ops/arctan",
                "kind": "link",
                "target": "arctan",
                "text": "arctan"
              },
              {
                "kind": "text",
                "text": " is a multi-valued function: for each "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " there are infinitely\nmany numbers "
              },
              {
                "kind": "code",
                "text": "z"
              },
              {
                "kind": "text",
                "text": " such that tan("
              },
              {
                "kind": "code",
                "text": "z"
              },
              {
                "kind": "text",
                "text": ") = "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": ".  The convention is to return\nthe angle "
              },
              {
                "kind": "code",
                "text": "z"
              },
              {
                "kind": "text",
                "text": " whose real part lies in [-pi/2, pi/2]."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For real-valued input data types, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arctan",
                "kind": "link",
                "target": "arctan",
                "text": "arctan"
              },
              {
                "kind": "text",
                "text": " always returns real output.\nFor each value that cannot be expressed as a real number or infinity,\nit yields "
              },
              {
                "kind": "code",
                "text": "nan"
              },
              {
                "kind": "text",
                "text": " and sets the "
              },
              {
                "kind": "code",
                "text": "invalid"
              },
              {
                "kind": "text",
                "text": " floating point error flag."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "For complex-valued input, "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arctan",
                "kind": "link",
                "target": "arctan",
                "text": "arctan"
              },
              {
                "kind": "text",
                "text": " is a complex analytic function that\nhas ["
              },
              {
                "kind": "code",
                "text": "1j, infj"
              },
              {
                "kind": "text",
                "text": "] and ["
              },
              {
                "kind": "code",
                "text": "-1j, -infj"
              },
              {
                "kind": "text",
                "text": "] as branch cuts, and is continuous\nfrom the left on the former and from the right on the latter."
              }
            ],
            "type": "paragraph"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The inverse tangent is also known as "
              },
              {
                "external_url": "",
                "href": "/docs/api/ops/arctan",
                "kind": "link",
                "target": "arctan",
                "text": "atan"
              },
              {
                "kind": "text",
                "text": " or tan^{-1}."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "inline": [
