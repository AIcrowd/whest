        "title": "Raises"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import whest as we"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from we.linalg import matrix_power"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "i = we.array([[0, 1], [-1, 0]]) # matrix equiv. of the imaginary unit"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "matrix_power(i, 3) # should = -i"
              },
              {
                "kind": "output",
                "text": "array([[ 0, -1],"
              },
              {
                "kind": "output",
                "text": "       [ 1,  0]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "matrix_power(i, 0)"
              },
              {
                "kind": "output",
                "text": "array([[1, 0],"
              },
              {
                "kind": "output",
                "text": "       [0, 1]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "matrix_power(i, -3) # should = 1/(-i) = i, but w/ f.p. elements"
              },
              {
                "kind": "output",
                "text": "array([[ 0.,  1.],"
              },
              {
                "kind": "output",
                "text": "       [-1.,  0.]])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "Somewhat more sophisticated example"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "q = we.zeros((4, 4))"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "q[0:2, 0:2] = -i"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "q[2:4, 2:4] = i"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "q # one of the three quaternion units not equal to 1"
              },
              {
                "kind": "output",
                "text": "array([[ 0., -1.,  0.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [ 1.,  0.,  0.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [ 0.,  0.,  0.,  1.],"
              },
              {
                "kind": "output",
                "text": "       [ 0.,  0., -1.,  0.]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "matrix_power(q, 2) # = -we.eye(4)"
              },
              {
                "kind": "output",
                "text": "array([[-1.,  0.,  0.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [ 0., -1.,  0.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [ 0.,  0., -1.,  0.],"
              },
              {
                "kind": "output",
                "text": "       [ 0.,  0.,  0., -1.]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
