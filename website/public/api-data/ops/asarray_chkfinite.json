                    "inline": [
                      {
                        "kind": "text",
                        "text": "Input data, in any form that can be converted to an array.  This\nincludes lists, lists of tuples, tuples, tuples of tuples, tuples\nof lists and ndarrays.  Success requires no NaNs or Infs."
                      }
                    ],
                    "type": "paragraph"
                  }
