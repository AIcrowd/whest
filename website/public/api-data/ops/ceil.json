    "sections": [
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "Return the ceiling of the input, element-wise."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Summary"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "text",
                "text": "The ceil of the scalar "
              },
              {
                "kind": "code",
                "text": "x"
              },
              {
                "kind": "text",
                "text": " is the smallest integer "
              },
              {
                "kind": "code",
                "text": "i"
              },
              {
                "kind": "text",
                "text": ", such that\n"
              },
              {
                "kind": "code",
                "text": "i >= x"
              },
              {
                "kind": "text",
                "text": ".  It is often denoted as "
              },
              {
                "kind": "math",
                "latex": "\\lceil x \\rceil"
              },
              {
                "kind": "text",
                "text": "."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Extended Summary"
      },
