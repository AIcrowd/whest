          {
            "name": "index_array",
            "type": "ndarray",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "An array of indices or a single index value."
              }
            ]
          }
        ]
      },
      {
        "kind": "examples",
        "title": "Examples",
        "blocks": [
          {
            "type": "code",
            "language": "text",
            "code": ">>> import numpy as np\n>>> a = np.array([[np.nan, 4], [2, 3]])\n>>> np.argmax(a)\n0\n>>> np.nanargmax(a)\n1\n>>> np.nanargmax(a, axis=0)\narray([1, 0])\n>>> np.nanargmax(a, axis=1)\narray([1, 1])"
          }
        ]
