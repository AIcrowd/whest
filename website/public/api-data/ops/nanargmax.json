    "cost_formula": "numel(input)",
    "cost_formula_latex": "$\\text{numel}(\\text{input})$",
    "notes": "Index of maximum ignoring NaNs.",
    "summary": "Return the indices of the maximum values in the specified axis ignoring NaNs. For all-NaN slices ``ValueError`` is raised. Warning: the results cannot be trusted if a slice contains only NaNs and -Infs.",
    "signature": "we.nanargmax(a, axis=None, out=None, *, keepdims=<no value>)"
  },
  "docs": {
    "sections": [
      {
        "kind": "summary",
        "title": "Summary",
        "blocks": [
          {
            "type": "paragraph",
            "text": "Return the indices of the maximum values in the specified axis ignoring\nNaNs. For all-NaN slices ``ValueError`` is raised. Warning: the\nresults cannot be trusted if a slice contains only NaNs and -Infs."
          }
        ]
      },
      {
        "kind": "parameters",
        "title": "Parameters",
        "items": [
          {
            "name": "a",
            "type": "array_like",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Input data."
              }
            ]
          },
          {
            "name": "axis",
            "type": "int, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "Axis along which to operate.  By default flattened input is used."
              }
            ]
          },
          {
            "name": "out",
            "type": "array, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If provided, the result will be inserted into this array. It should\nbe of the appropriate shape and dtype."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.22.0",
                "body": "",
                "raw": ".. versionadded:: 1.22.0"
              }
            ]
          },
          {
            "name": "keepdims",
            "type": "bool, optional",
            "desc_blocks": [
              {
                "type": "paragraph",
                "text": "If this is set to True, the axes which are reduced are left\nin the result as dimensions with size one. With this option,\nthe result will broadcast correctly against the array."
              },
              {
                "type": "directive",
                "name": "versionadded:: 1.22.0",
                "body": "",
                "raw": ".. versionadded:: 1.22.0"
              }
            ]
          }
        ]
      },
      {
        "kind": "returns",
        "title": "Returns",
