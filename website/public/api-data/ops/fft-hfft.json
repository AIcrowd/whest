                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "array_like",
                "inline": [
                  {
                    "kind": "text",
                    "text": "The input array."
                  }
                ],
                "name": "a",
                "type": "field_list"
              },
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "Length of the transformed axis of the output. For "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " output\npoints, "
                      },
                      {
                        "kind": "code",
                        "text": "n//2 + 1"
                      },
                      {
                        "kind": "text",
                        "text": " input points are necessary.  If the input is\nlonger than this, it is cropped.  If it is shorter than this, it is\npadded with zeros.  If "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " is not given, it is taken to be "
                      },
                      {
                        "kind": "code",
                        "text": "2*(m-1)"
                      },
                      {
                        "kind": "text",
                        "text": "\nwhere "
                      },
                      {
                        "kind": "code",
                        "text": "m"
                      },
                      {
                        "kind": "text",
                        "text": " is the length of the input along the axis specified by\n"
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": "."
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "int, optional",
                "inline": [
                  {
