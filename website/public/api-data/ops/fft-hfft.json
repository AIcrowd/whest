      {
        "blocks": [
          {
            "links": [
              {
                "description": "Compute the one-dimensional FFT for real input.",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "Compute the one-dimensional FFT for real input."
                  }
                ],
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.rfft.html",
                "href": "",
                "label": "rfft",
                "original_target": "rfft",
                "role": "",
                "target": "rfft",
                "unresolved": false
              },
              {
                "description": "The inverse of `hfft`.",
                "description_inline": [
                  {
                    "kind": "text",
                    "text": "The inverse of "
                  },
                  {
                    "kind": "code",
                    "text": "hfft"
                  },
                  {
                    "kind": "text",
                    "text": "."
                  }
                ],
                "external_url": "https://numpy.org/doc/stable/reference/generated/numpy.ihfft.html",
                "href": "",
                "label": "ihfft",
                "original_target": "ihfft",
                "role": "",
                "target": "ihfft",
                "unresolved": false
              }
            ],
            "type": "link_list"
          }
        ],
        "title": "See also"
      },
      {
        "blocks": [
          {
            "inline": [
              {
                "kind": "code",
                "text": "hfft"
              },
              {
                "kind": "text",
                "text": "/"
              },
              {
                "kind": "code",
                "text": "ihfft"
              },
              {
                "kind": "text",
                "text": " are a pair analogous to "
              },
              {
                "kind": "code",
                "text": "rfft"
              },
              {
                "kind": "text",
                "text": "/"
              },
              {
                "kind": "code",
                "text": "irfft"
              },
              {
                "kind": "text",
                "text": ", but for the\nopposite case: here the signal has Hermitian symmetry in the time\ndomain and is real in the frequency domain. So here it's "
              },
              {
                "kind": "code",
                "text": "hfft"
              },
              {
                "kind": "text",
                "text": " for\nwhich you must supply the length of the result if it is to be odd."
              }
            ],
            "type": "paragraph"
          },
          {
            "items": [
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "even: "
                      },
                      {
                        "kind": "code",
                        "text": "ihfft(hfft(a, 2*len(a) - 2)) == a"
                      },
                      {
                        "kind": "text",
                        "text": ", within roundoff error,"
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              },
              {
                "blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "odd: "
                      },
                      {
                        "kind": "code",
                        "text": "ihfft(hfft(a, 2*len(a) - 1)) == a"
                      },
                      {
                        "kind": "text",
                        "text": ", within roundoff error."
                      }
                    ],
                    "type": "paragraph"
                  }
                ]
              }
            ],
            "ordered": false,
            "type": "list"
          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "The correct interpretation of the hermitian input depends on the length of\nthe original data, as given by "
              },
              {
                "kind": "code",
                "text": "n"
              },
              {
                "kind": "text",
                "text": ". This is because each input shape could\ncorrespond to either an odd or even length signal. By default, "
              },
              {
                "kind": "code",
                "text": "hfft"
              },
              {
                "kind": "text",
                "text": "\nassumes an even output length which puts the last entry at the Nyquist\nfrequency; aliasing with its symmetric counterpart. By Hermitian symmetry,\nthe value is thus treated as purely real. To avoid losing information, the\nshape of the full signal "
              },
              {
                "kind": "strong",
                "text": "must"
              },
              {
                "kind": "text",
                "text": " be given."
              }
            ],
            "type": "paragraph"
          }
        ],
        "title": "Notes"
      },
      {
        "blocks": [
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "import flopscope as fnp"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "signal = fnp.array([1, 2, 3, 4, 3, 2])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fft.fft(signal)"
              },
              {
                "kind": "output",
                "text": "array([15.+0.j,  -4.+0.j,   0.+0.j,  -1.-0.j,   0.+0.j,  -4.+0.j]) # may vary"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fft.hfft(signal[:4]) # Input first half of signal"
              },
              {
                "kind": "output",
                "text": "array([15.,  -4.,   0.,  -1.,   0.,  -4.])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.fft.hfft(signal, 6)  # Input entire signal and truncate"
              },
              {
                "kind": "output",
                "text": "array([15.,  -4.,   0.,  -1.,   0.,  -4.])"
              }
            ],
            "type": "doctest_block"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "signal = fnp.array([[1, 1.j], [-1.j, 2]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "fnp.conj(signal.T) - signal   # check Hermitian symmetry"
              },
              {
                "kind": "output",
                "text": "array([[ 0.-0.j,  -0.+0.j], # may vary"
              },
              {
                "kind": "output",
                "text": "       [ 0.+0.j,  0.-0.j]])"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "freq_spectrum = fnp.fft.hfft(signal)"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "freq_spectrum"
              },
              {
                "kind": "output",
                "text": "array([[ 1.,  1.],"
              },
              {
                "kind": "output",
                "text": "       [ 2., -2.]])"
              }
            ],
            "type": "doctest_block"
          }
        ],
        "title": "Examples"
      }
    ]
  },
  "op": {
    "category": "counted_custom",
    "cost_formula": "5n * ceil(log2(n))",
    "cost_formula_latex": "$5n \\cdot \\lceil\\log_2 n\\rceil$",
    "flopscope_ref": "fnp.fft.hfft",
    "module": "numpy.fft",
    "name": "fft.hfft",
    "notes": "FFT of Hermitian-symmetric signal. Cost: 5*n_out*ceil(log2(n_out)) (Cooley-Tukey radix-2; Van Loan 1992 \u00a71.4).",
    "numpy_ref": "np.fft.hfft",
    "signature": "fnp.fft.hfft(a, n=None, axis=-1, norm=None, out=None)",
    "status": "supported",
    "summary": "Compute the FFT of a signal that has Hermitian symmetry, i.e., a real spectrum.",
    "weight": 1.0
  },
