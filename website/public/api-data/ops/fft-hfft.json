      },
      {
        "blocks": [
          {
            "items": [
              {
                "body_blocks": [
                  {
                    "inline": [
                      {
                        "kind": "text",
                        "text": "The truncated or zero-padded input, transformed along the axis\nindicated by "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": ", or the last one if "
                      },
                      {
                        "kind": "code",
                        "text": "axis"
                      },
                      {
                        "kind": "text",
                        "text": " is not specified.\nThe length of the transformed axis is "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": ", or, if "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " is not given,\n"
                      },
                      {
                        "kind": "code",
                        "text": "2*m - 2"
                      },
                      {
                        "kind": "text",
                        "text": " where "
                      },
                      {
                        "kind": "code",
                        "text": "m"
                      },
                      {
                        "kind": "text",
                        "text": " is the length of the transformed axis of\nthe input. To get an odd number of output points, "
                      },
                      {
                        "kind": "code",
                        "text": "n"
                      },
                      {
                        "kind": "text",
                        "text": " must be\nspecified, for instance as "
                      },
                      {
                        "kind": "code",
                        "text": "2*m - 1"
                      },
                      {
                        "kind": "text",
                        "text": " in the typical case,"
                      }
                    ],
                    "type": "paragraph"
                  }
                ],
                "data_type": "ndarray",
                "inline": [
                  {
