          },
          {
            "inline": [
              {
                "kind": "text",
                "text": "NumPy supports PEP 3141 numbers:"
              }
            ],
            "type": "paragraph"
          },
          {
            "lines": [
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from fractions import Fraction"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "we.isscalar(Fraction(5, 17))"
              },
              {
                "kind": "output",
                "text": "True"
              },
              {
                "kind": "input",
                "prompt": ">>>",
                "text": "from numbers import Number"
              },
              {
                "kind": "input",
